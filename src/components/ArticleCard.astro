---
interface Props {
  title: string;
  description: string;
  slug: string;
  publishDate: Date;
  category: string;
  heroImage?: string;
}

const { title, description, slug, publishDate, category, heroImage } = Astro.props;

const categoryLabels: Record<string, string> = {
  technika: 'Technika',
  dotace: 'Dotace',
  trh: 'Trh',
  legislativa: 'Legislativa',
  znacky: 'Značky',
  novinky: 'Novinky',
};

const date = new Intl.DateTimeFormat('cs-CZ', { day: 'numeric', month: 'long', year: 'numeric' }).format(publishDate);
---

<div class="card-wrap">
  <a href={`/novinky/${slug}/`} class="card">
    <div class="card-img">
      {heroImage
        ? <img src={heroImage} alt={title} loading="lazy" />
        : <span>📰</span>
      }
    </div>
    <div class="card-body">
      <h3>{title}</h3>
      <p>{description}</p>
      <time>{date}</time>
    </div>
  </a>
  <a
    href={`/novinky/kategorie/${category}/`}
    class="tag"
    title={`Všechny články v kategorii ${categoryLabels[category] ?? category}`}
  >
    {categoryLabels[category] ?? category}
  </a>
</div>

<style>
  .card-wrap {
    position: relative;
  }
  .card {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: 18px;
    overflow: hidden;
    border: none;
    background: #fff;
    box-shadow: 0 0 10px rgba(0, 0, 0, .12);
    transition: transform .2s, box-shadow .2s;
  }
  .card:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0, 0, 0, .09); }

  .card-img {
    position: relative;
    width: 100%;
    height: 200px;
    background: #f0f0f0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 48px;
    overflow: hidden;
  }
  .card-img img { width: 100%; height: 100%; object-fit: cover; }

  .tag {
    position: absolute;
    top: 168px; /* card-img is 200px — puts tag at bottom-left of image */
    left: 12px;
    z-index: 2;
    background: #FFFF00;
    color: #000;
    font-size: 11px;
    font-weight: 400;
    font-family: 'Chakra Petch', sans-serif;
    padding: 4px 10px;
    border-radius: 6px;
    text-transform: uppercase;
    letter-spacing: .4px;
    text-decoration: none;
    transition: background .15s, transform .15s;
    cursor: pointer;
  }
  .tag:hover {
    background: #1a1a1a;
    color: #FFFF00;
  }

  .card-body { padding: 18px 18px 20px; }
  .card-body h3 { font-size: 16px; font-weight: 400; line-height: 1.4; margin-bottom: 8px; color: #1a1a1a; }
  .card-body p { font-size: 13px; color: #666; line-height: 1.5; margin-bottom: 12px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .card-body time { font-size: 12px; color: #aaa; }
</style>
