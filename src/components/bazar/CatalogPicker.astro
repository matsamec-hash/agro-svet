---
interface PickerOption {
  slug: string;
  label: string;
  [key: string]: unknown;
}

interface Props {
  id: string;
  name: string;
  label: string;
  placeholder?: string;
  options: PickerOption[];
  value?: string | null;
  valueLabel?: string | null;
  filterAttr?: string;
  filterValue?: string;
  ostatniLabel?: string;
}

const {
  id,
  name,
  label,
  placeholder = 'Začněte psát pro vyhledání…',
  options,
  value = null,
  valueLabel = null,
  filterAttr,
  filterValue,
  ostatniLabel = 'Není v seznamu (ostatní)',
} = Astro.props;

const optionsJson = JSON.stringify(options);
---

<div class="catalog-picker" data-picker-id={id} data-filter-attr={filterAttr ?? ''} data-filter-value={filterValue ?? ''}>
  <label for={`${id}-input`}>{label}</label>
  <div class="picker-wrap">
    <input
      type="text"
      id={`${id}-input`}
      class="form-input picker-input"
      placeholder={placeholder}
      value={valueLabel ?? ''}
      autocomplete="off"
    />
    <input type="hidden" id={`${id}-value`} name={name} value={value ?? ''} />
    <button type="button" class="picker-clear" id={`${id}-clear`} aria-label="Vymazat" tabindex="-1">✕</button>
    <div class="picker-dropdown" id={`${id}-dropdown`} hidden>
      <ul class="picker-list" id={`${id}-list`}></ul>
    </div>
  </div>
  <small class="picker-hint" id={`${id}-hint`}>
    {value ? `Vybráno: ${valueLabel ?? value}` : 'Pokud model není v seznamu, ponechte pole prázdné — popis doplníte v názvu a popisku.'}
  </small>
</div>

<script is:inline define:vars={{ id, optionsJson, ostatniLabel }}>
(function() {
  const OPTIONS = JSON.parse(optionsJson);

  const input = document.getElementById(`${id}-input`);
  const hidden = document.getElementById(`${id}-value`);
  const dropdown = document.getElementById(`${id}-dropdown`);
  const list = document.getElementById(`${id}-list`);
  const clear = document.getElementById(`${id}-clear`);
  const hint = document.getElementById(`${id}-hint`);
  const wrap = input?.closest('.catalog-picker');

  if (!input || !hidden || !dropdown || !list || !wrap) return;

  let activeIdx = -1;
  let current = [];

  function getFilter() {
    const attr = wrap.dataset.filterAttr;
    const val = wrap.dataset.filterValue;
    return attr && val ? { attr, val } : null;
  }

  function sortOptions(list) {
    // Sort: year_from DESC (newest first), then power_hp DESC
    return [...list].sort((a, b) => {
      const yA = a.year_from ?? 0;
      const yB = b.year_from ?? 0;
      if (yB !== yA) return yB - yA;
      const pA = a.power_hp ?? 0;
      const pB = b.power_hp ?? 0;
      return pB - pA;
    });
  }

  function filterOptions(q) {
    const filter = getFilter();
    const needle = q.trim().toLowerCase();
    let pool = OPTIONS;
    if (filter) pool = pool.filter((o) => o[filter.attr] === filter.val);
    if (needle) pool = pool.filter((o) => String(o.label).toLowerCase().includes(needle));
    return sortOptions(pool).slice(0, 100);
  }

  // Flatten items + group headers into a single navigable array.
  // Each entry is either { type: 'header', label, key } or { type: 'item', option, idx }
  // Only 'item' entries are selectable.
  function buildRows(items) {
    const rows = [];
    let lastGroup = '';
    items.forEach((o) => {
      const brandName = o.brand_name || '';
      const seriesName = o.series_name || '';
      const groupKey = `${o.brand_slug || ''}::${o.series_slug || ''}`;
      if (groupKey !== lastGroup) {
        lastGroup = groupKey;
        rows.push({ type: 'header', label: seriesName ? `${brandName} — ${seriesName}` : brandName, key: groupKey });
      }
      rows.push({ type: 'item', option: o });
    });
    return rows;
  }

  function selectableCount(rows) {
    return rows.filter((r) => r.type === 'item').length;
  }

  function nthSelectable(rows, n) {
    let i = -1;
    for (const r of rows) {
      if (r.type === 'item') {
        i++;
        if (i === n) return r.option;
      }
    }
    return null;
  }

  function render() {
    list.innerHTML = '';
    const rows = buildRows(current);

    if (current.length === 0) {
      const li = document.createElement('li');
      li.className = 'picker-empty';
      li.textContent = 'Žádný model nenalezen.';
      list.appendChild(li);
    } else {
      let selectableIdx = 0;
      rows.forEach((row) => {
        if (row.type === 'header') {
          const header = document.createElement('li');
          header.className = 'picker-group-header';
          header.textContent = row.label;
          list.appendChild(header);
        } else {
          const o = row.option;
          const myIdx = selectableIdx++;
          const li = document.createElement('li');
          li.className = 'picker-item' + (myIdx === activeIdx ? ' active' : '');
          li.dataset.slug = o.slug;
          li.dataset.label = o.label;
          const yr = o.year_from ? (o.year_to ? ` · ${o.year_from}–${o.year_to}` : ` · ${o.year_from}–`) : '';
          const hp = o.power_hp ? `${o.power_hp} k` : '';
          li.innerHTML =
            `<span class="picker-item-label">${o.name || o.label}</span>` +
            (hp || yr ? `<span class="picker-item-meta">${hp}${yr}</span>` : '');
          li.addEventListener('mousedown', (e) => {
            e.preventDefault();
            select(o);
          });
          list.appendChild(li);
        }
      });
    }

    // "Ostatní" always at bottom (ostatní = activeIdx === current.length)
    const ostatniLi = document.createElement('li');
    ostatniLi.className = 'picker-item picker-ostatni' + (activeIdx === current.length ? ' active' : '');
    ostatniLi.textContent = ostatniLabel;
    ostatniLi.addEventListener('mousedown', (e) => {
      e.preventDefault();
      selectOstatni();
    });
    list.appendChild(ostatniLi);
  }

  function open() {
    dropdown.hidden = false;
    current = filterOptions(input.value);
    activeIdx = -1;
    render();
  }

  function close() {
    dropdown.hidden = true;
  }

  function select(option) {
    hidden.value = option.slug;
    input.value = option.label;
    hint.textContent = `Vybráno: ${option.label}`;
    close();
    // Dispatch selection event so parent can auto-fill related fields
    wrap.dispatchEvent(new CustomEvent('catalog-picker-selected', {
      detail: { option },
      bubbles: true,
    }));
  }

  function selectOstatni() {
    hidden.value = '';
    input.value = '';
    hint.textContent = 'Vybráno: Ostatní — upřesněte v popisu inzerátu.';
    close();
    wrap.dispatchEvent(new CustomEvent('catalog-picker-cleared', { bubbles: true }));
  }

  input.addEventListener('focus', open);
  input.addEventListener('input', () => {
    hidden.value = ''; // typing clears selection until user picks
    current = filterOptions(input.value);
    activeIdx = -1;
    render();
    dropdown.hidden = false;
  });
  input.addEventListener('blur', () => setTimeout(close, 150));
  input.addEventListener('keydown', (e) => {
    const total = current.length + 1; // +1 for ostatní
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      activeIdx = Math.min(activeIdx + 1, total - 1);
      render();
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      activeIdx = Math.max(activeIdx - 1, -1);
      render();
    } else if (e.key === 'Enter') {
      if (activeIdx >= 0) {
        e.preventDefault();
        if (activeIdx < current.length) {
          select(current[activeIdx]);
        } else {
          selectOstatni();
        }
      }
    } else if (e.key === 'Escape') {
      close();
    }
  });

  clear?.addEventListener('click', () => {
    selectOstatni();
    hint.textContent = 'Pokud model není v seznamu, ponechte pole prázdné.';
  });

  // Cross-component filter update (e.g. category change filters models)
  wrap.addEventListener('catalog-filter-change', (e) => {
    const detail = e.detail || {};
    wrap.dataset.filterAttr = detail.attr || '';
    wrap.dataset.filterValue = detail.val || '';
    if (input.value) {
      const filter = getFilter();
      if (filter && hidden.value) {
        // Check if currently selected option still matches filter
        const currentSelected = OPTIONS.find((o) => o.slug === hidden.value);
        if (currentSelected && currentSelected[filter.attr] !== filter.val) {
          hidden.value = '';
          input.value = '';
          hint.textContent = 'Filtr se změnil — vyberte znovu.';
        }
      }
    }
  });
})();
</script>

<style>
  .catalog-picker { display: flex; flex-direction: column; gap: 6px; margin-bottom: 18px; }
  .catalog-picker > label {
    font-family: 'Chakra Petch', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: #333;
  }
  .picker-wrap { position: relative; }
  .picker-input { width: 100%; padding-right: 36px; }
  .picker-clear {
    position: absolute;
    right: 10px;
    top: 50%;
    transform: translateY(-50%);
    background: transparent;
    border: none;
    color: #767676;
    font-size: 14px;
    cursor: pointer;
    padding: 4px 6px;
  }
  .picker-clear:hover { color: #000; }
  .picker-dropdown {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    right: 0;
    max-height: 280px;
    overflow-y: auto;
    background: #fff;
    border: 1px solid #d9d9d9;
    border-radius: 8px;
    box-shadow: 0 8px 24px rgba(0,0,0,.08);
    z-index: 20;
  }
  .picker-list { list-style: none; margin: 0; padding: 4px; }
  .picker-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    padding: 8px 12px;
    border-radius: 6px;
    cursor: pointer;
    font-size: 14px;
  }
  .picker-item:hover, .picker-item.active {
    background: #FFFF00;
    color: #000;
  }
  .picker-item-label { color: #1a1a1a; }
  .picker-item-meta { font-size: 12px; color: #666; white-space: nowrap; }
  .picker-item:hover .picker-item-meta, .picker-item.active .picker-item-meta { color: #333; }
  .picker-group-header {
    padding: 8px 12px 4px;
    font-family: 'Chakra Petch', sans-serif;
    font-size: 11px;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: #666;
    background: transparent;
  }
  .picker-ostatni {
    border-top: 1px solid #f0f0f0;
    margin-top: 4px;
    color: #666;
    font-style: italic;
  }
  .picker-empty {
    padding: 12px;
    color: #767676;
    font-size: 13px;
    font-style: italic;
  }
  .picker-hint {
    font-size: 12px;
    color: #666;
    line-height: 1.4;
  }
</style>
