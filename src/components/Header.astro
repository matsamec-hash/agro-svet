---
const nav = [
  { label: 'Novinky', href: '/novinky/' },
  { label: 'Encyklopedie', href: '/encyklopedie/' },
  { label: 'Značky', href: '/znacky/' },
  { label: 'Půda', href: '/puda/' },
  { label: 'Média', href: '/media/' },
];
const current = Astro.url.pathname;
---

<header style="background:#fff; border-bottom:1px solid #e8e8e8; position:sticky; top:0; z-index:100;">
  <div style="max-width:1280px; margin:0 auto; padding:0 32px; display:flex; align-items:center; justify-content:space-between; height:68px;">

    <a href="/" style="display:inline-block; background:#FFFF00; padding:8px 14px; border-radius:4px; text-decoration:none;">
      <span style="font-family:'Space Mono',monospace; font-weight:700; font-size:16px; color:#000; white-space:nowrap;">agro-svět.cz</span>
    </a>

    <nav style="display:flex; align-items:center; gap:2px;" id="main-nav">
      {nav.map(item => (
        <a
          href={item.href}
          style={`text-decoration:none; font-size:14px; font-weight:500; padding:8px 14px; border-radius:6px; white-space:nowrap; color:${current.startsWith(item.href) ? '#000' : '#555'}; background:${current.startsWith(item.href) ? '#f5f5f5' : 'transparent'};`}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Mobile hamburger -->
    <button id="hamburger" style="display:none; background:none; border:none; cursor:pointer; padding:8px;" aria-label="Menu">
      <svg id="icon-open" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
      <svg id="icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="2" stroke-linecap="round" style="display:none;">
        <line x1="4" y1="4" x2="20" y2="20"/><line x1="20" y1="4" x2="4" y2="20"/>
      </svg>
    </button>
  </div>

  <!-- Mobile nav drawer -->
  <div id="mobile-nav" style="display:none; background:#fff; border-top:1px solid #e8e8e8; padding:12px 24px 20px;">
    {nav.map(item => (
      <a
        href={item.href}
        style={`display:block; padding:12px 0; font-size:16px; font-weight:600; text-decoration:none; border-bottom:1px solid #f0f0f0; color:${current.startsWith(item.href) ? '#000' : '#444'};`}
      >
        {item.label}
      </a>
    ))}
  </div>
</header>

<style>
  @media (max-width: 768px) {
    #main-nav { display: none !important; }
    #hamburger { display: block !important; }
  }
  header a:hover { background: #f0f0f0 !important; color: #000 !important; }
</style>

<script>
  const hamburger = document.getElementById('hamburger');
  const mobileNav = document.getElementById('mobile-nav');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');
  let open = false;

  hamburger?.addEventListener('click', () => {
    open = !open;
    mobileNav!.style.display = open ? 'block' : 'none';
    iconOpen!.style.display = open ? 'none' : 'block';
    iconClose!.style.display = open ? 'block' : 'none';
  });
</script>
