---
type NavItem = { label: string; href: string; children?: { label: string; href: string }[] };
const nav: NavItem[] = [
  {
    label: 'Novinky',
    href: '/novinky/',
    children: [
      { label: 'Všechny novinky', href: '/novinky/' },
      { label: 'Technika', href: '/novinky/kategorie/technika/' },
      { label: 'Dotace', href: '/novinky/kategorie/dotace/' },
      { label: 'Trh', href: '/novinky/kategorie/trh/' },
      { label: 'Legislativa', href: '/novinky/kategorie/legislativa/' },
      { label: 'Značky', href: '/novinky/kategorie/znacky/' },
    ],
  },
  {
    label: 'Technika',
    href: '/stroje/',
    children: [
      { label: 'Všechna technika', href: '/stroje/' },
      { label: 'Traktory', href: '/stroje/traktory/' },
      { label: 'Kombajny', href: '/stroje/kombajny/' },
      { label: 'Značky', href: '/stroje/#znacky' },
    ],
  },
  { label: 'Zvířata', href: '/plemena/' },
  { label: 'Zemědělská půda', href: '/puda/' },
  { label: 'Data', href: '/statistiky/' },
  { label: 'Agro bazar', href: '/bazar/' },
  { label: 'Fotosoutěž', href: '/fotosoutez/' },
];
const current = Astro.url.pathname;
---

<header style="background:#fff; border-bottom:1px solid #e8e8e8; position:sticky; top:0; z-index:100;">
  <div style="max-width:1280px; margin:0 auto; padding:0 32px; display:flex; align-items:center; gap:48px; height:88px;">

    <a href="/" style="display:inline-block; background:#FFFF00; padding:8px 18px; border-radius:6px; text-decoration:none;">
      <span style="font-family:'Chakra Petch',sans-serif; font-weight:400; font-size:28px; color:#000; white-space:nowrap; letter-spacing:.005em;">agro-svět.cz</span>
    </a>

    <nav class="nav-desktop" id="main-nav">
      {nav.map(item => (
        item.children ? (
          <div class="nav-item-wrap">
            <a
              href={item.href}
              class:list={['nav-link', { active: current.startsWith(item.href) }]}
            >
              {item.label}
              <svg class="nav-caret" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m6 9 6 6 6-6"/></svg>
            </a>
            <div class="nav-submenu">
              {item.children.map((c) => (
                <a href={c.href} class="nav-subitem">{c.label}</a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={item.href}
            class:list={['nav-link', { active: current.startsWith(item.href) }]}
          >
            {item.label}
          </a>
        )
      ))}
    </nav>

    <!-- Search (toggles input) -->
    <div class="search-container" id="search-container">
      <button type="button" class="search-icon-btn" id="search-toggle" aria-label="Hledat">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
        </svg>
      </button>
      <form class="search-form" id="search-form" action="/hledat/" method="GET" hidden>
        <input type="search" name="q" placeholder="Hledat…" class="search-field" id="search-field" />
      </form>
    </div>

    <!-- User menu (client-rendered based on /api/bazar/me) -->
    <div id="user-menu" class="user-menu" hidden>
      <button id="user-btn" class="user-btn" aria-haspopup="true" aria-expanded="false">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="8" r="4"/>
          <path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8"/>
        </svg>
        <span id="user-name">Účet</span>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
      </button>
      <div id="user-dropdown" class="user-dropdown" hidden>
        <a href="/bazar/moje/" class="user-dropdown-item">Moje inzeráty</a>
        <a href="/bazar/novy/" class="user-dropdown-item">+ Nový inzerát</a>
        <a href="/bazar/profil/" class="user-dropdown-item">Profil</a>
        <div class="user-dropdown-sep"></div>
        <a href="/bazar/odhlaseni/" class="user-dropdown-item">Odhlásit se</a>
      </div>
    </div>

    <!-- Guest link (shown when not logged in) -->
    <a href="/bazar/prihlaseni/" id="guest-link" class="guest-link" hidden>Přihlásit</a>

    <!-- Mobile hamburger -->
    <button
      id="hamburger"
      class="hamburger-btn"
      aria-label="Menu"
      aria-expanded="false"
      aria-controls="mobile-nav"
    >
      <svg id="icon-open" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
      <svg id="icon-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="2" stroke-linecap="round" style="display:none;">
        <line x1="4" y1="4" x2="20" y2="20"/><line x1="20" y1="4" x2="4" y2="20"/>
      </svg>
    </button>
  </div>

  <!-- Mobile nav drawer -->
  <div id="mobile-nav" style="display:none; background:#fff; border-top:1px solid #e8e8e8; padding:12px 24px 20px;">
    {nav.map(item => (
      <>
        <a
          href={item.href}
          style={`display:block; padding:12px 0; font-size:16px; font-weight:400; text-decoration:none; border-bottom:1px solid #f0f0f0; color:${current.startsWith(item.href) ? '#000' : '#444'};`}
        >
          {item.label}
        </a>
        {item.children && item.children.map((c) => (
          <a
            href={c.href}
            style="display:block; padding:8px 0 8px 16px; font-size:14px; text-decoration:none; border-bottom:1px solid #f6f6f6; color:#666;"
          >
            › {c.label}
          </a>
        ))}
      </>
    ))}
  </div>
</header>

<style>
  .nav-desktop {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-left: auto;
  }

  .nav-link {
    position: relative;
    text-decoration: none;
    font-family: 'Chakra Petch', sans-serif;
    font-size: 18px;
    font-weight: 600;
    letter-spacing: 0.01em;
    padding: 8px 14px;
    white-space: nowrap;
    color: #1a1a1a;
    background: transparent;
    overflow: hidden;
  }

  .nav-link.active {
    color: #000;
  }

  /* Double Line — top line */
  .nav-link::before,
  .nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    width: 100%;
    height: 2px;
    background: #1a1a1a;
    transform: translateX(-101%);
    transition: transform .35s cubic-bezier(.4, 0, .2, 1);
  }

  .nav-link::before {
    top: 0;
  }

  /* Double Line — bottom line (slides from opposite side) */
  .nav-link::after {
    bottom: 0;
    transform: translateX(101%);
  }

  .nav-link:hover::before {
    transform: translateX(0);
  }

  .nav-link:hover::after {
    transform: translateX(0);
  }

  .nav-link:hover {
    color: #000;
  }

  .nav-item-wrap {
    position: relative;
    display: inline-flex;
    align-items: stretch;
  }
  .nav-item-wrap .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .nav-caret {
    width: 12px;
    height: 12px;
    opacity: .6;
    transition: transform .2s;
  }
  .nav-item-wrap:hover .nav-caret { transform: rotate(180deg); }
  .nav-submenu {
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    min-width: 220px;
    background: #fff;
    border: 1px solid #e0e0e0;
    border-radius: 10px;
    box-shadow: 0 8px 24px rgba(0,0,0,.08);
    padding: 6px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: opacity .15s, transform .15s, visibility .15s;
    z-index: 110;
  }
  .nav-item-wrap:hover .nav-submenu,
  .nav-item-wrap:focus-within .nav-submenu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .nav-subitem {
    display: block;
    padding: 9px 14px;
    font-family: 'Chakra Petch', sans-serif;
    font-size: 14px;
    color: #1a1a1a;
    text-decoration: none;
    border-radius: 6px;
  }
  .nav-subitem:hover {
    background: #FFFF00;
  }

  /* Search */
  .search-container {
    display: inline-flex;
    align-items: center;
    margin-left: 4px;
  }
  .search-icon-btn {
    background: #fff;
    border: 1px solid #e0e0e0;
    color: #1a1a1a;
    width: 44px;
    height: 44px;
    border-radius: 10px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: border-color .15s, box-shadow .15s;
  }
  .search-icon-btn svg { width: 20px; height: 20px; }
  .search-icon-btn:hover { border-color: #FFFF00; box-shadow: 0 0 0 3px rgba(255,255,0,.3); }

  /* Slide-down search panel: fills header width, doesn't collide with nav */
  .search-form {
    position: absolute;
    top: 88px;
    left: 0;
    right: 0;
    width: 100%;
    background: #fff;
    border-top: 1px solid #e8e8e8;
    border-bottom: 1px solid #e8e8e8;
    padding: 14px 32px;
    z-index: 120;
    box-shadow: 0 6px 16px rgba(0,0,0,.06);
    box-sizing: border-box;
  }
  .search-field {
    display: block;
    max-width: 720px;
    margin: 0 auto;
    width: 100%;
    height: 44px;
    padding: 0 16px;
    font-family: inherit;
    font-size: 15px;
    background: #fff;
    border: 1px solid #1a1a1a;
    border-radius: 10px;
    outline: none;
  }
  .search-field:focus { box-shadow: 0 0 0 3px rgba(255,255,0,.4); }

  /* User menu */
  .user-menu {
    position: relative;
    margin-left: 8px;
  }
  .user-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 14px 9px 12px;
    background: #fff;
    border: 1px solid #e0e0e0;
    border-radius: 10px;
    font-family: 'Chakra Petch', sans-serif;
    font-size: 15px;
    color: #1a1a1a;
    cursor: pointer;
    transition: border-color .15s, box-shadow .15s;
  }
  .user-btn svg { width: 20px; height: 20px; }
  .user-btn svg:last-child { width: 14px; height: 14px; }
  .user-btn:hover { border-color: #FFFF00; box-shadow: 0 0 0 3px rgba(255,255,0,.3); }
  .user-dropdown {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    min-width: 200px;
    background: #fff;
    border: 1px solid #e0e0e0;
    border-radius: 10px;
    box-shadow: 0 8px 24px rgba(0,0,0,.08);
    z-index: 110;
    padding: 6px;
  }
  .user-dropdown-item {
    display: block;
    padding: 9px 12px;
    font-size: 14px;
    color: #1a1a1a;
    text-decoration: none;
    border-radius: 6px;
  }
  .user-dropdown-item:hover { background: #FFFF00; }
  .user-dropdown-sep {
    height: 1px;
    background: #eee;
    margin: 4px 8px;
  }
  .guest-link {
    margin-left: 8px;
    padding: 9px 18px;
    font-family: 'Chakra Petch', sans-serif;
    font-size: 15px;
    background: #1a1a1a;
    color: #fff;
    text-decoration: none;
    border-radius: 10px;
  }
  .guest-link:hover { background: #000; }

  .hamburger-btn {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
  }
  .hamburger-btn:hover { background: rgba(0, 0, 0, .04); }

  @media (max-width: 1025px) {
    #main-nav { display: none !important; }
    .hamburger-btn { display: inline-flex !important; }
  }
</style>

<script>
  const hamburger = document.getElementById('hamburger');
  const mobileNav = document.getElementById('mobile-nav');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');
  let open = false;

  hamburger?.addEventListener('click', () => {
    open = !open;
    mobileNav!.style.display = open ? 'block' : 'none';
    iconOpen!.style.display = open ? 'none' : 'block';
    iconClose!.style.display = open ? 'block' : 'none';
    hamburger.setAttribute('aria-expanded', String(open));
  });

  // Search toggle
  const searchToggle = document.getElementById('search-toggle');
  const searchForm = document.getElementById('search-form') as HTMLFormElement | null;
  const searchField = document.getElementById('search-field') as HTMLInputElement | null;
  searchToggle?.addEventListener('click', () => {
    if (!searchForm || !searchField) return;
    searchForm.hidden = !searchForm.hidden;
    if (!searchForm.hidden) searchField.focus();
  });
  document.addEventListener('click', (e) => {
    const container = document.getElementById('search-container');
    if (!container || !searchForm) return;
    if (!container.contains(e.target as Node)) searchForm.hidden = true;
  });

  // User menu — fetch auth state from /api/bazar/me
  (async () => {
    const menu = document.getElementById('user-menu') as HTMLElement | null;
    const guest = document.getElementById('guest-link') as HTMLElement | null;
    const btn = document.getElementById('user-btn');
    const dropdown = document.getElementById('user-dropdown');
    const nameSpan = document.getElementById('user-name');
    if (!menu || !guest) return;

    try {
      const res = await fetch('/api/bazar/me', { credentials: 'same-origin' });
      const data = await res.json();
      if (data.logged_in) {
        menu.hidden = false;
        if (nameSpan && data.name) nameSpan.textContent = data.name;
        btn?.addEventListener('click', () => {
          if (!dropdown) return;
          dropdown.hidden = !dropdown.hidden;
          btn.setAttribute('aria-expanded', String(!dropdown.hidden));
        });
        document.addEventListener('click', (e) => {
          if (!menu.contains(e.target as Node) && dropdown) dropdown.hidden = true;
        });
      } else {
        guest.hidden = false;
      }
    } catch {
      guest.hidden = false;
    }
  })();
</script>
