---
const nav = [
  { label: 'Stroje', href: '/stroje/' },
  { label: 'Plemena', href: '/plemena/' },
  { label: 'Zemědělská půda', href: '/puda/' },
  { label: 'Statistiky', href: '/statistiky/' },
  { label: 'Agro bazar', href: '/bazar/' },
];
const current = Astro.url.pathname;
---

<header style="background:#fff; border-bottom:1px solid #e8e8e8; position:sticky; top:0; z-index:100;">
  <div style="max-width:1280px; margin:0 auto; padding:0 32px; display:flex; align-items:center; gap:48px; height:60px;">

    <a href="/" style="display:inline-block; background:#FFFF00; padding:6px 12px; border-radius:4px; text-decoration:none;">
      <span style="font-family:'Chakra Petch',sans-serif; font-weight:400; font-size:17px; color:#000; white-space:nowrap;">agro-svět.cz</span>
    </a>

    <nav class="nav-desktop" id="main-nav">
      {nav.map(item => (
        <a
          href={item.href}
          class:list={['nav-link', { active: current.startsWith(item.href) }]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Mobile hamburger -->
    <button id="hamburger" style="display:none; background:none; border:none; cursor:pointer; padding:8px;" aria-label="Menu">
      <svg id="icon-open" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
      <svg id="icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1a1a1a" stroke-width="2" stroke-linecap="round" style="display:none;">
        <line x1="4" y1="4" x2="20" y2="20"/><line x1="20" y1="4" x2="4" y2="20"/>
      </svg>
    </button>
  </div>

  <!-- Mobile nav drawer -->
  <div id="mobile-nav" style="display:none; background:#fff; border-top:1px solid #e8e8e8; padding:12px 24px 20px;">
    {nav.map(item => (
      <a
        href={item.href}
        style={`display:block; padding:12px 0; font-size:16px; font-weight:400; text-decoration:none; border-bottom:1px solid #f0f0f0; color:${current.startsWith(item.href) ? '#000' : '#444'};`}
      >
        {item.label}
      </a>
    ))}
  </div>
</header>

<style>
  .nav-desktop {
    display: flex;
    align-items: center;
    gap: 2px;
    margin-left: auto;
  }

  .nav-link {
    position: relative;
    text-decoration: none;
    font-family: 'Chakra Petch', sans-serif;
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.01em;
    padding: 6px 12px;
    white-space: nowrap;
    color: #555;
    background: transparent;
    overflow: hidden;
  }

  .nav-link.active {
    color: #000;
  }

  /* Double Line — top line */
  .nav-link::before,
  .nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    width: 100%;
    height: 2px;
    background: #1a1a1a;
    transform: translateX(-101%);
    transition: transform .35s cubic-bezier(.4, 0, .2, 1);
  }

  .nav-link::before {
    top: 0;
  }

  /* Double Line — bottom line (slides from opposite side) */
  .nav-link::after {
    bottom: 0;
    transform: translateX(101%);
  }

  .nav-link:hover::before {
    transform: translateX(0);
  }

  .nav-link:hover::after {
    transform: translateX(0);
  }

  .nav-link:hover {
    color: #000;
  }

  @media (max-width: 1025px) {
    #main-nav { display: none !important; }
    #hamburger { display: block !important; }
  }
</style>

<script>
  const hamburger = document.getElementById('hamburger');
  const mobileNav = document.getElementById('mobile-nav');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');
  let open = false;

  hamburger?.addEventListener('click', () => {
    open = !open;
    mobileNav!.style.display = open ? 'block' : 'none';
    iconOpen!.style.display = open ? 'none' : 'block';
    iconClose!.style.display = open ? 'block' : 'none';
  });
</script>
