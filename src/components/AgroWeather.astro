---
import {
  fetchCityStrip,
  fetchAgroWeather,
  weatherEmoji,
  weatherLabel,
  dayLabelCs,
  type CityWeather,
  type AgroWeather,
} from '../lib/open-meteo';

interface Props {
  mode: 'strip' | 'puda' | 'commodity';
}
const { mode } = Astro.props;

let cities: CityWeather[] = [];
let agro: AgroWeather | null = null;
if (mode === 'strip') {
  cities = await fetchCityStrip();
} else {
  agro = await fetchAgroWeather();
}

// Drought heuristic: past 7d precip < 5mm = "sucho", < 15 = "spíše sucho"
const droughtLabel = (mm: number) => mm < 5 ? 'Sucho' : mm < 15 ? 'Spíše sucho' : mm < 30 ? 'Normální' : 'Mokro';
const droughtColor = (mm: number) => mm < 5 ? '#C24414' : mm < 15 ? '#E89000' : mm < 30 ? '#0B7A3B' : '#1976D2';

// Frost risk in next 7 days
const frostDays = agro ? agro.daily.tempMin.filter((t) => t < 0).length : 0;
// Total precip 7 days ahead
const totalPrecipAhead = agro ? Math.round(agro.daily.precipMm.reduce((a, b) => a + b, 0) * 10) / 10 : 0;
---

{mode === 'strip' && cities.length > 0 && (
  <section class="aw-strip" aria-label="Počasí pro pole" data-aw-strip>
    <div class="aw-strip-inner">
      <div class="aw-strip-label">
        <span class="aw-dot"></span>
        <span class="aw-label-text" data-aw-title>Počasí pro pole</span>
        <span class="aw-label-sub" data-aw-subtitle>Aktuální · 6 měst</span>
      </div>

      <div class="aw-cities" data-aw-cities>
        {cities.map((c) => (
          <div class="aw-city">
            <span class="aw-city-icon" aria-hidden="true">{weatherEmoji(c.weatherCode)}</span>
            <div class="aw-city-data">
              <span class="aw-city-name">{c.name}</span>
              <span class="aw-city-temp">{c.tempC}°</span>
              {c.precipMm > 0 && <span class="aw-city-rain">{c.precipMm} mm</span>}
            </div>
          </div>
        ))}
      </div>

      <div class="aw-user" data-aw-user hidden></div>

      <div class="aw-actions">
        <button type="button" class="aw-geo-btn" data-aw-locate>
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 0 0-8 8c0 5.5 8 12 8 12s8-6.5 8-12a8 8 0 0 0-8-8z"/></svg>
          <span data-aw-locate-label>Moje pole</span>
        </button>
        <button type="button" class="aw-reset-btn" data-aw-reset hidden>
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
        <a class="aw-strip-src" href="https://open-meteo.com/" target="_blank" rel="noopener noreferrer">Open-Meteo</a>
      </div>
    </div>
  </section>
)}

<script is:inline>
  (function(){
    const el = document.querySelector('[data-aw-strip]');
    if (!el) return;
    const cities = el.querySelector('[data-aw-cities]');
    const user = el.querySelector('[data-aw-user]');
    const title = el.querySelector('[data-aw-title]');
    const subtitle = el.querySelector('[data-aw-subtitle]');
    const btn = el.querySelector('[data-aw-locate]');
    const btnLabel = el.querySelector('[data-aw-locate-label]');
    const reset = el.querySelector('[data-aw-reset]');
    const STORAGE = 'aw-user-loc-v1';
    const TTL_MS = 60 * 60 * 1000; // 1h cache

    const WMO = {
      0:['☀️','Jasno'],1:['🌤️','Polojasno'],2:['⛅','Polojasno'],3:['☁️','Zataženo'],
      45:['🌫️','Mlha'],48:['🌫️','Námraza'],
      51:['🌦️','Mrholení'],53:['🌦️','Mrholení'],55:['🌧️','Silné mrholení'],
      61:['🌧️','Slabý déšť'],63:['🌧️','Déšť'],65:['🌧️','Silný déšť'],
      71:['🌨️','Slabé sněžení'],73:['🌨️','Sněžení'],75:['❄️','Silné sněžení'],
      80:['🌦️','Přeháňky'],81:['🌧️','Přeháňky'],82:['⛈️','Silné přeháňky'],
      95:['⛈️','Bouřka'],96:['⛈️','Bouřka s krupobitím'],99:['⛈️','Silná bouřka']
    };
    const dayCs = (iso) => {
      const d = new Date(iso + 'T12:00:00');
      return ['ne','po','út','st','čt','pá','so'][d.getDay()];
    };

    async function reverseGeo(lat, lon) {
      try {
        const res = await fetch('https://geocoding-api.open-meteo.com/v1/reverse?latitude=' + lat + '&longitude=' + lon + '&count=1&language=cs');
        if (!res.ok) return null;
        const j = await res.json();
        const r = j.results && j.results[0];
        return r ? (r.name || r.admin1 || null) : null;
      } catch { return null; }
    }

    async function fetchForecast(lat, lon) {
      const url = 'https://api.open-meteo.com/v1/forecast?latitude=' + lat + '&longitude=' + lon +
        '&current=temperature_2m,weather_code,wind_speed_10m,precipitation' +
        '&daily=temperature_2m_max,temperature_2m_min,precipitation_sum,precipitation_probability_max,weather_code' +
        '&forecast_days=5&timezone=Europe%2FPrague';
      const res = await fetch(url);
      if (!res.ok) throw new Error('forecast fetch failed');
      return res.json();
    }

    function renderUser(loc, data) {
      const cur = data.current || {};
      const d = data.daily || {};
      const wc = WMO[cur.weather_code] || ['🌡️','—'];
      const cards = (d.time || []).map((iso, i) => {
        const code = d.weather_code[i];
        const w = WMO[code] || ['🌡️','—'];
        const rain = d.precipitation_sum[i];
        return '<div class="aw-day5">' +
          '<span class="aw-d5-name">' + (i === 0 ? 'Dnes' : dayCs(iso)) + '</span>' +
          '<span class="aw-d5-icon" title="' + w[1] + '">' + w[0] + '</span>' +
          '<span class="aw-d5-tmax">' + Math.round(d.temperature_2m_max[i]) + '°</span>' +
          '<span class="aw-d5-tmin">' + Math.round(d.temperature_2m_min[i]) + '°</span>' +
          (rain > 0 ? '<span class="aw-d5-rain">' + (Math.round(rain * 10) / 10) + ' mm</span>' : '') +
        '</div>';
      }).join('');

      user.innerHTML = cards;
      user.hidden = false;
      cities.hidden = true;
      title.textContent = 'Vaše pole · ' + (loc.name || 'aktuální poloha');
      subtitle.textContent = 'Nyní ' + Math.round(cur.temperature_2m) + '° · ' + wc[1] + ' · ' + Math.round(cur.wind_speed_10m) + ' km/h';
      btnLabel.textContent = 'Aktualizovat';
      reset.hidden = false;
    }

    function showCities() {
      user.hidden = true;
      cities.hidden = false;
      title.textContent = 'Počasí pro pole';
      subtitle.textContent = 'Aktuální · 6 měst';
      btnLabel.textContent = 'Moje pole';
      reset.hidden = true;
    }

    async function load(lat, lon, name) {
      btn.disabled = true;
      btnLabel.textContent = 'Načítám…';
      try {
        const data = await fetchForecast(lat, lon);
        const cityName = name || await reverseGeo(lat, lon);
        const loc = { lat: lat, lon: lon, name: cityName, ts: Date.now() };
        localStorage.setItem(STORAGE, JSON.stringify(loc));
        renderUser(loc, data);
      } catch (e) {
        btnLabel.textContent = 'Chyba — zkusit znovu';
        setTimeout(() => { btnLabel.textContent = 'Moje pole'; }, 2500);
      } finally {
        btn.disabled = false;
      }
    }

    btn.addEventListener('click', () => {
      const cached = localStorage.getItem(STORAGE);
      if (cached) {
        try {
          const loc = JSON.parse(cached);
          if (loc.lat && loc.lon) { load(loc.lat, loc.lon, loc.name); return; }
        } catch {}
      }
      if (!navigator.geolocation) {
        btnLabel.textContent = 'Geolokace nedostupná';
        return;
      }
      btnLabel.textContent = 'Žádám polohu…';
      navigator.geolocation.getCurrentPosition(
        (pos) => load(pos.coords.latitude, pos.coords.longitude, null),
        () => { btnLabel.textContent = 'Povolení odmítnuto'; setTimeout(() => { btnLabel.textContent = 'Moje pole'; }, 2500); },
        { timeout: 8000, maximumAge: 5 * 60 * 1000 }
      );
    });

    reset.addEventListener('click', () => {
      localStorage.removeItem(STORAGE);
      showCities();
    });

    // Auto-restore from cache on load (if fresh)
    const cached = localStorage.getItem(STORAGE);
    if (cached) {
      try {
        const loc = JSON.parse(cached);
        if (loc.lat && loc.lon && (Date.now() - (loc.ts || 0) < TTL_MS)) {
          fetchForecast(loc.lat, loc.lon).then((data) => renderUser(loc, data)).catch(() => {});
        }
      } catch {}
    }
  })();
</script>

{(mode === 'puda' || mode === 'commodity') && agro && (
  <section class="aw-card" aria-label="Počasí pro pole">
    <header class="aw-card-head">
      <div class="aw-card-titles">
        <span class="aw-card-kicker">
          <span class="aw-dot"></span>
          {mode === 'puda' ? 'Půda · vlhkost a srážky' : 'Plodiny · 7denní výhled'}
        </span>
        <h3>{mode === 'puda' ? 'Stav půdy a srážková bilance' : 'Počasí pro vegetační období'}</h3>
        <span class="aw-card-loc">{agro.city.name} · {agro.current.tempC}° · {weatherLabel(agro.current.weatherCode)}</span>
      </div>
      <a class="aw-src" href="https://open-meteo.com/" target="_blank" rel="noopener noreferrer">Zdroj: Open-Meteo ↗</a>
    </header>

    {mode === 'puda' && (
      <div class="aw-puda-grid">
        <div class="aw-metric">
          <span class="aw-m-label">Půdní vlhkost 0–3 cm</span>
          <span class="aw-m-val">{(agro.soil.moisture0_3cm * 100).toFixed(1)}<span class="aw-m-unit"> %</span></span>
          <span class="aw-m-hint">m³ vody / m³ půdy · povrch</span>
        </div>
        <div class="aw-metric">
          <span class="aw-m-label">Půdní vlhkost 3–9 cm</span>
          <span class="aw-m-val">{(agro.soil.moisture3_9cm * 100).toFixed(1)}<span class="aw-m-unit"> %</span></span>
          <span class="aw-m-hint">kořenová zóna obilnin a řepky</span>
        </div>
        <div class="aw-metric">
          <span class="aw-m-label">Srážky · 7 dní zpět</span>
          <span class="aw-m-val">{agro.past7d.precipSum}<span class="aw-m-unit"> mm</span></span>
          <span class="aw-m-hint" style={`color:${droughtColor(agro.past7d.precipSum)};font-weight:600`}>
            {droughtLabel(agro.past7d.precipSum)}
          </span>
        </div>
        <div class="aw-metric">
          <span class="aw-m-label">Srážky · 7 dní vpřed</span>
          <span class="aw-m-val">{totalPrecipAhead}<span class="aw-m-unit"> mm</span></span>
          <span class="aw-m-hint">{agro.daily.precipMm.filter((v) => v > 1).length} dnů s deštěm</span>
        </div>
        <div class="aw-metric">
          <span class="aw-m-label">Teplota půdy · povrch</span>
          <span class="aw-m-val">{agro.soil.temp0cm}<span class="aw-m-unit"> °C</span></span>
          <span class="aw-m-hint">6 cm: {agro.soil.temp6cm} °C</span>
        </div>
        <div class="aw-metric">
          <span class="aw-m-label">Teplota · průměr 7 dní</span>
          <span class="aw-m-val">{agro.past7d.tempAvg.toFixed(1)}<span class="aw-m-unit"> °C</span></span>
          <span class="aw-m-hint">vegetační base 5 °C</span>
        </div>
      </div>
    )}

    {mode === 'commodity' && (
      <>
        <div class="aw-summary">
          <div class="aw-sum-cell">
            <span class="aw-sum-val">{totalPrecipAhead}</span>
            <span class="aw-sum-unit">mm srážek</span>
            <span class="aw-sum-hint">7 dní vpřed</span>
          </div>
          <div class="aw-sum-cell">
            <span class="aw-sum-val">{frostDays}</span>
            <span class="aw-sum-unit">dnů s mrazem</span>
            <span class="aw-sum-hint" style={frostDays > 0 ? 'color:#C24414;font-weight:600' : ''}>
              {frostDays > 0 ? 'Riziko mrazu!' : 'Bez mrazu'}
            </span>
          </div>
          <div class="aw-sum-cell">
            <span class="aw-sum-val">{Math.max(...agro.daily.tempMax)}°</span>
            <span class="aw-sum-unit">max. teplota</span>
            <span class="aw-sum-hint">týdenní maximum</span>
          </div>
          <div class="aw-sum-cell">
            <span class="aw-sum-val">{Math.round(agro.daily.sunshineH.reduce((a, b) => a + b, 0))}</span>
            <span class="aw-sum-unit">h slunce</span>
            <span class="aw-sum-hint">7denní suma</span>
          </div>
        </div>

        <div class="aw-week">
          {agro.daily.dates.map((date, i) => (
            <div class="aw-day">
              <span class="aw-day-name">{dayLabelCs(date)}</span>
              <span class="aw-day-icon">{weatherEmoji(agro.daily.weatherCode[i])}</span>
              <span class="aw-day-tmax">{agro.daily.tempMax[i]}°</span>
              <span class="aw-day-tmin">{agro.daily.tempMin[i]}°</span>
              {agro.daily.precipMm[i] > 0 && (
                <span class="aw-day-rain">{agro.daily.precipMm[i]} mm</span>
              )}
            </div>
          ))}
        </div>
      </>
    )}
  </section>
)}

{(mode === 'strip' && cities.length === 0) && null}
{(mode !== 'strip' && !agro) && null}

<style>
  /* ─── STRIP (homepage) — neo-brutal light ─── */
  .aw-strip {
    background: #fff;
    color: #0A0A0B;
    border-radius: 16px;
    padding: 0;
    margin: 0 auto 28px;
    max-width: 1280px;
    border: 1.5px solid #0A0A0B;
    box-shadow: 4px 4px 0 #0A0A0B;
    overflow: hidden;
  }
  .aw-strip-inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: stretch;
    gap: 0;
  }
  .aw-strip-label {
    display: flex; flex-direction: column; justify-content: center; gap: 2px;
    padding: 14px 18px;
    background: #FFFF00;
    border-right: 1.5px solid #0A0A0B;
    flex-shrink: 0;
  }
  .aw-label-text {
    font: 700 14px 'Chakra Petch', sans-serif; letter-spacing: -.01em;
    color: #0A0A0B; display: inline-flex; align-items: center;
  }
  .aw-label-sub {
    font: 600 10px 'Chakra Petch', sans-serif; letter-spacing: .14em;
    color: #0A0A0B; text-transform: uppercase; opacity: .7;
  }
  .aw-dot {
    display: inline-block; width: 7px; height: 7px; background: #0A0A0B; border-radius: 50%;
    margin-right: 7px;
    animation: aw-pulse 2s infinite;
  }
  @keyframes aw-pulse { 0%,100%{opacity:1} 50%{opacity:.4} }

  .aw-cities {
    display: flex; gap: 0; flex-wrap: nowrap; overflow-x: auto;
    align-items: stretch;
  }
  .aw-city {
    display: flex; align-items: center; gap: 10px;
    padding: 12px 16px;
    border-right: 1px solid #EAEAEC;
    flex-shrink: 0;
    transition: background .15s;
  }
  .aw-city:last-child { border-right: 0; }
  .aw-city:hover { background: #FBFAF4; }
  .aw-city-icon { font-size: 22px; line-height: 1; }
  .aw-city-data { display: flex; flex-direction: column; gap: 0; line-height: 1.15; }
  .aw-city-name {
    font: 600 11px 'Chakra Petch', sans-serif; color: #6B6B72;
    letter-spacing: .06em; text-transform: uppercase;
  }
  .aw-city-temp { font: 700 17px 'Chakra Petch', sans-serif; color: #0A0A0B; letter-spacing: -.01em; }
  .aw-city-rain {
    font: 600 10px 'Chakra Petch', sans-serif; color: #1976D2; letter-spacing: .04em;
    margin-top: 1px;
  }

  /* Geolocation actions */
  .aw-actions {
    display: flex; align-items: center; gap: 8px;
    padding: 12px 16px;
    border-left: 1.5px solid #0A0A0B;
    background: #FBFAF4;
    flex-shrink: 0;
  }
  .aw-geo-btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 8px 14px; background: #FFFF00;
    border: 1.5px solid #0A0A0B; border-radius: 10px;
    color: #0A0A0B; cursor: pointer;
    font: 700 12.5px 'Chakra Petch', sans-serif; letter-spacing: .02em;
    box-shadow: 2px 2px 0 #0A0A0B;
    transition: transform .15s, box-shadow .15s, background .15s;
  }
  .aw-geo-btn:hover {
    transform: translate(-1px,-1px); box-shadow: 3px 3px 0 #0A0A0B; background: #FFEA00;
  }
  .aw-geo-btn:active { transform: translate(0,0); box-shadow: 0 0 0 #0A0A0B; }
  .aw-geo-btn:disabled { opacity: .6; cursor: wait; }
  .aw-reset-btn {
    display: inline-flex; align-items: center; justify-content: center;
    width: 30px; height: 30px; padding: 0;
    background: #fff; border: 1.5px solid #0A0A0B;
    border-radius: 8px; color: #0A0A0B; cursor: pointer;
    transition: background .15s;
  }
  .aw-reset-btn:hover { background: #FFFF00; }
  .aw-strip-src {
    font-size: 10.5px; color: #6B6B72; text-decoration: none;
    border-bottom: 1px dotted #c0c0c5; padding-bottom: 1px;
  }
  .aw-strip-src:hover { color: #0A0A0B; border-bottom-color: #0A0A0B; }

  /* User-location 5-day cards — children are injected via innerHTML so they
     never receive Astro's scope attribute; selectors must be :global. */
  .aw-user {
    display: flex; gap: 0; align-items: stretch; overflow-x: auto;
  }
  .aw-user :global(.aw-day5) {
    display: flex; flex-direction: column; align-items: center; gap: 2px;
    padding: 10px 14px; min-width: 76px;
    border-right: 1px solid #EAEAEC;
    flex-shrink: 0;
  }
  .aw-user :global(.aw-day5:last-child) { border-right: 0; }
  .aw-user :global(.aw-d5-name) {
    font: 700 10.5px 'Chakra Petch', sans-serif; letter-spacing: .12em; text-transform: uppercase;
    color: #6B6B72;
  }
  .aw-user :global(.aw-d5-icon) { font-size: 22px; line-height: 1; margin: 2px 0; }
  .aw-user :global(.aw-d5-tmax) {
    font: 700 16px 'Chakra Petch', sans-serif; color: #0A0A0B; letter-spacing: -.01em;
  }
  .aw-user :global(.aw-d5-tmin) { font: 500 11px 'Chakra Petch', sans-serif; color: #6B6B72; }
  .aw-user :global(.aw-d5-rain) {
    font: 600 10px 'Chakra Petch', sans-serif; color: #1976D2; letter-spacing: .04em;
    margin-top: 2px;
  }

  @media (max-width: 800px) {
    .aw-strip-inner { grid-template-columns: 1fr; }
    .aw-strip-label {
      border-right: 0; border-bottom: 1.5px solid #0A0A0B;
      padding: 10px 16px; flex-direction: row; align-items: baseline; gap: 10px;
    }
    .aw-actions {
      border-left: 0; border-top: 1.5px solid #0A0A0B;
      justify-content: space-between;
    }
    .aw-city { padding: 10px 12px; }
  }

  /* ─── CARD (puda / commodity) ─── */
  .aw-card {
    background: #fff;
    border: 1px solid #EAEAEC;
    border-radius: 18px;
    box-shadow: 0 1px 2px rgba(10,10,12,.04);
    padding: 24px 26px;
    margin: 32px 0 36px;
    scroll-margin-top: 200px;
  }
  .aw-card-head {
    display: flex; justify-content: space-between; align-items: flex-end; gap: 16px;
    margin-bottom: 18px; padding-bottom: 14px; border-bottom: 1px solid #F4F2E9;
    flex-wrap: wrap;
  }
  .aw-card-titles { display: flex; flex-direction: column; gap: 4px; }
  .aw-card-kicker {
    font: 600 11px 'Chakra Petch', sans-serif; letter-spacing: .18em; text-transform: uppercase;
    color: #6B6B72; display: flex; align-items: center;
  }
  .aw-card-kicker .aw-dot {
    background: #0B7A3B; box-shadow: 0 0 0 3px rgba(11,122,59,.2);
  }
  .aw-card h3 {
    font: 700 22px 'Chakra Petch', sans-serif; letter-spacing: -.02em;
    color: #0A0A0B; margin: 0;
  }
  .aw-card-loc {
    font: 500 13px 'Chakra Petch', sans-serif; color: #6B6B72; margin-top: 2px;
  }
  .aw-src {
    font-size: 11.5px; color: #888; text-decoration: none;
    border-bottom: 1px dotted #c0c0c5; padding-bottom: 1px;
  }
  .aw-src:hover { color: #0A0A0B; border-bottom-color: #0A0A0B; }

  /* Půda — metric grid */
  .aw-puda-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 14px;
  }
  .aw-metric {
    background: #FBFAF4; border: 1px solid #EAEAEC; border-radius: 12px;
    padding: 14px 16px; display: flex; flex-direction: column; gap: 4px;
  }
  .aw-m-label {
    font: 600 11px 'Chakra Petch', sans-serif; letter-spacing: .12em; text-transform: uppercase;
    color: #6B6B72;
  }
  .aw-m-val {
    font: 700 26px 'Chakra Petch', sans-serif; letter-spacing: -.02em; color: #0A0A0B;
    line-height: 1;
  }
  .aw-m-unit { font-size: 13px; color: #6B6B72; font-weight: 400; }
  .aw-m-hint { font-size: 12px; color: #6B6B72; margin-top: 2px; }

