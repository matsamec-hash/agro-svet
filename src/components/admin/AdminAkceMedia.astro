---
// Admin blok správy médií akce: galerie fotek (přidat/smazat) + cena.
// JS obsluhuje stránka /admin/akce/ (deleguje přes data-atributy).
interface Img { id: string; url: string }
interface Props {
  id: string;
  cena: string | null;
  images: Img[];
  fotoFallbackUrl: string | null;
}
const { id, cena, images, fotoFallbackUrl } = Astro.props;
const hasPhoto = images.length > 0 || !!fotoFallbackUrl;
---
<div class="media-row" data-id={id}>
  <div class="media-block">
    <span class="media-label">Fotky {hasPhoto && <b>({images.length || 1})</b>}</span>
    <div class="gallery">
      {images.map((img) => (
        <span class="g-thumb">
          <img src={img.url} alt="" />
          <button type="button" class="g-del" data-image-id={img.id} title="Smazat fotku">✕</button>
        </span>
      ))}
      {images.length === 0 && fotoFallbackUrl && (
        <span class="g-thumb">
          <img src={fotoFallbackUrl} alt="" />
          <button type="button" class="g-del" data-legacy title="Smazat fotku">✕</button>
        </span>
      )}
      {!hasPhoto && <span class="media-empty">Zatím žádná fotka</span>}
      <label class="btn-upload">
        📷 <span data-upload-text>Přidat fotky</span>
        <input type="file" data-foto accept="image/jpeg,image/png,image/webp" multiple hidden />
      </label>
    </div>
  </div>

  <div class="media-block">
    <span class="media-label">Vstupné / cena</span>
    <div class="cena-row">
      <input type="text" class="cena-input" data-cena value={cena ?? ''} placeholder="např. zdarma, 100 Kč, děti 50 Kč" maxlength="120" />
      <button type="button" class="btn-save" data-cena-save>Uložit</button>
    </div>
  </div>
</div>
