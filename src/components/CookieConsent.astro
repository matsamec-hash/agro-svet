---
import { getLocaleFromUrl, useTranslations, navHref } from '../i18n/utils';
const GA_ID = "G-HC3JY466RR";
// Po middleware rewritu je Astro.url kanonická cs cesta → locale MUSÍ z locals
// (jinak banner vždy cs i na /sk). Fallback na URL pro jistotu.
const locale = Astro.locals.locale ?? getLocaleFromUrl(Astro.url);
const tr = useTranslations(locale);
---
<div id="cc" class="cc" hidden>
  <div class="cc-inner">
    <p><Fragment set:html={tr('cc.text')} /> <a href={navHref(locale, '/zpracovani-osobnich-udaju/')}>{tr('cc.more')}</a></p>
    <div class="cc-actions">
      <button id="cc-essentials" class="btn-ghost">{tr('cc.essentials')}</button>
      <button id="cc-all" class="btn-primary">{tr('cc.acceptAll')}</button>
    </div>
  </div>
</div>

<script define:vars={{ GA_ID }}>
  function ccInit() {
    const KEY = 'agrosvet-cookie-consent';
    const banner = document.getElementById('cc');
    const stored = localStorage.getItem(KEY);

    function loadGA() {
      if (!GA_ID) return;
      const s = document.createElement('script');
      s.src = `https://www.googletagmanager.com/gtag/js?id=${GA_ID}`;
      s.async = true;
      document.head.appendChild(s);
      window.dataLayer = window.dataLayer || [];
      function gtag(){ window.dataLayer.push(arguments); }
      window.gtag = gtag;
      gtag('js', new Date());
      gtag('config', GA_ID, { anonymize_ip: true });
    }

    if (stored === 'all') loadGA();
    else if (stored !== 'essentials') banner.hidden = false;

    document.getElementById('cc-essentials')?.addEventListener('click', () => {
      localStorage.setItem(KEY, 'essentials');
      banner.hidden = true;
    });
    document.getElementById('cc-all')?.addEventListener('click', () => {
      localStorage.setItem(KEY, 'all');
      banner.hidden = true;
      loadGA();
    });
  }
  if (document.readyState === 'complete') ccInit();
  else window.addEventListener('load', ccInit, { once: true });
</script>

<style>
  .cc { position: fixed; bottom: 16px; left: 16px; right: 16px; max-width: 760px; margin: 0 auto; background: #1a1a1a; color: #fff; border-radius: 12px; padding: 18px 22px; z-index: 1000; box-shadow: 0 8px 32px rgba(0,0,0,.3); font-family: 'Chakra Petch', system-ui, sans-serif; }
  .cc-inner { display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }
  .cc p { margin: 0; font-size: 13px; color: rgba(255,255,255,.85); flex: 1; min-width: 260px; line-height: 1.5; }
  .cc a { color: #FFFF00; text-decoration: underline; }
  .cc-actions { display: flex; gap: 8px; }
  .cc-actions button { padding: 9px 16px; border-radius: 6px; font-size: 12px; font-weight: 700; border: 1px solid; cursor: pointer; font-family: inherit; }
  .btn-ghost { background: transparent; color: #fff; border-color: rgba(255,255,255,.3); }
  .btn-primary { background: #FFFF00; color: #1a1a1a; border-color: #FFFF00; }
</style>
