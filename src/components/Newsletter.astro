---
const variant = Astro.props.variant ?? 'full';
---

<section class={`newsletter newsletter--${variant}`}>
  <div class="newsletter-box">
    <div class="newsletter-text">
      <span class="newsletter-eyebrow">Newsletter</span>
      <h2 class="newsletter-title">Novinky z agro světa do mailu</h2>
      <p class="newsletter-perex">
        Jednou týdně to nejdůležitější ze zemědělství, techniky, dotací a trhu — přímo do schránky.
      </p>
    </div>
    <form id="newsletter-form" class="newsletter-form">
      <input
        id="newsletter-email"
        type="email"
        placeholder="Váš e-mail"
        required
        autocomplete="email"
        class="newsletter-input"
      />
      <button type="submit" id="newsletter-btn" class="newsletter-btn">
        Odebírat
      </button>
    </form>
    <p id="newsletter-msg" class="newsletter-msg">Žádný spam. Odhlášení kdykoliv.</p>
    <p class="newsletter-gdpr">
      Odebíráním souhlasíte se <a href="/zpracovani-osobnich-udaju/">zpracováním osobních údajů</a>. Odhlásit se můžete kdykoliv.
    </p>
  </div>
</section>

<style>
  .newsletter {
    background: #FFFF00;
    padding: 72px 32px;
    position: relative;
    overflow: hidden;
  }
  .newsletter--compact { padding: 48px 24px; }
  .newsletter::before {
    content: '';
    position: absolute;
    top: -120px; right: -120px;
    width: 380px; height: 380px;
    background: rgba(0,0,0,.06); border-radius: 50%;
    pointer-events: none;
  }
  .newsletter::after {
    content: '';
    position: absolute;
    bottom: -100px; left: -100px;
    width: 300px; height: 300px;
    background: rgba(0,0,0,.04); border-radius: 50%;
    pointer-events: none;
  }
  .newsletter-box {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
    position: relative;
    z-index: 1;
  }
  .newsletter-eyebrow {
    display: inline-block;
    background: #1a1a1a;
    color: #FFFF00;
    font-family: 'Chakra Petch', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: .22em;
    text-transform: uppercase;
    padding: 5px 12px;
    border-radius: 999px;
    margin-bottom: 18px;
  }
  .newsletter-title {
    font-family: 'Chakra Petch', sans-serif;
    font-weight: 700;
    font-size: clamp(2rem, 5vw, 3rem);
    color: #0A0A0B;
    margin: 0 0 14px;
    line-height: 1.05;
    letter-spacing: -.03em;
  }
  .newsletter-perex {
    font-family: 'Roboto Condensed', sans-serif;
    font-size: 17px;
    color: rgba(0,0,0,.72);
    margin: 0 auto 28px;
    line-height: 1.55;
    max-width: 540px;
  }
  .newsletter-form {
    display: flex;
    gap: 10px;
    max-width: 480px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .newsletter-input {
    flex: 1;
    min-width: 0;
    padding: 14px 18px;
    border-radius: 12px;
    border: 1.5px solid rgba(0,0,0,.18);
    background: #fff;
    color: #0A0A0B;
    font-family: 'Roboto Condensed', sans-serif;
    font-size: 15px;
    outline: none;
    transition: border-color .15s, box-shadow .15s;
  }
  .newsletter-input:focus {
    border-color: #0A0A0B;
    box-shadow: 0 0 0 4px rgba(10,10,12,.12);
  }
  .newsletter-btn {
    background: #0A0A0B;
    color: #FFFF00;
    font-family: 'Chakra Petch', sans-serif;
    font-weight: 700;
    font-size: 15px;
    letter-spacing: .02em;
    padding: 14px 26px;
    border: 0;
    border-radius: 12px;
    cursor: pointer;
    transition: transform .12s, box-shadow .12s, background .15s;
    box-shadow: 0 6px 16px -6px rgba(10,10,12,.4);
  }
  .newsletter-btn:hover { transform: translateY(-1px); box-shadow: 0 12px 26px -8px rgba(10,10,12,.4); }
  .newsletter-btn:active { transform: translateY(0); }
  .newsletter-btn:disabled { opacity: 0.6; cursor: wait; }
  .newsletter-msg {
    font-family: 'Roboto Condensed', sans-serif;
    font-size: 13px;
    color: rgba(0,0,0,.55);
    margin: 16px 0 0;
  }
  .newsletter-gdpr {
    font-family: 'Roboto Condensed', sans-serif;
    font-size: 12px;
    color: rgba(0,0,0,.5);
    margin: 8px 0 0;
    line-height: 1.5;
  }
  .newsletter-gdpr a {
    color: rgba(0,0,0,.7);
    text-decoration: underline;
  }
  .newsletter-gdpr a:hover { color: #0A0A0B; }
  @media (max-width: 520px) {
    .newsletter-form { flex-direction: column; }
    .newsletter-btn { width: 100%; }
  }
</style>

<script>
  document.getElementById('newsletter-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const emailInput = document.getElementById('newsletter-email') as HTMLInputElement;
    const btn = document.getElementById('newsletter-btn') as HTMLButtonElement;
    const msg = document.getElementById('newsletter-msg') as HTMLElement;
    const email = emailInput.value.trim();
    if (!email) return;

    btn.disabled = true;
    btn.textContent = '...';

    try {
      const res = await fetch('/api/newsletter/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      const data = await res.json().catch(() => ({}));

      if (res.ok && data.status === 'pending_confirmation') {
        msg.textContent = 'Zkontrolujte e-mail a klikněte na potvrzovací odkaz.';
        msg.style.color = '#0B7A3B';
        msg.style.fontWeight = '700';
        emailInput.value = '';
      } else if (res.ok && data.status === 'already_confirmed') {
        msg.textContent = 'Tento e-mail už newsletter odebírá.';
        msg.style.color = '#0A0A0B';
        msg.style.fontWeight = '700';
      } else if (data.error === 'invalid_email') {
        msg.textContent = 'Zadejte platný e-mail.';
        msg.style.color = '#C24414';
        msg.style.fontWeight = '700';
      } else {
        throw new Error(data.error || 'subscribe_failed');
      }
    } catch {
      msg.textContent = 'Něco se pokazilo. Zkuste to znovu.';
      msg.style.color = '#C24414';
      msg.style.fontWeight = '700';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Odebírat';
    }
  });
</script>
