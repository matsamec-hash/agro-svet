  .catalog-page .brand-meta{display:flex;gap:8px;font-size:13px;color:var(--muted);align-items:center;margin-top:4px;flex-wrap:wrap}
  .catalog-page .brand-meta .sep{width:3px;height:3px;background:var(--muted-2);border-radius:50%}
  .catalog-page .brand-meta strong{color:#17171A;font-weight:600}
  .catalog-page .brand-cta{
    font:600 13px 'Chakra Petch',sans-serif;color:#000;text-decoration:none;
    background:var(--yellow);padding:11px 16px;border-radius:10px;
    display:inline-flex;align-items:center;gap:8px;transition:.15s;
  }
  .catalog-page .brand-cta:hover{transform:translateY(-1px);box-shadow:0 10px 30px -8px var(--yellow-glow)}
  .catalog-page .brand-cta svg{width:14px;height:14px}

  .catalog-page .block-label{
    font:600 11px 'Chakra Petch',sans-serif;letter-spacing:.18em;text-transform:uppercase;
    color:var(--muted);display:flex;align-items:center;gap:12px;margin:4px 0 14px;
  }
  .catalog-page .block-label::after{content:"";flex:1;height:1px;background:var(--line)}
  .catalog-page .block-label .status{
    display:inline-flex;align-items:center;gap:7px;padding:4px 10px;border-radius:999px;
    font-size:11px;letter-spacing:.14em;
  }
  .catalog-page .block-label .status.current{background:var(--green-soft);color:var(--green)}
  .catalog-page .block-label .status.current .dot{width:7px;height:7px;background:var(--green);border-radius:50%;animation:cb-pulse 2s infinite}
  @keyframes cb-pulse{0%,100%{box-shadow:0 0 0 0 rgba(11,122,59,.4)}50%{box-shadow:0 0 0 5px rgba(11,122,59,0)}}

  .catalog-page .family-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:14px}
  .catalog-page .family-tile{
    position:relative;display:flex;flex-direction:column;
    background:var(--card);border:1px solid var(--line);border-radius:var(--r-lg);
    overflow:hidden;text-decoration:none;color:inherit;
    transition:.25s cubic-bezier(.2,.7,.2,1);
  }
  .catalog-page .family-tile:hover{transform:translateY(-2px);box-shadow:var(--sh-3);border-color:var(--yellow)}
  .catalog-page .family-tile:focus-visible{outline:3px solid var(--yellow);outline-offset:3px}
  .catalog-page .ft-cover{
    height:140px;position:relative;overflow:hidden;
    background-size:cover;background-position:center;background-color:#2a2a30;
    display:flex;align-items:flex-end;
  }
  .catalog-page .ft-cover::after{
    content:"";position:absolute;inset:0;pointer-events:none;
    background:linear-gradient(180deg, rgba(0,0,0,.05) 0%, rgba(0,0,0,.02) 50%, rgba(0,0,0,.4) 100%);
  }
  .catalog-page .ft-silhouette{
    position:absolute;left:8px;bottom:8px;width:120px;height:auto;
    opacity:.85;pointer-events:none;
  }
  .catalog-page .ft-credit{
    position:absolute;right:6px;bottom:6px;z-index:2;
    background:rgba(255,255,255,.92);backdrop-filter:blur(4px);
    color:#0A0A0B;font:500 9px 'Chakra Petch',sans-serif;
    padding:3px 7px;border-radius:4px;letter-spacing:.04em;
    opacity:0;transition:opacity .15s;pointer-events:none;
    white-space:nowrap;
  }
  .catalog-page .family-tile:hover .ft-credit{opacity:1}
  .catalog-page .brand-credit{font-size:12px;color:var(--muted)}
  .catalog-page .brand-credit a{color:var(--muted);text-decoration:underline;text-decoration-color:var(--line-2)}
  .catalog-page .brand-credit a:hover{color:#000;text-decoration-color:#000}
  .catalog-page .ft-body{padding:14px 16px 14px;display:flex;flex-direction:column;gap:9px;flex:1}
  .catalog-page .ft-head{display:flex;justify-content:space-between;align-items:flex-start;gap:10px}
  .catalog-page .ft-title{font:700 18px 'Chakra Petch',sans-serif;color:var(--ink);letter-spacing:-.01em;line-height:1.1}
  .catalog-page .ft-sub{font-size:12px;color:var(--muted);margin-top:3px;line-height:1.35}
  .catalog-page .ft-count{
    font:600 11px 'Chakra Petch',sans-serif;color:#17171A;
    background:#F4F2E9;padding:3px 8px;border-radius:6px;letter-spacing:.04em;
    white-space:nowrap;
  }

  .catalog-page .ft-bar-wrap{display:flex;flex-direction:column;gap:4px}
  .catalog-page .ft-bar-row{display:flex;justify-content:space-between;align-items:center;
    font:500 11px 'Chakra Petch',sans-serif;color:var(--muted);letter-spacing:.08em;text-transform:uppercase}
  .catalog-page .ft-bar-row .v{font:600 12px 'Chakra Petch',sans-serif;color:#17171A;text-transform:none;letter-spacing:-.01em}
  .catalog-page .ft-bar{height:5px;background:#F1EFE7;border-radius:999px;overflow:hidden;position:relative}
  .catalog-page .ft-bar::before{
    content:"";position:absolute;top:0;bottom:0;
    left:var(--from,0%);width:var(--span,30%);
    background:linear-gradient(90deg,var(--yellow) 0%,#FFD400 100%);
    border-radius:999px;box-shadow:0 0 6px rgba(255,212,0,.6);
  }

  .catalog-page .ft-foot{
    display:flex;justify-content:space-between;align-items:center;
    margin-top:auto;padding-top:9px;border-top:1px dashed var(--line);
    font-size:12.5px;color:var(--muted);
  }
  .catalog-page .ft-foot .year{display:inline-flex;align-items:center;gap:5px;font:500 12px 'Chakra Petch',sans-serif;color:#17171A}
  .catalog-page .ft-foot .year svg{width:13px;height:13px;color:var(--muted)}
  .catalog-page .ft-foot .go{font:700 13px 'Chakra Petch',sans-serif;color:#0A0A0B;display:inline-flex;align-items:center;gap:4px;transition:transform .15s}
  .catalog-page .family-tile:hover .ft-foot .go{transform:translateX(2px)}

  .catalog-page .show-all-cta{
    display:flex;justify-content:space-between;align-items:center;gap:12px;
    margin-top:14px;padding:13px 18px;
    background:transparent;color:#17171A;text-decoration:none;
    border:1px dashed var(--line-2);border-radius:var(--r-md);
    transition:.15s;flex-wrap:wrap;
  }
  .catalog-page .show-all-cta:hover{background:var(--yellow-soft);border-color:var(--yellow);border-style:solid}
  .catalog-page .sac-t{font:600 14px 'Chakra Petch',sans-serif;color:#17171A;letter-spacing:-.01em}
  .catalog-page .sac-t strong{color:#000;font-weight:700}
  .catalog-page .sac-d{font-size:13px;color:var(--muted);margin-left:4px;font-weight:500}
  .catalog-page .sac-arrow{
    display:inline-flex;align-items:center;justify-content:center;
    color:#0A0A0B;font:700 13px 'Chakra Petch',sans-serif;gap:6px;white-space:nowrap;
  }
  .catalog-page .sac-arrow svg{width:14px;height:14px;transition:transform .15s}
  .catalog-page .show-all-cta:hover .sac-arrow svg{transform:translateX(3px)}

  .catalog-page .big-cta{
    margin-top:32px;padding:36px;border-radius:var(--r-xl);
    background:linear-gradient(135deg,var(--yellow) 0%,#FFD400 100%);
    display:grid;grid-template-columns:1.4fr 1fr;gap:28px;align-items:center;
    position:relative;overflow:hidden;box-shadow:0 10px 30px -8px var(--yellow-glow);
  }
  .catalog-page .big-cta::before{
    content:"";position:absolute;inset:0;pointer-events:none;
    background:radial-gradient(400px 300px at 100% 100%, rgba(0,0,0,.12), transparent);
  }
  .catalog-page .big-cta h2{font-family:'Chakra Petch',sans-serif;font-size:30px;line-height:1.05;letter-spacing:-.02em;position:relative;z-index:2;color:#0A0A0B;margin:0}
  .catalog-page .big-cta p{color:#2a2a2a;margin-top:10px;font-size:15px;position:relative;z-index:2}
  .catalog-page .cta-kicker{
    display:inline-block;font:600 11px 'Chakra Petch',sans-serif;letter-spacing:.2em;text-transform:uppercase;
    color:#0A0A0B;background:rgba(0,0,0,.08);padding:6px 12px;border-radius:999px;margin-bottom:14px;position:relative;z-index:2;
  }
  .catalog-page .cta-btn{
    background:#0A0A0B;color:#fff;padding:15px 24px;border-radius:14px;text-decoration:none;
    font:700 14px 'Chakra Petch',sans-serif;letter-spacing:.04em;
    display:inline-flex;align-items:center;gap:10px;margin-top:18px;
    transition:.15s;position:relative;z-index:2;
  }
  .catalog-page .cta-btn:hover{transform:translateY(-2px);box-shadow:0 14px 30px -10px rgba(0,0,0,.4)}
  .catalog-page .cta-btn svg{width:14px;height:14px}
  .catalog-page .cta-right{position:relative;z-index:2;min-height:200px;display:flex;align-items:center;justify-content:center}
  .catalog-page .cta-photo{
    width:100%;height:200px;border-radius:16px;
    background-size:cover;background-position:center;
    box-shadow:0 20px 40px -12px rgba(0,0,0,.3), 0 0 0 1px rgba(0,0,0,.1);
    position:relative;overflow:hidden;
  }
  .catalog-page .cta-photo::after{content:"";position:absolute;inset:0;background:linear-gradient(135deg,transparent 40%,rgba(0,0,0,.15))}

  @media (max-width:960px){
    .catalog-page .hero{grid-template-columns:1fr;padding:32px 24px 28px;gap:18px}
    .catalog-page .hero-right{min-height:200px;order:2}
    .catalog-page .hero-photo{min-height:200px}
    .catalog-page .big-cta{grid-template-columns:1fr;padding:28px}
    .catalog-page .cta-right{min-height:0}
    .catalog-page .cta-photo{height:180px}
    .catalog-page .hero-stats .s + .s{padding-left:0;border-left:0}
  }
  @media (max-width:600px){
    .catalog-page{padding:20px 16px 60px}
    .catalog-page .brand{padding:18px}
    .catalog-page .brand-head{align-items:flex-start}
    .catalog-page .show-all-cta{flex-direction:column;align-items:flex-start;gap:8px}
    .catalog-page .split-bar{top:72px}
  }

  /* Filter bar */
  .catalog-page .filter-bar{
    background:var(--card);border:1px solid var(--line);border-radius:14px;
    padding:14px 18px;margin:0 0 22px;box-shadow:var(--sh-1);
  }
  .catalog-page .filter-head{
    display:flex;align-items:center;gap:14px;flex-wrap:wrap;
    padding-bottom:10px;margin-bottom:12px;border-bottom:1px dashed var(--line);
  }
  .catalog-page .filter-title{font:700 13px 'Chakra Petch',sans-serif;letter-spacing:.1em;text-transform:uppercase;color:var(--ink)}
  .catalog-page .filter-result{font:600 13px 'Chakra Petch',sans-serif;color:var(--muted);margin-left:auto}
  .catalog-page .filter-result.is-filtered{color:var(--ink)}
  .catalog-page .filter-reset{
    background:var(--yellow-soft);border:1px solid var(--yellow);
    color:var(--ink);padding:6px 12px;border-radius:8px;cursor:pointer;
    font:700 11.5px 'Chakra Petch',sans-serif;letter-spacing:.06em;transition:.15s;
  }
  .catalog-page .filter-reset:hover{background:var(--yellow);transform:translateY(-1px)}
  .catalog-page .filter-controls{display:flex;gap:18px;flex-wrap:wrap;align-items:flex-start}
  .catalog-page .filter-group{display:flex;flex-direction:column;gap:5px;min-width:140px}
  .catalog-page .filter-label{font:600 11px 'Chakra Petch',sans-serif;letter-spacing:.1em;text-transform:uppercase;color:var(--muted)}
  .catalog-page .range-inputs{display:flex;align-items:center;gap:6px}
  .catalog-page .filter-num{
    width:72px;padding:7px 10px;font:600 13px 'Chakra Petch',sans-serif;
    background:#FBFAF4;border:1px solid var(--line);border-radius:7px;color:var(--ink);
    outline:none;transition:.12s;
  }
  .catalog-page .filter-num:focus{border-color:var(--yellow);box-shadow:0 0 0 3px rgba(255,234,0,.25);background:#fff}
  .catalog-page .range-sep{color:var(--muted-2);font-size:12px}
  .catalog-page .filter-checkbox{
    display:inline-flex;align-items:center;gap:8px;
    font:600 13px 'Chakra Petch',sans-serif;color:var(--ink);cursor:pointer;
    padding:8px 0;
  }
  .catalog-page .filter-checkbox input{width:16px;height:16px;accent-color:var(--ink);cursor:pointer}
  .catalog-page .filter-checkbox .muted{color:var(--muted);font-weight:500}
  .catalog-page .filter-brands{position:relative}
  .catalog-page .filter-brands-summary{
    list-style:none;cursor:pointer;padding:7px 12px;background:#FBFAF4;
    border:1px solid var(--line);border-radius:7px;font:600 13px 'Chakra Petch',sans-serif;
    color:var(--ink);user-select:none;transition:.12s;
  }
  .catalog-page .filter-brands-summary::-webkit-details-marker{display:none}
  .catalog-page .filter-brands[open] .filter-brands-summary{background:var(--yellow-soft);border-color:var(--yellow)}
  .catalog-page .filter-brands-summary .fb-count{color:var(--muted);font-weight:500;margin-left:4px;font-size:12px}
  .catalog-page .filter-brands-list{
    position:absolute;top:100%;left:0;margin-top:6px;z-index:20;
    background:#fff;border:1px solid var(--line);border-radius:10px;
    padding:8px 12px;min-width:220px;max-height:320px;overflow-y:auto;
    box-shadow:var(--sh-2);display:flex;flex-direction:column;gap:2px;
  }

  /* Filtered-out states */
  .catalog-page .family-tile.is-hidden,
  .catalog-page .brand.is-hidden,
  .catalog-page .pill.is-hidden {
    display:none !important;
  }
  .catalog-page .filter-empty{
    background:var(--bg-cream);border:1px dashed var(--line-2);
    border-radius:14px;padding:48px 32px;text-align:center;
    font:500 15px 'Chakra Petch',sans-serif;color:var(--muted);
    display:none;
  }
  .catalog-page .filter-empty.is-visible{display:block}
  .catalog-page .filter-empty strong{color:var(--ink);display:block;margin-bottom:8px;font-size:18px}

  @media (max-width:720px){
    .catalog-page .filter-controls{flex-direction:column;align-items:stretch}
    .catalog-page .filter-group{min-width:0}
    .catalog-page .filter-brands-list{position:static;margin-top:8px;width:auto}
    .catalog-page .filter-result{margin-left:0;width:100%}
  }
</style>

<script>
  // ── Filter logic ──────────────────────────────────────────────────────────
  // Filters family tiles in-place; hides whole brand sections that lose all
  // visible tiles. URL is updated via replaceState so the filter survives
  // reload + back/forward.
  // i18n strings are passed from the frontmatter via a JSON <script> data island
  // (#cb-i18n) so the filter result + brand-count labels are localized while the
  // server-rendered HTML stays byte-identical per locale.
  const i18nEl = document.getElementById('cb-i18n');
  const I18N = i18nEl ? JSON.parse(i18nEl.textContent || '{}') : { result: '{rows} řad ve {brands} značkách', brandAll: '(vše)' };
  const filterBar = document.getElementById('filter-bar');
  const hpMinInput = document.getElementById('filter-hp-min') as HTMLInputElement | null;
  const hpMaxInput = document.getElementById('filter-hp-max') as HTMLInputElement | null;
  const yearMinInput = document.getElementById('filter-year-min') as HTMLInputElement | null;
  const yearMaxInput = document.getElementById('filter-year-max') as HTMLInputElement | null;
  const currentInput = document.getElementById('filter-current') as HTMLInputElement | null;
  const brandCheckboxes = document.querySelectorAll<HTMLInputElement>('.filter-brand-cb');
  const brandCountEl = document.getElementById('filter-brand-count');
  const resetBtn = document.getElementById('filter-reset');
  const resultEl = document.getElementById('filter-result');
  const emptyEl = document.getElementById('filter-empty');
  const tiles = Array.from(document.querySelectorAll<HTMLElement>('.catalog-page .family-tile'));
  const brandSections = Array.from(document.querySelectorAll<HTMLElement>('.catalog-page .brand[id]'));
  const brandPills = Array.from(document.querySelectorAll<HTMLAnchorElement>('.catalog-page .brand-pills .pill'));

  type FilterState = {
    hpMin: number | null;
    hpMax: number | null;
    yearMin: number | null;
    yearMax: number | null;
    currentOnly: boolean;
    brands: Set<string>;
  };

  const allBrandSlugs = new Set(Array.from(brandCheckboxes, (cb) => cb.value));

  function readState(): FilterState {
    const checkedBrands = new Set<string>();
    brandCheckboxes.forEach((cb) => { if (cb.checked) checkedBrands.add(cb.value); });
    return {
      hpMin: hpMinInput?.value ? parseInt(hpMinInput.value, 10) || null : null,
      hpMax: hpMaxInput?.value ? parseInt(hpMaxInput.value, 10) || null : null,
      yearMin: yearMinInput?.value ? parseInt(yearMinInput.value, 10) || null : null,
      yearMax: yearMaxInput?.value ? parseInt(yearMaxInput.value, 10) || null : null,
      currentOnly: currentInput?.checked ?? true,
      brands: checkedBrands,
    };
  }

  function tileMatches(tile: HTMLElement, st: FilterState): boolean {
    if (!st.brands.has(tile.dataset.brand ?? '')) return false;
    if (st.currentOnly && tile.dataset.current !== '1') return false;
    const tMinHp = parseInt(tile.dataset.minHp ?? '', 10);
    const tMaxHp = parseInt(tile.dataset.maxHp ?? '', 10);
    if (st.hpMin !== null && !Number.isNaN(tMaxHp) && tMaxHp < st.hpMin) return false;
    if (st.hpMax !== null && !Number.isNaN(tMinHp) && tMinHp > st.hpMax) return false;
    const tMinYear = parseInt(tile.dataset.minYear ?? '', 10);
    const tMaxYear = parseInt(tile.dataset.maxYear ?? '', 10);
    if (st.yearMin !== null && !Number.isNaN(tMaxYear) && tMaxYear < st.yearMin) return false;
    if (st.yearMax !== null && !Number.isNaN(tMinYear) && tMinYear > st.yearMax) return false;
    return true;
  }

  function isFiltered(st: FilterState): boolean {
    if (st.hpMin !== null || st.hpMax !== null) return true;
    if (st.yearMin !== null || st.yearMax !== null) return true;
    if (!st.currentOnly) return true;
    if (st.brands.size !== allBrandSlugs.size) return true;
    return false;
  }

  function applyFilters() {
    const st = readState();
    let visibleTiles = 0;
    const visibleBrandSlugs = new Set<string>();
    for (const tile of tiles) {
      const match = tileMatches(tile, st);
      tile.classList.toggle('is-hidden', !match);
      if (match) {
        visibleTiles += 1;
        if (tile.dataset.brand) visibleBrandSlugs.add(tile.dataset.brand);
      }
    }
    for (const sec of brandSections) {
      const hide = !visibleBrandSlugs.has(sec.dataset.brand ?? '');
      sec.classList.toggle('is-hidden', hide);
    }
    for (const pill of brandPills) {
      const href = pill.getAttribute('href') ?? '';
      const slug = href.startsWith('#') ? href.slice(1) : '';
      pill.classList.toggle('is-hidden', slug !== '' && !visibleBrandSlugs.has(slug));
    }
    if (resultEl) {
      const filtered = isFiltered(st);
      resultEl.textContent = I18N.result
        .replace('{rows}', String(visibleTiles))
        .replace('{brands}', String(visibleBrandSlugs.size));
      resultEl.classList.toggle('is-filtered', filtered);
    }
    if (resetBtn) resetBtn.hidden = !isFiltered(st);
    if (emptyEl) emptyEl.classList.toggle('is-visible', visibleTiles === 0);
    if (brandCountEl) {
      brandCountEl.textContent = st.brands.size === allBrandSlugs.size ? I18N.brandAll : `(${st.brands.size})`;
    }
    syncUrl(st);
  }

  function syncUrl(st: FilterState) {
    if (!('replaceState' in history)) return;
    const params = new URLSearchParams();
    if (st.hpMin !== null) params.set('hp_min', String(st.hpMin));
    if (st.hpMax !== null) params.set('hp_max', String(st.hpMax));
    if (st.yearMin !== null) params.set('year_min', String(st.yearMin));
    if (st.yearMax !== null) params.set('year_max', String(st.yearMax));
    if (!st.currentOnly) params.set('current', '0');
    if (st.brands.size !== allBrandSlugs.size) params.set('brand', Array.from(st.brands).sort().join(','));
    const qs = params.toString();
    const url = qs ? `${location.pathname}?${qs}` : location.pathname;
    history.replaceState(null, '', url + location.hash);
  }

  function loadFromUrl() {
    const params = new URLSearchParams(location.search);
    if (hpMinInput && params.has('hp_min')) hpMinInput.value = params.get('hp_min') ?? '';
    if (hpMaxInput && params.has('hp_max')) hpMaxInput.value = params.get('hp_max') ?? '';
    if (yearMinInput && params.has('year_min')) yearMinInput.value = params.get('year_min') ?? '';
    if (yearMaxInput && params.has('year_max')) yearMaxInput.value = params.get('year_max') ?? '';
    if (currentInput && params.get('current') === '0') currentInput.checked = false;
    if (params.has('brand')) {
      const wanted = new Set(params.get('brand')!.split(',').filter(Boolean));
      brandCheckboxes.forEach((cb) => { cb.checked = wanted.has(cb.value); });
    }
  }

  function resetFilters() {
    if (hpMinInput) hpMinInput.value = '';
    if (hpMaxInput) hpMaxInput.value = '';
    if (yearMinInput) yearMinInput.value = '';
    if (yearMaxInput) yearMaxInput.value = '';
    if (currentInput) currentInput.checked = true;
    brandCheckboxes.forEach((cb) => { cb.checked = true; });
    applyFilters();
  }

  if (filterBar) {
    loadFromUrl();
    hpMinInput?.addEventListener('input', applyFilters);
    hpMaxInput?.addEventListener('input', applyFilters);
    yearMinInput?.addEventListener('input', applyFilters);
    yearMaxInput?.addEventListener('input', applyFilters);
    currentInput?.addEventListener('change', applyFilters);
    brandCheckboxes.forEach((cb) => cb.addEventListener('change', applyFilters));
    resetBtn?.addEventListener('click', resetFilters);
    applyFilters();
  }

  // ── Scroll-spy for brand pills (existing behavior, preserved) ────────────
  const pills = document.querySelectorAll<HTMLAnchorElement>('.catalog-page .brand-pills .pill');
  const sections = document.querySelectorAll<HTMLElement>('.catalog-page .brand[id]');
  if (pills.length && sections.length && 'IntersectionObserver' in window) {
    const byId = new Map<string, HTMLAnchorElement>();
    pills.forEach((p) => {
      const href = p.getAttribute('href') || '';
      if (href.startsWith('#')) byId.set(href.slice(1), p);
    });
    const io = new IntersectionObserver((entries) => {
      let topMost: { id: string; top: number } | null = null;
      entries.forEach((e) => {
        if (e.isIntersecting) {
          const target = e.target as HTMLElement;
          const top = e.boundingClientRect.top;
          if (!topMost || top < topMost.top) topMost = { id: target.id, top };
        }
      });
      if (topMost) {
        pills.forEach((p) => p.classList.remove('active'));
        const t = topMost as { id: string; top: number };
        byId.get(t.id)?.classList.add('active');
      }
    }, { rootMargin: '-160px 0px -60% 0px', threshold: 0 });
    sections.forEach((s) => io.observe(s));
  }
</script>
