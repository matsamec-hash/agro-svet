    transition:.15s;
  }
  .catalog-page .pill:hover{background:var(--yellow-soft);border-color:var(--yellow);transform:translateY(-1px)}
  .catalog-page .pill.active{background:#0A0A0B;color:#fff;border-color:#0A0A0B}
  .catalog-page .pill .c{background:rgba(0,0,0,.06);color:#4a4a50;padding:1px 7px;border-radius:10px;font-size:11px;font-weight:600}
