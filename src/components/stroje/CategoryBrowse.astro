---
import { getAllBrands, seriesFamily, familyLabel, type StrojKategorie } from '../../lib/stroje';

interface Props {
  category: StrojKategorie;
}
const { category } = Astro.props;

const categoryLabels: Record<StrojKategorie, string> = {
  traktory: 'Traktory',
  kombajny: 'Kombajny',
};
const categoryHero: Record<StrojKategorie, string> = {
  traktory: '/images/traktor.webp',
  kombajny: '/images/kombajn.webp',
};
const categoryLede: Record<StrojKategorie, string> = {
  traktory:
    'Kompletní encyklopedie modelových řad — od zahradních „jednadvacítek“ po 620k obry na polích. Aktuální produkce i historické modely pro bazarový průzkum.',
  kombajny:
    'Přehled sklízecích mlátiček — od kompaktních 4-bubnových po hybridy s rotorem. Kapacita zásobníku, šířka záběru, motorizace per modelová řada.',
};

const brandCreditUrl: Record<string, string> = {
  'john-deere': 'https://www.deere.cz/cs/traktory/',
  fendt: 'https://www.fendt.com/cz/traktory',
  claas: 'https://www.claas.com/cs-cz/zemedelske-stroje/traktory',
  zetor: 'https://www.zetor.com/cs/zetor-products',
};
function brandCreditLabel(slug: string): string {
  const url = brandCreditUrl[slug];
  if (!url) return '';
  try {
    return new URL(url).hostname.replace(/^www\./, '');
  } catch {
    return '';
  }
}

const brandColors: Record<string, [string, string]> = {
  'john-deere': ['#4A9838', '#2E6B22'],
  fendt: ['#3FA85D', '#0E6730'],
  claas: ['#9C9532', '#65601A'],
  'deutz-fahr': ['#2BA84A', '#1a5e2a'],
  kubota: ['#FF6B1A', '#C24414'],
  'new-holland': ['#3874AC', '#1A4370'],
  'case-ih': ['#D62A2A', '#8F1818'],
  'massey-ferguson': ['#D62A2A', '#8F1818'],
  valtra: ['#1F1F1F', '#0A0A0A'],
  zetor: ['#E93A3A', '#A01818'],
};
const brandInitials: Record<string, string> = {
  'john-deere': 'JD',
  fendt: 'F',
  claas: 'C',
  'deutz-fahr': 'DF',
  kubota: 'K',
  'new-holland': 'NH',
  'case-ih': 'CI',
  'massey-ferguson': 'MF',
  valtra: 'V',
  zetor: 'Z',
};
function brandTone(slug: string): [string, string] {
  return brandColors[slug] ?? ['#2a2a30', '#0a0a0b'];
}
function brandInitial(slug: string, name: string): string {
  return brandInitials[slug] ?? name.slice(0, 2).toUpperCase();
}

type Tile = {
  family: string;
  label: string;
  modelCount: number;
  seriesCount: number;
  minHp: number | null;
  maxHp: number | null;
  minYear: number | null;
  maxYear: number | null;
  hasCurrent: boolean;
  coverImage: string | null;
};

type BrandSection = {
  slug: string;
  name: string;
  country: string;
  founded: number;
  modelCount: number;
  seriesCount: number;
  minHp: number | null;
  maxHp: number | null;
  topTiles: Tile[];
  legacyCount: number;
  legacyModelCount: number;
  legacyExamples: string[];
};

const HP_MAX_FOR_BAR = category === 'traktory' ? 620 : 700;
const TOP_TILES = 4;
const PRIORITY_BRANDS = ['john-deere', 'fendt', 'claas'];

function buildTilesForCategory(brand: any): Tile[] {
  const cat = brand.categories?.[category];
  if (!cat) return [];
  const byFamily = new Map<string, Tile>();
  for (const s of cat.series ?? []) {
    const fam = (s as any).family || seriesFamily(s.slug);
    const labelOverride = (s as any).family_label;
    let t = byFamily.get(fam);
    if (!t) {
      t = {
        family: fam,
        label: labelOverride || familyLabel(fam),
        modelCount: 0,
        seriesCount: 0,
        minHp: null,
        maxHp: null,
        minYear: null,
        maxYear: null,
        hasCurrent: false,
        coverImage: null,
      };
      byFamily.set(fam, t);
    }
    t.seriesCount += 1;
    if (labelOverride) t.label = labelOverride;
    if (!t.coverImage && (s as any).image_url) t.coverImage = (s as any).image_url;
    for (const m of s.models ?? []) {
      t.modelCount += 1;
      if (m.power_hp !== null) {
        t.minHp = t.minHp === null ? m.power_hp : Math.min(t.minHp, m.power_hp);
        t.maxHp = t.maxHp === null ? m.power_hp : Math.max(t.maxHp, m.power_hp);
      }
      if (m.year_from !== null) {
        t.minYear = t.minYear === null ? m.year_from : Math.min(t.minYear, m.year_from);
      }
      if (m.year_to === null && m.year_from !== null) {
        t.hasCurrent = true;
      } else if (m.year_to !== null) {
        t.maxYear = t.maxYear === null ? m.year_to : Math.max(t.maxYear, m.year_to);
      }
    }
  }
  return [...byFamily.values()];
}

function tileSort(a: Tile, b: Tile): number {
  if (a.hasCurrent !== b.hasCurrent) return a.hasCurrent ? -1 : 1;
  const aMax = a.maxHp ?? 0;
  const bMax = b.maxHp ?? 0;
  if (aMax !== bMax) return bMax - aMax;
  if (a.modelCount !== b.modelCount) return b.modelCount - a.modelCount;
  return a.family.localeCompare(b.family, 'cs');
}

function familySublabel(family: string): string {
  if (/^\d+$/.test(family)) return `${family}. řada`;
  return '';
}

function hpBar(min: number | null, max: number | null): { from: number; span: number } {
  if (min === null || max === null) return { from: 0, span: 0 };
  const from = Math.max(0, Math.min(100, (min / HP_MAX_FOR_BAR) * 100));
  const to = Math.max(0, Math.min(100, (max / HP_MAX_FOR_BAR) * 100));
  return { from, span: Math.max(2, to - from) };
}

const sections: BrandSection[] = [];
for (const b of getAllBrands() as any[]) {
  const tiles = buildTilesForCategory(b);
  if (tiles.length === 0) continue;
  const sorted = [...tiles].sort(tileSort);
  const currentSorted = sorted.filter((t) => t.hasCurrent);
  const legacyTiles = sorted.filter((t) => !t.hasCurrent);
  const topTiles = currentSorted.slice(0, TOP_TILES);
  // Display strongest-on-the-right (ASC by max hp) for natural left-to-right reading
  topTiles.sort((a, b) => (a.maxHp ?? 0) - (b.maxHp ?? 0));
  if (topTiles.length === 0) continue;
  const modelCount = tiles.reduce((acc, t) => acc + t.modelCount, 0);
  const seriesCount = tiles.reduce((acc, t) => acc + t.seriesCount, 0);
  const hpAll = tiles.flatMap((t) => [t.minHp, t.maxHp]).filter((x): x is number => x !== null);
  const legacyModelCount = legacyTiles.reduce((acc, t) => acc + t.modelCount, 0);

  sections.push({
    slug: b.slug,
    name: b.name,
    country: b.country,
    founded: b.founded,
    modelCount,
    seriesCount,
    minHp: hpAll.length ? Math.min(...hpAll) : null,
    maxHp: hpAll.length ? Math.max(...hpAll) : null,
    topTiles,
    legacyCount: legacyTiles.length,
    legacyModelCount,
    legacyExamples: legacyTiles.slice(0, 4).map((t) => t.label),
  });
}
sections.sort((a, b) => {
  const aPrio = PRIORITY_BRANDS.indexOf(a.slug);
  const bPrio = PRIORITY_BRANDS.indexOf(b.slug);
  if (aPrio !== -1 && bPrio !== -1) return aPrio - bPrio;
  if (aPrio !== -1) return -1;
  if (bPrio !== -1) return 1;
  return b.modelCount - a.modelCount;
});

const totalModels = sections.reduce((acc, s) => acc + s.modelCount, 0);
const totalBrands = sections.length;
const allHp = sections.flatMap((s) => [s.minHp, s.maxHp]).filter((x): x is number => x !== null);
const minHp = allHp.length ? Math.min(...allHp) : null;
const maxHp = allHp.length ? Math.max(...allHp) : null;

const catLabel = categoryLabels[category];
const catHeroImage = categoryHero[category];
const catLede = categoryLede[category];
---

<div class="catalog-page">

  <nav class="breadcrumb" aria-label="Cesta">
    <a href="/">Domů</a>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
    <a href="/stroje/">Technika</a>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
    <span class="current">{catLabel}</span>
  </nav>

  <section class="hero">
    <div class="hero-left">
      <span class="kicker"><span class="dot"></span>Katalog · Technika</span>
      <h1>{catLabel} <em>všech značek</em></h1>
      <p class="hero-lede">{catLede}</p>

      <div class="hero-stats">
        <div class="s"><span class="n">{totalModels}+</span><span class="l">modelů</span></div>
        <div class="s"><span class="n">{totalBrands}</span><span class="l">značek</span></div>
        {minHp !== null && maxHp !== null && (
          <div class="s"><span class="n">{minHp}–{maxHp} k</span><span class="l">výkon</span></div>
        )}
      </div>

      <form class="search" role="search" action="/hledat/" method="GET">
        <input type="search" name="q" placeholder={`Hledejte model, řadu nebo značku — např. "Zetor Proxima 120"`} aria-label="Vyhledat" />
        <button type="submit">
          Hledat
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </button>
      </form>
    </div>

    <div class="hero-right">
      <div class="hero-photo" style={`background-image:url('${catHeroImage}')`}>
        <div class="hero-photo-badge"><span class="n">{totalModels}+</span> modelů v katalogu</div>
      </div>
    </div>
  </section>

  <div class="split-bar">
    <div class="split-inner">
      <nav class="brand-pills" aria-label="Značky">
        {sections.map((s, i) => (
          <a class:list={['pill', { active: i === 0 }]} href={`#${s.slug}`}>{s.name} <span class="c">{s.modelCount}</span></a>
        ))}
      </nav>
    </div>
  </div>

  {sections.map((s) => {
    const [c1, c2] = brandTone(s.slug);
    return (
      <section class="brand" id={s.slug}>
        <div class="brand-head">
          <div class="brand-title">
            <div class="brand-logo">
              <img src={`/images/stroje/brands/${s.slug}.png`} alt={`${s.name} logo`} loading="lazy" />
            </div>
            <div class="brand-name">
              <h2><a href={`/stroje/${s.slug}/`}>{s.name}</a></h2>
              <div class="brand-meta">
                <span>{s.country} · od <strong>{s.founded}</strong></span><span class="sep"></span>
                <strong>{s.modelCount} modelů</strong> <span>v {s.seriesCount} řadách</span>
                {s.minHp !== null && s.maxHp !== null && (<><span class="sep"></span><strong>{s.minHp}–{s.maxHp} k</strong></>)}
                {brandCreditUrl[s.slug] && (
                  <>
                    <span class="sep"></span>
                    <span class="brand-credit">Foto: <a href={brandCreditUrl[s.slug]} target="_blank" rel="noopener">{brandCreditLabel(s.slug)}</a></span>
                  </>
                )}
              </div>
            </div>
          </div>
          <a class="brand-cta" href={`/stroje/${s.slug}/`}>
            Všechny modely
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>

        <div class="block-label">
          <span class="status current"><span class="dot"></span>Aktuální v prodeji</span>
        </div>

        <div class="family-grid">
          {s.topTiles.map((t) => {
            const bar = hpBar(t.minHp, t.maxHp);
            const yearStr = t.minYear !== null
              ? (t.hasCurrent ? `${t.minYear}–dosud` : (t.maxYear ? `${t.minYear}–${t.maxYear}` : `${t.minYear}`))
              : '';
            const sub = familySublabel(t.family);
            const hpStr = t.minHp !== null && t.maxHp !== null
              ? (t.minHp === t.maxHp ? `${t.minHp} k` : `${t.minHp}–${t.maxHp} k`)
              : '';
            const coverStyle = t.coverImage
              ? `background-image:url('${t.coverImage}'); background-color:#FFFFFF; background-size:cover; background-position:center;`
              : `background:linear-gradient(135deg, ${c1} 0%, ${c2} 100%)`;
            return (
              <a class="family-tile" href={`/stroje/${s.slug}/rada/${category}/${t.family}/`}>
                <div class="ft-cover" data-has-photo={t.coverImage ? 'true' : 'false'} style={coverStyle}>
                  {!t.coverImage && (
                    <svg class="ft-silhouette" width="120" height="68" viewBox="0 0 140 80" fill="rgba(0,0,0,.18)" aria-hidden="true">
                      {category === 'traktory' ? (
                        <>
                          <circle cx="100" cy="58" r="16"/><circle cx="42" cy="60" r="11"/>
                          <path d="M26 54 Q32 28 54 26 L78 22 L86 12 L112 11 L120 22 L132 32 L132 54 Z"/>
                        </>
                      ) : (
                        <>
                          <rect x="20" y="42" width="100" height="22" rx="3"/>
                          <path d="M20 42 Q25 24 50 22 L110 22 Q120 24 120 42 Z"/>
                          <circle cx="40" cy="68" r="8"/><circle cx="100" cy="68" r="8"/>
                        </>
                      )}
                    </svg>
                  )}
                </div>
                <div class="ft-body">
                  <div class="ft-head">
                    <div>
                      <div class="ft-title">{t.label}</div>
                      {sub && <div class="ft-sub">{sub}</div>}
                    </div>
                    <span class="ft-count">{t.modelCount} {t.modelCount === 1 ? 'model' : t.modelCount < 5 ? 'modely' : 'modelů'}</span>
                  </div>
                  {hpStr && (
                    <div class="ft-bar-wrap">
                      <div class="ft-bar-row"><span>Výkon</span><span class="v">{hpStr}</span></div>
                      <div class="ft-bar" style={`--from:${bar.from}%;--span:${bar.span}%`}></div>
                    </div>
                  )}
                  <div class="ft-foot">
                    <span class="year">
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M3 10h18M8 2v4M16 2v4"/></svg>
                      {yearStr}
                    </span>
                    <span class="go">Řada →</span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>

        <a href={`/stroje/${s.slug}/`} class="show-all-cta">
          <span class="sac-t">
            Zobrazit všech <strong>{s.modelCount} modelů</strong> {s.name}
            {s.legacyCount > 0 && (
              <span class="sac-d">· včetně starších řad{s.legacyExamples.length > 0 ? ` (${s.legacyExamples.join(', ')})` : ''}</span>
            )}
          </span>
          <span class="sac-arrow">
            Všechny modely
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </span>
        </a>
      </section>
    );
  })}

  <section class="big-cta">
    <div>
      <span class="cta-kicker">Nenašli jste svůj model?</span>
      <h2>Prodáváte {category === 'traktory' ? 'traktor' : 'kombajn'}?<br />Inzerát v Agro bazaru zdarma.</h2>
      <p>30 dní inzerát · až 5 fotek · kontakt přímo na prodejce · bez provize.</p>
      <a class="cta-btn" href="/bazar/novy/">
        Přidat inzerát zdarma
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
    <div class="cta-right">
      <div class="cta-photo" style={`background-image:url('${catHeroImage}')`}></div>
    </div>
  </section>

</div>

<style>
  .catalog-page{
    --yellow:#FFEA00;
    --yellow-soft:#FFF6A8;
    --yellow-glow:rgba(255,234,0,.35);
    --ink:#0A0A0B;
    --body:#1E1E22;
    --muted:#6B6B72;
    --muted-2:#9A9AA3;
    --line:#EAEAEC;
    --line-2:#DFDFE3;
    --bg-cream:#FBFAF4;
    --card:#FFFFFF;
    --green:#0B7A3B;
    --green-soft:#E3F3EA;
    --r-xl:24px;
    --r-lg:18px;
    --r-md:12px;
    --sh-1:0 1px 2px rgba(10,10,12,.04), 0 0 0 1px rgba(10,10,12,.03);
    --sh-2:0 4px 14px rgba(10,10,12,.06), 0 0 0 1px rgba(10,10,12,.04);
    --sh-3:0 18px 40px -12px rgba(10,10,12,.18), 0 0 0 1px rgba(10,10,12,.04);
    max-width:1280px;margin:0 auto;padding:26px 24px 96px;
    color:var(--body);
  }

  .catalog-page .breadcrumb{display:flex;gap:8px;align-items:center;font-size:13px;color:var(--muted);margin-bottom:22px}
  .catalog-page .breadcrumb a{color:var(--muted);text-decoration:none;transition:color .15s}
  .catalog-page .breadcrumb a:hover{color:#000}
  .catalog-page .breadcrumb svg{width:14px;height:14px;color:var(--muted-2)}
  .catalog-page .breadcrumb .current{color:#000;font-weight:600}

  .catalog-page .hero{
    position:relative;overflow:hidden;color:#fff;border-radius:var(--r-xl);
    background:radial-gradient(600px 300px at 15% 20%, rgba(255,234,0,.18), transparent 60%),
      radial-gradient(700px 400px at 90% 90%, rgba(80,80,90,.4), transparent 60%),
      linear-gradient(135deg, #0E0E10 0%, #1C1C20 60%, #2A2A2F 100%);
    padding:48px 48px 40px;margin-bottom:22px;
    box-shadow:var(--sh-3);
    display:grid;grid-template-columns:1.35fr 1fr;gap:32px;align-items:center;
  }
  .catalog-page .hero::before{
    content:"";position:absolute;inset:0;pointer-events:none;opacity:.35;
    background-image:linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
    background-size:48px 48px;
    mask-image:radial-gradient(600px 400px at 70% 100%, black, transparent 70%);
  }
  .catalog-page .hero-left{position:relative;z-index:2}
  .catalog-page .kicker{
    display:inline-flex;align-items:center;gap:10px;
    font:600 11px/1 'Chakra Petch',sans-serif;letter-spacing:.22em;text-transform:uppercase;
    color:var(--yellow);margin-bottom:18px;
    padding:8px 14px;border:1px solid rgba(255,234,0,.4);border-radius:999px;
    background:rgba(255,234,0,.06);
  }
  .catalog-page .kicker .dot{width:7px;height:7px;background:var(--yellow);border-radius:50%;box-shadow:0 0 0 3px rgba(255,234,0,.2)}
  .catalog-page .hero h1{
    font-family:'Chakra Petch',sans-serif;font-weight:700;
    font-size:clamp(2.2rem,5vw,4rem);color:#fff;line-height:.98;letter-spacing:-.03em;margin:0;
  }
  .catalog-page .hero h1 em{font-style:normal;color:var(--yellow);text-shadow:0 0 40px rgba(255,234,0,.5)}
  .catalog-page .hero-lede{max-width:560px;font-size:16.5px;color:#c8c8d0;margin:18px 0 22px;line-height:1.55}

  .catalog-page .hero-stats{display:flex;gap:28px;flex-wrap:wrap;margin-bottom:24px;font-family:'Chakra Petch',sans-serif}
  .catalog-page .hero-stats .s{display:flex;flex-direction:column;gap:3px}
  .catalog-page .hero-stats .n{font-size:26px;font-weight:700;color:#fff;line-height:1;letter-spacing:-.02em}
  .catalog-page .hero-stats .l{font-size:11px;color:#8a8a92;letter-spacing:.14em;text-transform:uppercase;font-weight:500}
  .catalog-page .hero-stats .s + .s{padding-left:28px;border-left:1px solid rgba(255,255,255,.12)}

  .catalog-page .search{display:flex;gap:8px;background:#fff;border-radius:14px;padding:6px;max-width:600px;
    box-shadow:0 14px 40px -10px rgba(0,0,0,.4), 0 0 0 1px rgba(255,255,255,.1);
  }
  .catalog-page .search input{flex:1;border:0;outline:0;padding:14px 16px 14px 46px;
    font:400 15px 'Roboto Condensed',sans-serif;border-radius:10px;color:#0A0A0B;
    background:url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="%236B6B72" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.35-4.35"/></svg>') no-repeat 14px center;
  }
  .catalog-page .search input::placeholder{color:#9A9AA3}
  .catalog-page .search button{
    background:linear-gradient(180deg,#17171A 0%,#0A0A0B 100%);color:#fff;border:0;
    border-radius:10px;padding:0 22px;font:600 14px 'Chakra Petch',sans-serif;letter-spacing:.04em;
    display:inline-flex;align-items:center;gap:8px;cursor:pointer;transition:transform .15s;
  }
  .catalog-page .search button:hover{transform:translateY(-1px)}
  .catalog-page .search button svg{width:16px;height:16px}

  .catalog-page .hero-right{position:relative;z-index:1;min-height:300px;display:flex;align-items:center;justify-content:center}
  .catalog-page .hero-photo{
    width:100%;height:100%;min-height:300px;
    background-size:cover;background-position:center;
    border-radius:18px;
    box-shadow:0 30px 60px -20px rgba(0,0,0,.5), 0 0 0 1px rgba(255,255,255,.08);
    position:relative;overflow:hidden;
  }
