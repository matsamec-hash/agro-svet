---
import { getAllBrands, seriesFamily, familyLabel, type StrojKategorie } from '../../lib/stroje';
import { useTranslations, plural, tf, getLocaleFromUrl, localizeInternalHref } from '../../i18n/utils';

interface Props {
  category: StrojKategorie;
}
const { category } = Astro.props;

const locale = Astro.locals.locale ?? getLocaleFromUrl(Astro.url);
const tr = useTranslations(locale);

const categoryHero: Record<StrojKategorie, string> = {
  traktory: '/images/traktor.webp',
  kombajny: '/images/kombajn.webp',
};

const brandCreditUrl: Record<string, string> = {
  'john-deere': 'https://www.deere.cz/cs/traktory/',
  fendt: 'https://www.fendt.com/cz/traktory',
  claas: 'https://www.claas.com/cs-cz/zemedelske-stroje/traktory',
  zetor: 'https://www.zetor.com/cs/zetor-products',
  'massey-ferguson': 'https://www.masseyferguson.com/en.html',
};
function brandCreditLabel(slug: string): string {
  const url = brandCreditUrl[slug];
  if (!url) return '';
  try {
    return new URL(url).hostname.replace(/^www\./, '');
  } catch {
    return '';
  }
}

const brandColors: Record<string, [string, string]> = {
  'john-deere': ['#4A9838', '#2E6B22'],
  fendt: ['#3FA85D', '#0E6730'],
  claas: ['#9C9532', '#65601A'],
  'deutz-fahr': ['#2BA84A', '#1a5e2a'],
  kubota: ['#FF6B1A', '#C24414'],
  'new-holland': ['#3874AC', '#1A4370'],
  'case-ih': ['#D62A2A', '#8F1818'],
  'massey-ferguson': ['#D62A2A', '#8F1818'],
  valtra: ['#1F1F1F', '#0A0A0A'],
  zetor: ['#E93A3A', '#A01818'],
};
const brandInitials: Record<string, string> = {
  'john-deere': 'JD',
  fendt: 'F',
  claas: 'C',
  'deutz-fahr': 'DF',
  kubota: 'K',
  'new-holland': 'NH',
  'case-ih': 'CI',
  'massey-ferguson': 'MF',
  valtra: 'V',
  zetor: 'Z',
};
function brandTone(slug: string): [string, string] {
  return brandColors[slug] ?? ['#2a2a30', '#0a0a0b'];
}
function brandInitial(slug: string, name: string): string {
  return brandInitials[slug] ?? name.slice(0, 2).toUpperCase();
}

type Tile = {
  family: string;
  label: string;
  modelCount: number;
  seriesCount: number;
  minHp: number | null;
  maxHp: number | null;
  minYear: number | null;
  maxYear: number | null;
  hasCurrent: boolean;
  coverImage: string | null;
  coverCreditUrl: string | null;
  coverCreditAuthor: string | null;
  coverCreditLicense: string | null;
};

type BrandSection = {
  slug: string;
  name: string;
  country: string;
  founded: number;
  modelCount: number;
  seriesCount: number;
  minHp: number | null;
  maxHp: number | null;
  topTiles: Tile[];
  legacyCount: number;
  legacyModelCount: number;
  legacyExamples: string[];
};

const HP_MAX_FOR_BAR = category === 'traktory' ? 620 : 700;
const TOP_TILES = 4;
const PRIORITY_BRANDS = ['john-deere', 'fendt', 'claas'];

function buildTilesForCategory(brand: any): Tile[] {
  const cat = brand.categories?.[category];
  if (!cat) return [];
  const byFamily = new Map<string, Tile>();
  for (const s of cat.series ?? []) {
    const fam = (s as any).family || seriesFamily(s.slug);
    const labelOverride = (s as any).family_label;
    let t = byFamily.get(fam);
    if (!t) {
      t = {
        family: fam,
        label: labelOverride || familyLabel(fam),
        modelCount: 0,
        seriesCount: 0,
        minHp: null,
        maxHp: null,
        minYear: null,
        maxYear: null,
        hasCurrent: false,
        coverImage: null,
        coverCreditUrl: null,
        coverCreditAuthor: null,
        coverCreditLicense: null,
      };
      byFamily.set(fam, t);
    }
    t.seriesCount += 1;
    if (labelOverride) t.label = labelOverride;
    if (!t.coverImage && (s as any).image_url) {
      t.coverImage = (s as any).image_url;
      t.coverCreditUrl = (s as any).image_credit_url || null;
      t.coverCreditAuthor = (s as any).image_credit || null;
      t.coverCreditLicense = (s as any).image_license || null;
    }
    for (const m of s.models ?? []) {
      t.modelCount += 1;
      if (m.power_hp !== null) {
        t.minHp = t.minHp === null ? m.power_hp : Math.min(t.minHp, m.power_hp);
        t.maxHp = t.maxHp === null ? m.power_hp : Math.max(t.maxHp, m.power_hp);
      }
      if (m.year_from !== null) {
        t.minYear = t.minYear === null ? m.year_from : Math.min(t.minYear, m.year_from);
      }
      if (m.year_to === null && m.year_from !== null) {
        t.hasCurrent = true;
      } else if (m.year_to !== null) {
        t.maxYear = t.maxYear === null ? m.year_to : Math.max(t.maxYear, m.year_to);
      }
    }
  }
  return [...byFamily.values()];
}

function tileSort(a: Tile, b: Tile): number {
  if (a.hasCurrent !== b.hasCurrent) return a.hasCurrent ? -1 : 1;
  const aMax = a.maxHp ?? 0;
  const bMax = b.maxHp ?? 0;
  if (aMax !== bMax) return bMax - aMax;
  if (a.modelCount !== b.modelCount) return b.modelCount - a.modelCount;
  return a.family.localeCompare(b.family, 'cs');
}

function familySublabel(family: string): string {
  if (/^\d+$/.test(family)) return `${family}. řada`;
  return '';
}

function hpBar(min: number | null, max: number | null): { from: number; span: number } {
  if (min === null || max === null) return { from: 0, span: 0 };
  const from = Math.max(0, Math.min(100, (min / HP_MAX_FOR_BAR) * 100));
  const to = Math.max(0, Math.min(100, (max / HP_MAX_FOR_BAR) * 100));
  return { from, span: Math.max(2, to - from) };
}

const sections: BrandSection[] = [];
for (const b of getAllBrands() as any[]) {
  const tiles = buildTilesForCategory(b);
  if (tiles.length === 0) continue;
  const sorted = [...tiles].sort(tileSort);
  const currentSorted = sorted.filter((t) => t.hasCurrent);
  const legacyTiles = sorted.filter((t) => !t.hasCurrent);
  const topTiles = currentSorted.slice(0, TOP_TILES);
  // Display strongest-on-the-right (ASC by max hp) for natural left-to-right reading
  topTiles.sort((a, b) => (a.maxHp ?? 0) - (b.maxHp ?? 0));
  if (topTiles.length === 0) continue;
  const modelCount = tiles.reduce((acc, t) => acc + t.modelCount, 0);
  const seriesCount = tiles.reduce((acc, t) => acc + t.seriesCount, 0);
  const hpAll = tiles.flatMap((t) => [t.minHp, t.maxHp]).filter((x): x is number => x !== null);
  const legacyModelCount = legacyTiles.reduce((acc, t) => acc + t.modelCount, 0);

  sections.push({
    slug: b.slug,
    name: b.name,
    country: b.country,
    founded: b.founded,
    modelCount,
    seriesCount,
    minHp: hpAll.length ? Math.min(...hpAll) : null,
    maxHp: hpAll.length ? Math.max(...hpAll) : null,
    topTiles,
    legacyCount: legacyTiles.length,
    legacyModelCount,
    legacyExamples: legacyTiles.slice(0, 4).map((t) => t.label),
  });
}
sections.sort((a, b) => {
  const aPrio = PRIORITY_BRANDS.indexOf(a.slug);
  const bPrio = PRIORITY_BRANDS.indexOf(b.slug);
  if (aPrio !== -1 && bPrio !== -1) return aPrio - bPrio;
  if (aPrio !== -1) return -1;
  if (bPrio !== -1) return 1;
  return b.modelCount - a.modelCount;
});

const totalModels = sections.reduce((acc, s) => acc + s.modelCount, 0);
const totalBrands = sections.length;
const allHp = sections.flatMap((s) => [s.minHp, s.maxHp]).filter((x): x is number => x !== null);
const minHp = allHp.length ? Math.min(...allHp) : null;
const maxHp = allHp.length ? Math.max(...allHp) : null;

const catLabel = tr(`cat.label.${category}`);
const catHeroImage = categoryHero[category];
const catLede = tr(`cat.lede.${category}`);

const js = {
  result: tr('cat.jsResult'),
  brandAll: tr('cat.jsBrandAll'),
};

// Load-bearing newline: the original markup placed several text labels on their
// own (indented) source lines, which Astro emits as `\n<text>\n`. Replacing the
// text with an expression collapses that whitespace to a single space, so we
// re-inject the literal newline to keep the cs HTML byte-identical.
const NL = '\n';
---

<div class="catalog-page">

  <nav class="breadcrumb" aria-label={tr('cat.bcAria')}>
    <a href="/">{tr('cat.bc.home')}</a>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
    <a href={localizeInternalHref(locale, '/stroje/')}>{tr('cat.bc.tech')}</a>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
    <span class="current">{catLabel}</span>
  </nav>

  <section class="hero">
    <div class="hero-left">
      <span class="kicker"><span class="dot"></span>{tr('cat.heroKicker')}</span>
      <h1>{catLabel} <em>{tr('cat.heroH1Suffix')}</em></h1>
      <p class="hero-lede">{catLede}</p>

      <div class="hero-stats">
        <div class="s"><span class="n">{totalModels}+</span><span class="l">{tr('cat.statModels')}</span></div>
        <div class="s"><span class="n">{totalBrands}</span><span class="l">{tr('cat.statBrands')}</span></div>
        {minHp !== null && maxHp !== null && (
          <div class="s"><span class="n">{minHp}–{maxHp} k</span><span class="l">{tr('cat.statPower')}</span></div>
        )}
      </div>

      <form class="search" role="search" action="/hledat/" method="GET">
        <input type="search" name="q" placeholder={tr('cat.searchPlaceholder')} aria-label={tr('cat.searchAria')} />
        <button type="submit">{NL + tr('cat.searchButton') + NL}<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </button>
      </form>
    </div>

    <div class="hero-right">
      <div class="hero-photo" style={`background-image:url('${catHeroImage}')`}>
        <div class="hero-photo-badge"><span class="n">{totalModels}+</span> {tr('cat.badge')}</div>
      </div>
    </div>
  </section>

  <div class="split-bar">
    <div class="split-inner">
      <nav class="brand-pills" aria-label={tr('cat.brandsAria')}>
        {sections.map((s, i) => (
          <a class:list={['pill', { active: i === 0 }]} href={`#${s.slug}`}>{s.name} <span class="c">{s.modelCount}</span></a>
        ))}
      </nav>
    </div>
  </div>

  <!-- Filter bar — client-side filters tiles by power / year / current production / brand -->
  <div class="filter-bar" id="filter-bar" data-min-hp={minHp ?? 0} data-max-hp={maxHp ?? (category === 'traktory' ? 620 : 700)}>
    <div class="filter-head">
      <span class="filter-title">{tr('cat.filterTitle')}</span>
      <span class="filter-result" id="filter-result">{tf(locale, 'cat.filterResult', { models: totalModels, brands: totalBrands })}</span>
      <button type="button" class="filter-reset" id="filter-reset" hidden>{tr('cat.filterReset')}</button>
    </div>
    <div class="filter-controls">
      <div class="filter-group filter-range">
        <label class="filter-label" for="filter-hp-min">{tr('cat.filterPower')}</label>
        <div class="range-inputs">
          <input type="number" id="filter-hp-min" class="filter-num" min={minHp ?? 0} max={maxHp ?? 700} placeholder={`${minHp ?? 0}`} inputmode="numeric" aria-label={tr('cat.filterPowerMinAria')} />
          <span class="range-sep">–</span>
          <input type="number" id="filter-hp-max" class="filter-num" min={minHp ?? 0} max={maxHp ?? 700} placeholder={`${maxHp ?? 700}`} inputmode="numeric" aria-label={tr('cat.filterPowerMaxAria')} />
        </div>
      </div>

      <div class="filter-group filter-range">
        <label class="filter-label" for="filter-year-min">{tr('cat.filterYear')}</label>
        <div class="range-inputs">
          <input type="number" id="filter-year-min" class="filter-num" min="1950" max="2030" placeholder="1990" inputmode="numeric" aria-label={tr('cat.filterYearMinAria')} />
          <span class="range-sep">–</span>
          <input type="number" id="filter-year-max" class="filter-num" min="1950" max="2030" placeholder="2026" inputmode="numeric" aria-label={tr('cat.filterYearMaxAria')} />
        </div>
      </div>

      <div class="filter-group">
        <label class="filter-checkbox">
          <input type="checkbox" id="filter-current" checked />
          <span>{tr('cat.filterCurrentOnly')}</span>
        </label>
      </div>

      <details class="filter-group filter-brands">
        <summary class="filter-brands-summary">{tr('cat.filterBrands')} <span class="fb-count" id="filter-brand-count"></span></summary>
        <div class="filter-brands-list">
          {sections.map((s) => (
            <label class="filter-checkbox">
              <input type="checkbox" class="filter-brand-cb" value={s.slug} checked />
              <span>{s.name} <span class="muted">({s.modelCount})</span></span>
            </label>
          ))}
        </div>
      </details>
    </div>
  </div>

  {sections.map((s) => {
    const [c1, c2] = brandTone(s.slug);
    return (
      <section
        class="brand"
        id={s.slug}
        data-brand={s.slug}
        data-min-hp={s.minHp ?? ''}
        data-max-hp={s.maxHp ?? ''}
      >
        <div class="brand-head">
          <div class="brand-title">
            <div class="brand-logo" data-letter={s.name.charAt(0).toUpperCase()}>
              <img src={`/images/stroje/brands/${s.slug}.png`} alt={tf(locale, 'cat.brandLogoAlt', { brand: s.name })} loading="lazy" onerror="this.remove()" />
            </div>
            <div class="brand-name">
              <h2><a href={`/stroje/${s.slug}/`}>{s.name}</a></h2>
              <div class="brand-meta">
                <span>{s.country} · {tr('cat.brandFoundedPrefix')} <strong>{s.founded}</strong></span><span class="sep"></span>
                <strong>{s.modelCount} {tr('cat.brandModelsLabel')}</strong> <span>{tf(locale, 'cat.brandSeriesLabel', { count: s.seriesCount })}</span>
                {s.minHp !== null && s.maxHp !== null && (<><span class="sep"></span><strong>{s.minHp}–{s.maxHp} k</strong></>)}
                {brandCreditUrl[s.slug] && (
                  <>
                    <span class="sep"></span>
                    <span class="brand-credit">{tr('cat.photo')} <a href={brandCreditUrl[s.slug]} target="_blank" rel="noopener">{brandCreditLabel(s.slug)}</a></span>
                  </>
                )}
              </div>
            </div>
          </div>
          <a class="brand-cta" href={`/stroje/${s.slug}/`}>{NL + tr('cat.brandCta') + NL}<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>

        <div class="block-label">
          <span class="status current"><span class="dot"></span>{tr('cat.blockCurrent')}</span>
        </div>

        <div class="family-grid">
          {s.topTiles.map((t) => {
            const bar = hpBar(t.minHp, t.maxHp);
            const yearStr = t.minYear !== null
              ? (t.hasCurrent ? tf(locale, 'cat.tileYearToNow', { from: t.minYear }) : (t.maxYear ? `${t.minYear}–${t.maxYear}` : `${t.minYear}`))
              : '';
            const sub = familySublabel(t.family);
            const hpStr = t.minHp !== null && t.maxHp !== null
              ? (t.minHp === t.maxHp ? `${t.minHp} k` : `${t.minHp}–${t.maxHp} k`)
              : '';
            const coverStyle = t.coverImage
              ? `background-image:url('${t.coverImage}'); background-color:#FFFFFF; background-size:cover; background-position:center;`
              : `background:linear-gradient(135deg, ${c1} 0%, ${c2} 100%)`;
            return (
              <a
                class="family-tile"
                href={`/stroje/${s.slug}/rada/${category}/${t.family}/`}
                data-brand={s.slug}
                data-min-hp={t.minHp ?? ''}
                data-max-hp={t.maxHp ?? ''}
                data-min-year={t.minYear ?? ''}
                data-max-year={t.maxYear ?? ''}
                data-current={t.hasCurrent ? '1' : '0'}
              >
                <div class="ft-cover" data-has-photo={t.coverImage ? 'true' : 'false'} style={coverStyle}>
                  {t.coverImage && (() => {
                    const url = t.coverCreditUrl || brandCreditUrl[s.slug];
                    if (!url) return null;
                    let host = '';
                    try { host = new URL(url).hostname.replace(/^www\./, ''); } catch {}
                    if (!host) return null;
                    // For Wikipedia/CC photos, show author + license
                    if (t.coverCreditAuthor && t.coverCreditLicense) {
                      const short = t.coverCreditAuthor.length > 30 ? t.coverCreditAuthor.slice(0, 28) + '…' : t.coverCreditAuthor;
                      const titleAttr = `${tr('cat.photo')} ${t.coverCreditAuthor} (${t.coverCreditLicense}) via ${host} · upraveno (crop, WebP)\n${url}`;
                      return <span class="ft-credit" title={titleAttr}>© {short} / {t.coverCreditLicense}</span>;
                    }
                    return <span class="ft-credit" title={`${tr('cat.photo')} ${host} (${url})`}>{tr('cat.photo')} {host}</span>;
                  })()}
                  {!t.coverImage && (
                    <svg class="ft-silhouette" width="120" height="68" viewBox="0 0 140 80" fill="rgba(0,0,0,.18)" aria-hidden="true">
                      {category === 'traktory' ? (
                        <>
                          <circle cx="100" cy="58" r="16"/><circle cx="42" cy="60" r="11"/>
                          <path d="M26 54 Q32 28 54 26 L78 22 L86 12 L112 11 L120 22 L132 32 L132 54 Z"/>
                        </>
                      ) : (
                        <>
                          <rect x="20" y="42" width="100" height="22" rx="3"/>
                          <path d="M20 42 Q25 24 50 22 L110 22 Q120 24 120 42 Z"/>
                          <circle cx="40" cy="68" r="8"/><circle cx="100" cy="68" r="8"/>
                        </>
                      )}
                    </svg>
                  )}
                </div>
                <div class="ft-body">
                  <div class="ft-head">
                    <div>
                      <div class="ft-title">{t.label}</div>
                      {sub && <div class="ft-sub">{sub}</div>}
                    </div>
                    <span class="ft-count">{t.modelCount} {plural(locale, t.modelCount, { one: tr('cat.tileModelOne'), few: tr('cat.tileModelFew'), many: tr('cat.tileModelMany') })}</span>
                  </div>
                  {hpStr && (
                    <div class="ft-bar-wrap">
                      <div class="ft-bar-row"><span>{tr('cat.tilePower')}</span><span class="v">{hpStr}</span></div>
                      <div class="ft-bar" style={`--from:${bar.from}%;--span:${bar.span}%`}></div>
                    </div>
                  )}
                  <div class="ft-foot">
                    <span class="year">
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M3 10h18M8 2v4M16 2v4"/></svg>
                      {yearStr}
                    </span>
                    <span class="go">{tr('cat.tileGo')}</span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>

        <a href={`/stroje/${s.slug}/`} class="show-all-cta">
          <span class="sac-t">{NL}{tr('cat.showAllPrefix')} <strong>{s.modelCount} {tr('cat.showAllModels')}</strong> {s.name}
            {s.legacyCount > 0 && (
              <span class="sac-d">{tr('cat.showAllLegacy')}{s.legacyExamples.length > 0 ? ` (${s.legacyExamples.join(', ')})` : ''}</span>
            )}
          </span>
          <span class="sac-arrow">{NL + tr('cat.showAllArrow') + NL}<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </span>
        </a>
      </section>
    );
  })}

  <div class="filter-empty" id="filter-empty">
    <strong>{tr('cat.emptyTitle')}</strong>{NL + tr('cat.emptyBody') + NL}</div>

  <section class="big-cta">
    <div>
      <span class="cta-kicker">{tr('cat.ctaKicker')}</span>
      <h2>{tr('cat.ctaH1Lead')} {category === 'traktory' ? tr('cat.ctaH1Traktor') : tr('cat.ctaH1Kombajn')}{tr('cat.ctaH1Tail')}<br />{tr('cat.ctaH1Line2')}</h2>
      <p>{tr('cat.ctaP')}</p>
      <a class="cta-btn" href="/bazar/novy/">{NL + tr('cat.ctaButton') + NL}<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
    <div class="cta-right">
      <div class="cta-photo" style={`background-image:url('${catHeroImage}')`}></div>
    </div>
  </section>

  <script type="application/json" id="cb-i18n" set:html={JSON.stringify(js)} />

</div>

<style>
  .catalog-page{
    --yellow:#FFEA00;
    --yellow-soft:#FFF6A8;
    --yellow-glow:rgba(255,234,0,.35);
    --ink:#0A0A0B;
    --body:#1E1E22;
    --muted:#6B6B72;
    --muted-2:#9A9AA3;
    --line:#EAEAEC;
    --line-2:#DFDFE3;
    --bg-cream:#FBFAF4;
    --card:#FFFFFF;
    --green:#0B7A3B;
    --green-soft:#E3F3EA;
    --r-xl:24px;
    --r-lg:18px;
    --r-md:12px;
    --sh-1:0 1px 2px rgba(10,10,12,.04), 0 0 0 1px rgba(10,10,12,.03);
    --sh-2:0 4px 14px rgba(10,10,12,.06), 0 0 0 1px rgba(10,10,12,.04);
    --sh-3:0 18px 40px -12px rgba(10,10,12,.18), 0 0 0 1px rgba(10,10,12,.04);
    max-width:1280px;margin:0 auto;padding:26px 24px 96px;
    color:var(--body);
  }

  .catalog-page .breadcrumb{display:flex;gap:8px;align-items:center;font-size:13px;color:var(--muted);margin-bottom:22px}
