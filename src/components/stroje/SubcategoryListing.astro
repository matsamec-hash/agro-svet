---
// Sdílený listing kategorie strojů (značky + modely). Renderován z:
//  (a) /stroje/[subcategory] (prerendered cs) a
//  (b) /_subcat/[subcategory] (SSR) — cíl rewritu z [brand] pro /sk /uk /pl,
//      protože /stroje/[subcategory] koliduje s /stroje/[brand] a pod locale
//      prefixem by 404-lo. Canonical vždy /stroje/{subcat}/.
import Layout from '../../layouts/Layout.astro';
import { getAllBrands, getAllModels, getFunctionalGroupForCategory, categoryLabel, functionalGroupLabel, type StrojKategorie } from '../../lib/stroje';
import { itemListSchema } from '../../lib/structured-data';
import { useTranslations, tf, localizePath } from '../../i18n/utils';

interface Props { subcat: StrojKategorie; locale: string; }
const { subcat, locale } = Astro.props;
const tr = useTranslations(locale);

const allBrands = getAllBrands();
const allModels = getAllModels();
const subcatModels = allModels.filter((m) => m.effective_category === subcat);
const subcatBrands = [...new Set(subcatModels.map((m) => m.brand_slug))]
  .map((slug) => allBrands.find((b) => b.slug === slug))
  .filter((b): b is NonNullable<typeof b> => Boolean(b));

const prettyName = categoryLabel(subcat, locale);
const prettyLower = prettyName.toLowerCase();
const groupSlug = getFunctionalGroupForCategory(subcat);
const groupName = groupSlug ? functionalGroupLabel(groupSlug, locale) : null;

function modelUrlPart(slug: string, brandSlug: string): string {
  return slug.startsWith(brandSlug + '-') ? slug.slice(brandSlug.length + 1) : slug;
}
const topModels = [...subcatModels]
  .sort((a, b) => (b.power_hp ?? 0) - (a.power_hp ?? 0) || a.name.localeCompare(b.name, 'cs'))
  .slice(0, 30);

const O = 'https://agro-svet.cz';
const canonical = `${O}${localizePath(locale, `/stroje/${subcat}/`)}`;
const breadcrumbItems: any[] = [
  { '@type': 'ListItem', position: 1, name: tr('cat.bc.home'), item: `${O}${localizePath(locale, '/')}` },
  { '@type': 'ListItem', position: 2, name: tr('cat.bc.tech'), item: `${O}${localizePath(locale, '/stroje/')}` },
];
if (groupSlug && groupName) {
  breadcrumbItems.push({ '@type': 'ListItem', position: 3, name: tr('cat.zem.back'), item: `${O}${localizePath(locale, '/stroje/zemedelske-stroje/')}` });
  breadcrumbItems.push({ '@type': 'ListItem', position: 4, name: groupName, item: `${O}${localizePath(locale, `/stroje/zemedelske-stroje/${groupSlug}/`)}` });
  breadcrumbItems.push({ '@type': 'ListItem', position: 5, name: prettyName, item: canonical });
} else {
  breadcrumbItems.push({ '@type': 'ListItem', position: 3, name: prettyName, item: canonical });
}
const breadcrumbJsonLd = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: breadcrumbItems };
const brandsListJsonLd = subcatBrands.length > 0
  ? itemListSchema(
      subcatBrands.map((b) => ({ url: localizePath(locale, `/stroje/${b.slug}/`), name: `${b.name} ${prettyLower}` })),
      tf(locale, 'cat.sub.brandsMaking', { catLower: prettyLower }),
    )
  : null;
---

<Layout
  title={tf(locale, 'cat.sub.title', { cat: prettyName })}
  description={tf(locale, 'cat.sub.desc', { catLower: prettyLower, n: subcatModels.length, b: subcatBrands.length })}
  canonical={canonical}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
  {brandsListJsonLd && <script type="application/ld+json" is:inline set:html={JSON.stringify(brandsListJsonLd)} />}
  <div style="max-width:1280px; margin:0 auto; padding:48px 32px 80px;">
    <div style="margin-bottom:8px;">
      {groupSlug && groupName ? (
        <a href={localizePath(locale, `/stroje/zemedelske-stroje/${groupSlug}/`)} style="font-size:13px; color:#666; text-decoration:none;">← {groupName}</a>
      ) : (
        <a href={localizePath(locale, '/stroje/zemedelske-stroje/')} style="font-size:13px; color:#666; text-decoration:none;">← {tr('cat.zem.back')}</a>
      )}
    </div>

    <div style="margin-bottom:32px;">
      <span style="display:inline-block; font-family:'Chakra Petch',sans-serif; font-size:11px; letter-spacing:2px; text-transform:uppercase; color:#1a1a1a; background:#FFFF00; padding:4px 10px; border-radius:3px; margin-bottom:14px;">{groupName ?? tr('cat.sub.badgeFallback')}</span>
      <h1 style="font-family:'Chakra Petch',sans-serif; font-size:clamp(2rem,5vw,3.2rem); font-weight:700; letter-spacing:-1px; color:#1a1a1a; margin-bottom:14px;">{prettyName}</h1>
      <div style="display:flex; gap:16px; flex-wrap:wrap; font-size:14px; color:#666;">
        <span>{subcatModels.length} {tr('cat.statModels')}</span>
        <span>·</span>
        <span>{subcatBrands.length} {tr('cat.zem.brandsWord')}</span>
      </div>
    </div>

    {subcatBrands.length === 0 ? (
      <div style="background:#fff; border:1px solid #e8e8e8; border-radius:18px; padding:40px; text-align:center;">
        <h2 style="font-family:'Chakra Petch',sans-serif; font-size:20px; font-weight:700; color:#1a1a1a; margin-bottom:10px;">{tr('cat.zem.comingSoon')}</h2>
        <p style="color:#666;">{tr('cat.sub.comingSoonText')}</p>
      </div>
    ) : (
      <>
        <h2 style="font-family:'Chakra Petch',sans-serif; font-size:22px; font-weight:700; color:#1a1a1a; margin-bottom:14px;">{tf(locale, 'cat.sub.brandsMaking', { catLower: prettyLower })}</h2>
        <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:14px;">
          {subcatBrands.map((b) => {
            const brandCatModels = subcatModels.filter((m) => m.brand_slug === b.slug);
            const seriesCount = new Set(brandCatModels.map((m) => m.series_slug)).size;
            return (
              <a href={localizePath(locale, `/stroje/${b.slug}/`)} style="display:block; text-decoration:none; color:inherit; background:#fff; border:1px solid #e8e8e8; border-radius:14px; padding:16px; transition:border-color .2s, box-shadow .2s;" class="brand-card">
                <h3 style="font-family:'Chakra Petch',sans-serif; font-size:18px; font-weight:700; color:#1a1a1a; margin-bottom:6px;">{b.name}</h3>
                <div style="font-size:12px; color:#767676;">{b.country ?? ''}</div>
                <div style="font-size:12px; color:#666; margin-top:8px;">{brandCatModels.length} {tr('cat.statModels')} · {seriesCount} {tr('cat.sub.seriesWord')}</div>
              </a>
            );
          })}
        </div>
      </>
    )}

    {topModels.length > 0 && (
      <div style="margin-top:48px;">
        <h2 style="font-family:'Chakra Petch',sans-serif; font-size:22px; font-weight:700; color:#1a1a1a; margin-bottom:14px;">{tf(locale, 'cat.sub.modelsHeading', { catLower: prettyLower })}</h2>
        <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:12px;">
          {topModels.map((m) => {
            const mYr = m.year_from ? (m.year_to ? `${m.year_from}–${m.year_to}` : `${m.year_from}–${tr('cat.rada.dosud')}`) : '';
            const meta = [m.power_hp ? `${m.power_hp} k` : '', mYr].filter(Boolean).join(' · ');
            return (
              <a href={localizePath(locale, `/stroje/${m.brand_slug}/${m.series_slug}/${modelUrlPart(m.slug, m.brand_slug)}/`)} style="display:block; text-decoration:none; color:inherit; background:#fff; border:1px solid #e8e8e8; border-radius:12px; padding:14px 16px; transition:border-color .2s, box-shadow .2s;" class="model-card">
                <div style="font-family:'Chakra Petch',sans-serif; font-size:15px; font-weight:700; color:#1a1a1a; margin-bottom:4px;">{m.brand_name} {m.name}</div>
                <div style="font-size:12px; color:#666;">{meta}</div>
              </a>
            );
          })}
        </div>
        {subcatModels.length > topModels.length && (
          <p style="font-size:13px; color:#767676; margin-top:12px;">{tf(locale, 'cat.sub.shownOf', { shown: topModels.length, total: subcatModels.length })}</p>
        )}
      </div>
    )}
  </div>

  <style>
    .brand-card:hover { border-color: #FFFF00 !important; box-shadow: 0 6px 20px rgba(0,0,0,.08); transform: translateY(-2px); }
    .model-card:hover { border-color: #FFFF00 !important; box-shadow: 0 4px 14px rgba(0,0,0,.07); transform: translateY(-1px); }
  </style>
</Layout>
