---
// Interaktivní převodník jednotek plochy. Embedded ve /slovnik/* pro jednotky
// plochy a ve standalone kalkulačce /kalkulacka/prevody-jednotek/.
// Vanilla JS, žádné závislosti.

export interface Props {
  defaultUnit?: string;
  defaultValue?: number;
  heading?: string;
  caption?: string;
  headingLevel?: 'h2' | 'h3';
  /** BCP-47 locale pro formátování čísel ve výsledcích. Default 'cs-CZ'. */
  numberLocale?: string;
  /** Lokalizované UI stringy (default = cs). */
  ui?: { inputLabel?: string; unitSelectLabel?: string };
  /** Lokalizované názvy jednotek (id → name). Chybějící klíč → cs default. */
  unitNames?: Record<string, string>;
  /** Vizuální srovnání plochy s referencemi (hřiště, náměstí…). Když prázdné, panel se nezobrazí. */
  comparisons?: { emoji: string; name: string; m2: number }[];
  comparisonsHeading?: string;
  comparisonsCaption?: string;
}

const {
  defaultUnit = 'ha',
  defaultValue = 1,
  heading = 'Převodník jednotek plochy',
  caption,
  headingLevel = 'h2',
  numberLocale = 'cs-CZ',
  ui = {},
  unitNames = {},
  comparisons = [],
  comparisonsHeading = 'Kolik to je?',
  comparisonsCaption,
} = Astro.props;

const uiText = {
  inputLabel: ui.inputLabel ?? 'Zadej hodnotu',
  unitSelectLabel: ui.unitSelectLabel ?? 'Vyber jednotku',
};

// All factors in m² (square meters). `name` se lokalizuje přes unitNames override.
const UNITS = [
  { id: 'm2', label: 'm²', name: unitNames.m2 ?? 'metr čtvereční', factor: 1, decimals: 2 },
  { id: 'a', label: 'a', name: unitNames.a ?? 'ar', factor: 100, decimals: 4 },
  { id: 'ha', label: 'ha', name: unitNames.ha ?? 'hektar', factor: 10_000, decimals: 6 },
  { id: 'km2', label: 'km²', name: unitNames.km2 ?? 'kilometr čtvereční', factor: 1_000_000, decimals: 8 },
  { id: 'acre', label: 'akr', name: unitNames.acre ?? 'akr (acre)', factor: 4046.8564224, decimals: 5 },
  { id: 'jitro', label: 'jitro', name: unitNames.jitro ?? 'rakouské/české jitro', factor: 5754.642, decimals: 5 },
  { id: 'korec', label: 'korec', name: unitNames.korec ?? 'český korec', factor: 2877.32, decimals: 5 },
  { id: 'strych', label: 'strych', name: unitNames.strych ?? 'český strych', factor: 2877.32, decimals: 5 },
  { id: 'morgen', label: 'morgen', name: unitNames.morgen ?? 'pruský morgen', factor: 2553.2, decimals: 5 },
];

const Heading = headingLevel;
---

<section
  class="area-conv"
  data-default-unit={defaultUnit}
  data-default-value={String(defaultValue)}
  aria-label="Převodník jednotek plochy"
>
  <Heading class="ac-h">{heading}</Heading>

  <form class="ac-form" autocomplete="off" onsubmit="return false">
    <label class="ac-input-row">
      <span class="ac-label">{uiText.inputLabel}</span>
      <span class="ac-input-wrap">
        <input
          type="number"
          inputmode="decimal"
          step="any"
          min="0"
          class="ac-input"
          id="ac-input"
          value={defaultValue}
        />
        <select class="ac-unit" id="ac-unit" aria-label={uiText.unitSelectLabel}>
          {UNITS.map((u) => (
            <option value={u.id} selected={u.id === defaultUnit}>{u.label} ({u.name})</option>
          ))}
        </select>
      </span>
    </label>

    <div class="ac-results" id="ac-results" role="region" aria-live="polite">
      {UNITS.map((u) => (
        <div class="ac-result" data-unit={u.id}>
          <span class="ac-r-label">{u.label}</span>
          <span class="ac-r-value">—</span>
          <span class="ac-r-name">{u.name}</span>
        </div>
      ))}
    </div>
  </form>

  {comparisons.length > 0 && (
    <div class="ac-compare">
      <h3 class="ac-cmp-h">{comparisonsHeading}</h3>
      <p class="ac-cmp-primary" id="ac-cmp-primary" aria-live="polite"></p>
      <div class="ac-cmp-field" id="ac-cmp-visual" aria-hidden="true"></div>
      <div class="ac-cmp-refs" id="ac-cmp-refs" role="group" aria-label="Porovnat s"></div>
      {comparisonsCaption && <p class="ac-cmp-caption">{comparisonsCaption}</p>}
    </div>
  )}

  {caption && <p class="ac-caption">{caption}</p>}
</section>

<script is:inline define:vars={{ UNITS, numberLocale, COMPARISONS: comparisons }}>
  (function () {
    const root = document.currentScript.previousElementSibling;
    if (!root) return;
    const input = root.querySelector('#ac-input');
    const unitSel = root.querySelector('#ac-unit');
    const results = root.querySelector('#ac-results');
    if (!input || !unitSel || !results) return;
    const cmpPrimary = root.querySelector('#ac-cmp-primary');
    const cmpVisual = root.querySelector('#ac-cmp-visual');
    const cmpRefs = root.querySelector('#ac-cmp-refs');
    const TILE_CAP = 48;
    const hasCompare = cmpRefs && COMPARISONS && COMPARISONS.length;
    let activeRef = null; // index reference; null = automatický výběr
    let lastM2 = NaN;
    const fmtCount = (n) =>
      (n >= 100 ? Math.round(n) : n >= 10 ? Math.round(n * 10) / 10 : Math.round(n * 100) / 100)
        .toLocaleString(numberLocale, { maximumFractionDigits: 2 });

    // automatický výběr: největší reference, u které vyjde počet ≥ 1 (jinak nejmenší)
    function autoIdx(m2) {
      const order = COMPARISONS.map((r, i) => i).sort((a, b) => COMPARISONS[a].m2 - COMPARISONS[b].m2);
      let idx = order[0];
      for (const i of order) if (m2 / COMPARISONS[i].m2 >= 1) idx = i;
      return idx;
    }

    function updateCompare(m2) {
      if (!hasCompare) return;
      lastM2 = m2;
      const valid = isFinite(m2) && m2 > 0;
      // výběrová tlačítka (s počtem u každé reference)
      cmpRefs.innerHTML = COMPARISONS.map((r, i) =>
        `<button type="button" class="ac-cmp-ref" data-ref="${i}">` +
        `<span class="ac-cmp-emoji">${r.emoji}</span>` +
        `<span class="ac-cmp-ref-name">${r.name}</span>` +
        `<b>${valid ? fmtCount(m2 / r.m2) + '×' : '—'}</b></button>`
      ).join('');
      if (!valid) {
        if (cmpPrimary) cmpPrimary.textContent = '';
        if (cmpVisual) cmpVisual.innerHTML = '';
        return;
      }
      const idx = activeRef != null ? activeRef : autoIdx(m2);
      const r = COMPARISONS[idx];
      const count = m2 / r.m2;
      const btns = cmpRefs.querySelectorAll('.ac-cmp-ref');
      if (btns[idx]) btns[idx].classList.add('active');
      if (cmpPrimary) cmpPrimary.innerHTML =
        `≈ <strong>${fmtCount(count)}×</strong> <span class="ac-cmp-emoji">${r.emoji}</span> ${r.name}`;
      if (cmpVisual) {
        const whole = Math.min(Math.ceil(count), TILE_CAP);
        const frac = count - Math.floor(count);
        let tiles = '';
        for (let i = 0; i < whole; i++) {
          const partial = i === whole - 1 && frac > 0 && count <= TILE_CAP;
          tiles += `<span class="ac-cmp-tile${partial ? ' partial' : ''}"` +
            `${partial ? ` style="--frac:${Math.max(0.12, frac).toFixed(3)}"` : ''}>` +
            `<span class="ac-cmp-tile-emoji">${r.emoji}</span></span>`;
        }
        if (count > TILE_CAP) tiles += `<span class="ac-cmp-more">+${fmtCount(count - TILE_CAP)}</span>`;
        cmpVisual.innerHTML = tiles;
      }
    }

    if (hasCompare) cmpRefs.addEventListener('click', (e) => {
      const btn = e.target.closest('.ac-cmp-ref');
      if (!btn) return;
      activeRef = Number(btn.dataset.ref);
      updateCompare(lastM2);
    });

    const fmt = (n, decimals) => {
      if (!isFinite(n)) return '—';
      if (n === 0) return '0';
      // Czech formatting: space thousands, comma decimal
      const abs = Math.abs(n);
      let d;
      if (abs >= 1000) d = 0;
      else if (abs >= 1) d = 2;
      else if (abs >= 0.01) d = 4;
      else d = decimals;
      return n
        .toLocaleString(numberLocale, { maximumFractionDigits: d, minimumFractionDigits: 0 })
        .replace(/ /g, ' ');
    };

    function recalc() {
      const raw = parseFloat(String(input.value).replace(',', '.'));
      const fromUnit = UNITS.find((u) => u.id === unitSel.value);
      if (!fromUnit || !isFinite(raw)) {
        results.querySelectorAll('.ac-r-value').forEach((el) => { el.textContent = '—'; });
        updateCompare(NaN);
        return;
      }
      const m2 = raw * fromUnit.factor;
      updateCompare(m2);
      UNITS.forEach((u) => {
        const cell = results.querySelector(`[data-unit="${u.id}"] .ac-r-value`);
        if (!cell) return;
        const val = m2 / u.factor;
        cell.textContent = fmt(val, u.decimals);
        const row = cell.closest('.ac-result');
        if (row) row.classList.toggle('is-source', u.id === fromUnit.id);
      });
    }

    input.addEventListener('input', recalc);
    unitSel.addEventListener('change', recalc);
    recalc();
  })();
</script>

<style>
  .area-conv {
    margin: 28px 0;
    padding: 20px 22px;
    background: linear-gradient(180deg, #fffef8 0%, #fff 100%);
    border: 1.5px solid #FFEA00;
    border-radius: 12px;
  }
  .ac-h {
    font-size: 18px;
    font-weight: 800;
    color: #0A0A0B;
    margin: 0 0 14px;
    letter-spacing: -0.3px;
  }
  .ac-form { display: flex; flex-direction: column; gap: 14px; }
  .ac-input-row { display: flex; flex-direction: column; gap: 6px; }
  .ac-label {
    font-size: 12px;
    font-weight: 700;
    color: #6B6B72;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .ac-input-wrap {
    display: flex;
    gap: 8px;
    align-items: stretch;
  }
  .ac-input {
    flex: 1 1 auto;
    min-width: 0;
    padding: 10px 14px;
    font-size: 18px;
    font-weight: 700;
    border: 1.5px solid #d4d4d8;
    border-radius: 8px;
    background: #fff;
    color: #0A0A0B;
    font-variant-numeric: tabular-nums;
  }
  .ac-input:focus { outline: none; border-color: #0A0A0B; }
  .ac-unit {
    flex: 0 0 auto;
    padding: 10px 12px;
    font-size: 14px;
    font-weight: 600;
    border: 1.5px solid #d4d4d8;
    border-radius: 8px;
    background: #fff;
    color: #0A0A0B;
    cursor: pointer;
    max-width: 240px;
  }
  .ac-unit:focus { outline: none; border-color: #0A0A0B; }

  .ac-results {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 8px;
    padding-top: 4px;
  }
  .ac-result {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    column-gap: 8px;
    padding: 8px 12px;
    background: #fff;
    border: 1px solid #eaeaec;
    border-radius: 8px;
    font-size: 13px;
    line-height: 1.3;
  }
  .ac-result.is-source {
    background: #FFFBCC;
    border-color: #FFEA00;
  }
  .ac-r-label {
    grid-row: 1 / span 2;
    align-self: center;
    font-size: 13px;
    font-weight: 800;
    color: #6B6B72;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    min-width: 38px;
  }
  .ac-r-value {
    grid-column: 2;
    grid-row: 1;
    font-size: 15px;
    font-weight: 700;
    color: #0A0A0B;
    font-variant-numeric: tabular-nums;
  }
  .ac-r-name {
    grid-column: 2;
    grid-row: 2;
    font-size: 11px;
    color: #6B6B72;
  }
  .ac-caption {
    margin: 10px 0 0;
    font-size: 12px;
    color: #6B6B72;
    line-height: 1.5;
  }

  /* Vizuální srovnání plochy */
  .ac-compare {
    margin-top: 18px;
    padding-top: 16px;
    border-top: 1px dashed #e3e3d6;
  }
  .ac-cmp-h {
    font-size: 12px;
    font-weight: 700;
    color: #6B6B72;
    margin: 0 0 10px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .ac-cmp-primary {
    margin: 0 0 12px;
    font-size: 17px;
    line-height: 1.3;
    color: #0A0A0B;
    min-height: 22px;
  }
  /* :global — obsah polí níže se vkládá přes innerHTML (scoped selektory by nesedly) */
  .ac-cmp-primary :global(strong) { font-size: 26px; font-weight: 800; letter-spacing: -0.5px; }
  .ac-compare :global(.ac-cmp-emoji) { font-size: 1.05em; }

  /* pole s proporčními dlaždicemi */
  .ac-cmp-field {
    display: flex;
    flex-wrap: wrap;
    align-content: flex-start;
    gap: 5px;
    padding: 12px;
    min-height: 62px;
    background: repeating-linear-gradient(0deg, #f5faf1, #f5faf1 11px, #eef6e8 11px, #eef6e8 12px);
    border: 1px solid #d8e6cf;
    border-radius: 10px;
    margin-bottom: 14px;
  }
  .ac-cmp-field :global(.ac-cmp-tile) {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    background: #fff;
    border: 1.5px solid #6ba84f;
    border-radius: 7px;
    box-shadow: 0 1px 2px rgba(10,10,12,.06);
  }
  .ac-cmp-field :global(.ac-cmp-tile-emoji) { font-size: 17px; line-height: 1; }
  .ac-cmp-field :global(.ac-cmp-tile.partial) { opacity: var(--frac, .5); border-style: dashed; }
  .ac-cmp-field :global(.ac-cmp-more) {
    display: flex; align-items: center;
    padding: 0 10px; height: 34px;
    font-size: 13px; font-weight: 800; color: #4d7a37;
  }

  /* klikací výběr reference */
  .ac-cmp-refs { display: flex; flex-wrap: wrap; gap: 6px; }
  .ac-cmp-refs :global(.ac-cmp-ref) {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 11px;
    background: #fff;
    border: 1px solid #e0e0d4;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 600;
    color: #0A0A0B;
    cursor: pointer;
    transition: border-color .12s ease, background .12s ease;
  }
  .ac-cmp-refs :global(.ac-cmp-ref:hover) { border-color: #6ba84f; }
  .ac-cmp-refs :global(.ac-cmp-ref-name) { color: #3a3a40; }
  .ac-cmp-refs :global(.ac-cmp-ref b) {
    font-weight: 800;
    color: #2f6b2f;
    font-variant-numeric: tabular-nums;
    padding-left: 7px;
    border-left: 1px solid #e8e8dc;
  }
  .ac-cmp-refs :global(.ac-cmp-ref.active) { background: #eaf5e2; border-color: #6ba84f; }
  .ac-cmp-caption { margin: 12px 0 0; font-size: 11px; color: #6B6B72; line-height: 1.5; }

  @media (max-width: 480px) {
    .ac-input-wrap { flex-direction: column; }
    .ac-unit { max-width: none; }
    .ac-results { grid-template-columns: 1fr 1fr; }
  }
</style>
