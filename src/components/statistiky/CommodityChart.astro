---
// src/components/statistiky/CommodityChart.astro
//
// Only the commodity NAMES are needed server-side (for the button row).
// Chart data, events, and 5y averages are fetched client-side from
// /statistiky/commodity-data-recent.json (eager, ~85 KB) and
// /statistiky/commodity-data.json (lazy, ~256 KB, only on "Vše"). Passing
// the full series as a prop used to bundle the 256 KB commodities.json into
// the homepage Worker chunk for no SSR benefit.
import { useTranslations } from '../../i18n/utils';

interface Props {
  commodityNames: readonly string[]; // 9 names rendered as pill buttons
  dataBase?: string; // suffix for JSON endpoint paths, e.g. '-sk' → /statistiky/commodity-data-recent-sk.json
  numLocale?: string; // e.g. 'sk-SK'; defaults to 'cs-CZ'
  locale?: string; // 'cs' | 'sk'; used to derive localized insight fragments
}
const { commodityNames, dataBase = '', numLocale = 'cs-CZ', locale = 'cs' } = Astro.props;
const tt = useTranslations(locale);
const isSk = locale === 'sk';
const L = {
  avgLabel:  isSk ? '5-ročný priemer'   : '5letý průměr',
  avgPrefix: isSk ? 'Aktuálna hodnota ' : 'Aktuální hodnota ',
  avgSuffix: isSk ? ' vs. 5-ročný priemer.' : ' vs. 5letý průměr.',
  nowPrefix: isSk ? 'Aktuálne '         : 'Aktuálně ',
};
const default0 = commodityNames[0] ?? 'Pšenice';
---

<section class="sp-section" id="trh">
  <header class="sp-section-head">
    <h2>{tt('stat.commodity.title')}</h2>
    <span class="sp-section-sub">{tt('stat.commodity.sub')}</span>
    <a class="sp-src" href={tt('stat.commodity.sourceHref')} target="_blank" rel="noopener noreferrer">{tt('stat.commodity.source')} <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg></a>
  </header>

  <div class="sp-controls">
    <div class="sp-pills-row" role="tablist" aria-label={tt('stat.commodity.ariaCommodity')}>
      {commodityNames.map((name, i) => (
        <button class:list={['sp-mini-pill', { active: i === 0 }]} data-commodity={name} type="button">{name}</button>
      ))}
    </div>
    {locale !== 'sk' && (
      <div class="sp-time-row" role="tablist" aria-label={tt('stat.commodity.ariaWindow')}>
        <button class="sp-time-btn" data-window="1y" type="button">1 rok</button>
        <button class="sp-time-btn active" data-window="5y" type="button">5 let</button>
        <button class="sp-time-btn" data-window="all" type="button">Vše</button>
      </div>
    )}
  </div>

  <div class="sp-chart-card">
    <div class="sp-chart-canvas-wrap">
      <canvas id="commodityLongChart"></canvas>
    </div>
    <div class="sp-chart-insight" id="commodityInsight"></div>
  </div>
</section>

<!-- Chart data se loaduje async z /statistiky/commodity-data.json (24h CF cache).
     Šetří ~86 KB inline JSON v HTML. Element zůstává jako sentinel pro init script
     — když je v DOM, page má chart, fetch může proběhnout. -->
<div id="commodityChartData" data-base={dataBase} data-numlocale={numLocale} data-avg-label={L.avgLabel} data-avg-prefix={L.avgPrefix} data-avg-suffix={L.avgSuffix} data-now-prefix={L.nowPrefix} hidden></div>

<!-- Chart.js — eager init if Chart už loaded (např. /statistiky/), jinak lazy přes
     IntersectionObserver: na homepage se ~80KB Chart.js bundle neloaduje dokud
     se uživatel nepřiblíží k chart sekci. -->
<script is:inline>
  (function () {
    const dataEl = document.getElementById('commodityChartData');
    const canvasEl = document.getElementById('commodityLongChart');
    if (!dataEl || !canvasEl) return;
    // Idempotence: pokud na page už běží statistiky-page init (initCommodityChart()), neopakovat
    if (canvasEl.dataset.initialized === 'true') return;
    canvasEl.dataset.initialized = 'true';

    function loadScript(src) {
      return new Promise((resolve, reject) => {
        if (document.querySelector(`script[src="${src}"]`)) return resolve();
        const s = document.createElement('script');
        s.src = src; s.async = false;
        s.onload = () => resolve(); s.onerror = reject;
        document.head.appendChild(s);
      });
    }

    async function ensureChart() {
      if (typeof Chart === 'undefined') {
        await loadScript('https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js');
        await loadScript('https://cdn.jsdelivr.net/npm/chartjs-plugin-annotation@3');
      }
      Chart.defaults.font.family = "'Chakra Petch', sans-serif";
      Chart.defaults.font.size = 12;
      Chart.defaults.color = '#6B6B72';
      if (window['chartjs-plugin-annotation']) Chart.register(window['chartjs-plugin-annotation']);
    }

    // Two-tier fetch:
    //   - recent: last 60 months only (~85 KB) — eager, covers default "5y" view
    //   - full:   complete history (~256 KB) — lazy, fetched only when user
    //             clicks "Vše"
    // Cached on window so multiple chart instances on the same page share.
    // dataBase suffix (e.g. '-sk') points to locale-specific JSON endpoints.
    var dataBase = dataEl.dataset.base || '';
    var numLocale = dataEl.dataset.numlocale || 'cs-CZ';
    var L = {
      avgLabel:  dataEl.dataset.avgLabel  || '',
      avgPrefix: dataEl.dataset.avgPrefix || '',
      avgSuffix: dataEl.dataset.avgSuffix || '',
      nowPrefix: dataEl.dataset.nowPrefix || '',
    };
    var recentKey = '__commodityRecentPromise' + dataBase;
    var fullKey = '__commodityFullPromise' + dataBase;
    if (!window[recentKey]) {
      window[recentKey] = fetch('/statistiky/commodity-data-recent' + dataBase + '.json')
        .then((r) => { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); });
    }
    function loadFull() {
      if (!window[fullKey]) {
        window[fullKey] = fetch('/statistiky/commodity-data' + dataBase + '.json')
          .then((r) => { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); });
      }
      return window[fullKey];
    }

    async function bootstrap() {
      await ensureChart();
      const data = await window[recentKey];
      run(data);
    }

    function run(__data) {

    const SHORT_MONTHS = ['Led','Úno','Bře','Dub','Kvě','Čvn','Čvc','Srp','Zář','Říj','Lis','Pro'];
    const YELLOW = '#FFEA00';
    const INK = '#0A0A0B';

    let { series, events, fiveYearAvg, default0 } = __data;
    let currentName = default0;
    const activeBtn = document.querySelector('.sp-time-btn.active');
    let currentWindow = activeBtn ? activeBtn.dataset.window : 'all';
    let chart = null;
    let fullLoaded = !__data.partial;

    function buildAnnotations(labels) {
      const anns = {};
      const labelSet = new Set(labels);
      events.forEach((ev, i) => {
        const [yy, mm] = ev.date.split('-').map(Number);
        const lbl = `${SHORT_MONTHS[mm - 1]} ${yy}`;
        if (!labelSet.has(lbl)) return;
        anns['ev' + i] = {
          type: 'line', xMin: lbl, xMax: lbl,
          borderColor: 'rgba(10,10,11,.35)', borderWidth: 1, borderDash: [4, 4],
          label: { display: true, content: ev.label, position: 'start',
            backgroundColor: 'rgba(255,234,0,.92)', color: '#0A0A0B',
            font: { size: 10, weight: 600 }, padding: 4, yAdjust: -2 },
        };
      });
      return anns;
    }
    function filterByWindow(data, w) {
      if (w === 'all') return data;
      return data.slice(-(w === '1y' ? 12 : 60));
    }

    function render() {
      const s = series.find(x => x.name === currentName);
      if (!s) return;
      const filtered = filterByWindow(s.data, currentWindow);
      const labels = filtered.map(d => d.label);
      const avgs = (fiveYearAvg[currentName] || []).filter(p => labels.includes(p.label));
      const avgMap = new Map(avgs.map(p => [p.label, p.avg]));
      const avgLine = labels.map(l => avgMap.get(l) ?? null);

      const datasets = [{
        label: currentName, data: filtered.map(d => d.value),
        borderColor: YELLOW, backgroundColor: 'rgba(255,234,0,.12)',
        borderWidth: 2.5, pointRadius: 0, pointHoverRadius: 5, tension: 0.35, fill: true,
      }];
      if (avgLine.some(v => v !== null)) {
        datasets.push({
          label: L.avgLabel, data: avgLine, borderColor: 'rgba(107,107,114,.6)',
          borderWidth: 1.5, borderDash: [3, 3], pointRadius: 0, tension: 0.3, fill: false,
        });
      }

      const cfg = {
        type: 'line', data: { labels, datasets },
        options: {
          responsive: true, maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          plugins: {
            legend: { position: 'top', labels: { usePointStyle: true, padding: 14, font: { size: 12 } } },
            tooltip: { backgroundColor: INK, padding: 12, cornerRadius: 10,
              callbacks: { label: ctx => `${ctx.dataset.label}: ${ctx.parsed.y.toLocaleString(numLocale)} ${s.unit}` } },
            annotation: { annotations: buildAnnotations(labels) },
          },
          scales: {
            x: { grid: { display: false }, ticks: { maxRotation: 0, autoSkip: true, maxTicksLimit: 12, font: { size: 11 } } },
            y: { grid: { color: 'rgba(10,10,12,.06)' }, ticks: { callback: v => v.toLocaleString(numLocale) } },
          },
        },
      };
      if (chart) chart.destroy();
      chart = new Chart(canvasEl, cfg);

      const insightEl = document.getElementById('commodityInsight');
      if (insightEl) {
        const last = filtered[filtered.length - 1];
        const avg = avgMap.get(last?.label);
        if (last && avg) {
          const diff = ((last.value / avg) - 1) * 100;
          insightEl.textContent = `${L.avgPrefix}${last.value.toLocaleString(numLocale)} ${s.unit} ${diff >= 0 ? '+' : ''}${diff.toFixed(1)} %${L.avgSuffix}`;
        } else {
          insightEl.textContent = `${L.nowPrefix}${last?.value.toLocaleString(numLocale) ?? '–'} ${s.unit}.`;
        }
      }
    }

    document.querySelectorAll('.sp-mini-pill[data-commodity]').forEach(b => {
      b.addEventListener('click', () => {
        document.querySelectorAll('.sp-mini-pill[data-commodity]').forEach(x => x.classList.remove('active'));
        b.classList.add('active');
        currentName = b.dataset.commodity;
        render();
      });
    });
    document.querySelectorAll('.sp-time-btn').forEach(b => {
      b.addEventListener('click', async () => {
        document.querySelectorAll('.sp-time-btn').forEach(x => x.classList.remove('active'));
        b.classList.add('active');
        currentWindow = b.dataset.window;
        // "Vše" needs the full series — lazy-fetch on first click.
        if (currentWindow === 'all' && !fullLoaded) {
          try {
            const full = await loadFull();
            series = full.series;
            events = full.events;
            fiveYearAvg = full.fiveYearAvg;
            fullLoaded = true;
          } catch { /* fall back to recent data — still renders, just truncated */ }
        }
        render();
      });
    });

    render();
    }

    // Eager init pokud Chart už načten (statistiky page má eager <script src=>),
    // jinak počkat na IntersectionObserver — homepage tak neloaduje ~80KB Chart.js
    // dokud user nedoscrolluje k chart sekci.
    if (typeof Chart !== 'undefined') {
      bootstrap();
    } else if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries, obs) => {
        if (!entries.some(e => e.isIntersecting)) return;
        obs.disconnect();
        bootstrap();
      }, { rootMargin: '300px' });
      io.observe(canvasEl);
    } else {
      bootstrap();
    }
  })();
</script>

<style>
  .sp-section{margin:32px 0 36px;scroll-margin-top:200px}
  .sp-section-head{margin-bottom:14px}
  .sp-section-head h2{font:700 24px 'Chakra Petch',sans-serif;letter-spacing:-.02em;margin:0;color:#0A0A0B}
  .sp-section-sub{display:block;font-size:13px;color:#6B6B72;margin-top:2px}
  .sp-src{
    display:inline-flex;align-items:center;gap:4px;margin-top:6px;
    font-size:11.5px;color:#888;text-decoration:none;
    border-bottom:1px dotted #c0c0c5;padding-bottom:1px;
    transition:color .15s, border-color .15s;
  }
  .sp-src:hover{color:#0A0A0B;border-bottom-color:#0A0A0B}
  .sp-src svg{color:#a0a0a8;transition:transform .15s}
  .sp-src:hover svg{color:#0A0A0B;transform:translate(1px,-1px)}
  .sp-controls{display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;margin-bottom:14px}
  .sp-pills-row{display:flex;gap:6px;flex-wrap:wrap}
  .sp-mini-pill{
    padding:6px 12px;background:#fff;border:1px solid #EAEAEC;border-radius:999px;
    font:500 13px 'Chakra Petch',sans-serif;color:#0A0A0B;cursor:pointer;
    transition:.15s;
    /* iOS Safari tap fix: manipulation odstraňuje 300ms double-tap-zoom delay
       a zabraňuje cancellation tapu při minimálním movementu prstu. */
    touch-action:manipulation;-webkit-tap-highlight-color:rgba(255,234,0,.3);
  }
  .sp-mini-pill:hover{background:#FFF6A8;border-color:#FFEA00}
  .sp-mini-pill.active{background:#0A0A0B;color:#fff;border-color:#0A0A0B}
  .sp-time-row{display:flex;gap:4px;background:#F4F2E9;border-radius:999px;padding:3px}
  .sp-time-btn{
    padding:8px 14px;background:transparent;border:0;border-radius:999px;
    font:600 13px 'Chakra Petch',sans-serif;color:#6B6B72;cursor:pointer;
    /* iOS Safari tap fix — viz .sp-mini-pill. Plus min-height 36px pro spolehlivý tap target. */
    touch-action:manipulation;-webkit-tap-highlight-color:rgba(255,234,0,.3);
    min-height:36px;
  }
  .sp-time-btn.active{background:#fff;color:#0A0A0B;box-shadow:0 1px 2px rgba(0,0,0,.06)}
  .sp-chart-card{
    background:#fff;border:1px solid #EAEAEC;border-radius:18px;padding:20px 22px;
    box-shadow:0 1px 2px rgba(10,10,12,.04);
  }
  /* Fix Chart.js infinite vertical growth bug — canvas wrap musí mít explicit max height
     (responsive:true + maintainAspectRatio:false jinak roste do nekonečna) */
  .sp-chart-canvas-wrap{
    position:relative;height:380px;max-height:60vh;width:100%;
  }
  .sp-chart-canvas-wrap canvas{display:block;width:100% !important;height:100% !important}
  .sp-chart-insight{
    margin-top:12px;padding:10px 14px;background:#FFF6A8;border-radius:10px;
    font:500 13px 'Chakra Petch',sans-serif;color:#0A0A0B;
  }
</style>
