---
// src/components/statistiky/PriceScissors.astro
import type { PriceScissorsPoint } from '../../lib/agro-derived';

interface Props {
  points: PriceScissorsPoint[];
  insight: string;   // generovaný text, např. "V 2022 vstupy +120%, výstupy +95% → marže -15%"
  baseYear: number;
}
const { points, insight, baseYear } = Astro.props;
---

<section class="sp-section" id="cenove-nuzky">
  <header class="sp-section-head">
    <h2>⚡ Cenové nůžky — co dražší: vstupy nebo výstupy?</h2>
    <span class="sp-section-sub">
      Vývoj cen vstupů (nafta + NPK hnojivo) a výstupů (4 hlavní komodity: pšenice, ječmen, řepka, kukuřice).
      Hodnota {baseYear} = 100 (oba indexy začínají na 100). Když rostou vstupy rychleji, nůžky se rozevírají
      a farmář vydělává méně.
    </span>
  </header>

  <div class="sp-chart-card">
    <canvas id="scissorsChart" height="380"></canvas>
    <div class="scissors-legend">
      <span class="sl-item"><span class="sl-dot" style="background:#C24414"></span>Vstupy (nafta + NPK)</span>
      <span class="sl-item"><span class="sl-dot" style="background:#0B7A3B"></span>Výstupy (4 komodity)</span>
      <span class="sl-item sl-fill"><span class="sl-dot" style="background:rgba(194,68,20,.18);border:1px dashed #C24414"></span>Marže záporná (vstupy &gt; výstupy)</span>
    </div>
    <div class="sp-chart-insight" data-tone="warn">⚠ {insight}</div>
    <p class="sp-chart-help">
      <strong>Jak číst:</strong> obě čáry začínají v roce {baseYear} na hodnotě 100.
      Když se čáry rozevřou (nafta-NPK červená nahoru, komodity zelená dole), farmář
      <strong>doplácí</strong> — vstupy zdražily víc než to, co prodá. V roce 2022 vstupy
      vyletěly o 96&nbsp;%, ale komodity jen o 75&nbsp;% → klasické cenové nůžky.
    </p>
  </div>
</section>

<script type="application/json" id="scissorsData" set:html={JSON.stringify({ points })}></script>

<style>
  .sp-section{margin:32px 0 36px;scroll-margin-top:200px}
  .sp-section-head{margin-bottom:14px}
  .sp-section-head h2{font:700 24px 'Chakra Petch',sans-serif;letter-spacing:-.02em;margin:0;color:#0A0A0B}
  .sp-section-sub{display:block;font-size:13px;color:#6B6B72;margin-top:2px}
  .sp-chart-card{
    background:#fff;border:1px solid #EAEAEC;border-radius:18px;padding:24px 26px;
    box-shadow:0 1px 2px rgba(10,10,12,.04);
  }
  .sp-chart-insight{
    margin-top:14px;padding:12px 16px;border-radius:10px;
    font:500 13.5px 'Chakra Petch',sans-serif;
  }
  .sp-chart-insight[data-tone="warn"]{background:rgba(194,68,20,.08);color:#7A2A0E}
  .sp-chart-help{margin:10px 0 0;font-size:13px;color:#6B6B72;line-height:1.55}
  .scissors-legend{display:flex;flex-wrap:wrap;gap:18px;margin:12px 0 4px;font-size:13px;color:#3a3a40}
  .sl-item{display:inline-flex;align-items:center;gap:7px;font-family:'Chakra Petch',sans-serif;font-weight:500}
  .sl-dot{display:inline-block;width:14px;height:14px;border-radius:3px}
  .sl-fill .sl-dot{border-radius:3px}
</style>
