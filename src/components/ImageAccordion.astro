---
const items = [
  {
    label: 'Traktory',
    href: '/encyklopedie/?kategorie=traktor',
    img: '/images/traktor.webp',
  },
  {
    label: 'Kombajny',
    href: '/encyklopedie/?kategorie=kombajn',
    img: '/images/kombajn.webp',
  },
  {
    label: 'Stroje',
    href: '/encyklopedie/?kategorie=stroj',
    img: 'https://images.unsplash.com/photo-1500937386664-56d1dfef3854?w=1200&auto=format&fit=crop&q=85',
  },
  {
    label: 'Agro bazar',
    href: '/bazar/',
    img: 'https://images.unsplash.com/photo-1464226184884-fa280b87c399?w=1200&auto=format&fit=crop&q=85',
  },
];
---

<div class="ia-wrap">
  <div class="ia-row">
    {items.map((item) => (
      <a class="ia-panel" href={item.href}>
        <img src={item.img} alt={item.label} class="ia-img" />
        <div class="ia-overlay"></div>
        <div class="ia-content">
          <h3>{item.label}</h3>
          <span class="ia-btn">Navštívit sekci</span>
        </div>
      </a>
    ))}
  </div>
</div>

<style>
  .ia-wrap {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 32px;
  }

  .ia-row {
    display: flex;
    gap: 10px;
    height: min(35vh, 300px);
  }

  .ia-panel {
    flex: 1;
    position: relative;
    border-radius: 22px;
    overflow: hidden;
    cursor: pointer;
    text-decoration: none;
    transition: flex 2s ease;
    min-width: 0;
    box-shadow: 0 0 10px rgba(0, 0, 0, .12);
  }

  .ia-panel:hover {
    flex: 2;
  }

  .ia-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1s cubic-bezier(.4, 0, .2, 1);
  }

  .ia-panel:hover .ia-img {
    transform: scale(1.08);
  }

  .ia-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: rgba(0, 0, 0, .2);
    transition: background .6s;
  }

  .ia-panel:hover .ia-overlay {
    background: rgba(0, 0, 0, .45);
  }

  /* Centered content wrapper */
  .ia-content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 14px;
  }

  .ia-content h3 {
    color: #fff;
    font-family: 'Chakra Petch', sans-serif;
    font-size: 22px;
    font-weight: 300;
    font-style: italic;
    margin: 0;
    text-align: center;
    text-shadow: 0 1px 6px rgba(0, 0, 0, .35);
    opacity: 0;
    transform: translateY(-30px);
    transition: opacity .5s .1s, transform .5s .1s;
  }

  .ia-panel:hover .ia-content h3 {
    opacity: 1;
    transform: translateY(0);
  }

  .ia-btn {
    color: #fff;
    font-family: 'Chakra Petch', sans-serif;
    font-size: 12px;
    font-weight: 300;
    padding: 7px 18px;
    border: 1px solid rgba(255, 255, 255, .75);
    text-align: center;
    white-space: nowrap;
    opacity: 0;
    transform: translateY(30px);
    transition: opacity .5s .1s, transform .5s .1s;
  }

  .ia-panel:hover .ia-btn {
    opacity: 1;
    transform: translateY(0);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .ia-wrap { padding: 0 16px; }
    .ia-row { flex-direction: column; height: auto; gap: 6px; }
    .ia-panel { height: 100px; flex: none !important; border-radius: 16px; }
    .ia-panel:hover { height: 220px; }
  }
</style>
