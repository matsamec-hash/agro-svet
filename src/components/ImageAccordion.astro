---
const items = [
  {
    label: 'Traktory',
    icon: '🚜',
    href: '/encyklopedie/?kategorie=traktor',
    popis: 'Traktory všech výkonových tříd — od kompaktních až po těžké stroje pro velkovýrobu.',
    img: 'https://images.unsplash.com/photo-1574943320219-553eb213f72d?w=1000&auto=format&fit=crop&q=85',
  },
  {
    label: 'Kombajny',
    icon: '🌾',
    href: '/encyklopedie/?kategorie=kombajn',
    popis: 'Sklízecí mlátičky pro efektivní sklizeň obilnin, řepky a kukuřice.',
    img: 'https://images.unsplash.com/photo-1625246333195-78d9c38ad449?w=1000&auto=format&fit=crop&q=85',
  },
  {
    label: 'Stroje',
    icon: '⚙️',
    href: '/encyklopedie/?kategorie=stroj',
    popis: 'Zemědělské stroje pro zpracování půdy, setí, postřik a sklizeň pícnin.',
    img: 'https://images.unsplash.com/photo-1591086757064-2b6a0b2c4b18?w=1000&auto=format&fit=crop&q=85',
  },
  {
    label: 'Agro bazar',
    icon: '🛒',
    href: '/bazar/',
    popis: 'Inzeráty od zemědělců i firem — nová i použitá technika za nejlepší ceny.',
    img: 'https://images.unsplash.com/photo-1464226184884-fa280b87c399?w=1000&auto=format&fit=crop&q=85',
  },
];
---

<div class="accordion-wrap">
  <div class="accordion" id="accordion">
    {items.map((item, i) => (
      <div class="acc-item" data-index={i} style={`background-image:url('${item.img}')`}>
        <div class="acc-overlay"></div>
        <div class="acc-label">
          <span class="acc-icon">{item.icon}</span>
          <span class="acc-label-text">{item.label}</span>
        </div>
        <div class="acc-content">
          <h3>{item.label}</h3>
          <p>{item.popis}</p>
          <a href={item.href} class="btn-visit">
            Navštívit sekci
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .accordion-wrap {
    max-width: 1280px;
    margin: 32px auto;
    padding: 0 32px;
  }

  .accordion {
    display: flex;
    gap: 10px;
    height: 460px;
  }

  .acc-item {
    flex: 1;
    position: relative;
    cursor: pointer;
    border-radius: 18px;
    overflow: hidden;
    background-size: cover;
    background-position: center;
    background-color: #111;
    transition: flex 0.9s cubic-bezier(.4,0,.2,1);
    min-width: 0;
  }

  .acc-item.expanded { flex: 3; }

  .acc-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,.72) 0%, rgba(0,0,0,.18) 55%, rgba(0,0,0,.04) 100%);
  }

  /* Label — always visible when collapsed */
  .acc-label {
    position: absolute;
    bottom: 22px;
    left: 0;
    right: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    transition: opacity .3s .1s, transform .3s .1s;
  }

  .acc-icon { font-size: 22px; line-height: 1; }

  .acc-label-text {
    font-size: 13px;
    font-weight: 700;
    color: #fff;
    white-space: nowrap;
  }

  .acc-item.expanded .acc-label {
    opacity: 0;
    transform: translateY(8px);
    pointer-events: none;
  }

  /* Expanded content */
  .acc-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 36px 28px;
    z-index: 2;
    opacity: 0;
    transform: translateY(14px);
    transition: opacity .35s, transform .35s;
    pointer-events: none;
  }

  .acc-item.expanded .acc-content {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    transition-delay: .15s;
  }

  .acc-content h3 {
    color: #fff;
    font-size: 32px;
    font-weight: 800;
    letter-spacing: -0.5px;
    margin-bottom: 10px;
    text-shadow: 0 2px 10px rgba(0,0,0,.4);
  }

  .acc-content p {
    color: rgba(255,255,255,.78);
    font-size: 14px;
    line-height: 1.55;
    margin-bottom: 22px;
    max-width: 320px;
  }

  .btn-visit {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #FFFF00;
    color: #000;
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 13px;
    padding: 11px 20px;
    border-radius: 8px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background .15s, transform .15s;
    white-space: nowrap;
  }

  .btn-visit:hover {
    background: #e6e600;
    transform: translateY(-1px);
  }

  @media (max-width: 768px) {
    .accordion-wrap { padding: 0 16px; margin: 20px auto; }
    .accordion { flex-direction: column; height: auto; gap: 8px; }
    .acc-item { height: 100px; flex: none !important; border-radius: 12px; }
    .acc-item.expanded { height: 280px; }
    .acc-label { opacity: 1 !important; transform: none !important; }
  }
</style>

<script>
  const items = document.querySelectorAll('.acc-item');
  const accordion = document.getElementById('accordion');

  items.forEach(item => {
    item.addEventListener('mouseenter', () => {
      items.forEach(i => i.classList.remove('expanded'));
      item.classList.add('expanded');
    });
  });

  accordion?.addEventListener('mouseleave', () => {
    items.forEach(i => i.classList.remove('expanded'));
  });
</script>
