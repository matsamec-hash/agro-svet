---
interface Props {
  active: 'komodity' | 'puda';
}
const { active } = Astro.props;

const items = [
  { key: 'komodity', label: 'Trhy a komodity', href: '/statistiky/', sub: 'Ceny, vstupy, sklizeň, regiony' },
  { key: 'puda', label: 'Zemědělská půda', href: '/puda/', sub: 'Cena, struktura, eroze, vlastnictví' },
];
---

<nav class="data-seg" aria-label="Sekce Data — přepínač podsekcí">
  <span class="data-seg-label">Datová sekce</span>
  <div class="data-seg-tabs" role="tablist">
    {items.map((it) => (
      <a
        href={it.href}
        role="tab"
        class:list={['data-seg-tab', { active: it.key === active }]}
        aria-current={it.key === active ? 'page' : undefined}
        aria-selected={it.key === active}
      >
        <span class="data-seg-icon" aria-hidden="true">
          {it.key === 'komodity' ? (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m7 14 4-4 3 3 5-5"/></svg>
          ) : (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V12"/><path d="M12 12c0-3 2-5 5-5 0 3-2 5-5 5z"/><path d="M12 12c0-3-2-5-5-5 0 3 2 5 5 5z"/><path d="M12 7c0-2 1-4 3-4 0 2-1 4-3 4z"/></svg>
          )}
        </span>
        <span class="data-seg-text">
          <span class="data-seg-name">{it.label}</span>
          <span class="data-seg-sub">{it.sub}</span>
        </span>
        {it.key === active && (
          <span class="data-seg-dot" aria-hidden="true"></span>
        )}
      </a>
    ))}
  </div>
</nav>

<style>
  .data-seg {
    --yellow:#FFEA00; --ink:#0A0A0B; --line:#EAEAEC; --muted:#6B6B72;
    display:flex;flex-direction:column;gap:8px;
    margin:0 0 22px;
  }
  .data-seg-label {
    font:600 11px 'Chakra Petch',sans-serif;
    letter-spacing:.22em;text-transform:uppercase;
    color:var(--muted);padding-left:2px;
  }
  .data-seg-tabs {
    display:grid;grid-template-columns:1fr 1fr;gap:10px;
  }
  .data-seg-tab {
    display:flex;align-items:center;gap:14px;
    padding:18px 22px;
    background:#fff;border:1px solid var(--line);border-radius:18px;
    text-decoration:none;color:var(--ink);
    transition:transform .15s, border-color .15s, box-shadow .15s, background .15s;
    position:relative;
    box-shadow:0 1px 2px rgba(10,10,12,.04);
  }
  .data-seg-tab:hover {
    transform:translateY(-1px);
    border-color:var(--yellow);
    box-shadow:0 10px 26px -10px rgba(255,234,0,.35);
  }
  .data-seg-tab.active {
    background:linear-gradient(135deg, #FFEA00 0%, #FFD400 100%);
    border-color:var(--yellow);
    box-shadow:0 14px 36px -14px rgba(255,234,0,.55);
  }
  .data-seg-tab.active:hover { transform:translateY(-1px) }

  .data-seg-icon {
    width:42px;height:42px;flex-shrink:0;
    display:flex;align-items:center;justify-content:center;
    background:#FBFAF4;border-radius:12px;
    color:var(--ink);
    transition:background .15s, color .15s;
  }
  .data-seg-tab.active .data-seg-icon {
    background:var(--ink);color:var(--yellow);
  }

  .data-seg-text { display:flex;flex-direction:column;gap:2px;flex:1;min-width:0 }
  .data-seg-name {
    font:700 16.5px 'Chakra Petch',sans-serif;letter-spacing:-.01em;
    color:var(--ink);
  }
  .data-seg-sub {
    font:500 12.5px 'Chakra Petch',sans-serif;letter-spacing:.02em;
    color:var(--muted);
  }
  .data-seg-tab.active .data-seg-sub { color:rgba(10,10,12,.7) }

  .data-seg-dot {
    width:8px;height:8px;border-radius:50%;background:var(--ink);flex-shrink:0;
    box-shadow:0 0 0 4px rgba(10,10,12,.12);
    animation:seg-pulse 2s infinite;
  }
  @keyframes seg-pulse{0%,100%{opacity:1}50%{opacity:.55}}

  @media (max-width:640px){
    .data-seg-tabs { grid-template-columns:1fr;gap:8px }
    .data-seg-tab { padding:14px 16px }
    .data-seg-icon { width:38px;height:38px }
    .data-seg-name { font-size:15px }
    .data-seg-sub { font-size:12px }
  }
</style>
