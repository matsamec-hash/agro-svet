---
interface Props {
  active: 'komodity' | 'puda';
}
const { active } = Astro.props;

const items = [
  { key: 'komodity', label: 'Trhy a komodity', href: '/statistiky/', emoji: '📊' },
  { key: 'puda', label: 'Zemědělská půda', href: '/puda/', emoji: '🌱' },
];
---

<nav class="data-seg" aria-label="Sekce Data">
  {items.map((it) => (
    <a
      href={it.href}
      class:list={['data-seg-tab', { active: it.key === active }]}
      aria-current={it.key === active ? 'page' : undefined}
    >
      <span class="data-seg-emoji" aria-hidden="true">{it.emoji}</span>
      <span class="data-seg-label">{it.label}</span>
    </a>
  ))}
</nav>

<style>
  .data-seg {
    --yellow:#FFEA00; --ink:#0A0A0B; --line:#EAEAEC;
    display:inline-flex;gap:4px;
    background:#FBFAF4;border:1px solid var(--line);border-radius:14px;
    padding:4px;margin:0 0 24px;
  }
  .data-seg-tab {
    display:inline-flex;align-items:center;gap:8px;
    padding:9px 16px;border-radius:10px;
    font:600 13.5px 'Chakra Petch',sans-serif;letter-spacing:.01em;
    color:var(--ink);text-decoration:none;
    transition:.15s;white-space:nowrap;
  }
  .data-seg-tab:hover { background:#fff; }
  .data-seg-tab.active {
    background:var(--ink);color:#fff;
    box-shadow:0 6px 16px -6px rgba(10,10,12,.35);
  }
  .data-seg-tab.active:hover { background:var(--ink); }
  .data-seg-emoji { font-size:16px;line-height:1 }
  @media (max-width:520px){
    .data-seg{display:flex;width:100%}
    .data-seg-tab{flex:1;justify-content:center;padding:10px 8px;font-size:12.5px}
    .data-seg-label{font-size:12.5px}
  }
</style>
