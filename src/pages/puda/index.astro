  /* Chart sections — sjednoceno se sp-section pattern */
  .chart-section { margin: 32px 0 36px; padding: 28px 30px; background:#fff; border-radius:18px; border:1px solid #EAEAEC; box-shadow:0 1px 2px rgba(10,10,12,.04); scroll-margin-top:200px; }
  .chart-section header { margin-bottom: 18px; }
  .chart-section h2 { font:700 24px 'Chakra Petch',sans-serif; letter-spacing:-.02em; margin:0; color:#0A0A0B; }
  .chart-section .sub { display:block; font-size:13px; color:#6B6B72; margin-top:2px; }
  .chart-wrap { display:flex; flex-direction:column; gap:16px; }
  .chart-svg { width:100%; height:auto; display:block; }
  .chart-insight { font-size:14px; color:#1E1E22; line-height:1.6; padding:12px 16px; background:#FFF6A8; border:1px solid #FFEA00; border-radius:10px; font-weight:500; }

  /* Two-column */
  .two-col { display:grid; grid-template-columns:repeat(auto-fit, minmax(300px, 1fr)); gap:14px; margin: 32px 0 36px; scroll-margin-top:200px; }
  .card-chart { padding:24px 26px; background:#fff; border-radius:18px; border:1px solid #EAEAEC; box-shadow:0 1px 2px rgba(10,10,12,.04); scroll-margin-top:200px; }
  .card-chart h3 { font:700 18px 'Chakra Petch',sans-serif; letter-spacing:-.01em; margin:0; color:#0A0A0B; }
  .card-chart .sub { display:block; font-size:13px; color:#6B6B72; margin-top:2px; margin-bottom:18px; }
  .card-note { font-size:13px; color:#6B6B72; line-height:1.55; margin:18px 0 0; }

  /* Source link konzistentní s .sp-src ve statistiky komponentách */
  .src-link {
    display:inline-flex;align-items:center;gap:4px;margin-top:6px;
    font-size:11.5px;color:#888;text-decoration:none;
    border-bottom:1px dotted #c0c0c5;padding-bottom:1px;
    transition:color .15s, border-color .15s;
  }
  .src-link:hover{color:#0A0A0B;border-bottom-color:#0A0A0B}
  .src-link svg{color:#a0a0a8;transition:transform .15s}
  .src-link:hover svg{color:#0A0A0B;transform:translate(1px,-1px)}

  .donut-wrap { display:flex; gap:20px; align-items:center; flex-wrap:wrap; }
  .donut-svg { width:200px; height:200px; flex-shrink:0; }
  .donut-legend { list-style:none; padding:0; margin:0; flex:1; min-width:180px; display:flex; flex-direction:column; gap:8px; }
  .donut-legend li { display:flex; align-items:center; gap:10px; font-size:13px; }
  .donut-legend .dot { width:12px; height:12px; border-radius:3px; flex-shrink:0; }
  .donut-legend .lbl { color:#1E1E22; flex:1; }
  .donut-legend .val { color:#6B6B72; font-size:12px; }

  /* Threats bars */
  .threats { display:flex; flex-direction:column; gap:14px; }
  .threat { display:flex; flex-direction:column; gap:4px; }
  .threat-bar { height:24px; background:var(--c); width:var(--w); border-radius:6px; position:relative; min-width:36px; transition: width .8s ease; }
  .threat-bar span { position:absolute; right:8px; top:50%; transform:translateY(-50%); font-size:12px; color:#fff; font-weight:700; }
  .threat-lbl { font-size:13px; color:#1E1E22; }

  /* Facts grid */
  .facts-grid { display:grid; grid-template-columns:repeat(auto-fit, minmax(260px, 1fr)); gap:14px; margin: 32px 0 36px; scroll-margin-top:200px; }
  .fact { padding:22px 24px; background:#fff; border-radius:18px; border:1px solid #EAEAEC; box-shadow:0 1px 2px rgba(10,10,12,.04); display:flex; flex-direction:column; }
  .fact-val { font-family:'Chakra Petch',sans-serif; font-size:28px; font-weight:700; color:#0A0A0B; line-height:1; display:block; letter-spacing:-.02em; }
  .fact-unit { font-size:14px; color:#6B6B72; font-weight:400; }
  .fact-lbl { font-size:14px; color:#0A0A0B; font-weight:600; margin-top:8px; display:block; }
  .fact-note { font-size:12.5px; color:#6B6B72; margin-top:6px; display:block; line-height:1.5; }

  /* Crops */
  .crops-section { margin: 32px 0 36px; padding: 28px 30px; background:#fff; border-radius:18px; border:1px solid #EAEAEC; box-shadow:0 1px 2px rgba(10,10,12,.04); scroll-margin-top:200px; }
  .crops-section header { margin-bottom: 18px; }
  .crops-section h2 { font:700 24px 'Chakra Petch',sans-serif; letter-spacing:-.02em; margin:0; color:#0A0A0B; }
  .crops-section .sub { display:block; font-size:13px; color:#6B6B72; margin-top:2px; }
  .crops-bars { display:flex; flex-direction:column; gap:12px; }
  .crop-row { display:grid; grid-template-columns:200px 1fr; gap:16px; align-items:center; }
  .crop-name { font-size:14px; color:#444; }
  .crop-bar-wrap { display:flex; align-items:center; gap:12px; }
  .crop-bar { height:22px; border-radius:4px; min-width:24px; transition: width .8s ease; }
  .crop-val { font-size:13px; color:#666; white-space:nowrap; }
  .section-note { font-size:14px; color:#1E1E22; line-height:1.6; padding:12px 16px; background:#FFF6A8; border:1px solid #FFEA00; border-radius:10px; margin-top:24px; font-weight:500; }

  /* Topics */
  .topics-section { margin: 32px 0 36px; scroll-margin-top:200px; }
  .topics-section h2 { font:700 24px 'Chakra Petch',sans-serif; letter-spacing:-.02em; margin:0 0 18px; color:#0A0A0B; }
  .topics-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(300px, 1fr)); gap:14px; }
  .puda-card { display:block; text-decoration:none; color:inherit; border-radius:18px; padding:24px 26px; background:#fff; border:1px solid #EAEAEC; box-shadow:0 1px 2px rgba(10,10,12,.04); transition: box-shadow .2s, transform .2s, border-color .2s; }
  .puda-card:hover { box-shadow:0 14px 36px -16px rgba(10,10,12,.18); transform:translateY(-2px); border-color:#FFEA00; }
  .card-icon { width:48px; height:48px; background:#FFFF00; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:24px; margin-bottom:16px; }
  .puda-card h3 { font:700 18px 'Chakra Petch',sans-serif; letter-spacing:-.01em; color:#0A0A0B; margin:0 0 8px; }
  .puda-card p { font-size:14px; color:#6B6B72; line-height:1.55; margin:0 0 14px; display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden; }
  .card-cta { font-size:13px; color:#1a1a1a; font-weight:600; }

  /* Sources */
  .sources-section { margin-top:48px; padding-top:32px; border-top:1px solid #EAEAEC; }
  .sources-section h3 { font:700 16px 'Chakra Petch',sans-serif; letter-spacing:-.01em; margin:0 0 16px; color:#0A0A0B; }
  .sources-section ul { padding:0; margin:0; list-style:none; display:flex; flex-direction:column; gap:8px; }
  .sources-section li { font-size:13px; }
  .sources-section a { color:#6B6B72; text-decoration:underline; text-decoration-color:#c0c0c5; text-underline-offset:2px; }
  .sources-section a:hover { color:#0A0A0B; text-decoration-color:#FFEA00; }
  .updated { font-size:12px; color:#888; margin-top:18px; }

  @media (max-width: 768px) {
    .puda-root { padding: 32px 16px 64px; }
    .crop-row { grid-template-columns:1fr; gap:6px; }
    .chart-section, .crops-section, .card-chart { padding:20px; }
  }

  /* ===== Interaktivita ===== */

  /* Line chart — stroke draw on scroll */
  .chart-svg .line-path { stroke-dasharray: 1500; stroke-dashoffset: 1500; }
  .chart-svg .line-area { opacity: 0; }
  .reveal.in-view .line-path { animation: drawLine 1.6s cubic-bezier(.6,.05,.3,1) forwards; }
  .reveal.in-view .line-area { animation: fadeIn .8s .8s ease forwards; }
  @keyframes drawLine { to { stroke-dashoffset: 0; } }
  @keyframes fadeIn { to { opacity: 1; } }

  /* Line points — pulse on hover */
  .line-point { transition: r .15s, fill .15s; pointer-events: none; }
  .line-point-hit { cursor: crosshair; }
  .line-point.is-hover { r: 8; fill: #1a1a1a; stroke: #FFFF00; stroke-width: 2.5; }
  .line-guide { transition: opacity .15s; pointer-events: none; }
  .line-guide.is-hover { opacity: .5; }

  /* Donut — radial reveal + hover scale */
  .donut-svg { overflow: visible; }
  .donut-svg path { transform-origin: 100px 100px; transition: transform .25s cubic-bezier(.5,0,.3,1), opacity .2s; cursor: pointer; }
  .donut-svg path { stroke-dasharray: 600; stroke-dashoffset: 600; }
  .reveal.in-view .donut-svg path { animation: dash 1.0s cubic-bezier(.6,.05,.3,1) forwards; }
  .reveal.in-view .donut-svg path:nth-child(2) { animation-delay: .15s; }
  .reveal.in-view .donut-svg path:nth-child(3) { animation-delay: .3s; }
  @keyframes dash { to { stroke-dashoffset: 0; } }
  .donut-svg path:hover, .donut-svg path.is-active { transform: scale(1.06); }
  .donut-svg.has-active path:not(.is-active) { opacity: .35; }
  .donut-center { opacity: 0; transition: opacity .35s ease .9s; }
  .reveal.in-view .donut-center { opacity: 1; }

  /* Donut legend sync */
  .donut-legend li { padding:8px 10px; border-radius:8px; cursor:pointer; transition: background .15s; }
  .donut-legend li:hover, .donut-legend li.is-active { background: #f5f3ea; }

  /* Threats + crops bars — width fly-in + hover lift */
  .threat-bar, .crop-bar {
    width: 0 !important;
    transition: width 1.0s cubic-bezier(.6,.05,.3,1), filter .15s, transform .15s;
    cursor: pointer;
  }
  .reveal.in-view .threat-bar { width: var(--w) !important; }
  .reveal.in-view .crop-bar { width: var(--final-w, var(--w, 0)) !important; }
  .threat-bar:hover, .crop-bar:hover {
    filter: brightness(1.10) saturate(1.15);
    transform: translateX(2px);
  }
  .threat { transition: opacity .15s; }
  .threats:has(.threat-bar:hover) .threat:not(:has(.threat-bar:hover)) { opacity: .55; }

  /* Tooltip — shared. Default above element, .below variant pod ním (auto-flip pokud point u top) */
  .puda-tooltip {
    position: fixed; z-index: 999; pointer-events: none;
    background: #1a1a1a; color: #fff; padding: 9px 13px; border-radius: 8px;
    font-size: 13px; line-height: 1.45; white-space: nowrap;
    box-shadow: 0 4px 14px rgba(0,0,0,.25);
    opacity: 0; transform: translate(-50%, -120%) translateY(6px);
    transition: opacity .15s, transform .15s;
  }
  .puda-tooltip.is-visible { opacity: 1; transform: translate(-50%, -120%); }
  .puda-tooltip.is-visible.below { transform: translate(-50%, 20%); }
  .puda-tooltip strong { color: #FFFF00; }
</style>

<script is:inline>
  (function () {
    // ── IntersectionObserver: trigger .in-view on reveal sekce ──
    const reveals = document.querySelectorAll('.reveal');
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add('in-view');
            io.unobserve(e.target);
          }
        }
      }, { rootMargin: '0px 0px -60px 0px', threshold: 0.15 });
      reveals.forEach(el => io.observe(el));
    } else {
      reveals.forEach(el => el.classList.add('in-view'));
    }

    // ── Tooltip helper ──
    let tip = document.querySelector('.puda-tooltip');
    if (!tip) {
      tip = document.createElement('div');
      tip.className = 'puda-tooltip';
      document.body.appendChild(tip);
    }
    function showTip(html, x, y) {
      tip.innerHTML = html;
      tip.style.left = x + 'px';
      tip.style.top = y + 'px';
      // Auto-flip: pokud je point blízko top viewport, dej tooltip POD něj
      tip.classList.toggle('below', y < 80);
      tip.classList.add('is-visible');
    }
    function hideTip() { tip.classList.remove('is-visible'); }

    // ── Line chart hit columns (Voronoi-style): hover tooltip + guide line + point pulse ──
    document.querySelectorAll('.line-point-hit').forEach(pt => {
      pt.addEventListener('mouseenter', () => {
        const rok = pt.dataset.rok;
        const cena = parseFloat(pt.dataset.cena);
        const cenaKc = (cena * 1000).toLocaleString('cs-CZ');
        // Tooltip: pozice nad datapointem v SVG (ne kde je kurzor — Voronoi sloupec je široký)
        const svg = pt.closest('svg');
        const ptRect = svg.getBoundingClientRect();
        const dx = parseFloat(pt.dataset.x);
        const dy = parseFloat(pt.dataset.y);
        const vbW = svg.viewBox.baseVal.width;
        const vbH = svg.viewBox.baseVal.height;
        const screenX = ptRect.left + (dx / vbW) * ptRect.width;
        const screenY = ptRect.top + (dy / vbH) * ptRect.height;
        showTip(`<strong>${rok}</strong><br>${cena.toLocaleString('cs-CZ')} tis. Kč/ha<br><span style="opacity:.7;font-size:11px">${cenaKc} Kč/ha</span>`, screenX, screenY);
        // Pulse visible point + guide line
        svg.querySelectorAll('.line-point').forEach(p => p.classList.toggle('is-hover', p.dataset.rok === rok));
        svg.querySelectorAll('.line-guide').forEach(g => g.classList.toggle('is-hover', g.dataset.rokLine === rok));
      });
      pt.addEventListener('mouseleave', () => {
        hideTip();
        document.querySelectorAll('.line-point.is-hover, .line-guide.is-hover').forEach(p => p.classList.remove('is-hover'));
      });
    });

    // ── Donut: hover slice ↔ legend sync + tooltip ──
    document.querySelectorAll('.donut-svg').forEach(svg => {
      const paths = svg.querySelectorAll('path[data-name]');
      const legend = svg.parentElement.querySelector('.donut-legend');
      const items = legend ? legend.querySelectorAll('li[data-name]') : [];

      function activate(name) {
        if (name) svg.classList.add('has-active');
        else svg.classList.remove('has-active');
        paths.forEach(p => p.classList.toggle('is-active', p.dataset.name === name));
        items.forEach(li => li.classList.toggle('is-active', li.dataset.name === name));
      }

      paths.forEach(p => {
        p.addEventListener('mouseenter', (ev) => {
          activate(p.dataset.name);
          const ha = parseInt(p.dataset.ha);
          showTip(`<strong>${p.dataset.name}</strong><br>${p.dataset.pct} % · ${ha.toLocaleString('cs-CZ')} tis. ha`, ev.clientX, ev.clientY);
        });
        p.addEventListener('mousemove', (ev) => { tip.style.left = ev.clientX + 'px'; tip.style.top = (ev.clientY - 14) + 'px'; });
        p.addEventListener('mouseleave', () => { activate(null); hideTip(); });
      });

      items.forEach(li => {
        li.addEventListener('mouseenter', () => activate(li.dataset.name));
        li.addEventListener('mouseleave', () => activate(null));
      });
    });

    // ── Threats bars: tooltip s detail ke každému typu ohrožení ──
    const threatDetails = {
      'Vodní eroze': 'Hlavně Vysočina a Hanácká nížina. ~21 mil. tun ornice ročně.',
      'Zhutnění': 'Těžká mechanizace + intenzivní zpracování. VÚMOP odhad 50 %.',
      'Větrná eroze': 'Hlavně jižní Morava. Nejvyšší stupeň 4 %.',
      'Dehumifikace (5–15 % pokles humusu)': 'Pokles chovu zvířat → méně organických hnojiv → ztráta humusu.',
    };
    document.querySelectorAll('.threat-bar[data-final]').forEach(bar => {
      bar.addEventListener('mouseenter', () => {
        const lbl = bar.parentElement.querySelector('.threat-lbl')?.textContent ?? '';
        const detail = threatDetails[lbl] ?? '';
        const r = bar.getBoundingClientRect();
        showTip(`<strong>${lbl}</strong><br>${bar.dataset.final} % zemědělské půdy ČR${detail ? '<br><span style="opacity:.75;font-size:11px">' + detail + '</span>' : ''}`,
          r.left + r.width - 30, r.top);
      });
      bar.addEventListener('mouseleave', hideTip);
    });

    // ── Crop bars: tooltip ──
    const cropDetails = {
      'Pšenice ozimá': 'Hlavní obilovina ČR. Výnos 6,4–6,9 t/ha.',
      'Řepka ozimá': '16 % všech polí ČR (vs. EU průměr 6,3 %). 2024 -9,4 % YoY.',
      'Ječmen': 'Sladovnický + krmný. 2024 -4 % YoY.',
      'Kukuřice na zrno': '2024 +11 %. Jihomoravský kraj +32 % ploch.',
      'Ostatní obiloviny + okopaniny': 'Žito, oves, brambory, řepa cukrová.',
    };
    document.querySelectorAll('.crop-bar').forEach(bar => {
      const row = bar.closest('.crop-row');
      const name = row?.querySelector('.crop-name')?.textContent ?? '';
      const valEl = row?.querySelector('.crop-val')?.textContent ?? '';
      const detail = cropDetails[name] ?? '';
      bar.addEventListener('mouseenter', () => {
        const r = bar.getBoundingClientRect();
        showTip(`<strong>${name}</strong><br>${valEl}${detail ? '<br><span style="opacity:.75;font-size:11px">' + detail + '</span>' : ''}`,
          r.left + r.width - 30, r.top);
      });
      bar.addEventListener('mouseleave', hideTip);
    });
  })();
</script>
