---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import DataSegmentNav from '../../components/DataSegmentNav.astro';
import PillsNav from '../../components/statistiky/PillsNav.astro';
import { getCollection } from 'astro:content';

const PUDA_PILLS = [
  { label: 'Témata', href: '#temata' },
  { label: 'Cena', href: '#cena' },
  { label: 'Struktura', href: '#struktura' },
  { label: 'Ohrožení', href: '#ohrozeni' },
  { label: 'Vlastnictví', href: '#vlastnictvi' },
  { label: 'Plodiny', href: '#plodiny' },
];

const pudaItems = await getCollection('puda');

// Time series cena půdy 2000-2025 (FARMY.CZ Index, Tomáš Valka)
const cenaPudy = [
  { rok: 2000, cena: 60 },
  { rok: 2010, cena: 90 },
  { rok: 2014, cena: 150 },
  { rok: 2019, cena: 250 },
  { rok: 2020, cena: 265 },
  { rok: 2021, cena: 290 },
  { rok: 2022, cena: 340 },
  { rok: 2023, cena: 350 },
  { rok: 2024, cena: 360 },
  { rok: 2025, cena: 372.55 },
];
const cenaMin = 0;
const cenaMax = 400;
const cenaW = 1200;
const cenaH = 360;
const cenaPad = { l: 50, r: 20, t: 20, b: 30 };
const cenaPlotW = cenaW - cenaPad.l - cenaPad.r;
const cenaPlotH = cenaH - cenaPad.t - cenaPad.b;
const cenaPoints = cenaPudy.map((d) => {
  const x = cenaPad.l + ((d.rok - 2000) / 25) * cenaPlotW;
  const y = cenaPad.t + cenaPlotH - ((d.cena - cenaMin) / (cenaMax - cenaMin)) * cenaPlotH;
  return { ...d, x, y };
});
const cenaPath = cenaPoints.map((p, i) => `${i === 0 ? 'M' : 'L'}${p.x.toFixed(1)},${p.y.toFixed(1)}`).join(' ');
const cenaArea = `${cenaPath} L${cenaPoints[cenaPoints.length - 1].x.toFixed(1)},${(cenaPad.t + cenaPlotH).toFixed(1)} L${cenaPoints[0].x.toFixed(1)},${(cenaPad.t + cenaPlotH).toFixed(1)} Z`;

// Struktura ZPF (donut)
const struktura = [
  { name: 'Orná půda', pct: 71, ha: 2525, color: '#FFD700' },
  { name: 'Travní porosty (TTP)', pct: 27, ha: 969, color: '#7CB342' },
  { name: 'Sady, vinice, zahrady', pct: 2, ha: 70, color: '#FF7043' },
];
const donutR = 80;
const donutCx = 100;
const donutCy = 100;
let cumPct = 0;
const donutSegs = struktura.map((s) => {
  const startAngle = (cumPct / 100) * 2 * Math.PI - Math.PI / 2;
  cumPct += s.pct;
  const endAngle = (cumPct / 100) * 2 * Math.PI - Math.PI / 2;
  const x1 = donutCx + donutR * Math.cos(startAngle);
  const y1 = donutCy + donutR * Math.sin(startAngle);
  const x2 = donutCx + donutR * Math.cos(endAngle);
  const y2 = donutCy + donutR * Math.sin(endAngle);
  const largeArc = s.pct > 50 ? 1 : 0;
  return {
    ...s,
    path: `M${donutCx},${donutCy} L${x1.toFixed(2)},${y1.toFixed(2)} A${donutR},${donutR} 0 ${largeArc},1 ${x2.toFixed(2)},${y2.toFixed(2)} Z`,
  };
});
---

<Layout title="Zemědělská půda v ČR — fakta, ceny, eroze" description="Aktuální data o zemědělské půdě v ČR: cena 372 550 Kč/ha, úbytek 10,8 ha denně, 60 % polí ohroženo vodní erozí. Ornice, eroze, výživa a ochrana půdního fondu.">
  <div class="puda-root">

    <DataSegmentNav active="puda" />

    <!-- Hero (sjednoceno se statistiky) -->
    <section class="sp-hero">
      <div class="sp-hero-left">
        <span class="sp-kicker"><span class="dot"></span>PŮDA · DATOVÁ POVER-MAPA</span>
        <h1>Zemědělská <em>půda</em></h1>
        <p class="sp-hero-lede">
          Půda je nejcennější zemědělský zdroj — a v Česku jí ubývá rekordním tempem. Sledujte aktuální ceny,
          vývoj výměry, ohrožení erozí a strukturální fakta o českém zemědělském půdním fondu.
        </p>
      </div>
      <div class="sp-hero-right">
        <div class="sp-hero-photo" style="background-image:url('/images/kombajn.webp')">
          <div class="sp-hero-photo-badge">372 550 Kč/ha · 2025</div>
        </div>
      </div>
    </section>

    <!-- Big numbers (samostatná sekce pod heroem) -->
    <section class="big-numbers">
        {[
          {
            val: '372 550', unit: ' Kč/ha',
            lbl: 'Průměrná tržní cena orné půdy',
            trend: '+3,4 % YoY · 2025',
            source: 'FARMY.CZ Index farmářské půdy',
            url: 'https://www.farmy.cz/cena-pudy/',
          },
          {
            val: '+517 %', unit: '',
            lbl: 'Růst ceny půdy za 25 let',
            trend: '2000 → 2025',
            source: 'FARMY.CZ + studie Tomáš Valka (ČZU)',
            url: 'https://www.farmy.cz/cena-pudy/',
          },
          {
            val: '10,8', unit: ' ha/den',
            lbl: 'Úbytek zemědělské půdy',
            trend: 'Dlouhodobý průměr od 1999',
            source: 'ČÚZK + MZe Zelená zpráva',
            url: 'https://eagri.cz/public/web/mze/zemedelstvi/publikace-a-dokumenty/zelene-zpravy/',
          },
          {
            val: '>50 %', unit: '',
            lbl: 'Polí ohroženo vodní erozí',
            trend: 'VÚMOP, novější odhad až 60 %',
            source: 'VÚMOP — Monitoring eroze',
            url: 'https://www.vumop.cz/projekty/monitoring-eroze',
          },
        ].map((b) => (
          <div class="bn">
            <span class="bn-val">{b.val.replace(/ /g, ' ')}{b.unit && <span class="bn-unit">{b.unit}</span>}</span>
            <span class="bn-lbl">{b.lbl}</span>
            <span class="bn-trend">{b.trend}</span>
            <a class="bn-source" href={b.url} target="_blank" rel="noopener noreferrer">
              <span class="bn-source-prefix">Zdroj:</span> {b.source}
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
            </a>
          </div>
        ))}
    </section>

    <PillsNav items={PUDA_PILLS} />

    <!-- Témata (na začátek) -->
    <section class="topics-section" id="temata">
      <h2>Hloubkově k tématům</h2>
      <div class="topics-grid">
        {pudaItems.map(item => (
          <a href={`/puda/${item.id}/`} class="puda-card">
            <div class="card-icon">🌱</div>
            <h3>{item.data.title}</h3>
            <p>{item.data.popis}</p>
            <span class="card-cta">Číst dál →</span>
          </a>
        ))}
      </div>
    </section>

    <!-- Cena půdy graf -->
    <section class="chart-section reveal" data-reveal="line" id="cena">
      <header>
        <h2>Cena zemědělské půdy 2000–2025</h2>
        <span class="sub">Průměrná tržní cena hektaru orné půdy v tis. Kč.</span>
        <a class="src-link" href="https://www.farmy.cz/cena-pudy/" target="_blank" rel="noopener noreferrer">Zdroj: FARMY.CZ Index + studie Tomáš Valka (ČZU) <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg></a>
      </header>
      <div class="chart-wrap">
        <svg viewBox={`0 0 ${cenaW} ${cenaH}`} class="chart-svg" role="img" aria-label="Vývoj ceny zemědělské půdy 2000-2025">
          {[0, 100, 200, 300, 400].map((v) => {
            const y = cenaPad.t + cenaPlotH - ((v - cenaMin) / (cenaMax - cenaMin)) * cenaPlotH;
            return (
              <>
                <line x1={cenaPad.l} y1={y} x2={cenaW - cenaPad.r} y2={y} stroke="#eee" stroke-width="1"/>
                <text x={cenaPad.l - 8} y={y + 5} text-anchor="end" font-size="13" fill="#888">{v}</text>
              </>
            );
          })}
          <path d={cenaArea} fill="rgba(255, 215, 0, .25)" class="line-area"/>
          <path d={cenaPath} stroke="#1a1a1a" stroke-width="2.5" fill="none" stroke-linecap="round" class="line-path"/>
          {cenaPoints.map((p, i) => {
            // Vertikální hover sloupec — Voronoi-style: půlka cesty k sousedovi
            const prevX = i > 0 ? cenaPoints[i-1].x : p.x - 50;
            const nextX = i < cenaPoints.length - 1 ? cenaPoints[i+1].x : p.x + 50;
            const colX = (prevX + p.x) / 2;
            const colW = (nextX - prevX) / 2;
            return (
              <>
                <rect x={colX} y={cenaPad.t} width={colW} height={cenaPlotH}
                      fill="transparent" class="line-point-hit"
                      data-rok={p.rok} data-cena={p.cena} data-x={p.x} data-y={p.y}/>
                <line x1={p.x} y1={cenaPad.t} x2={p.x} y2={cenaPad.t + cenaPlotH}
                      stroke="#1a1a1a" stroke-width="1" stroke-dasharray="3 3" opacity="0"
                      class="line-guide" data-rok-line={p.rok}/>
                <circle cx={p.x} cy={p.y} r="5" fill="#FFFF00" stroke="#1a1a1a" stroke-width="2" class="line-point" data-rok={p.rok}/>
                <text x={p.x} y={p.y - 14} text-anchor="middle" font-size="13" font-weight="700" fill="#1a1a1a" class="line-price-label">{Math.round(p.cena)}</text>
                {(i === 0 || i === cenaPoints.length - 1 || i % 2 === 0) && (
                  <text x={p.x} y={cenaPad.t + cenaPlotH + 22} text-anchor="middle" font-size="13" fill="#666">{p.rok}</text>
                )}
              </>
            );
          })}
        </svg>
        <div class="chart-insight">
          Z 60 tis. Kč/ha v roce 2000 na <strong>372 550 Kč/ha v 2025</strong> — sedminásobný růst za jednu generaci.
          Po raketovém růstu 2014–2022 (+10–15 % p.a.) přichází mírná stagnace, růst zpomalil na 3,4 % v 2025.
        </div>
      </div>
    </section>

    <!-- Struktura ZPF + Eroze -->
    <section class="two-col" id="struktura">
      <div class="card-chart reveal" data-reveal="donut">
        <h3>Struktura zemědělského půdního fondu</h3>
        <span class="sub">3 535 tis. ha = 45 % rozlohy ČR (2024)</span>
        <a class="src-link" href="https://csu.gov.cz/zemedelstvi" target="_blank" rel="noopener noreferrer">Zdroj: ČSÚ — Statistika zemědělství <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg></a>
        <div class="donut-wrap">
          <svg viewBox="0 0 200 200" class="donut-svg" role="img" aria-label="Struktura ZPF">
            {donutSegs.map((s) => (
              <path d={s.path} fill={s.color} stroke="#fff" stroke-width="1" data-name={s.name} data-pct={s.pct} data-ha={s.ha}/>
            ))}
            <circle cx={donutCx} cy={donutCy} r="40" fill="#fff"/>
            <text x={donutCx} y={donutCy - 4} text-anchor="middle" font-size="14" font-weight="700" fill="#1a1a1a" class="donut-center">3 535</text>
            <text x={donutCx} y={donutCy + 12} text-anchor="middle" font-size="10" fill="#666" class="donut-center">tis. ha</text>
          </svg>
          <ul class="donut-legend">
            {struktura.map((s) => (
              <li data-name={s.name}>
                <span class="dot" style={`background:${s.color}`}></span>
                <span class="lbl">{s.name}</span>
                <span class="val"><strong>{s.pct} %</strong> · {s.ha} tis. ha</span>
              </li>
            ))}
          </ul>
        </div>
        <p class="card-note">Trvalé travní porosty rostou: z 23 % (2002) na 27 % (2024) — důsledek dotační politiky a ochrany proti erozi.</p>
      </div>

      <div class="card-chart reveal" data-reveal="bars" id="ohrozeni">
        <h3>Ohrožení půdy</h3>
        <span class="sub">Procento zemědělské půdy ČR.</span>
        <a class="src-link" href="https://www.vumop.cz/projekty/monitoring-eroze" target="_blank" rel="noopener noreferrer">Zdroj: VÚMOP — Monitoring eroze <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg></a>
        <div class="threats">
          <div class="threat">
            <div class="threat-bar" style="--w:60%; --c:#E53935" data-final="60"><span>60 %</span></div>
            <span class="threat-lbl">Vodní eroze</span>
          </div>
          <div class="threat">
            <div class="threat-bar" style="--w:50%; --c:#FB8C00" data-final="50"><span>50 %</span></div>
            <span class="threat-lbl">Zhutnění</span>
          </div>
          <div class="threat">
            <div class="threat-bar" style="--w:30%; --c:#FFB300" data-final="30"><span>30 %</span></div>
            <span class="threat-lbl">Větrná eroze</span>
          </div>
          <div class="threat">
            <div class="threat-bar" style="--w:15%; --c:#FFC107" data-final="15"><span>15 %</span></div>
            <span class="threat-lbl">Dehumifikace (5–15 % pokles humusu)</span>
          </div>
        </div>
        <p class="card-note">Hlavní rizika: jižní Morava (větrná), Vysočina a Hanácká nížina (vodní). Dehumifikace souvisí s poklesem chovu zvířat → méně statkových hnojiv.</p>
      </div>
    </section>

    <!-- Vlastnictví + Pacht fakta -->
    <section class="facts-grid" id="vlastnictvi">
      {[
        {
          val: '3,2 mil.',
          unit: '',
          lbl: 'vlastníků zemědělské půdy v ČR',
          note: 'Drtivá většina pronajímá. Průměr na osobu jen ~1 ha.',
          source: 'ČÚZK — katastr nemovitostí',
          url: 'https://www.cuzk.gov.cz/Periodika-a-publikace/Statisticke-udaje/Souhrne-prehledy-pudniho-fondu.aspx',
        },
        {
          val: '~60 %',
          unit: '',
          lbl: 'pronajímané orné půdy',
          note: 'Před 10 lety to bylo až 90 %. Trend: vlastní podíl podniků roste.',
          source: 'ČSÚ — Strukturální šetření v zemědělství 2020',
          url: 'https://csu.gov.cz/strukturalni-setreni-v-zemedelstvi-2020',
        },
        {
          val: '3 000–7 000',
          unit: ' Kč/ha/rok',
          lbl: 'Pachtovné',
          note: 'Top kvality přes 10 000 Kč/ha. Roční růst ~1 000 Kč/ha.',
          source: 'FARMY.CZ Index + ČSÚ',
          url: 'https://www.farmy.cz/cena-pudy/',
        },
        {
          val: '130',
          unit: ' ha',
          lbl: 'Průměrná česká farma',
          note: 'Největší v EU (průměr EU 16,6 ha, Polsko 11 ha). Dědictví JZD.',
          source: 'Eurostat — Farm structure survey 2020',
          url: 'https://ec.europa.eu/eurostat/statistics-explained/index.php?title=Farms_and_farmland_in_the_European_Union_-_statistics',
        },
        {
          val: '77 %',
          unit: '',
          lbl: 'orné půdy v rukou ~3 000 největších podniků',
          note: 'Koncentrace ZPF: 3 % podniků hospodaří na ~77 % výměry. Pozůstatek velkých JZD.',
          source: 'ČSÚ + MZe Zelená zpráva 2023',
          url: 'https://eagri.cz/public/web/mze/zemedelstvi/publikace-a-dokumenty/zelene-zpravy/',
        },
        {
          val: '30',
          unit: ' ha',
          lbl: 'maximální blok jedné plodiny',
          note: 'DZES 7 (od 2024): na svahu nad 7° max. 10 ha. Cíl: snížit větrnou a vodní erozi.',
          source: 'MZe — Strategický plán SZP 2023–2027',
          url: 'https://eagri.cz/public/web/mze/dotace/szp-pro-obdobi-2023-2027/',
        },
        {
          val: '25 %',
          unit: '',
          lbl: 'katastrů s dokončenými KPÚ',
          note: 'NKÚ: zbývajících 75 % potrvá ~50 let a bude stát ~150 mld. Kč.',
          source: 'NKÚ — kontrolní závěr 23/15 (2023)',
          url: 'https://www.nku.cz/cz/pro-media/tiskove-zpravy/komplexni-pozemkove-upravy-id12863/',
        },
        {
          val: '16,4 %',
          unit: '',
          lbl: 'ekologicky obhospodařované půdy',
          note: '618 313 ha (LPIS 2025). Cíl MZe: 22 % do 2027.',
          source: 'ÚKZÚZ LPIS + MZe',
          url: 'https://eagri.cz/public/web/mze/zemedelstvi/ekologicke-zemedelstvi/',
        },
      ].map((f) => (
        <div class="fact">
          <span class="fact-val">{f.val}{f.unit && <span class="fact-unit">{f.unit}</span>}</span>
          <span class="fact-lbl">{f.lbl}</span>
          <span class="fact-note">{f.note}</span>
          <a class="fact-source" href={f.url} target="_blank" rel="noopener noreferrer">
            <span class="fact-source-prefix">Zdroj:</span> {f.source}
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
          </a>
        </div>
      ))}
    </section>

    <!-- Hlavní plodiny -->
    <section class="crops-section reveal" data-reveal="bars" id="plodiny">
      <header>
        <h2>Hlavní plodiny na orné půdě (2024)</h2>
        <span class="sub">Sklizeň 7 525 tis. tun obilovin, soběstačnost 164,6 %.</span>
      </header>
      <div class="crops-bars">
        {[
          { name: 'Pšenice ozimá', ha: 780, color: '#FFD700' },
          { name: 'Řepka ozimá', ha: 344, color: '#FFB300' },
          { name: 'Ječmen', ha: 321, color: '#7CB342' },
          { name: 'Kukuřice na zrno', ha: 280, color: '#FB8C00' },
          { name: 'Ostatní obiloviny + okopaniny', ha: 800, color: '#9E9E9E' },
        ].map((c) => (
          <div class="crop-row">
            <span class="crop-name">{c.name}</span>
            <div class="crop-bar-wrap">
              <div class="crop-bar" style={`--w:${(c.ha / 800) * 100}%; background:${c.color}`}></div>
              <span class="crop-val">{c.ha} tis. ha</span>
            </div>
          </div>
        ))}
      </div>
      <p class="section-note">
        ČR má extrémní podíl řepky: <strong>16 % všech polí</strong> oseto řepkou (vs. EU průměr 6,3 %). Kukuřice rapidně roste,
        v Jihomoravském kraji +32 % ploch v 2024.
      </p>
    </section>

    <!-- Zdroje -->
    <section class="sources-section">
      <h3>Zdroje dat</h3>
      <ul>
        <li><a href="https://www.farmy.cz/informace_kolik_stoji_puda" target="_blank" rel="noopener">FARMY.CZ — Index farmářské půdy</a></li>
        <li><a href="https://csu.gov.cz/zemedelske-pudy-je-zase-mene" target="_blank" rel="noopener">ČSÚ — Statistika a my (úbytek ZPF)</a></li>
        <li><a href="https://www.vumop.cz/eroze-pudy/" target="_blank" rel="noopener">VÚMOP — Eroze půdy</a></li>
        <li><a href="https://eagri.cz/public/web/mze/puda/" target="_blank" rel="noopener">MZe — Půda a krajina</a></li>
        <li><a href="https://www.zememeric.cz/cuzk-souhrnna-zprava-o-pudnim-fondu-za-rok-2024/" target="_blank" rel="noopener">ČÚZK — Souhrnná zpráva o půdním fondu 2024</a></li>
        <li><a href="https://www.tomasvalka.cz/vyvoj-cen-zemedelske-pudy-za-poslednich-25-let/" target="_blank" rel="noopener">Tomáš Valka — Vývoj cen půdy</a></li>
        <li><a href="https://www.asz.cz/" target="_blank" rel="noopener">ASZ ČR — Asociace soukromého zemědělství</a></li>
      </ul>
      <p class="updated">Datová pover-mapa naposledy aktualizována: duben 2026.</p>
    </section>

  </div>
</Layout>

<style>
  .puda-root {
    --bg-cream: #FBFAF4;
    max-width: 1280px; margin: 0 auto; padding: 26px 24px 96px;
    background: var(--bg-cream); color: #1E1E22;
  }

  /* Hero — sjednoceno s /statistiky/ (sp-hero pattern) */
  .sp-hero {
    --yellow:#FFEA00; --ink:#0A0A0B; --r-xl:24px;
    position:relative;overflow:hidden;color:#fff;border-radius:var(--r-xl);
    background:radial-gradient(600px 300px at 15% 20%, rgba(255,234,0,.18), transparent 60%),
      radial-gradient(700px 400px at 90% 90%, rgba(80,80,90,.4), transparent 60%),
      linear-gradient(135deg, #0E0E10 0%, #1C1C20 60%, #2A2A2F 100%);
    padding:48px 48px 40px;margin-bottom:22px;
    box-shadow:0 18px 40px -12px rgba(10,10,12,.18), 0 0 0 1px rgba(10,10,12,.04);
    display:grid;grid-template-columns:1.35fr 1fr;gap:32px;align-items:center;
  }
  .sp-hero::before{
    content:"";position:absolute;inset:0;pointer-events:none;opacity:.35;
    background-image:linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px),
