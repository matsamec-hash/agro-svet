    opacity:0;transition:opacity .15s, color .15s;
    align-self:flex-start;
  }
  .bn-source svg, .fact-source svg { color:#aaa;transition:transform .15s }
  .bn:hover .bn-source, .bn:focus-within .bn-source,
  .fact:hover .fact-source, .fact:focus-within .fact-source { opacity:1 }
  .bn-source:hover, .fact-source:hover { color:#1a1a1a }
  .bn-source:hover svg, .fact-source:hover svg { color:#1a1a1a;transform:translate(1px,-1px) }
