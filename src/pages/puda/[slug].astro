---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const items = await getCollection('puda');
  return items.map(item => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);
---

<Layout title={item.data.title} description={item.data.popis}>
  <div style="max-width:780px; margin:0 auto; padding:48px 32px 96px;">

    <div style="font-size:13px; color:#666; margin-bottom:28px;">
      <a href="/puda/" style="color:#666; text-decoration:none;">Půda</a>
      <span style="margin:0 8px;">›</span>
      <span>{item.data.title}</span>
    </div>

    <h1 style="font-size:clamp(2rem,5vw,3rem); font-weight:900; letter-spacing:-1px; line-height:1.15; color:#1a1a1a; margin-bottom:16px;">{item.data.title}</h1>
    <p style="font-size:18px; color:#555; line-height:1.65; margin-bottom:40px; padding-bottom:32px; border-bottom:1px solid #ebebeb;">{item.data.popis}</p>

    <div class="prose"><Content /></div>

    <div style="margin-top:48px;">
      <a href="/puda/" style="display:inline-flex; align-items:center; gap:8px; color:#1a1a1a; font-weight:400; font-size:14px; text-decoration:none; border:2px solid #1a1a1a; padding:10px 18px; border-radius:8px;">
        ← Zpět na půdu
      </a>
    </div>
  </div>
</Layout>

<style>
  .prose :global(h2) { font-size:1.5rem; font-weight:400; margin:2em 0 .75em; letter-spacing:-.3px; color:#1a1a1a; }
  .prose :global(h3) { font-size:1.15rem; font-weight:400; margin:1.5em 0 .5em; color:#1a1a1a; }
  .prose :global(p) { font-size:17px; line-height:1.75; color:#333; margin-bottom:1.25em; }
  .prose :global(ul), .prose :global(ol) { padding-left:1.5em; margin-bottom:1.25em; }
  .prose :global(li) { font-size:16px; line-height:1.7; color:#333; margin-bottom:.4em; }
  .prose :global(strong) { font-weight:700; color:#1a1a1a; }
  .prose :global(table) { width:100%; border-collapse:collapse; margin-bottom:1.5em; font-size:15px; }
  .prose :global(th) { background:#f5f5f5; font-weight:600; padding:10px 14px; border:1px solid #e0e0e0; text-align:left; }
  .prose :global(td) { padding:9px 14px; border:1px solid #ebebeb; }
</style>
