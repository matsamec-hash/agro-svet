---
export const prerender = false;
import Layout from '../../../layouts/Layout.astro';
import { trivia } from '../../../lib/historie';

const locale = Astro.locals.locale ?? 'cs';
const csOnly = locale !== 'cs';
Astro.response.headers.set('Cache-Control', 'public, max-age=600, s-maxage=86400, stale-while-revalidate=604800');

const eraLabel: Record<string, string> = {
  'prvni-rep': 'První republika',
  socialismus: 'Éra JZD',
  moderni: 'Dnešek',
};
// karty s porovnáním kdysi → dnes ukázat první (jsou nejnázornější)
const sorted = [...trivia].sort((a, b) => Number(Boolean(b.then && b.now)) - Number(Boolean(a.then && a.now)));
const comparisons = trivia.filter((t) => t.then && t.now).length;
---
<Layout
  title="Zajímavosti z historie českého zemědělství — rekordy a srovnání"
  description="Rekordy, kuriozity a srovnání kdysi vs. dnes z historie československého a českého zemědělství: dojivost, stavy zvířat, technika i pozemková reforma."
  canonical="/historie/zajimavosti/"
  noindex={csOnly}
  noHreflang={true}
>
  <main class="hz">
    <header class="hz-hero">
      <p class="hz-eyebrow">HISTORIE ČESKÉHO ZEMĚDĚLSTVÍ</p>
      <h1>Zajímavosti a rekordy</h1>
      <p class="hz-lede">Čísla a příběhy, které ukazují, jak se české zemědělství proměnilo od první republiky po dnešek — od pozemkové reformy přes rekordní stavy zvířat po šestinásobný růst dojivosti. Data podle ČSÚ.</p>
    </header>

    <section class="hz-grid">
      {sorted.map((t) => (
        <article class={`hz-card era-${t.era ?? 'moderni'}`}>
          {t.era && <span class="hz-tag">{eraLabel[t.era] ?? ''}</span>}
          <h2>{t.title}</h2>
          <p>{t.body}</p>
          {t.then && t.now && (
            <div class="hz-vs">
              <span class="hz-then"><span class="hz-vs-k">kdysi</span>{t.then}</span>
              <svg class="hz-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
              <span class="hz-now"><span class="hz-vs-k">dnes</span>{t.now}</span>
            </div>
          )}
        </article>
      ))}
    </section>

    <nav class="hz-more">
      <a href="/historie/data/">Zemědělství v datech →</a>
      <a href="/historie/">← Historie českého zemědělství</a>
    </nav>
  </main>
</Layout>

<style>
  .hz { max-width: 1040px; margin: 0 auto; padding: 24px 16px 64px; }

  .hz-hero { background: radial-gradient(700px 300px at 12% 0%, #16321f, transparent 60%), #0f1c14; color: #e8f3ec; border-radius: 18px; padding: 40px 32px; margin-bottom: 26px; }
  .hz-eyebrow { font-size: 12px; letter-spacing: 2px; color: #6fae86; margin: 0 0 10px; font-weight: 600; }
  .hz-hero h1 { font-size: clamp(24px, 4vw, 32px); margin: 0 0 12px; line-height: 1.1; }
  .hz-lede { color: #b9cdc0; max-width: 66ch; line-height: 1.6; margin: 0; }

  .hz-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
  .hz-card { position: relative; border: 1px solid #e2e9e4; border-left: 4px solid #1c7c48; border-radius: 12px; padding: 20px; background: #fff; transition: box-shadow .16s, transform .16s; }
  .hz-card:hover { transform: translateY(-2px); box-shadow: 0 12px 26px -16px #0f1c1455; }
  .hz-card.era-prvni-rep { border-left-color: #b8860b; }
  .hz-card.era-socialismus { border-left-color: #b23b3b; }
  .hz-card.era-moderni { border-left-color: #1c7c48; }
  .hz-tag { display: inline-block; font-size: 11px; font-weight: 700; letter-spacing: .5px; text-transform: uppercase; color: #56655c; background: #eef2ef; padding: 3px 9px; border-radius: 999px; margin-bottom: 10px; }
  .hz-card.era-prvni-rep .hz-tag { color: #8a6508; background: #f6eed6; }
  .hz-card.era-socialismus .hz-tag { color: #8f2f2f; background: #f4e4e4; }
  .hz-card h2 { font-size: 18px; margin: 0 0 8px; line-height: 1.25; }
  .hz-card p { color: #46504a; margin: 0 0 14px; line-height: 1.55; font-size: 14.5px; }

  .hz-vs { display: flex; align-items: stretch; gap: 10px; }
  .hz-then, .hz-now { flex: 1; display: flex; flex-direction: column; gap: 3px; font-weight: 700; font-size: 14px; padding: 10px 12px; border-radius: 9px; }
  .hz-then { background: #f4f2ec; color: #6b6250; }
  .hz-now { background: #e7f3ec; color: #14663a; }
  .hz-vs-k { font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; opacity: .7; }
  .hz-arrow { color: #1c7c48; align-self: center; flex: 0 0 auto; }

  .hz-more { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 12px; margin-top: 30px; padding-top: 18px; border-top: 1px solid #e6ece8; }
  .hz-more a { color: #1c7c48; font-weight: 700; text-decoration: none; font-size: 14px; }
  .hz-more a:hover { text-decoration: underline; }
</style>
