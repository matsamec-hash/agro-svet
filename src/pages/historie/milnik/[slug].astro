---
export const prerender = false;
import Layout from '../../../layouts/Layout.astro';
import { milestoneBySlug, milestones } from '../../../lib/historie';

const locale = Astro.locals.locale ?? 'cs';
const csOnly = locale !== 'cs';
const slug = Astro.params.slug!;
const m = milestoneBySlug(slug);
if (!m) return Astro.redirect('/historie/', 302);
Astro.response.headers.set('Cache-Control', 'public, max-age=600, s-maxage=86400, stale-while-revalidate=604800');

const era = (y: number) => (y < 1948 ? 'prvni-rep' : y < 1990 ? 'socialismus' : 'moderni');
const eraLabel: Record<string, string> = { 'prvni-rep': 'První republika', socialismus: 'Éra JZD', moderni: 'Po roce 1989' };
const e = era(m.year);

const idx = milestones.findIndex((x) => x.slug === slug);
const prev = idx > 0 ? milestones[idx - 1] : null;
const next = idx >= 0 && idx < milestones.length - 1 ? milestones[idx + 1] : null;
const lead = m.detail?.[0] ?? m.note;
---
<Layout
  title={`${m.year} — ${m.title} | Historie českého zemědělství`}
  description={`${m.title} (${m.year}). ${(m.detail?.[0] ?? m.note).slice(0, 150)}`}
  canonical={`/historie/milnik/${slug}/`}
  ogType="article"
  noindex={csOnly}
  noHreflang={true}
>
  <main class={`ml era-${e}`}>
    <nav class="ml-crumb"><a href="/historie/">← Historie českého zemědělství</a></nav>

    <header class="ml-hero">
      <span class="ml-eratag">{eraLabel[e]}</span>
      <div class="ml-year">{m.year}</div>
      <h1>{m.title}</h1>
      <p class="ml-lead">{lead}</p>
    </header>

    {m.data && m.data.length > 0 && (
      <section class="ml-data" aria-label="Dobová data">
        {m.data.map((d) => (
          <div class="ml-fact">
            <span class="ml-fact-v">{d.value}</span>
            <span class="ml-fact-l">{d.label}{d.source && <span class="ml-fact-src"> · {d.source}</span>}</span>
          </div>
        ))}
      </section>
    )}

    {m.detail && m.detail.length > 1 && (
      <div class="ml-body">
        {m.detail.slice(1).map((p) => <p>{p}</p>)}
      </div>
    )}

    <nav class="ml-nav">
      {prev
        ? <a class="ml-navlink" href={`/historie/milnik/${prev.slug}/`}><span class="ml-nk">← {prev.year}</span><span class="ml-nt">{prev.title}</span></a>
        : <span></span>}
      {next
        ? <a class="ml-navlink ml-navlink--next" href={`/historie/milnik/${next.slug}/`}><span class="ml-nk">{next.year} →</span><span class="ml-nt">{next.title}</span></a>
        : <span></span>}
    </nav>

    <nav class="ml-more">
      <a href="/historie/dobovy-tisk/">Dobový tisk →</a>
      <a href="/historie/technika/">Historická technika →</a>
      <a href="/historie/data/">Zemědělství v datech →</a>
    </nav>
  </main>
</Layout>

<style>
  .ml { max-width: 760px; margin: 0 auto; padding: 20px 16px 64px; --acc: #1c7c48; --accsoft: #e7f3ec; }
  .ml.era-prvni-rep { --acc: #b8860b; --accsoft: #f6eed6; }
  .ml.era-socialismus { --acc: #b23b3b; --accsoft: #f4e4e4; }
  .ml.era-moderni { --acc: #1c7c48; --accsoft: #e7f3ec; }

  .ml-crumb a { color: var(--acc); text-decoration: none; font-size: 14px; font-weight: 600; }
  .ml-crumb { margin-bottom: 16px; }

  .ml-hero { border-left: 5px solid var(--acc); padding: 4px 0 4px 20px; margin-bottom: 24px; }
  .ml-eratag { display: inline-block; font-size: 11px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: var(--acc); background: var(--accsoft); padding: 4px 10px; border-radius: 999px; margin-bottom: 12px; }
  .ml-year { font-size: clamp(40px, 9vw, 68px); font-weight: 800; line-height: .9; color: var(--acc); letter-spacing: -2px; }
  .ml-hero h1 { font-size: clamp(24px, 4.5vw, 34px); margin: 6px 0 12px; line-height: 1.1; }
  .ml-lead { font-size: 17px; line-height: 1.6; color: #2c3730; margin: 0; }

  .ml-data { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 12px; margin: 0 0 26px; }
  .ml-fact { padding: 15px 16px; border: 1px solid #e2e9e4; border-top: 3px solid var(--acc); border-radius: 10px; background: #fff; display: flex; flex-direction: column; gap: 4px; }
  .ml-fact-v { font-size: 18px; font-weight: 800; color: #0f1c14; letter-spacing: -.3px; }
  .ml-fact-l { font-size: 12.5px; color: #56655c; line-height: 1.35; }
  .ml-fact-src { color: #98a4ad; }

  .ml-body p { font-size: 16px; line-height: 1.7; color: #2c3730; margin: 0 0 16px; }

  .ml-nav { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin: 26px 0 22px; }
  .ml-navlink { display: flex; flex-direction: column; gap: 3px; padding: 14px 16px; border: 1px solid #e2e9e4; border-radius: 12px; text-decoration: none; transition: border-color .15s, box-shadow .15s; }
  .ml-navlink:hover { border-color: var(--acc); box-shadow: 0 8px 20px -14px #0f1c1455; }
  .ml-navlink--next { text-align: right; }
  .ml-nk { font-size: 13px; font-weight: 700; color: var(--acc); }
  .ml-nt { font-size: 14px; color: #2c3730; }

  .ml-more { display: flex; flex-wrap: wrap; gap: 16px; padding-top: 18px; border-top: 1px solid #e6ece8; }
  .ml-more a { color: var(--acc); font-weight: 700; text-decoration: none; font-size: 14px; }
  .ml-more a:hover { text-decoration: underline; }
</style>
