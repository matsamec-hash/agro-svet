---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const znacky = await getCollection('znacky');
const sorted = znacky.sort((a, b) => a.data.name.localeCompare(b.data.name, 'cs'));
---

<Layout title="Značky" description="Přehled světových výrobců zemědělské techniky — od Claas a John Deere po Fendt, New Holland a Zetor.">
  <div style="max-width:1280px; margin:0 auto; padding:48px 32px 80px;">

    <div style="margin-bottom:48px;">
      <span style="" class="section-label" style="">Značky</span>
      <h1 style="font-size:clamp(2rem,5vw,3.2rem); font-weight:900; letter-spacing:-1px; line-height:1.1; color:#1a1a1a; margin-bottom:16px;">
        Výrobci zemědělské techniky
      </h1>
      <p style="font-size:16px; color:#666; max-width:560px; line-height:1.6;">
        Profily světových i domácích výrobců — historie, portfolio a zastoupení v České republice.
      </p>
    </div>

    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:16px;">
      {sorted.map(znacka => (
        <a href={`/znacky/${znacka.id}/`} style="display:block; text-decoration:none; color:inherit; border:none; border-radius:14px; padding:24px; background:#fff; box-shadow:0 0 10px rgba(0,0,0,.12); transition:box-shadow .2s, transform .2s;" class="brand-card">
          <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:14px;">
            <h3 style="font-size:20px; font-weight:400; color:#1a1a1a;">{znacka.data.name}</h3>
            <span style="font-size:12px; color:#767676; white-space:nowrap;">{znacka.data.zeme}</span>
          </div>
          <p style="font-size:14px; color:#666; line-height:1.55; margin-bottom:16px; display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden;">{znacka.data.popis}</p>
          <div style="display:flex; align-items:center; justify-content:space-between;">
            <span style="font-size:12px; color:#767676;">od {znacka.data.zalozena}</span>
            <div style="display:flex; gap:4px; flex-wrap:wrap; justify-content:flex-end;">
              {znacka.data.kategorie.slice(0,2).map(k => (
                <span style="background:#f5f5f5; color:#555; font-size:11px; padding:2px 8px; border-radius:20px;">{k}</span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>

<style>
  .brand-card:hover { box-shadow:0 6px 20px rgba(0,0,0,.09); transform:translateY(-2px); }
</style>
