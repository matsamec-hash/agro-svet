---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { getCollection, getEntry, render } from 'astro:content';
import { itemListSchema } from '../../lib/structured-data';
import { getAllModels } from '../../lib/stroje';
import { TIER_LISTS, rankForTierList } from '../../lib/tier-lists';
import { useTranslations, tf, getLocaleFromUrl, localizePath } from '../../i18n/utils';

const locale = Astro.locals.locale ?? getLocaleFromUrl(Astro.url);
const tr = useTranslations(locale);
const NL = '\n';

export async function getStaticPaths() {
  const znacky = await getCollection('znacky');
  return znacky.map((z) => ({ params: { slug: z.id } }));
}

const { slug } = Astro.params;
// SK serves the localized profile from znackySk (fallback to cs if missing).
const znacka = (locale !== 'cs' ? await getEntry('znackySk', slug!) : undefined)
  ?? await getEntry('znacky', slug!);
if (!znacka) return Astro.rewrite('/404');
const { Content, headings } = await render(znacka);

const d = znacka.data as any;
const snapshot: { label: string; value: string }[] = d.snapshot ?? [];
const timeline: { year: number; label: string; detail?: string }[] = d.timeline ?? [];
const financials: { year: number; revenue?: string; netIncome?: string; note?: string }[] = d.financials ?? [];
const sources: { title: string; url: string }[] = d.sources ?? [];
const founder = d.founder as { name: string; birth?: string; death?: string; note?: string } | undefined;
const aktualizovano: Date | undefined = d.aktualizovano;
const aktualizovanoStr = aktualizovano
  ? new Intl.DateTimeFormat(locale === 'sk' ? 'sk-SK' : 'cs-CZ', { month: 'long', year: 'numeric' }).format(aktualizovano)
  : null;

// Osnova (table of contents): nadpisy z prózy (depth 2) + sekce ze šablony.
// Zlepšuje navigaci, jump-to odkazy ve vyhledávačích i orientaci pro LLM.
const toc: { text: string; slug: string }[] = [
  ...headings.filter((h) => h.depth === 2).map((h) => ({ text: h.text, slug: h.slug })),
  ...(timeline.length > 0 ? [{ text: tr('cat.zn.d.tocTimeline'), slug: 'timeline-heading' }] : []),
  ...(financials.length > 0 ? [{ text: tr('cat.zn.d.tocFinancials'), slug: 'financials-heading' }] : []),
  ...(sources.length > 0 ? [{ text: tr('cat.zn.d.tocSources'), slug: 'zdroje-heading' }] : []),
];
const hasRichProfile = toc.length >= 3;
const pageTitle = hasRichProfile ? tf(locale, 'cat.zn.d.titleSuffix', { brand: znacka.data.name }) : znacka.data.name;

const canonical = `https://agro-svet.cz${localizePath(locale, `/znacky/${znacka.id}/`)}`;
const sameAsList: string[] = [];
if ((znacka.data as any).wikipedia) sameAsList.push((znacka.data as any).wikipedia);
if ((znacka.data as any).wikidata) sameAsList.push((znacka.data as any).wikidata);
if (znacka.data.website) sameAsList.push(znacka.data.website);

const encyklopedie = await getCollection('encyklopedie');
const brandEncyclopedia = encyklopedie
  .filter((e) => e.data.znacka === znacka.id)
  .sort((a, b) => (b.data.rok_uvedeni ?? 0) - (a.data.rok_uvedeni ?? 0))
  .slice(0, 8);
const brandModels = brandEncyclopedia;

// Catalog models from stroje YAML (broader than encyklopedie). Sorted by
// power; cap at 12 for the "all models" grid.
const catalogModels = getAllModels()
  .filter((m) => m.brand_slug === znacka.id)
  .sort((a, b) => (b.power_hp ?? 0) - (a.power_hp ?? 0));
const catalogTop = catalogModels.slice(0, 12);
const catalogTraktoryCount = catalogModels.filter((m) => m.category === 'traktory').length;
const catalogKombajnyCount = catalogModels.filter((m) => m.category === 'kombajny').length;
const catalogStrojeCount = catalogModels.length - catalogTraktoryCount - catalogKombajnyCount;
// Reprodukuje původní JSX whitespace (text-node newline + collapse prázdných výrazů)
// bit-identicky; viz formule ověřená proti dist snapshotům více značek.
const catalogCountStr =
  ` ${catalogModels.length} ${tr('cat.zn.d.catalogModels')}${NL}`
  + (catalogTraktoryCount > 0 ? ` · ${catalogTraktoryCount} ${tr('cat.zn.d.catalogTraktory')}` : '') + ' '
  + (catalogKombajnyCount > 0 ? ` · ${catalogKombajnyCount} ${tr('cat.zn.d.catalogKombajny')}` : '') + ' '
  + (catalogStrojeCount > 0 ? ` · ${catalogStrojeCount} ${tr('cat.zn.d.catalogStroje')}` : '') + ' ';

// Tier-list occurrences: žebříčky kde značka figuruje v Top-12.
const tierAppearances = TIER_LISTS.flatMap((t) => {
  const ranked = rankForTierList(t);
  const hit = ranked.find((r) => r.model.brand_slug === znacka.id);
  if (!hit) return [];
  return [{ tier: t, rank: hit.rank, model: hit.model }];
}).slice(0, 6);

function modelUrl(m: { brand_slug: string; series_slug: string; slug: string }): string {
  const short = m.slug.startsWith(m.brand_slug + '-') ? m.slug.slice(m.brand_slug.length + 1) : m.slug;
  return `/stroje/${m.brand_slug}/${m.series_slug}/${short}/`;
}
function yearRange(m: { year_from: number | null; year_to: number | null }): string {
  if (!m.year_from) return '';
  if (m.year_to) return `${m.year_from}–${m.year_to}`;
  return `${m.year_from}–dosud`;
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': ['Brand', 'Organization'],
      name: znacka.data.name,
      description: znacka.data.popis,
      url: canonical,
      ...(sameAsList.length > 0 && { sameAs: sameAsList }),
      ...(znacka.data.logo && { logo: znacka.data.logo.startsWith('http') ? znacka.data.logo : `https://agro-svet.cz${znacka.data.logo}` }),
      ...(znacka.data.zalozena && { foundingDate: String(znacka.data.zalozena) }),
      ...(znacka.data.zeme && { foundingLocation: { '@type': 'Place', name: znacka.data.zeme } }),
      ...(founder && {
        founder: {
          '@type': 'Person',
          name: founder.name,
          ...(founder.birth && { birthDate: founder.birth }),
          ...(founder.death && { deathDate: founder.death }),
        },
      }),
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Domů', item: 'https://agro-svet.cz/' },
        { '@type': 'ListItem', position: 2, name: 'Značky', item: 'https://agro-svet.cz/znacky/' },
        { '@type': 'ListItem', position: 3, name: znacka.data.name, item: canonical },
      ],
    },
  ],
};
const modelListJsonLd = brandModels.length > 0
  ? itemListSchema(
      brandModels.map((e) => ({
        url: `/encyklopedie/${e.id}/`,
        name: e.data.name,
      })),
      `Modely v encyklopedii — ${znacka.data.name}`,
    )
  : null;
---

<Layout title={pageTitle} description={znacka.data.popis} canonical={canonical} ogImage={`https://agro-svet.cz/og/znacka-${znacka.id}.png`}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  {modelListJsonLd && <script type="application/ld+json" is:inline set:html={JSON.stringify(modelListJsonLd)} />}
  <div style="max-width:860px; margin:0 auto; padding:48px 32px 96px;">

    <div style="font-size:13px; color:#666; margin-bottom:28px;">
      <a href="/znacky/" style="color:#666; text-decoration:none;">{tr('cat.zn.d.bcBrands')}</a>
      <span style="margin:0 8px;">›</span>
      <span>{znacka.data.name}</span>
    </div>

    <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:24px; flex-wrap:wrap; margin-bottom:32px;">
      <div>
        <h1 style="font-size:clamp(2.4rem,6vw,3.6rem); font-weight:900; letter-spacing:-1.5px; line-height:1; color:#1a1a1a; margin-bottom:12px;">{znacka.data.name}</h1>
        <div style="display:flex; gap:10px; flex-wrap:wrap;">
          <span style="background:#FFFF00; color:#000; font-family:'Chakra Petch',sans-serif; font-size:11px; font-weight:400; padding:3px 10px; border-radius:4px;">{znacka.data.zeme}</span>
          <span style="background:#f5f5f5; color:#555; font-size:12px; padding:3px 10px; border-radius:4px;">{tf(locale, 'cat.zn.d.foundedTag', { founded: znacka.data.zalozena })}</span>
          {znacka.data.website && (
            <a href={znacka.data.website} target="_blank" rel="noopener" style="background:#f5f5f5; color:#555; font-size:12px; padding:3px 10px; border-radius:4px; text-decoration:none;">{NL}{tr('cat.zn.d.webMaker')}{NL}</a>
          )}
        </div>
      </div>
    </div>

    <p style="font-size:18px; color:#555; line-height:1.65; margin-bottom:28px;">{znacka.data.popis}</p>

    {snapshot.length > 0 && (
      <div class="snapshot-grid">
        {snapshot.map((s) => (
          <div class="snapshot-card">
            <span class="snapshot-value">{s.value}</span>
            <span class="snapshot-label">{s.label}</span>
          </div>
        ))}
      </div>
    )}

    {hasRichProfile && (
      <nav class="toc" aria-label={tr('cat.zn.d.tocAria')}>
        <span class="toc-title">{tr('cat.zn.d.toc')}</span>
        <ol class="toc-list">
          {toc.map((t) => (
            <li><a href={`#${t.slug}`}>{t.text}</a></li>
          ))}
        </ol>
      </nav>
    )}

    <div class="prose" style="margin-top:40px; padding-top:32px; border-top:1px solid #ebebeb;"><Content /></div>

    {timeline.length > 0 && (
      <section class="hub-section" aria-labelledby="timeline-heading">
        <header class="hub-section-head">
          <h2 id="timeline-heading">{tr('cat.zn.d.timeline')}</h2>
          <span class="hub-section-sub">{tr('cat.zn.d.timelineSub')}</span>
        </header>
        <ol class="timeline">
          {timeline.map((t) => (
            <li class="timeline-item">
              <span class="timeline-year">{t.year}</span>
              <div class="timeline-body">
                <strong class="timeline-label">{t.label}</strong>
                {t.detail && <span class="timeline-detail">{t.detail}</span>}
              </div>
            </li>
          ))}
        </ol>
      </section>
    )}

    {financials.length > 0 && (
      <section class="hub-section" aria-labelledby="financials-heading">
        <header class="hub-section-head">
          <h2 id="financials-heading">{tr('cat.zn.d.financials')}</h2>
          <span class="hub-section-sub">{tr('cat.zn.d.financialsSub')}</span>
        </header>
        <div class="fin-table-wrap">
          <table class="fin-table">
            <thead>
              <tr><th>{tr('cat.zn.d.thYear')}</th><th>{tr('cat.zn.d.thRevenue')}</th><th>{tr('cat.zn.d.thNetIncome')}</th></tr>
            </thead>
            <tbody>
              {financials.map((f) => (
                <tr>
                  <td>{f.year}{f.note && <span class="fin-note"> · {f.note}</span>}</td>
                  <td>{f.revenue ?? '—'}</td>
                  <td>{f.netIncome ?? '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )}

    {catalogTop.length > 0 && (
      <section class="hub-section" aria-labelledby="modely-heading">
        <header class="hub-section-head">
          <h2 id="modely-heading">{tr('cat.zn.d.catalog')}</h2>
          <span class="hub-section-sub">{catalogCountStr}</span>
        </header>
        <div class="model-grid">
          {catalogTop.map((m) => (
            <a href={modelUrl(m)} class="model-card">
              <div class="model-card-top">
                <span class="model-cat">{m.category === 'traktory' ? tr('cat.zn.d.catTagTraktor') : m.category === 'kombajny' ? tr('cat.zn.d.catTagKombajn') : tr('cat.zn.d.catTagStroj')}</span>
                {m.power_hp && <span class="model-power">{m.power_hp} k</span>}
              </div>
              <h3 class="model-name">{m.name}</h3>
              <div class="model-meta">
                <span>{m.series_name}</span>
                {yearRange(m) && <span class="model-year">{yearRange(m)}</span>}
              </div>
            </a>
          ))}
        </div>
        {catalogModels.length > catalogTop.length && (
          <a class="hub-section-more" href={`/stroje/${znacka.id}/`}>{tf(locale, 'cat.zn.d.catalogMore', { count: catalogModels.length, brand: znacka.data.name })}</a>
        )}
      </section>
    )}

    {brandEncyclopedia.length > 0 && (
      <section class="hub-section" aria-labelledby="encyklopedie-heading">
        <header class="hub-section-head">
          <h2 id="encyklopedie-heading">{tr('cat.zn.d.encyclopedia')}</h2>
          <span class="hub-section-sub">{tr('cat.zn.d.encyclopediaSub')}</span>
        </header>
        <div class="enc-grid">
          {brandEncyclopedia.map((e) => (
            <a href={`/encyklopedie/${e.id}/`} class="enc-card">
              <h3>{e.data.name}</h3>
              <p>{e.data.popis.slice(0, 140)}{e.data.popis.length > 140 ? '…' : ''}</p>
              {e.data.vykon && <span class="enc-power">{e.data.vykon}</span>}
            </a>
          ))}
        </div>
      </section>
    )}

    {tierAppearances.length > 0 && (
      <section class="hub-section" aria-labelledby="zebricky-heading">
        <header class="hub-section-head">
          <h2 id="zebricky-heading">{tf(locale, 'cat.zn.d.tiers', { brand: znacka.data.name })}</h2>
          <span class="hub-section-sub">{tr('cat.zn.d.tiersSub')}</span>
        </header>
        <div class="tier-grid">
          {tierAppearances.map((t) => (
            <a href={`/zebricky/${t.tier.slug}/`} class="tier-card">
              <span class="tier-rank">#{t.rank}</span>
              <div class="tier-body">
                <span class="tier-list-name">{t.tier.title}</span>
                <strong class="tier-model">{t.model.brand_name} {t.model.name}</strong>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {sources.length > 0 && (
      <section class="hub-section" aria-labelledby="zdroje-heading">
        <header class="hub-section-head">
          <h2 id="zdroje-heading">{tr('cat.zn.d.sources')}</h2>
        </header>
        <ol class="sources-list">
          {sources.map((s) => (
            <li><a href={s.url} target="_blank" rel="noopener nofollow">{s.title}</a></li>
          ))}
        </ol>
      </section>
    )}

    {aktualizovanoStr && (
      <p class="updated-line">{tf(locale, 'cat.zn.d.updated', { date: aktualizovanoStr! })}</p>
    )}

    <div style="margin-top:48px; display:flex; gap:10px; flex-wrap:wrap;">
      <a href="/znacky/" style="display:inline-flex; align-items:center; gap:8px; color:#1a1a1a; font-weight:400; font-size:14px; text-decoration:none; border:2px solid #1a1a1a; padding:10px 18px; border-radius:8px;">{NL}{tr('cat.zn.d.backToBrands')}{NL}</a>
      <a href={`/stroje/${znacka.id}/`} style="display:inline-flex; align-items:center; gap:8px; background:#0A0A0B; color:#FFEA00; font-weight:700; font-size:14px; text-decoration:none; padding:12px 18px; border-radius:8px;">{NL}{tf(locale, 'cat.zn.d.allModels', { brand: znacka.data.name })}{NL}</a>
      <a href={`/bazar/?znacka=${znacka.id}`} style="display:inline-flex; align-items:center; gap:8px; background:#FFEA00; color:#0A0A0B; font-weight:700; font-size:14px; text-decoration:none; padding:12px 18px; border-radius:8px;">{NL}{tr('cat.zn.d.bazarAds')}{NL}</a>
    </div>
  </div>
</Layout>

<style>
  .prose :global(h2) { font-size:1.5rem; font-weight:400; margin:2em 0 .75em; letter-spacing:-.3px; color:#1a1a1a; }
  .prose :global(h3) { font-size:1.15rem; font-weight:400; margin:1.5em 0 .5em; color:#1a1a1a; }
  .prose :global(p) { font-size:17px; line-height:1.75; color:#333; margin-bottom:1.25em; }
  .prose :global(ul), .prose :global(ol) { padding-left:1.5em; margin-bottom:1.25em; }
  .prose :global(li) { font-size:16px; line-height:1.7; color:#333; margin-bottom:.4em; }
  .prose :global(strong) { font-weight:700; color:#1a1a1a; }
  .prose :global(a) { color:#0B7A3B; text-decoration:underline; text-underline-offset:2px; }
  .prose :global(a:hover) { color:#095e2e; }

  /* Kotvy nepodběhnou sticky header */
  :global(h2[id]) { scroll-margin-top: 80px; }

  /* Osnova (table of contents) */
  .toc {
    margin-top: 28px;
    padding: 16px 20px;
    background: #fafafa;
    border: 1.5px solid #eaeaec;
    border-radius: 12px;
  }
  .toc-title {
    display: block;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: #6B6B72;
    font-weight: 700;
    margin-bottom: 8px;
  }
  .toc-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 4px 16px;
    counter-reset: toc;
  }
  .toc-list li { counter-increment: toc; }
  .toc-list a {
    display: inline-block;
    padding: 3px 0;
    font-size: 14px;
    color: #0B7A3B;
    text-decoration: none;
    line-height: 1.4;
  }
  .toc-list a::before {
    content: counter(toc) ". ";
    color: #b0b0b0;
    font-weight: 700;
  }
  .toc-list a:hover { text-decoration: underline; }

  /* Snapshot stat cards */
  .snapshot-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 10px;
    margin-bottom: 8px;
  }
  .snapshot-card {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 14px 16px;
    background: #fafafa;
    border: 1.5px solid #eaeaec;
    border-radius: 10px;
  }
  .snapshot-value { font-size: 16px; font-weight: 800; color: #0A0A0B; line-height: 1.2; }
  .snapshot-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; color: #6B6B72; font-weight: 700; }

  /* Vertical timeline */
  .timeline { list-style: none; margin: 0; padding: 0; position: relative; }
  .timeline::before {
    content: "";
    position: absolute;
    left: 7px;
    top: 6px;
    bottom: 6px;
    width: 2px;
    background: #eaeaec;
  }
  .timeline-item { position: relative; display: flex; gap: 18px; padding: 0 0 22px 0; }
  .timeline-item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 6px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #fff;
    border: 3px solid #0B7A3B;
    box-sizing: border-box;
  }
  .timeline-year {
    flex: 0 0 auto;
    margin-left: 34px;
    min-width: 54px;
    font-family: 'Chakra Petch', sans-serif;
    font-size: 18px;
    font-weight: 800;
    color: #0B7A3B;
    line-height: 1.3;
  }
  .timeline-body { display: flex; flex-direction: column; gap: 3px; }
  .timeline-label { font-size: 15px; font-weight: 700; color: #0A0A0B; line-height: 1.35; }
  .timeline-detail { font-size: 14px; color: #555; line-height: 1.6; }

  /* Financials table */
  .fin-table-wrap { overflow-x: auto; }
  .fin-table { width: 100%; border-collapse: collapse; font-size: 15px; }
  .fin-table th, .fin-table td { text-align: left; padding: 10px 14px; border-bottom: 1px solid #ebebeb; }
  .fin-table th { font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; color: #6B6B72; font-weight: 700; }
  .fin-table td { color: #333; }
  .fin-table tbody tr:hover { background: #fafafa; }
  .fin-note { font-size: 12px; color: #0B7A3B; font-weight: 700; }

  /* Sources */
  .sources-list { margin: 0; padding-left: 1.4em; }
  .sources-list li { font-size: 14px; line-height: 1.7; color: #555; margin-bottom: 4px; }
  .sources-list a { color: #0B7A3B; text-decoration: underline; text-underline-offset: 2px; }
  .sources-list a:hover { color: #095e2e; }

  .updated-line { margin-top: 28px; font-size: 13px; color: #999; font-style: italic; }

  .hub-section { margin: 48px 0 0; padding-top: 32px; border-top: 1px solid #ebebeb; }
  .hub-section-head { margin-bottom: 16px; }
  .hub-section-head h2 { font-size: 22px; font-weight: 700; color: #0A0A0B; margin: 0 0 4px; letter-spacing: -0.3px; }
  .hub-section-sub { font-size: 13px; color: #6B6B72; }
  .hub-section-more {
    display: inline-block;
    margin-top: 12px;
    font-size: 13px;
    font-weight: 700;
    color: #0B7A3B;
    text-decoration: none;
  }
  .hub-section-more:hover { text-decoration: underline; }

  .model-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 10px; }
  .model-card {
    display: block;
    padding: 14px 16px;
    background: #fff;
    border: 1.5px solid #eaeaec;
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition: border-color .15s, transform .15s;
  }
  .model-card:hover { border-color: #FFEA00; transform: translateY(-2px); }
  .model-card-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
  .model-cat { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: #6B6B72; }
  .model-power { font-size: 14px; font-weight: 800; color: #0B7A3B; font-family: 'Chakra Petch', sans-serif; }
  .model-name { font-size: 15px; font-weight: 700; color: #0A0A0B; margin: 0 0 4px; line-height: 1.2; }
  .model-meta { display: flex; justify-content: space-between; font-size: 11px; color: #6B6B72; }
  .model-year { color: #999; }

