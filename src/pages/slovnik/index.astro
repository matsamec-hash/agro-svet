---
// SSR (prerender:false): middleware servíruje /uk a /sk verzi přes locals.locale.
// Data + chrome lokalizované; cs render = dnešní literály VERBATIM (byte-identita).
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { getSlovnik, getKategorieLabels, type SlovnikKategorie } from '../../lib/slovnik';
import { breadcrumbSchema, itemListSchema } from '../../lib/structured-data';
import { SITE_URL } from '../../lib/config';
import { useTranslations, getLocaleFromUrl, tf } from '../../i18n/utils';

const locale = Astro.locals.locale ?? getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const base = locale === 'uk' ? '/uk' : locale === 'sk' ? '/sk' : '';
Astro.response.headers.set('Cache-Control', 'public, max-age=600, s-maxage=3600, stale-while-revalidate=86400');

const SLOVNIK = getSlovnik(locale);
const KATEGORIE_LABELS = getKategorieLabels(locale);
const canonical = `${SITE_URL}${base}/slovnik/`;

const byCategory = SLOVNIK.reduce((acc, t2) => {
  if (!acc[t2.kategorie]) acc[t2.kategorie] = [];
  acc[t2.kategorie].push(t2);
  return acc;
}, {} as Record<SlovnikKategorie, typeof SLOVNIK>);

for (const cat in byCategory) {
  byCategory[cat as SlovnikKategorie].sort((a, b) => a.term.localeCompare(b.term, locale));
}

const breadcrumbJsonLd = breadcrumbSchema([
  { name: t('slovnik.crumb.home'), url: `${base}/` },
  { name: t('slovnik.crumb.glossary'), url: canonical },
]);

const itemListJsonLd = itemListSchema(
  SLOVNIK.map((term) => ({ url: `${SITE_URL}${base}/slovnik/${term.slug}/`, name: term.term })),
  t('slovnik.index.collName'),
);
---

<Layout
  title={t('slovnik.index.title')}
  description={tf(locale, 'slovnik.index.desc', { n: SLOVNIK.length })}
  canonical={canonical}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(itemListJsonLd)} />

  <div class="slv-root">
    <nav class="breadcrumb" aria-label="Cesta">
      <a href={`${base}/`}>{t('slovnik.crumb.home')}</a>
      <span aria-hidden="true">›</span>
      <span class="current">{t('slovnik.crumb.glossary')}</span>
    </nav>

    <header class="slv-head">
      <span class="kicker">{tf(locale, 'slovnik.index.kicker', { n: SLOVNIK.length })}</span>
      <h1>{t('slovnik.index.h1')}</h1>
      <p class="lede">
        {t('slovnik.index.lede')}
      </p>
    </header>

    {Object.entries(byCategory).map(([cat, terms]) => (
      <section class="slv-cat">
        <h2>{KATEGORIE_LABELS[cat as SlovnikKategorie]}</h2>
        <div class="slv-grid">
          {terms.map((term) => (
            <a href={`${base}/slovnik/${term.slug}/`} class="slv-card">
              <h3>{term.term}</h3>
              {term.alias && term.alias.length > 0 && <span class="slv-alias">{term.alias.slice(0, 2).join(' · ')}</span>}
              <p>{term.shortDef.slice(0, 140)}{term.shortDef.length > 140 ? '…' : ''}</p>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</Layout>

<style>
  .slv-root { max-width: 1080px; margin: 0 auto; padding: 32px 24px 80px; }
  .breadcrumb { display: flex; gap: 8px; align-items: center; font-size: 13px; color: #666; margin-bottom: 20px; }
  .breadcrumb a { color: #666; text-decoration: none; }
  .breadcrumb a:hover { color: #000; }
  .breadcrumb .current { color: #000; font-weight: 600; }
  .slv-head { margin-bottom: 36px; max-width: 720px; }
  .kicker { display: inline-block; background: #FFEA00; color: #0A0A0B; font-size: 12px; font-weight: 700; padding: 4px 12px; border-radius: 4px; text-transform: uppercase; letter-spacing: 1px; }
  h1 { font-size: clamp(2rem, 5vw, 3rem); font-weight: 800; letter-spacing: -1px; line-height: 1.1; margin: 12px 0 12px; color: #1a1a1a; }
  .lede { font-size: 16px; color: #666; line-height: 1.6; margin: 0; }
  .slv-cat { margin-bottom: 36px; }
  .slv-cat h2 { font-size: 22px; font-weight: 700; color: #0A0A0B; margin: 0 0 16px; padding-bottom: 8px; border-bottom: 2px solid #FFEA00; }
  .slv-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 12px; }
  .slv-card {
    display: block;
    padding: 16px 18px;
    background: #fff;
    border: 1.5px solid #eaeaec;
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition: border-color .15s, transform .15s;
  }
  .slv-card:hover { border-color: #FFEA00; transform: translateY(-2px); }
  .slv-card h3 { font-size: 16px; font-weight: 700; color: #0A0A0B; margin: 0 0 4px; }
  .slv-alias { display: block; font-size: 11px; color: #6B6B72; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; font-weight: 600; }
  .slv-card p { font-size: 13px; color: #555; line-height: 1.5; margin: 4px 0 0; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
</style>
