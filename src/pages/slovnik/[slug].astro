---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { getSlovnik, getSlovnikTerm, getKategorieLabels } from '../../lib/slovnik';
import { breadcrumbSchema, faqPageSchema } from '../../lib/structured-data';
import { SITE_URL } from '../../lib/config';
import AreaConverter from '../../components/AreaConverter.astro';
import WeightConverter from '../../components/WeightConverter.astro';
import { injectLinks, createLinkContext } from '../../lib/auto-linker';
import { useTranslations, getLocaleFromUrl, tf } from '../../i18n/utils';

const locale = Astro.locals.locale ?? getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const base = locale === 'cs' ? '' : `/${locale}`;
Astro.response.headers.set('Cache-Control', 'public, max-age=600, s-maxage=3600, stale-while-revalidate=86400');

const { slug } = Astro.params;
const term = getSlovnikTerm(slug!, locale);
if (!term) return Astro.rewrite('/404');

const SLOVNIK = getSlovnik(locale);
const KATEGORIE_LABELS = getKategorieLabels(locale);
const pageUrl = `${SITE_URL}${base}/slovnik/${term.slug}/`;
const relatedTerms = (term.related ?? [])
  .map((s) => getSlovnikTerm(s, locale))
  .filter((rt): rt is NonNullable<typeof rt> => !!rt);

// Mapování slovnik slug → výchozí jednotka pro inline AreaConverter.
// Jen slugy v této mapě dostanou widget (jen jednotky plochy).
const AREA_UNIT_BY_SLUG: Record<string, string> = {
  hektar: 'ha',
  ar: 'a',
  'metr-ctvrecni': 'm2',
  'kilometr-ctvrecni': 'km2',
  akr: 'acre',
  jitro: 'jitro',
  korec: 'korec',
  strych: 'strych',
  morgen: 'morgen',
};
const areaUnit = AREA_UNIT_BY_SLUG[term.slug];

// Mapování pro WeightConverter — slovnik slug → výchozí jednotka hmotnosti.
const WEIGHT_UNIT_BY_SLUG: Record<string, string> = {
  'q-cent': 'q',
  tuna: 't',
  kilogram: 'kg',
  libra: 'lb',
  busl: 'bu',
  hektolitr: 'kg',
};
const weightUnit = WEIGHT_UNIT_BY_SLUG[term.slug];

const breadcrumbJsonLd = breadcrumbSchema([
  { name: t('slovnik.crumb.home'), url: `${base}/` },
  { name: t('slovnik.crumb.glossary'), url: `${base}/slovnik/` },
  { name: term.term, url: pageUrl },
]);

// DefinedTerm schema — Google sometimes uses this for definition snippets
// in AI Overviews / featured snippets.
const definedTermJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTerm',
  name: term.term,
  description: term.shortDef,
  inDefinedTermSet: {
    '@type': 'DefinedTermSet',
    name: t('slovnik.detail.definedTermSet'),
    url: `${SITE_URL}${base}/slovnik/`,
  },
  url: pageUrl,
  ...(term.alias && term.alias.length > 0 ? { alternateName: term.alias } : {}),
};

// FAQPage schema — pomáhá k rich snippetům / AI Overviews u definičních dotazů.
const faqJsonLd = term.faq && term.faq.length > 0 ? faqPageSchema(term.faq) : null;

// Build slug → display name lookup for wikilink resolution.
const SLOVNIK_BY_SLUG = new Map(SLOVNIK.map((tt) => [tt.slug, tt.term]));

// Render pipeline pro každý paragraph:
// 1. `[[slug]]` wikilinks → <a href="/slovnik/slug/">{term.term}</a>
//    (pokud slug existuje v SLOVNIK; jinak zachová literal)
// 2. `**bold**` → <strong>
// 3. auto-linker — značky/modely/plemena/další slovník hesla
//    (sdílený ctx = unikátní link na URL napříč celým article)
const linkCtx = createLinkContext(pageUrl);

const renderedParagraphs = term.longDef.split('\n\n').map((para) => {
  // Wikilinks first — pre-resolved <a> tags se ochrání před auto-linkerem
  // (PROTECTED_TAGS zahrnuje 'a').
  const withWikilinks = para.replace(/\[\[([a-z0-9-]+)\]\]/gi, (m, s) => {
    const name = SLOVNIK_BY_SLUG.get(s);
    if (!name) return m; // unknown slug — leave literal
    return `<a href="${base}/slovnik/${s}/">${name}</a>`;
  });
  const withBold = withWikilinks.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
  // CS-only auto-linker: injektovat CS značky/modely/slovník odkazy jen do CS textu.
  // Pro uk/sk by to vložilo CS entity do přeloženého textu — vynecháno.
  return locale === 'cs' ? injectLinks(withBold, linkCtx) : withBold;
});
---

<Layout
  title={`${term.term}${t('slovnik.detail.titleSuffix')}`}
  description={term.shortDef}
  canonical={pageUrl}
  ogType="article"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(definedTermJsonLd)} />
  {faqJsonLd && <script type="application/ld+json" is:inline set:html={JSON.stringify(faqJsonLd)} />}

  <article class="slv-detail-root">
    <nav class="breadcrumb" aria-label="Cesta">
      <a href={`${base}/`}>{t('slovnik.crumb.home')}</a>
      <span aria-hidden="true">›</span>
      <a href={`${base}/slovnik/`}>{t('slovnik.crumb.glossary')}</a>
      <span aria-hidden="true">›</span>
      <span class="current">{term.term}</span>
    </nav>

    <header class="slv-d-head">
      <span class="kicker">{KATEGORIE_LABELS[term.kategorie]}</span>
      <h1>{term.term}</h1>
      {term.alias && term.alias.length > 0 && (
        <div class="slv-d-alias">{t('slovnik.detail.also')} {term.alias.map((a) => <span>{a}</span>).reduce((acc, el, i) => i === 0 ? [el] : [...acc, <>, </>, el], [] as any[])}</div>
      )}
      <p class="slv-d-short"><strong>{term.shortDef}</strong></p>
    </header>

    {areaUnit && (
      <AreaConverter
        defaultUnit={areaUnit}
        defaultValue={1}
        heading={tf(locale, 'slovnik.detail.areaHeading', { term: term.term })}
        caption={t('slovnik.detail.areaCaption')}
      />
    )}

    {weightUnit && (
      <WeightConverter
        defaultUnit={weightUnit}
        defaultValue={1}
        heading={tf(locale, 'slovnik.detail.weightHeading', { term: term.term })}
        caption={t('slovnik.detail.weightCaption')}
      />
    )}

    <div class="slv-d-body prose">
      {renderedParagraphs.map((html) => (
        <p set:html={html}></p>
      ))}
    </div>

    {term.zajimavosti && term.zajimavosti.length > 0 && (
      <section class="slv-d-zaj">
        <h2>{t('slovnik.detail.zajimavosti')}</h2>
        <ul>
          {term.zajimavosti.map((z) => <li>{z}</li>)}
        </ul>
      </section>
    )}

    {term.faq && term.faq.length > 0 && (
      <section class="slv-d-faq">
        <h2>{t('slovnik.detail.faq')}</h2>
        {term.faq.map((f) => (
          <details class="slv-d-faq-item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </section>
    )}

    {term.externalUrl && (
      <div class="slv-d-external">
        <strong>{t('slovnik.detail.external')}</strong>{' '}
        <a href={term.externalUrl} rel="external nofollow noopener" target="_blank">
          {term.externalLabel ?? term.externalUrl}
        </a>
      </div>
    )}

    {relatedTerms.length > 0 && (
      <section class="slv-d-related">
        <h2>{t('slovnik.detail.related')}</h2>
        <div class="slv-d-rel-grid">
          {relatedTerms.map((rt) => (
            <a href={`${base}/slovnik/${rt.slug}/`} class="slv-d-rel-card">
              <h3>{rt.term}</h3>
              <p>{rt.shortDef.slice(0, 100)}{rt.shortDef.length > 100 ? '…' : ''}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <a class="slv-d-back" href={`${base}/slovnik/`}>{t('slovnik.detail.back')}</a>
  </article>
</Layout>

<style>
  .slv-detail-root { max-width: 720px; margin: 0 auto; padding: 32px 24px 80px; }
  .breadcrumb { display: flex; gap: 8px; align-items: center; font-size: 13px; color: #666; margin-bottom: 20px; flex-wrap: wrap; }
  .breadcrumb a { color: #666; text-decoration: none; }
  .breadcrumb a:hover { color: #000; }
  .breadcrumb .current { color: #000; font-weight: 600; }

  .slv-d-head { margin-bottom: 28px; padding-bottom: 24px; border-bottom: 1px solid #eaeaec; }
  .kicker { display: inline-block; background: #FFEA00; color: #0A0A0B; font-size: 12px; font-weight: 700; padding: 4px 12px; border-radius: 4px; text-transform: uppercase; letter-spacing: 1px; }
  h1 { font-size: clamp(2rem, 5vw, 2.8rem); font-weight: 800; letter-spacing: -1px; margin: 12px 0 8px; line-height: 1.15; color: #1a1a1a; }
  .slv-d-alias { font-size: 13px; color: #6B6B72; margin-bottom: 14px; }
  .slv-d-alias span { color: #444; font-weight: 500; }
  .slv-d-short { font-size: 17px; line-height: 1.6; color: #0A0A0B; margin: 12px 0 0; padding: 14px 16px; background: #fffef8; border-left: 3px solid #FFEA00; border-radius: 0 6px 6px 0; }

  .slv-d-body { font-size: 16px; line-height: 1.75; color: #333; }
  .slv-d-body p { margin: 0 0 16px; }
  .slv-d-body strong { color: #0A0A0B; }
  .slv-d-body a { color: #0A0A0B; text-decoration: underline; text-decoration-color: #FFEA00; text-decoration-thickness: 2px; text-underline-offset: 3px; transition: background .15s; }
  .slv-d-body a:hover { background: #FFEA00; }
  .slv-d-body a.auto-link { text-decoration-color: #EAEAEC; text-decoration-style: dotted; }
  .slv-d-body a.auto-link:hover { background: #FFEA00; text-decoration-color: #0A0A0B; }
  .slv-d-body a.auto-link-external::after { content: " ↗"; font-size: 0.85em; opacity: 0.55; }

  .slv-d-zaj { margin: 32px 0 8px; }
  .slv-d-zaj h2 { font-size: 20px; font-weight: 700; color: #0A0A0B; margin: 0 0 12px; }
  .slv-d-zaj ul { margin: 0; padding-left: 20px; }
  .slv-d-zaj li { font-size: 16px; line-height: 1.7; color: #333; margin: 0 0 8px; }

  .slv-d-faq { margin: 32px 0 8px; }
  .slv-d-faq h2 { font-size: 20px; font-weight: 700; color: #0A0A0B; margin: 0 0 12px; }
  .slv-d-faq-item {
    border: 1.5px solid #eaeaec;
    border-radius: 8px;
    padding: 12px 16px;
    margin: 0 0 10px;
    background: #fff;
  }
  .slv-d-faq-item summary { font-weight: 600; color: #0A0A0B; cursor: pointer; font-size: 15px; }
  .slv-d-faq-item p { margin: 10px 0 0; font-size: 15px; line-height: 1.7; color: #333; }

  .slv-d-external {
    margin: 24px 0;
    padding: 12px 16px;
    background: #f5f5f7;
    border-radius: 8px;
    font-size: 14px;
  }
  .slv-d-external a { color: #0B7A3B; text-decoration: underline; }

  .slv-d-related { margin: 40px 0 24px; }
  .slv-d-related h2 { font-size: 20px; font-weight: 700; color: #0A0A0B; margin: 0 0 16px; }
  .slv-d-rel-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 10px; }
  .slv-d-rel-card {
    display: block;
    padding: 14px 16px;
    background: #fff;
    border: 1.5px solid #eaeaec;
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: border-color .15s;
  }
  .slv-d-rel-card:hover { border-color: #FFEA00; }
  .slv-d-rel-card h3 { font-size: 14px; font-weight: 700; color: #0A0A0B; margin: 0 0 4px; }
  .slv-d-rel-card p { font-size: 12px; color: #666; line-height: 1.5; margin: 0; }

  .slv-d-back { display: inline-block; font-size: 13px; color: #666; text-decoration: none; font-weight: 600; }
  .slv-d-back:hover { color: #0A0A0B; }
</style>
