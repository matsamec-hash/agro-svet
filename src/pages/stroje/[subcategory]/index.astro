---
// Prerendered cs verze listingu kategorie. Non-cs (/sk /uk /pl) jde přes [brand]
// rewrite na /_subcat (SSR) — /stroje/[subcategory] koliduje s /stroje/[brand],
// takže pod locale prefixem by 404-lo. Sdílená logika v SubcategoryListing.astro.
export const prerender = true;
import SubcategoryListing from '../../../components/stroje/SubcategoryListing.astro';
import { FUNCTIONAL_GROUPS, type StrojKategorie } from '../../../lib/stroje';

export async function getStaticPaths() {
  const allCats = Object.values(FUNCTIONAL_GROUPS).flatMap((g) => g.categories);
  return allCats.map((cat) => ({ params: { subcategory: cat } }));
}
const { subcategory } = Astro.params;
---
<SubcategoryListing subcat={subcategory as StrojKategorie} locale="cs" />
