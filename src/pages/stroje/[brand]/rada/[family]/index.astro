---
export const prerender = true;
import Layout from '../../../../../layouts/Layout.astro';
import { getAllBrands, getBrand, seriesFamily, familyLabel, type StrojKategorie } from '../../../../../lib/stroje';

export async function getStaticPaths() {
  const paths: { params: { brand: string; family: string } }[] = [];
  for (const b of getAllBrands()) {
    const families = new Set<string>();
    for (const cat of Object.values(b.categories ?? {})) {
      for (const s of cat.series ?? []) families.add(seriesFamily(s.slug));
    }
    for (const f of families) paths.push({ params: { brand: b.slug, family: f } });
  }
  return paths;
}

const { brand: brandSlug, family } = Astro.params;
const brand = getBrand(brandSlug!);
if (!brand) return Astro.redirect('/stroje/');

const categoryLabels: Record<StrojKategorie, string> = {
  traktory: 'Traktory',
  kombajny: 'Kombajny',
};

// Filter series into this family per category
type Row = {
  slug: string;
  name: string;
  series_slug: string;
  series_name: string;
  series_description?: string;
  series_year_from: number | null;
  series_year_to: number | null;
  year_from: number | null;
  year_to: number | null;
  power_hp: number | null;
  power_kw: number | null;
  urlSlug: string;
};

type Section = {
  catSlug: StrojKategorie;
  catName: string;
  rows: Row[];
  series: Array<{ slug: string; name: string; description?: string; year_from: number | null; year_to: number | null; models: Row[] }>;
};

const sections: Section[] = [];
for (const [catKey, cat] of Object.entries(brand.categories ?? {}) as [StrojKategorie, any][]) {
  const matchingSeries = (cat.series ?? []).filter((s: any) => seriesFamily(s.slug) === family);
  if (matchingSeries.length === 0) continue;
  const rows: Row[] = [];
  const series: Section['series'] = [];
  for (const s of matchingSeries) {
    const seriesRows: Row[] = [];
    for (const m of s.models ?? []) {
      const urlSlug = m.slug.startsWith(brand.slug + '-') ? m.slug.slice(brand.slug.length + 1) : m.slug;
      const row: Row = {
        slug: m.slug,
        name: m.name,
        series_slug: s.slug,
        series_name: s.name,
        series_description: s.description,
        series_year_from: s.year_from ?? null,
        series_year_to: s.year_to ?? null,
        year_from: m.year_from,
        year_to: m.year_to,
        power_hp: m.power_hp,
        power_kw: m.power_kw,
        urlSlug,
      };
      rows.push(row);
      seriesRows.push(row);
    }
    series.push({
      slug: s.slug,
      name: s.name,
      description: s.description,
      year_from: s.year_from ?? null,
      year_to: s.year_to ?? null,
      models: seriesRows.sort((a, b) => (b.power_hp ?? 0) - (a.power_hp ?? 0)),
    });
  }
  sections.push({
    catSlug: catKey,
    catName: categoryLabels[catKey] ?? cat.name,
    rows,
    series,
  });
}

if (sections.length === 0) return Astro.redirect(`/stroje/${brand.slug}/`);

const label = familyLabel(family!);
const totalModels = sections.reduce((acc, s) => acc + s.rows.length, 0);
const allHp = sections.flatMap((s) => s.rows.map((r) => r.power_hp)).filter((x): x is number => x !== null);
const allYearsFrom = sections.flatMap((s) => s.rows.map((r) => r.year_from)).filter((x): x is number => x !== null);
const allYearsTo = sections.flatMap((s) => s.rows.map((r) => r.year_to));
const hasCurrentProduction = allYearsTo.some((y) => y === null);
const minHp = allHp.length ? Math.min(...allHp) : null;
const maxHp = allHp.length ? Math.max(...allHp) : null;
const minYear = allYearsFrom.length ? Math.min(...allYearsFrom) : null;
const maxYear = !hasCurrentProduction && allYearsTo.length
  ? Math.max(...(allYearsTo.filter((y): y is number => y !== null)))
  : null;
---

<Layout
  title={`${brand.name} ${label} — všechny modely`}
  description={`Všechny modely řady ${brand.name} ${label}. ${totalModels} modelů, výkon ${minHp}–${maxHp} k.`}
>
  <div style="max-width:1280px; margin:0 auto; padding:48px 32px 80px;">
    <div style="margin-bottom:8px; font-size:13px; color:#666;">
      <a href="/stroje/" style="color:#666; text-decoration:none;">Katalog</a>
      <span style="margin:0 6px;">/</span>
      <a href={`/stroje/${brand.slug}/`} style="color:#666; text-decoration:none;">{brand.name}</a>
      <span style="margin:0 6px;">/</span>
      <span style="color:#1a1a1a;">{label}</span>
    </div>

    <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:24px; flex-wrap:wrap; margin-bottom:32px; padding-bottom:24px; border-bottom:1px solid #e8e8e8;">
      <div>
        <span style="background:#FFFF00; color:#000; font-family:'Chakra Petch',sans-serif; font-size:11px; padding:3px 8px; border-radius:3px; text-transform:uppercase; letter-spacing:1px;">
          {brand.name}
        </span>
        <h1 style="font-family:'Chakra Petch',sans-serif; font-size:clamp(2rem,5vw,3rem); font-weight:700; letter-spacing:-1px; color:#1a1a1a; margin-top:10px; margin-bottom:14px;">
          {label}
        </h1>
        <div style="display:flex; gap:16px; flex-wrap:wrap; font-size:14px; color:#666;">
          <span>🔢 {totalModels} modelů</span>
          {minHp !== null && maxHp !== null && (
            <span>⚡ {minHp === maxHp ? `${minHp} k` : `${minHp}–${maxHp} k`}</span>
          )}
          {minYear !== null && (
            <span>📅 {hasCurrentProduction ? `${minYear}–dosud` : (maxYear ? `${minYear}–${maxYear}` : `${minYear}`)}</span>
          )}
        </div>
      </div>
      <a href={`/bazar/?brand=${encodeURIComponent(brand.slug)}&q=${encodeURIComponent(label)}`} style="background:#FFFF00; color:#000; padding:12px 20px; border-radius:10px; text-decoration:none; font-family:'Chakra Petch',sans-serif; font-weight:700; font-size:14px; white-space:nowrap;">
        Hledat v bazaru →
      </a>
    </div>

    {sections.map((sec) => (
      <section style="margin-bottom:48px;">
        {sections.length > 1 && (
          <h2 style="font-family:'Chakra Petch',sans-serif; font-size:22px; font-weight:700; color:#1a1a1a; margin-bottom:20px;">
            {sec.catName}
          </h2>
        )}

        {sec.series.map((s) => {
          const yr = s.year_from
            ? (s.year_to ? `${s.year_from}–${s.year_to}` : `${s.year_from}–dosud`)
            : '';
          return (
            <div style="margin-bottom:32px;">
              <div style="display:flex; justify-content:space-between; align-items:baseline; gap:12px; margin-bottom:10px; flex-wrap:wrap;">
                <h3 style="font-family:'Chakra Petch',sans-serif; font-size:18px; font-weight:700; color:#1a1a1a;">
                  {s.name}
                </h3>
                <span style="font-size:12px; color:#888;">{s.models.length} modelů · {yr}</span>
              </div>
              {s.description && <p style="font-size:14px; color:#666; line-height:1.55; margin-bottom:12px; max-width:820px;">{s.description}</p>}

              <div style="border:1px solid #e8e8e8; border-radius:14px; overflow:hidden; background:#fff;">
                <table style="width:100%; border-collapse:collapse; font-size:14px;">
                  <thead>
                    <tr style="background:#fafafa;">
                      <th style="text-align:left; padding:10px 14px; font-family:'Chakra Petch',sans-serif; font-size:11px; letter-spacing:.05em; text-transform:uppercase; color:#666; border-bottom:1px solid #e8e8e8;">Model</th>
                      <th style="text-align:left; padding:10px 14px; font-family:'Chakra Petch',sans-serif; font-size:11px; letter-spacing:.05em; text-transform:uppercase; color:#666; border-bottom:1px solid #e8e8e8;">Rok výroby</th>
                      <th style="text-align:left; padding:10px 14px; font-family:'Chakra Petch',sans-serif; font-size:11px; letter-spacing:.05em; text-transform:uppercase; color:#666; border-bottom:1px solid #e8e8e8;">Výkon</th>
                      <th style="padding:10px 14px; border-bottom:1px solid #e8e8e8;"></th>
                    </tr>
                  </thead>
                  <tbody>
                    {s.models.map((m, idx) => {
                      const myr = m.year_from ? (m.year_to ? `${m.year_from}–${m.year_to}` : `${m.year_from}–dosud`) : '—';
                      return (
                        <tr style={`border-bottom:${idx < s.models.length - 1 ? '1px solid #f2f2f2' : 'none'};`} class="hover-row">
                          <td style="padding:12px 14px;">
                            <a href={`/stroje/${brand.slug}/${s.slug}/${m.urlSlug}/`} style="font-family:'Chakra Petch',sans-serif; font-weight:700; color:#1a1a1a; text-decoration:none;">
                              {m.name}
                            </a>
                          </td>
                          <td style="padding:12px 14px; color:#666;">{myr}</td>
                          <td style="padding:12px 14px;">
                            {m.power_hp ? (
                              <>
                                <strong>{m.power_hp} k</strong>
                                {m.power_kw && <span style="color:#888; font-size:12px;"> ({m.power_kw} kW)</span>}
                              </>
                            ) : '—'}
                          </td>
                          <td style="padding:12px 14px; text-align:right;">
                            <a href={`/stroje/${brand.slug}/${s.slug}/${m.urlSlug}/`} style="font-size:12px; color:#1a1a1a; text-decoration:none; border:1px solid #ddd; padding:5px 10px; border-radius:6px;">Detail →</a>
                          </td>
                        </tr>
                      );
                    })}
                  </tbody>
                </table>
              </div>
            </div>
          );
        })}
      </section>
    ))}
  </div>

  <style>
    .hover-row:hover { background: #fcfcfc; }
  </style>
</Layout>
