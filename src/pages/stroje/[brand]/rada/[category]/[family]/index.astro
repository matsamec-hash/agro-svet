---
export const prerender = true;
import Layout from '../../../../../../layouts/Layout.astro';
import { getAllBrands, getBrand, seriesFamily, familyLabel, type StrojKategorie } from '../../../../../../lib/stroje';

export async function getStaticPaths() {
  const paths: { params: { brand: string; category: string; family: string } }[] = [];
  for (const b of getAllBrands()) {
    for (const [catKey, cat] of Object.entries(b.categories ?? {})) {
      const families = new Set<string>();
      for (const s of cat.series ?? []) {
        const fam = (s as any).family ?? seriesFamily(s.slug);
        families.add(String(fam));
      }
      for (const f of families) {
        paths.push({ params: { brand: b.slug, category: catKey, family: f } });
      }
    }
  }
  return paths;
}

const { brand: brandSlug, category: categorySlug, family } = Astro.params;
const brand = getBrand(brandSlug!);
if (!brand) return Astro.redirect('/stroje/');

const categoryLabels: Record<StrojKategorie, string> = {
  traktory: 'Traktory',
  kombajny: 'Kombajny',
};
const categoryHero: Record<StrojKategorie, string> = {
  traktory: '/images/traktor.webp',
  kombajny: '/images/kombajn.webp',
};
const catLabel = categoryLabels[categorySlug as StrojKategorie] ?? categorySlug;
const catHeroFallback = categoryHero[categorySlug as StrojKategorie] ?? '/images/traktor.webp';

const cat = brand.categories?.[categorySlug as StrojKategorie];
if (!cat) return Astro.redirect(`/stroje/${brand.slug}/`);

const matchingSeries = (cat.series ?? []).filter((s: any) => (s.family || seriesFamily(s.slug)) === family);
if (matchingSeries.length === 0) return Astro.redirect(`/stroje/${brand.slug}/`);

const brandColors: Record<string, [string, string]> = {
  'john-deere': ['#4A9838', '#2E6B22'],
  fendt: ['#3FA85D', '#0E6730'],
  claas: ['#9C9532', '#65601A'],
  'deutz-fahr': ['#2BA84A', '#1a5e2a'],
  kubota: ['#FF6B1A', '#C24414'],
  'new-holland': ['#3874AC', '#1A4370'],
  'case-ih': ['#D62A2A', '#8F1818'],
  'massey-ferguson': ['#D62A2A', '#8F1818'],
  valtra: ['#1F1F1F', '#0A0A0A'],
  zetor: ['#E93A3A', '#A01818'],
};
const [brandC1, brandC2] = brandColors[brand.slug] ?? ['#2a2a30', '#0a0a0b'];

type Row = {
  slug: string;
  name: string;
  year_from: number | null;
  year_to: number | null;
  power_hp: number | null;
  power_kw: number | null;
  urlSlug: string;
  isCurrent: boolean;
};

const seriesData = matchingSeries.map((s: any) => {
  const rows: Row[] = (s.models ?? []).map((m: any) => {
    const urlSlug = m.slug.startsWith(brand.slug + '-') ? m.slug.slice(brand.slug.length + 1) : m.slug;
    return {
      slug: m.slug,
      name: m.name,
      year_from: m.year_from,
      year_to: m.year_to,
      power_hp: m.power_hp,
      power_kw: m.power_kw,
      urlSlug,
      isCurrent: m.year_to === null && m.year_from !== null,
    };
  });
  rows.sort((a, b) => (b.power_hp ?? 0) - (a.power_hp ?? 0));
  const seriesIsCurrent = rows.some((r) => r.isCurrent);
  return {
    slug: s.slug,
    name: s.name,
    description: s.description,
    image_url: s.image_url ?? null,
    year_from: s.year_from ?? null,
    year_to: s.year_to ?? null,
    isCurrent: seriesIsCurrent,
    models: rows,
  };
});

// Sort series newest-first (current generations on top)
seriesData.sort((a, b) => {
  if (a.isCurrent !== b.isCurrent) return a.isCurrent ? -1 : 1;
  return (b.year_from ?? 0) - (a.year_from ?? 0);
});

const label = familyLabel(family!);
const totalModels = seriesData.reduce((acc, s) => acc + s.models.length, 0);
const allHp = seriesData.flatMap((s) => s.models.map((r) => r.power_hp)).filter((x): x is number => x !== null);
const allYearsFrom = seriesData.flatMap((s) => s.models.map((r) => r.year_from)).filter((x): x is number => x !== null);
const allYearsTo = seriesData.flatMap((s) => s.models.map((r) => r.year_to));
const hasCurrent = allYearsTo.some((y) => y === null);
const minHp = allHp.length ? Math.min(...allHp) : null;
const maxHp = allHp.length ? Math.max(...allHp) : null;
const minYear = allYearsFrom.length ? Math.min(...allYearsFrom) : null;
const maxYear = !hasCurrent && allYearsTo.length
  ? Math.max(...(allYearsTo.filter((y): y is number => y !== null)))
  : null;
const yearLine = minYear !== null
  ? (hasCurrent ? `${minYear}–dosud` : (maxYear ? `${minYear}–${maxYear}` : `${minYear}`))
  : '';
const hpLine = minHp !== null && maxHp !== null
  ? (minHp === maxHp ? `${minHp} k` : `${minHp}–${maxHp} k`)
  : '';

// Pick hero photo: first current series with image_url, else any series with image_url, else category fallback
let heroPhoto: string | null = null;
let heroCreditUrl: string | null = null;
let heroCreditAuthor: string | null = null;
let heroCreditLicense: string | null = null;
function setHeroFrom(s: any) {
  heroPhoto = s.image_url;
  heroCreditUrl = (s as any).image_credit_url || null;
  heroCreditAuthor = (s as any).image_credit || null;
  heroCreditLicense = (s as any).image_license || null;
}
for (const s of matchingSeries) if ((s as any).image_url && (s.year_to === null || (s.models ?? []).some((m: any) => m.year_to === null))) { setHeroFrom(s); break; }
if (!heroPhoto) for (const s of matchingSeries) if ((s as any).image_url) { setHeroFrom(s); break; }
if (!heroPhoto) heroPhoto = catHeroFallback;

const lede = seriesData.find((s) => s.description)?.description?.trim() ?? '';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Domů', item: 'https://agro-svet.cz/' },
    { '@type': 'ListItem', position: 2, name: 'Technika', item: 'https://agro-svet.cz/stroje/' },
    { '@type': 'ListItem', position: 3, name: brand.name, item: `https://agro-svet.cz/stroje/${brand.slug}/` },
    { '@type': 'ListItem', position: 4, name: catLabel, item: `https://agro-svet.cz/stroje/${categorySlug}/` },
    { '@type': 'ListItem', position: 5, name: label, item: `https://agro-svet.cz/stroje/${brand.slug}/rada/${categorySlug}/${family}/` },
  ],
};
---

<Layout
  title={`${brand.name} ${label} ${catLabel.toLowerCase()} — všechny modely`}
  description={`Všechny ${catLabel.toLowerCase()} řady ${brand.name} ${label}. ${totalModels} modelů${hpLine ? `, výkon ${hpLine}` : ''}${yearLine ? `, ${yearLine}` : ''}.`}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  <div class="rada-page">

    <nav class="breadcrumb" aria-label="Cesta">
      <a href="/">Domů</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/stroje/">Technika</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <a href={`/stroje/${brand.slug}/`}>{brand.name}</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <a href={`/stroje/${categorySlug}/`}>{catLabel}</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <span class="current">{label}</span>
    </nav>

    <section class="hero" style={`--brand-c1:${brandC1};--brand-c2:${brandC2};`}>
      <div class="hero-left">
        <div class="hero-tags">
          <span class="tag tag-brand">{brand.name}</span>
          <span class="tag tag-cat">{catLabel}</span>
          {hasCurrent && <span class="tag tag-current"><span class="dot"></span>Aktuální v prodeji</span>}
        </div>
        <h1>{label}</h1>
        {lede && <p class="hero-lede">{lede}</p>}

        <div class="hero-stats">
          <div class="s"><span class="n">{totalModels}</span><span class="l">modelů</span></div>
          <div class="s"><span class="n">{seriesData.length}</span><span class="l">{seriesData.length === 1 ? 'generace' : seriesData.length < 5 ? 'generace' : 'generací'}</span></div>
          {hpLine && <div class="s"><span class="n">{hpLine}</span><span class="l">výkon</span></div>}
          {yearLine && <div class="s"><span class="n">{yearLine}</span><span class="l">období</span></div>}
        </div>

        <div class="hero-actions">
          <a class="cta-primary" href={`/bazar/?brand=${encodeURIComponent(brand.slug)}&category=${categorySlug}&q=${encodeURIComponent(label)}`}>
            Hledat {label} v bazaru
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a class="cta-secondary" href={`/stroje/${brand.slug}/`}>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
            Vše o {brand.name}
          </a>
        </div>
      </div>

      <div class="hero-right">
        <div class="hero-photo" style={`background-image:url('${heroPhoto}')`}>
          <div class="hero-photo-badge"><span class="n">{seriesData.length}</span> {seriesData.length === 1 ? 'generace' : seriesData.length < 5 ? 'generace' : 'generací'}</div>
          {heroCreditAuthor && heroCreditUrl && (
            <a class="hero-photo-credit" href={heroCreditUrl} target="_blank" rel="noopener noreferrer"
               title={`Foto: ${heroCreditAuthor}${heroCreditLicense ? ` (${heroCreditLicense})` : ''} via Wikimedia Commons · upraveno (crop, konverze do WebP)`}>
              © {heroCreditAuthor}{heroCreditLicense ? ` · ${heroCreditLicense}` : ''} · upraveno
            </a>
          )}
        </div>
      </div>
    </section>

    {seriesData.length > 1 && (
      <div class="split-bar">
        <div class="split-inner">
          <span class="split-kicker">Generace</span>
          <nav class="series-pills" aria-label="Generace">
            {seriesData.map((s, i) => (
              <a class:list={['pill', { active: i === 0 }]} href={`#${s.slug}`}>
                {s.isCurrent && <span class="ind"></span>}
                {s.name.replace(/\s*\([^)]*\)\s*$/, '')}
                <span class="c">{s.models.length}</span>
              </a>
            ))}
          </nav>
        </div>
      </div>
    )}

    {seriesData.map((s) => {
      const yr = s.year_from
        ? (s.year_to ? `${s.year_from}–${s.year_to}` : `${s.year_from}–dosud`)
        : '';
      const seriesHpAll = s.models.map((m) => m.power_hp).filter((x): x is number => x !== null);
      const sMinHp = seriesHpAll.length ? Math.min(...seriesHpAll) : null;
      const sMaxHp = seriesHpAll.length ? Math.max(...seriesHpAll) : null;
      const sHp = sMinHp !== null && sMaxHp !== null
        ? (sMinHp === sMaxHp ? `${sMinHp} k` : `${sMinHp}–${sMaxHp} k`)
        : '';
      // Strip the year suffix from the name to display as just "Series" name
      const seriesNameClean = s.name.replace(/\s*\([^)]*\)\s*$/, '');
      return (
        <section class="series" id={s.slug}>
          <div class="series-head">
            <div class="series-title">
              <div class="series-title-main">
                <h2><a href={`/stroje/${brand.slug}/${s.slug}/`}>{seriesNameClean}</a></h2>
                {s.isCurrent ? (
                  <span class="badge current"><span class="dot"></span>Aktuální</span>
                ) : (
                  <span class="badge legacy">Historie</span>
                )}
              </div>
              <div class="series-meta">
                <strong>{s.models.length} {s.models.length === 1 ? 'model' : s.models.length < 5 ? 'modely' : 'modelů'}</strong>
                {sHp && (<><span class="sep"></span><span>{sHp}</span></>)}
                {yr && (<><span class="sep"></span><span>{yr}</span></>)}
              </div>
            </div>
            <a class="series-cta" href={`/stroje/${brand.slug}/${s.slug}/`}>
              Detail řady
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>

          {s.description && <p class="series-desc">{s.description}</p>}

          <div class="series-table">
            <div class="st-head">
              <span>Model</span>
              <span class="st-col-year">Rok výroby</span>
              <span class="st-col-power">Výkon</span>
              <span class="st-col-action"></span>
            </div>
            {s.models.map((m) => {
              const myr = m.year_from ? (m.year_to ? `${m.year_from}–${m.year_to}` : `${m.year_from}–dosud`) : '—';
              return (
                <a href={`/stroje/${brand.slug}/${s.slug}/${m.urlSlug}/`} class="st-row">
                  <span class="st-name">
                    {m.name}
                    {m.isCurrent && <span class="dot-current" title="Aktuální"></span>}
                  </span>
                  <span class="st-year">{myr}</span>
                  <span class="st-power">
                    {m.power_hp !== null ? (
                      <>
                        <strong>{m.power_hp} k</strong>
                        {m.power_kw && <span class="kw"> · {m.power_kw} kW</span>}
                      </>
                    ) : '—'}
                  </span>
                  <span class="st-go">Detail →</span>
                </a>
              );
            })}
          </div>
        </section>
      );
    })}

    <section class="big-cta">
      <div>
        <span class="cta-kicker">Hledáte {label}?</span>
        <h2>{brand.name} {label} v Agro bazaru<br />— inzeráty od soukromých prodejců i dealerů.</h2>
        <p>Filtrujte podle modelu, výkonu a roku. Kontakt přímo na prodejce, bez provize.</p>
        <div class="cta-actions">
          <a class="cta-btn primary" href={`/bazar/?brand=${encodeURIComponent(brand.slug)}&category=${categorySlug}&q=${encodeURIComponent(label)}`}>
            Otevřít bazar
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a class="cta-btn ghost" href="/bazar/novy/">Přidat vlastní inzerát</a>
        </div>
      </div>
      <div class="cta-right">
        <div class="cta-photo" style={`background-image:url('${heroPhoto}')`}></div>
      </div>
    </section>

  </div>
</Layout>

<style>
  .rada-page{
    --yellow:#FFEA00;
    --yellow-soft:#FFF6A8;
    --yellow-glow:rgba(255,234,0,.35);
    --ink:#0A0A0B;
    --body:#1E1E22;
    --muted:#6B6B72;
    --muted-2:#9A9AA3;
    --line:#EAEAEC;
    --line-2:#DFDFE3;
    --bg-cream:#FBFAF4;
    --card:#FFFFFF;
    --green:#0B7A3B;
    --green-soft:#E3F3EA;
    --legacy:#7A6B0B;
    --legacy-soft:#F5EFC8;
    --r-xl:24px;
    --r-lg:18px;
    --r-md:12px;
    --sh-1:0 1px 2px rgba(10,10,12,.04), 0 0 0 1px rgba(10,10,12,.03);
    --sh-2:0 4px 14px rgba(10,10,12,.06), 0 0 0 1px rgba(10,10,12,.04);
    --sh-3:0 18px 40px -12px rgba(10,10,12,.18), 0 0 0 1px rgba(10,10,12,.04);
    max-width:1280px;margin:0 auto;padding:26px 24px 96px;
    color:var(--body);
  }

  .rada-page .breadcrumb{display:flex;gap:8px;align-items:center;font-size:13px;color:var(--muted);margin-bottom:22px;flex-wrap:wrap}
  .rada-page .breadcrumb a{color:var(--muted);text-decoration:none;transition:color .15s}
  .rada-page .breadcrumb a:hover{color:#000}
  .rada-page .breadcrumb svg{width:14px;height:14px;color:var(--muted-2);flex-shrink:0}
  .rada-page .breadcrumb .current{color:#000;font-weight:600}

  .rada-page .hero{
    position:relative;overflow:hidden;color:#fff;border-radius:var(--r-xl);
    background:
      radial-gradient(600px 300px at 15% 20%, rgba(255,234,0,.18), transparent 60%),
      radial-gradient(700px 400px at 90% 90%, color-mix(in srgb, var(--brand-c1) 36%, transparent), transparent 60%),
      linear-gradient(135deg, #0E0E10 0%, #1C1C20 60%, #2A2A2F 100%);
    padding:44px 44px 38px;margin-bottom:22px;
    box-shadow:var(--sh-3);
    display:grid;grid-template-columns:1.35fr 1fr;gap:32px;align-items:center;
  }
  .rada-page .hero::before{
    content:"";position:absolute;inset:0;pointer-events:none;opacity:.35;
    background-image:linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
    background-size:48px 48px;
    mask-image:radial-gradient(600px 400px at 70% 100%, black, transparent 70%);
  }
  .rada-page .hero-left{position:relative;z-index:2}

  .rada-page .hero-tags{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px}
  .rada-page .tag{
    display:inline-flex;align-items:center;gap:6px;
    font:600 11px/1 'Chakra Petch',sans-serif;letter-spacing:.14em;text-transform:uppercase;
    padding:6px 11px;border-radius:6px;
  }
  .rada-page .tag-brand{background:var(--yellow);color:#0A0A0B}
  .rada-page .tag-cat{background:rgba(255,255,255,.1);color:#fff;border:1px solid rgba(255,255,255,.16)}
  .rada-page .tag-current{background:rgba(11,180,90,.16);color:#5cdc8c;border:1px solid rgba(11,180,90,.4)}
  .rada-page .tag-current .dot{width:7px;height:7px;background:#5cdc8c;border-radius:50%;box-shadow:0 0 0 3px rgba(92,220,140,.18)}

  .rada-page .hero h1{
    font-family:'Chakra Petch',sans-serif;font-weight:700;
    font-size:clamp(2.4rem,5.5vw,4.4rem);color:#fff;line-height:.96;letter-spacing:-.03em;margin:0;
  }
  .rada-page .hero-lede{max-width:560px;font-size:15.5px;color:#c8c8d0;margin:14px 0 22px;line-height:1.55}

  .rada-page .hero-stats{display:flex;gap:24px;flex-wrap:wrap;margin-bottom:22px;font-family:'Chakra Petch',sans-serif}
  .rada-page .hero-stats .s{display:flex;flex-direction:column;gap:3px}
  .rada-page .hero-stats .n{font-size:24px;font-weight:700;color:#fff;line-height:1;letter-spacing:-.02em}
  .rada-page .hero-stats .l{font-size:11px;color:#8a8a92;letter-spacing:.14em;text-transform:uppercase;font-weight:500}
  .rada-page .hero-stats .s + .s{padding-left:24px;border-left:1px solid rgba(255,255,255,.12)}

  .rada-page .hero-actions{display:flex;gap:10px;flex-wrap:wrap}
  .rada-page .cta-primary{
    display:inline-flex;align-items:center;gap:10px;
    background:var(--yellow);color:#0A0A0B;
    padding:13px 18px;border-radius:12px;text-decoration:none;
    font:700 14px 'Chakra Petch',sans-serif;letter-spacing:.02em;
    transition:transform .15s, box-shadow .15s;
    box-shadow:0 14px 40px -10px var(--yellow-glow);
  }
  .rada-page .cta-primary:hover{transform:translateY(-1px);box-shadow:0 20px 50px -8px var(--yellow-glow)}
  .rada-page .cta-secondary{
    display:inline-flex;align-items:center;gap:8px;
    color:#c8c8d0;background:rgba(255,255,255,.06);
    border:1px solid rgba(255,255,255,.12);
    padding:13px 16px;border-radius:12px;text-decoration:none;
    font:500 13px 'Chakra Petch',sans-serif;letter-spacing:.02em;
    transition:.15s;
  }
  .rada-page .cta-secondary:hover{background:rgba(255,255,255,.1);color:#fff;border-color:rgba(255,255,255,.2)}

  .rada-page .hero-right{position:relative;z-index:1;min-height:280px;display:flex;align-items:center;justify-content:center}
  .rada-page .hero-photo{
    width:100%;height:100%;min-height:280px;
    background-size:cover;background-position:center;
    border-radius:18px;
    box-shadow:0 30px 60px -20px rgba(0,0,0,.5), 0 0 0 1px rgba(255,255,255,.08);
    position:relative;overflow:hidden;
  }
  .rada-page .hero-photo::after{
    content:"";position:absolute;inset:0;
    background:linear-gradient(135deg, rgba(14,14,16,.1) 0%, transparent 40%, color-mix(in srgb, var(--brand-c1) 24%, transparent) 100%);
  }
  .rada-page .hero-photo-badge{
    position:absolute;left:16px;bottom:16px;z-index:2;
    background:rgba(10,10,11,.72);backdrop-filter:blur(10px);
    border:1px solid rgba(255,255,255,.1);
    color:#fff;padding:9px 13px;border-radius:10px;
    font:500 12px 'Chakra Petch',sans-serif;
  }
  .rada-page .hero-photo-badge .n{font-weight:700;color:var(--yellow)}
  .rada-page .hero-photo-credit{
    position:absolute;right:12px;bottom:12px;z-index:2;
    background:rgba(10,10,11,.6);backdrop-filter:blur(8px);
    border:1px solid rgba(255,255,255,.08);
    color:rgba(255,255,255,.78);text-decoration:none;
    padding:5px 9px;border-radius:7px;
    font:500 10.5px/1 'Chakra Petch',sans-serif;letter-spacing:.02em;
    max-width:60%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;
    transition:.15s;
  }
