---
export const prerender = true;
import Layout from '../../../../../../layouts/Layout.astro';
import { getAllBrands, getBrand, seriesFamily, familyLabel, type StrojKategorie } from '../../../../../../lib/stroje';

export async function getStaticPaths() {
  const paths: { params: { brand: string; category: string; family: string } }[] = [];
  for (const b of getAllBrands()) {
    for (const [catKey, cat] of Object.entries(b.categories ?? {})) {
      const families = new Set<string>();
      for (const s of cat.series ?? []) families.add(seriesFamily(s.slug));
      for (const f of families) {
        paths.push({ params: { brand: b.slug, category: catKey, family: f } });
      }
    }
  }
  return paths;
}

const { brand: brandSlug, category: categorySlug, family } = Astro.params;
const brand = getBrand(brandSlug!);
if (!brand) return Astro.redirect('/stroje/');

const categoryLabels: Record<StrojKategorie, string> = {
  traktory: 'Traktory',
  kombajny: 'Kombajny',
};
const catLabel = categoryLabels[categorySlug as StrojKategorie] ?? categorySlug;

const cat = brand.categories?.[categorySlug as StrojKategorie];
if (!cat) return Astro.redirect(`/stroje/${brand.slug}/`);

// Get series in this category that match the family
const matchingSeries = (cat.series ?? []).filter((s: any) => seriesFamily(s.slug) === family);
if (matchingSeries.length === 0) return Astro.redirect(`/stroje/${brand.slug}/`);

type Row = {
  slug: string;
  name: string;
  year_from: number | null;
  year_to: number | null;
  power_hp: number | null;
  power_kw: number | null;
  urlSlug: string;
};

const seriesData = matchingSeries.map((s: any) => {
  const rows: Row[] = (s.models ?? []).map((m: any) => {
    const urlSlug = m.slug.startsWith(brand.slug + '-') ? m.slug.slice(brand.slug.length + 1) : m.slug;
    return {
      slug: m.slug,
      name: m.name,
      year_from: m.year_from,
      year_to: m.year_to,
      power_hp: m.power_hp,
      power_kw: m.power_kw,
      urlSlug,
    };
  });
  rows.sort((a, b) => (b.power_hp ?? 0) - (a.power_hp ?? 0));
  return {
    slug: s.slug,
    name: s.name,
    description: s.description,
    year_from: s.year_from ?? null,
    year_to: s.year_to ?? null,
    models: rows,
  };
});

const label = familyLabel(family!);
const totalModels = seriesData.reduce((acc, s) => acc + s.models.length, 0);
const allHp = seriesData.flatMap((s) => s.models.map((r) => r.power_hp)).filter((x): x is number => x !== null);
const allYearsFrom = seriesData.flatMap((s) => s.models.map((r) => r.year_from)).filter((x): x is number => x !== null);
const allYearsTo = seriesData.flatMap((s) => s.models.map((r) => r.year_to));
const hasCurrent = allYearsTo.some((y) => y === null);
const minHp = allHp.length ? Math.min(...allHp) : null;
const maxHp = allHp.length ? Math.max(...allHp) : null;
const minYear = allYearsFrom.length ? Math.min(...allYearsFrom) : null;
const maxYear = !hasCurrent && allYearsTo.length
  ? Math.max(...(allYearsTo.filter((y): y is number => y !== null)))
  : null;
---

<Layout
  title={`${brand.name} ${label} ${catLabel.toLowerCase()} — všechny modely`}
  description={`Všechny ${catLabel.toLowerCase()} řady ${brand.name} ${label}. ${totalModels} modelů${minHp && maxHp ? `, výkon ${minHp}–${maxHp} k` : ''}.`}
>
  <div style="max-width:1280px; margin:0 auto; padding:48px 32px 80px;">
    <div style="margin-bottom:8px; font-size:13px; color:#666;">
      <a href="/stroje/" style="color:#666; text-decoration:none;">Katalog</a>
      <span style="margin:0 6px;">/</span>
      <a href={`/stroje/${brand.slug}/`} style="color:#666; text-decoration:none;">{brand.name}</a>
      <span style="margin:0 6px;">/</span>
      <span style="color:#666;">{catLabel}</span>
      <span style="margin:0 6px;">/</span>
      <span style="color:#1a1a1a;">{label}</span>
    </div>

    <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:24px; flex-wrap:wrap; margin-bottom:32px; padding-bottom:24px; border-bottom:1px solid #e8e8e8;">
      <div>
        <div style="display:flex; gap:8px; margin-bottom:10px; flex-wrap:wrap;">
          <span style="background:#FFFF00; color:#000; font-family:'Chakra Petch',sans-serif; font-size:11px; padding:3px 10px; border-radius:3px; text-transform:uppercase; letter-spacing:1px;">
            {brand.name}
          </span>
          <span style="background:#1a1a1a; color:#fff; font-family:'Chakra Petch',sans-serif; font-size:11px; padding:3px 10px; border-radius:3px; text-transform:uppercase; letter-spacing:1px;">
            {catLabel}
          </span>
        </div>
        <h1 style="font-family:'Chakra Petch',sans-serif; font-size:clamp(2rem,5vw,3rem); font-weight:700; letter-spacing:-1px; color:#1a1a1a; margin-bottom:14px;">
          {label}
        </h1>
        <div style="display:flex; gap:16px; flex-wrap:wrap; font-size:14px; color:#666;">
          <span>🔢 {totalModels} modelů</span>
          {minHp !== null && maxHp !== null && (
            <span>⚡ {minHp === maxHp ? `${minHp} k` : `${minHp}–${maxHp} k`}</span>
          )}
          {minYear !== null && (
            <span>📅 {hasCurrent ? `${minYear}–dosud` : (maxYear ? `${minYear}–${maxYear}` : `${minYear}`)}</span>
          )}
          <span>🧬 {seriesData.length} generací</span>
        </div>
      </div>
      <a href={`/bazar/?brand=${encodeURIComponent(brand.slug)}&category=${categorySlug}&q=${encodeURIComponent(label)}`} style="background:#FFFF00; color:#000; padding:12px 20px; border-radius:10px; text-decoration:none; font-family:'Chakra Petch',sans-serif; font-weight:700; font-size:14px; white-space:nowrap;">
        Hledat v bazaru →
      </a>
    </div>

    {seriesData.map((s) => {
      const yr = s.year_from
        ? (s.year_to ? `${s.year_from}–${s.year_to}` : `${s.year_from}–dosud`)
        : '';
      return (
        <div style="margin-bottom:32px;">
          <div style="display:flex; justify-content:space-between; align-items:baseline; gap:12px; margin-bottom:10px; flex-wrap:wrap;">
            <h3 style="font-family:'Chakra Petch',sans-serif; font-size:20px; font-weight:700; color:#1a1a1a;">
              <a href={`/stroje/${brand.slug}/${s.slug}/`} style="color:#1a1a1a; text-decoration:none;">{s.name}</a>
            </h3>
            <span style="font-size:12px; color:#666;">{s.models.length} modelů · {yr}</span>
          </div>
          {s.description && <p style="font-size:14px; color:#666; line-height:1.55; margin-bottom:12px; max-width:820px;">{s.description}</p>}

          <div style="border:1px solid #e8e8e8; border-radius:14px; overflow:hidden; background:#fff;">
            <table style="width:100%; border-collapse:collapse; font-size:14px;">
              <thead>
                <tr style="background:#fafafa;">
                  <th style="text-align:left; padding:10px 14px; font-family:'Chakra Petch',sans-serif; font-size:11px; letter-spacing:.05em; text-transform:uppercase; color:#666; border-bottom:1px solid #e8e8e8;">Model</th>
                  <th style="text-align:left; padding:10px 14px; font-family:'Chakra Petch',sans-serif; font-size:11px; letter-spacing:.05em; text-transform:uppercase; color:#666; border-bottom:1px solid #e8e8e8;">Rok výroby</th>
                  <th style="text-align:left; padding:10px 14px; font-family:'Chakra Petch',sans-serif; font-size:11px; letter-spacing:.05em; text-transform:uppercase; color:#666; border-bottom:1px solid #e8e8e8;">Výkon</th>
                  <th style="padding:10px 14px; border-bottom:1px solid #e8e8e8;"></th>
                </tr>
              </thead>
              <tbody>
                {s.models.map((m, idx) => {
                  const myr = m.year_from ? (m.year_to ? `${m.year_from}–${m.year_to}` : `${m.year_from}–dosud`) : '—';
                  return (
                    <tr style={`border-bottom:${idx < s.models.length - 1 ? '1px solid #f2f2f2' : 'none'};`} class="hover-row">
                      <td style="padding:12px 14px;">
                        <a href={`/stroje/${brand.slug}/${s.slug}/${m.urlSlug}/`} style="font-family:'Chakra Petch',sans-serif; font-weight:700; color:#1a1a1a; text-decoration:none;">
                          {m.name}
                        </a>
                      </td>
                      <td style="padding:12px 14px; color:#666;">{myr}</td>
                      <td style="padding:12px 14px;">
                        {m.power_hp ? (
                          <>
                            <strong>{m.power_hp} k</strong>
                            {m.power_kw && <span style="color:#666; font-size:12px;"> ({m.power_kw} kW)</span>}
                          </>
                        ) : '—'}
                      </td>
                      <td style="padding:12px 14px; text-align:right;">
                        <a href={`/stroje/${brand.slug}/${s.slug}/${m.urlSlug}/`} style="font-size:12px; color:#1a1a1a; text-decoration:none; border:1px solid #ddd; padding:5px 10px; border-radius:6px;">Detail →</a>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </div>
      );
    })}
  </div>

  <style>
    .hover-row:hover { background: #fcfcfc; }
  </style>
</Layout>
