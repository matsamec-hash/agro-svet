---
export const prerender = false;
import Layout from '../../../../../layouts/Layout.astro';
import { getAllBrands, getSeries, seriesFamily, familyLabel, type StrojKategorie, type StrojModel } from '../../../../../lib/stroje';
import { createServerClient } from '../../../../../lib/supabase';

export async function getStaticPaths() {
  const paths: { params: { brand: string; series: string; model: string }; props: { modelSlug: string } }[] = [];
  for (const brand of getAllBrands()) {
    for (const cat of Object.values(brand.categories || {})) {
      for (const s of cat.series || []) {
        for (const m of s.models || []) {
          const short = m.slug.startsWith(brand.slug + '-') ? m.slug.slice(brand.slug.length + 1) : m.slug;
          paths.push({
            params: { brand: brand.slug, series: s.slug, model: short },
            props: { modelSlug: m.slug },
          });
        }
      }
    }
  }
  return paths;
}

const { brand: brandSlug, series: seriesSlug } = Astro.params;
const { modelSlug } = Astro.props as { modelSlug: string };
const found = getSeries(brandSlug!, seriesSlug!);
if (!found) return Astro.redirect('/stroje/');
const { brand, category, series } = found;
const model: StrojModel | undefined = series.models.find((m) => m.slug === modelSlug);
if (!model) return Astro.redirect(`/stroje/${brandSlug}/${seriesSlug}/`);

const categoryLabels: Record<StrojKategorie, string> = {
  traktory: 'Traktory',
  kombajny: 'Kombajny',
};
const categorySingular: Record<StrojKategorie, string> = {
  traktory: 'traktor',
  kombajny: 'kombajn',
};
const categoryHero: Record<StrojKategorie, string> = {
  traktory: '/images/traktor.webp',
  kombajny: '/images/kombajn.webp',
};

const brandColors: Record<string, [string, string]> = {
  'john-deere': ['#4A9838', '#2E6B22'],
  fendt: ['#3FA85D', '#0E6730'],
  claas: ['#9C9532', '#65601A'],
  'deutz-fahr': ['#2BA84A', '#1a5e2a'],
  kubota: ['#FF6B1A', '#C24414'],
  'new-holland': ['#3874AC', '#1A4370'],
  'case-ih': ['#D62A2A', '#8F1818'],
  'massey-ferguson': ['#D62A2A', '#8F1818'],
  valtra: ['#1F1F1F', '#0A0A0A'],
  zetor: ['#E93A3A', '#A01818'],
};
const [brandC1, brandC2] = brandColors[brand.slug] ?? ['#2a2a30', '#0a0a0b'];

// Live count inzerátů tohoto konkrétního modelu
let modelBazarCount = 0;
try {
  const supabase = createServerClient();
  const { count } = await supabase
    .from('bazar_listings')
    .select('id', { count: 'exact', head: true })
    .eq('status', 'active')
    .eq('model_slug', model.slug);
  modelBazarCount = count ?? 0;
} catch {}

const family = (series as any).family || seriesFamily(series.slug);
const familyLab = familyLabel(family);

const yr = model.year_from ? (model.year_to ? `${model.year_from}–${model.year_to}` : `${model.year_from}–dosud`) : '';
const isCurrent = model.year_to === null && model.year_from !== null;
const seriesNameClean = series.name.replace(/\s*\([^)]*\)\s*$/, '');
const seriesYr = series.year_from ? (series.year_to ? `${series.year_from}–${series.year_to}` : `${series.year_from}–dosud`) : '';

// Related models in same series
const related = series.models
  .filter((m) => m.slug !== model.slug)
  .sort((a, b) => Math.abs((a.power_hp ?? 0) - (model.power_hp ?? 0)) - Math.abs((b.power_hp ?? 0) - (model.power_hp ?? 0)))
  .slice(0, 6);

function modelUrlPart(slug: string): string {
  return slug.startsWith(brand.slug + '-') ? slug.slice(brand.slug.length + 1) : slug;
}

// Build categorized spec rows
type SpecRow = { label: string; value: string };
const performanceSpecs: SpecRow[] = [];
const drivetrainSpecs: SpecRow[] = [];
const dimensionSpecs: SpecRow[] = [];
const otherSpecs: SpecRow[] = [];

if (model.power_hp) performanceSpecs.push({ label: 'Výkon', value: `${model.power_hp} k${model.power_kw ? ` (${model.power_kw} kW)` : ''}` });
if (model.engine) drivetrainSpecs.push({ label: 'Motor', value: model.engine });
if (model.transmission) drivetrainSpecs.push({ label: 'Převodovka', value: model.transmission });
if (model.weight_kg) dimensionSpecs.push({ label: 'Hmotnost', value: `${model.weight_kg.toLocaleString('cs-CZ')} kg` });
if (model.cutting_width_m) dimensionSpecs.push({ label: 'Záběr žacího stolu', value: `${model.cutting_width_m} m` });
if (model.grain_tank_l) dimensionSpecs.push({ label: 'Objem bunkru', value: `${model.grain_tank_l.toLocaleString('cs-CZ')} l` });
if (yr) performanceSpecs.push({ label: 'Roky výroby', value: yr });

if (model.specs) {
  const specGroups: Record<string, 'perf' | 'drive' | 'dim' | 'other'> = {
    hydraulika_l_min: 'drive',
    zadni_zaves_kg: 'dim',
    predni_zaves_kg: 'dim',
    emise: 'drive',
    kabina: 'other',
  };
  const specLabels: Record<string, string> = {
    hydraulika_l_min: 'Hydraulika',
    zadni_zaves_kg: 'Zadní závěs',
    predni_zaves_kg: 'Přední závěs',
    emise: 'Emisní norma',
    kabina: 'Kabina',
  };
  const specUnits: Record<string, string> = {
    hydraulika_l_min: ' l/min',
    zadni_zaves_kg: ' kg',
    predni_zaves_kg: ' kg',
  };
  for (const [k, v] of Object.entries(model.specs)) {
    if (v === null || v === undefined || v === '') continue;
    const label = specLabels[k] ?? k.replace(/_/g, ' ');
    const unit = specUnits[k] ?? '';
    const formatted = typeof v === 'number' ? v.toLocaleString('cs-CZ') + unit : String(v);
    const row = { label, value: formatted };
    const grp = specGroups[k] ?? 'other';
    if (grp === 'perf') performanceSpecs.push(row);
    else if (grp === 'drive') drivetrainSpecs.push(row);
    else if (grp === 'dim') dimensionSpecs.push(row);
    else otherSpecs.push(row);
  }
}

const totalSpecCount = performanceSpecs.length + drivetrainSpecs.length + dimensionSpecs.length + otherSpecs.length;

const heroPhoto = (series as any).image_url || categoryHero[category] || '/images/traktor.webp';

const pageTitle = `${brand.name} ${model.name}`;
const pageDesc = model.description
  ? model.description.slice(0, 160)
  : `${pageTitle} — ${categorySingular[category]} s výkonem ${model.power_hp ?? '?'} k, roky výroby ${yr}. Technické parametry a nabídka v bazaru.`;

const canonical = `https://agro-svet.cz/stroje/${brand.slug}/${series.slug}/${modelUrlPart(model.slug)}/`;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Domů', item: 'https://agro-svet.cz/' },
    { '@type': 'ListItem', position: 2, name: 'Technika', item: 'https://agro-svet.cz/stroje/' },
    { '@type': 'ListItem', position: 3, name: brand.name, item: `https://agro-svet.cz/stroje/${brand.slug}/` },
    { '@type': 'ListItem', position: 4, name: seriesNameClean, item: `https://agro-svet.cz/stroje/${brand.slug}/${series.slug}/` },
    { '@type': 'ListItem', position: 5, name: model.name, item: canonical },
  ],
};
---

<Layout title={`${pageTitle} — parametry a cena`} description={pageDesc} canonical={canonical}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  <div class="model-page">

    <nav class="breadcrumb" aria-label="Cesta">
      <a href="/">Domů</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/stroje/">Technika</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <a href={`/stroje/${brand.slug}/`}>{brand.name}</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <a href={`/stroje/${brand.slug}/${series.slug}/`}>{seriesNameClean}</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <span class="current">{model.name}</span>
    </nav>

    <section class="hero" style={`--brand-c1:${brandC1};--brand-c2:${brandC2};`}>
      <div class="hero-left">
        <div class="hero-tags">
          <span class="tag tag-brand">{brand.name}</span>
          <span class="tag tag-cat">{categoryLabels[category]}</span>
          <span class="tag tag-series">{seriesNameClean}</span>
          {isCurrent ? (
            <span class="tag tag-current"><span class="dot"></span>Aktuální v prodeji</span>
          ) : (
            <span class="tag tag-legacy">Historie</span>
          )}
        </div>
        <h1>{model.name}</h1>
        {yr && <div class="hero-year">{yr}</div>}

        {model.power_hp && (
          <div class="power-pill">
            <span class="pp-num">{model.power_hp}</span>
            <span class="pp-unit">k</span>
            {model.power_kw && <span class="pp-kw">· {model.power_kw} kW</span>}
          </div>
        )}

        {model.description && <p class="hero-lede">{model.description}</p>}

        <div class="hero-actions">
          <a class="cta-primary" href={`/bazar/?brand=${encodeURIComponent(brand.slug)}&category=${category}&q=${encodeURIComponent(model.name)}`}>
            {modelBazarCount > 0
              ? `${modelBazarCount} ${modelBazarCount === 1 ? 'inzerát' : modelBazarCount < 5 ? 'inzeráty' : 'inzerátů'} v bazaru`
              : `Hledat ${model.name} v bazaru`}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a class="cta-secondary" href={`/stroje/${brand.slug}/${series.slug}/`}>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
            Celá řada {seriesNameClean}
          </a>
        </div>
      </div>

      <div class="hero-right">
        <div class="hero-photo" style={`background-image:url('${heroPhoto}')`}>
          <div class="hero-photo-badge">
            <span class="n">{model.name}</span>
            {model.power_hp && <span class="pwr">{model.power_hp} k</span>}
          </div>
        </div>
      </div>
    </section>

    <div class="content-grid">
      <div class="content-main">
        {totalSpecCount > 0 ? (
          <section class="spec-card">
            <div class="card-head">
              <h2>Technické parametry</h2>
              <span class="card-head-meta">{totalSpecCount} {totalSpecCount === 1 ? 'parametr' : totalSpecCount < 5 ? 'parametry' : 'parametrů'}</span>
            </div>

            {performanceSpecs.length > 0 && (
              <div class="spec-group">
                <div class="spec-group-label">Výkon &amp; provoz</div>
                <dl class="spec-list">
                  {performanceSpecs.map((row) => (
                    <div class="spec-item"><dt>{row.label}</dt><dd>{row.value}</dd></div>
                  ))}
                </dl>
              </div>
            )}

            {drivetrainSpecs.length > 0 && (
              <div class="spec-group">
                <div class="spec-group-label">Pohon &amp; motor</div>
                <dl class="spec-list">
                  {drivetrainSpecs.map((row) => (
                    <div class="spec-item"><dt>{row.label}</dt><dd>{row.value}</dd></div>
                  ))}
                </dl>
              </div>
            )}

            {dimensionSpecs.length > 0 && (
              <div class="spec-group">
                <div class="spec-group-label">Rozměry &amp; kapacita</div>
                <dl class="spec-list">
                  {dimensionSpecs.map((row) => (
                    <div class="spec-item"><dt>{row.label}</dt><dd>{row.value}</dd></div>
                  ))}
                </dl>
              </div>
            )}

            {otherSpecs.length > 0 && (
              <div class="spec-group">
                <div class="spec-group-label">Vybavení</div>
                <dl class="spec-list">
                  {otherSpecs.map((row) => (
                    <div class="spec-item"><dt>{row.label}</dt><dd>{row.value}</dd></div>
                  ))}
                </dl>
              </div>
            )}
          </section>
        ) : (
          <section class="spec-card spec-empty">
            <h2>Technické parametry</h2>
            <p>Detailní parametry budou doplněny.</p>
          </section>
        )}

        {related.length > 0 && (
          <section class="related-card">
            <div class="card-head">
              <h2>Další modely v řadě {seriesNameClean}</h2>
              <a class="card-head-link" href={`/stroje/${brand.slug}/${series.slug}/`}>Všechny modely →</a>
            </div>
            <div class="rel-grid">
              {related.map((m) => {
                const mYr = m.year_from ? (m.year_to ? `${m.year_from}–${m.year_to}` : `${m.year_from}–dosud`) : '';
                const mIsCurrent = m.year_to === null && m.year_from !== null;
                return (
                  <a href={`/stroje/${brand.slug}/${series.slug}/${modelUrlPart(m.slug)}/`} class="rel-card">
                    <div class="rel-title">
                      {m.name}
                      {mIsCurrent && <span class="dot-current" title="Aktuální"></span>}
                    </div>
                    <div class="rel-meta">
                      <span class="rel-power">
                        {m.power_hp !== null ? <><strong>{m.power_hp} k</strong></> : '—'}
                      </span>
                      <span class="rel-year">{mYr}</span>
                    </div>
                  </a>
                );
              })}
            </div>
          </section>
        )}
      </div>

      <aside class="content-aside">
        <div class="aside-card primary-cta-card">
          <span class="acc-kicker">{modelBazarCount > 0 ? `${modelBazarCount} ${modelBazarCount === 1 ? 'aktuální inzerát' : modelBazarCount < 5 ? 'aktuální inzeráty' : 'aktuálních inzerátů'}` : 'Aktuální nabídky'}</span>
          <h3>{brand.name} {model.name}<br/>v Agro bazaru</h3>
          <p>{modelBazarCount > 0 ? 'Konkrétně tento model. Kontakt přímo na prodejce, bez provize.' : 'Filtrujte podle modelu, výkonu a roku. Kontakt přímo na prodejce, bez provize.'}</p>
          <a href={`/bazar/?brand=${encodeURIComponent(brand.slug)}&category=${category}&q=${encodeURIComponent(model.name)}`} class="aside-btn primary">
            {modelBazarCount > 0 ? `Zobrazit ${modelBazarCount === 1 ? 'inzerát' : 'inzeráty'}` : 'Otevřít bazar'}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a href="/bazar/novy/" class="aside-btn ghost-light">Přidat vlastní inzerát</a>
        </div>

        <div class="aside-card nav-card">
          <span class="acc-label">Kontext</span>
          <a href={`/stroje/${brand.slug}/`} class="aside-link">
            <span class="al-label">Značka</span>
            <span class="al-value">{brand.name}</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>
          <a href={`/stroje/${brand.slug}/rada/${category}/${family}/`} class="aside-link">
            <span class="al-label">Řada</span>
            <span class="al-value">{familyLab}</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>
          <a href={`/stroje/${brand.slug}/${series.slug}/`} class="aside-link">
            <span class="al-label">Generace</span>
            <span class="al-value">{seriesNameClean}{seriesYr ? ` · ${seriesYr}` : ''}</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </aside>
    </div>

  </div>
</Layout>

<style>
  .model-page{
    --yellow:#FFEA00;
    --yellow-soft:#FFF6A8;
    --yellow-glow:rgba(255,234,0,.35);
    --ink:#0A0A0B;
    --body:#1E1E22;
    --muted:#6B6B72;
    --muted-2:#9A9AA3;
    --line:#EAEAEC;
    --line-2:#DFDFE3;
    --bg-cream:#FBFAF4;
    --card:#FFFFFF;
    --green:#0B7A3B;
    --green-soft:#E3F3EA;
    --legacy:#7A6B0B;
    --legacy-soft:#F5EFC8;
    --r-xl:24px;
    --r-lg:18px;
    --r-md:12px;
    --sh-1:0 1px 2px rgba(10,10,12,.04), 0 0 0 1px rgba(10,10,12,.03);
    --sh-3:0 18px 40px -12px rgba(10,10,12,.18), 0 0 0 1px rgba(10,10,12,.04);
    max-width:1280px;margin:0 auto;padding:26px 24px 96px;
    color:var(--body);
  }

  .model-page .breadcrumb{display:flex;gap:8px;align-items:center;font-size:13px;color:var(--muted);margin-bottom:22px;flex-wrap:wrap}
  .model-page .breadcrumb a{color:var(--muted);text-decoration:none;transition:color .15s}
  .model-page .breadcrumb a:hover{color:#000}
  .model-page .breadcrumb svg{width:14px;height:14px;color:var(--muted-2);flex-shrink:0}
  .model-page .breadcrumb .current{color:#000;font-weight:600}

  .model-page .hero{
    position:relative;overflow:hidden;color:#fff;border-radius:var(--r-xl);
    background:
      radial-gradient(600px 300px at 15% 20%, rgba(255,234,0,.18), transparent 60%),
      radial-gradient(700px 400px at 90% 90%, color-mix(in srgb, var(--brand-c1) 36%, transparent), transparent 60%),
      linear-gradient(135deg, #0E0E10 0%, #1C1C20 60%, #2A2A2F 100%);
    padding:44px 44px 38px;margin-bottom:22px;
    box-shadow:var(--sh-3);
    display:grid;grid-template-columns:1.35fr 1fr;gap:32px;align-items:center;
  }
  .model-page .hero::before{
    content:"";position:absolute;inset:0;pointer-events:none;opacity:.35;
    background-image:linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
    background-size:48px 48px;
    mask-image:radial-gradient(600px 400px at 70% 100%, black, transparent 70%);
  }
  .model-page .hero-left{position:relative;z-index:2}

  .model-page .hero-tags{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px}
  .model-page .tag{
    display:inline-flex;align-items:center;gap:6px;
    font:600 11px/1 'Chakra Petch',sans-serif;letter-spacing:.14em;text-transform:uppercase;
    padding:6px 11px;border-radius:6px;
  }
  .model-page .tag-brand{background:var(--yellow);color:#0A0A0B}
  .model-page .tag-cat{background:rgba(255,255,255,.1);color:#fff;border:1px solid rgba(255,255,255,.16)}
  .model-page .tag-series{background:rgba(255,255,255,.06);color:#c8c8d0;border:1px solid rgba(255,255,255,.12)}
  .model-page .tag-current{background:rgba(11,180,90,.16);color:#5cdc8c;border:1px solid rgba(11,180,90,.4)}
  .model-page .tag-current .dot{width:7px;height:7px;background:#5cdc8c;border-radius:50%;box-shadow:0 0 0 3px rgba(92,220,140,.18)}
  .model-page .tag-legacy{background:rgba(180,160,80,.16);color:#dccc78;border:1px solid rgba(180,160,80,.32)}

  .model-page .hero h1{
    font-family:'Chakra Petch',sans-serif;font-weight:700;
    font-size:clamp(2.4rem,5.5vw,4.4rem);color:#fff;line-height:.96;letter-spacing:-.03em;margin:0;
  }
  .model-page .hero-year{margin-top:8px;font:500 16px 'Chakra Petch',sans-serif;color:var(--yellow);letter-spacing:.04em}
  .model-page .hero-lede{max-width:580px;font-size:15.5px;color:#c8c8d0;margin:14px 0 22px;line-height:1.65}

  .model-page .power-pill{
    display:inline-flex;align-items:baseline;gap:8px;margin-top:18px;
    background:rgba(255,234,0,.1);border:1px solid rgba(255,234,0,.4);
    color:var(--yellow);padding:14px 22px;border-radius:14px;
    font-family:'Chakra Petch',sans-serif;
    box-shadow:0 8px 30px -10px rgba(255,234,0,.4), inset 0 0 30px rgba(255,234,0,.08);
  }
  .model-page .pp-num{font-size:42px;font-weight:700;letter-spacing:-.04em;line-height:1}
  .model-page .pp-unit{font-size:18px;font-weight:600}
  .model-page .pp-kw{font-size:14px;color:#fff;opacity:.7;font-weight:500;margin-left:4px}

  .model-page .hero-actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:22px}
  .model-page .cta-primary{
    display:inline-flex;align-items:center;gap:10px;
    background:var(--yellow);color:#0A0A0B;
    padding:13px 18px;border-radius:12px;text-decoration:none;
    font:700 14px 'Chakra Petch',sans-serif;letter-spacing:.02em;
    transition:transform .15s, box-shadow .15s;
    box-shadow:0 14px 40px -10px var(--yellow-glow);
  }
  .model-page .cta-primary:hover{transform:translateY(-1px);box-shadow:0 20px 50px -8px var(--yellow-glow)}
  .model-page .cta-secondary{
    display:inline-flex;align-items:center;gap:8px;
    color:#c8c8d0;background:rgba(255,255,255,.06);
    border:1px solid rgba(255,255,255,.12);
    padding:13px 16px;border-radius:12px;text-decoration:none;
    font:500 13px 'Chakra Petch',sans-serif;letter-spacing:.02em;
    transition:.15s;
  }
