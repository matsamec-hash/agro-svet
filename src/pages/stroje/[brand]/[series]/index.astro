---
export const prerender = false;
import Layout from '../../../../layouts/Layout.astro';
import { getAllBrands, getSeries, seriesFamily, familyLabel, type StrojKategorie } from '../../../../lib/stroje';

export async function getStaticPaths() {
  const paths: { params: { brand: string; series: string } }[] = [];
  for (const brand of getAllBrands()) {
    for (const cat of Object.values(brand.categories || {})) {
      for (const s of cat.series || []) {
        paths.push({ params: { brand: brand.slug, series: s.slug } });
      }
    }
  }
  return paths;
}

const { brand: brandSlug, series: seriesSlug } = Astro.params;
const found = getSeries(brandSlug!, seriesSlug!);
if (!found) return Astro.redirect('/stroje/');
const { brand, category, series } = found;

const categoryLabels: Record<StrojKategorie, string> = {
  traktory: 'Traktory',
  kombajny: 'Kombajny',
};
const categoryHero: Record<StrojKategorie, string> = {
  traktory: '/images/traktor.webp',
  kombajny: '/images/kombajn.webp',
};

const brandColors: Record<string, [string, string]> = {
  'john-deere': ['#4A9838', '#2E6B22'],
  fendt: ['#3FA85D', '#0E6730'],
  claas: ['#9C9532', '#65601A'],
  'deutz-fahr': ['#2BA84A', '#1a5e2a'],
  kubota: ['#FF6B1A', '#C24414'],
  'new-holland': ['#3874AC', '#1A4370'],
  'case-ih': ['#D62A2A', '#8F1818'],
  'massey-ferguson': ['#D62A2A', '#8F1818'],
  valtra: ['#1F1F1F', '#0A0A0A'],
  zetor: ['#E93A3A', '#A01818'],
};
const [brandC1, brandC2] = brandColors[brand.slug] ?? ['#2a2a30', '#0a0a0b'];

const family = (series as any).family || seriesFamily(series.slug);
const familyLab = familyLabel(family);

const yr = series.year_from ? (series.year_to ? `${series.year_from}–${series.year_to}` : `${series.year_from}–dosud`) : '';
const isCurrent = series.year_to === null && series.year_from !== null;
const seriesNameClean = series.name.replace(/\s*\([^)]*\)\s*$/, '');

const hpValues = series.models.map((m) => m.power_hp).filter((x): x is number => x !== null);
const minHp = hpValues.length ? Math.min(...hpValues) : null;
const maxHp = hpValues.length ? Math.max(...hpValues) : null;
const hpRange = minHp !== null && maxHp !== null
  ? (minHp === maxHp ? `${minHp} k` : `${minHp}–${maxHp} k`)
  : '';

// Pull engine/transmission from any model (typically shared within a series)
const engines = Array.from(new Set(series.models.map((m) => m.engine).filter((x): x is string => !!x)));
const transmissions = Array.from(new Set(series.models.map((m) => m.transmission).filter((x): x is string => !!x)));
const sharedEngine = engines.length === 1 ? engines[0] : engines.length > 1 ? `${engines.length} variant motoru` : '';
const sharedTransmission = transmissions.length === 1 ? transmissions[0] : transmissions.length > 1 ? `${transmissions.length} variant převodovky` : '';

const sortedModels = [...series.models].sort((a, b) => (b.power_hp ?? 0) - (a.power_hp ?? 0));
const categoryHasGrainTank = category === 'kombajny';

function modelUrlPart(slug: string): string {
  return slug.startsWith(brand.slug + '-') ? slug.slice(brand.slug.length + 1) : slug;
}

// Sibling generations in same family
const sameCategory = brand.categories?.[category];
const siblings = (sameCategory?.series ?? [])
  .filter((s) => s.slug !== series.slug && ((s as any).family || seriesFamily(s.slug)) === family)
  .map((s) => {
    const sHpAll = (s.models ?? []).map((m) => m.power_hp).filter((x): x is number => x !== null);
    const sIsCurrent = (s.models ?? []).some((m) => m.year_to === null && m.year_from !== null);
    const sYr = s.year_from ? (s.year_to ? `${s.year_from}–${s.year_to}` : `${s.year_from}–dosud`) : '';
    return {
      slug: s.slug,
      name: s.name.replace(/\s*\([^)]*\)\s*$/, ''),
      year_from: s.year_from,
      yr: sYr,
      modelCount: (s.models ?? []).length,
      minHp: sHpAll.length ? Math.min(...sHpAll) : null,
      maxHp: sHpAll.length ? Math.max(...sHpAll) : null,
      isCurrent: sIsCurrent,
    };
  })
  .sort((a, b) => (b.year_from ?? 0) - (a.year_from ?? 0));

const heroPhoto = (series as any).image_url || categoryHero[category] || '/images/traktor.webp';
const heroCreditUrl: string | null = (series as any).image_credit_url || null;
const heroCreditAuthor: string | null = (series as any).image_credit || null;
const heroCreditLicense: string | null = (series as any).image_license || null;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Domů', item: 'https://agro-svet.cz/' },
    { '@type': 'ListItem', position: 2, name: 'Technika', item: 'https://agro-svet.cz/stroje/' },
    { '@type': 'ListItem', position: 3, name: brand.name, item: `https://agro-svet.cz/stroje/${brand.slug}/` },
    { '@type': 'ListItem', position: 4, name: familyLab, item: `https://agro-svet.cz/stroje/${brand.slug}/rada/${category}/${family}/` },
    { '@type': 'ListItem', position: 5, name: seriesNameClean, item: `https://agro-svet.cz/stroje/${brand.slug}/${series.slug}/` },
  ],
};
---

<Layout
  title={`${brand.name} ${series.name} — všechny modely`}
  description={`Přehled všech modelů řady ${brand.name} ${series.name}. Výkony ${hpRange || '—'}, roky výroby ${yr || '—'}.`}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  <div class="series-page">

    <nav class="breadcrumb" aria-label="Cesta">
      <a href="/">Domů</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/stroje/">Technika</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <a href={`/stroje/${brand.slug}/`}>{brand.name}</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <a href={`/stroje/${brand.slug}/rada/${category}/${family}/`}>{familyLab}</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <span class="current">{seriesNameClean}</span>
    </nav>

    <section class="hero" style={`--brand-c1:${brandC1};--brand-c2:${brandC2};`}>
      <div class="hero-left">
        <div class="hero-tags">
          <span class="tag tag-brand">{brand.name}</span>
          <span class="tag tag-cat">{categoryLabels[category]}</span>
          <span class="tag tag-fam">{familyLab}</span>
          {isCurrent ? (
            <span class="tag tag-current"><span class="dot"></span>Aktuální v prodeji</span>
          ) : (
            <span class="tag tag-legacy">Historie</span>
          )}
        </div>
        <h1>{seriesNameClean}</h1>
        {yr && <div class="hero-year">{yr}</div>}
        {series.description && <p class="hero-lede">{series.description}</p>}

        <div class="hero-stats">
          <div class="s"><span class="n">{series.models.length}</span><span class="l">{series.models.length === 1 ? 'model' : series.models.length < 5 ? 'modely' : 'modelů'}</span></div>
          {hpRange && <div class="s"><span class="n">{hpRange}</span><span class="l">výkon</span></div>}
          {sharedEngine && <div class="s"><span class="n n-text">{engines.length === 1 ? engines[0].split(' ').slice(0, 2).join(' ') : `${engines.length}×`}</span><span class="l">motor</span></div>}
          {sharedTransmission && <div class="s"><span class="n n-text">{transmissions.length === 1 ? transmissions[0].split(' ').slice(0, 2).join(' ') : `${transmissions.length}×`}</span><span class="l">převodovka</span></div>}
        </div>

        <div class="hero-actions">
          <a class="cta-primary" href={`/bazar/?brand=${encodeURIComponent(brand.slug)}&category=${category}&q=${encodeURIComponent(seriesNameClean)}`}>
            Hledat {seriesNameClean} v bazaru
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a class="cta-secondary" href={`/stroje/${brand.slug}/rada/${category}/${family}/`}>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
            Všechny generace {familyLab}
          </a>
        </div>
      </div>

      <div class="hero-right">
        <div class="hero-photo" style={`background-image:url('${heroPhoto}')`}>
          {series.models.length > 0 && (
            <div class="hero-photo-badge"><span class="n">{series.models.length}</span> {series.models.length === 1 ? 'model' : series.models.length < 5 ? 'modely' : 'modelů'}</div>
          )}
          {heroCreditAuthor && heroCreditUrl && (
            <a class="hero-photo-credit" href={heroCreditUrl} target="_blank" rel="noopener noreferrer"
               title={`Foto: ${heroCreditAuthor}${heroCreditLicense ? ` (${heroCreditLicense})` : ''} via Wikimedia Commons · upraveno (crop, konverze do WebP)`}>
              © {heroCreditAuthor}{heroCreditLicense ? ` · ${heroCreditLicense}` : ''} · upraveno
            </a>
          )}
        </div>
      </div>
    </section>

    <section class="models-section">
      <div class="ms-head">
        <div>
          <h2>Modely v řadě</h2>
          <p class="ms-sub">Seřazeno podle výkonu — od nejsilnějšího po nejslabší.</p>
        </div>
        {hpRange && <div class="ms-summary"><strong>{series.models.length}</strong> {series.models.length === 1 ? 'model' : series.models.length < 5 ? 'modely' : 'modelů'} · {hpRange}</div>}
      </div>

      <div class="models-table">
        <div class="mt-head">
          <span>Model</span>
          <span class="mt-col-power">Výkon</span>
          <span class="mt-col-year">Roky výroby</span>
          {categoryHasGrainTank && <span class="mt-col-tank">Bunkr</span>}
          <span class="mt-col-engine">Motor</span>
          <span class="mt-col-action"></span>
        </div>
        {sortedModels.map((m) => {
          const mYr = m.year_from ? (m.year_to ? `${m.year_from}–${m.year_to}` : `${m.year_from}–dosud`) : '—';
          const mIsCurrent = m.year_to === null && m.year_from !== null;
          return (
            <a href={`/stroje/${brand.slug}/${series.slug}/${modelUrlPart(m.slug)}/`} class="mt-row">
              <span class="mt-name">
                {m.name}
                {mIsCurrent && <span class="dot-current" title="Aktuální"></span>}
              </span>
              <span class="mt-power">
                {m.power_hp !== null ? (
                  <>
                    <strong>{m.power_hp} k</strong>
                    {m.power_kw && <span class="kw"> · {m.power_kw} kW</span>}
                  </>
                ) : '—'}
              </span>
              <span class="mt-year">{mYr}</span>
              {categoryHasGrainTank && (
                <span class="mt-tank">{m.grain_tank_l ? `${m.grain_tank_l.toLocaleString('cs-CZ')} l` : '—'}</span>
              )}
              <span class="mt-engine">{m.engine ?? '—'}</span>
              <span class="mt-go">Detail →</span>
            </a>
          );
        })}
      </div>
    </section>

    {siblings.length > 0 && (
      <section class="siblings">
        <div class="sib-head">
          <h2>Další generace {familyLab}</h2>
          <a class="sib-all" href={`/stroje/${brand.slug}/rada/${category}/${family}/`}>Všechny generace →</a>
        </div>
        <div class="sib-grid">
          {siblings.map((s) => {
            const sHp = s.minHp !== null && s.maxHp !== null
              ? (s.minHp === s.maxHp ? `${s.minHp} k` : `${s.minHp}–${s.maxHp} k`)
              : '';
            return (
              <a class="sib-card" href={`/stroje/${brand.slug}/${s.slug}/`}>
                <div class="sib-title-row">
                  <span class="sib-title">{s.name}</span>
                  {s.isCurrent ? (
                    <span class="sib-badge current"><span class="dot"></span>Aktuální</span>
                  ) : (
                    <span class="sib-badge legacy">Historie</span>
                  )}
                </div>
                <div class="sib-meta">
                  <span><strong>{s.modelCount}</strong> {s.modelCount === 1 ? 'model' : s.modelCount < 5 ? 'modely' : 'modelů'}</span>
                  {sHp && <><span class="sep"></span><span>{sHp}</span></>}
                  {s.yr && <><span class="sep"></span><span>{s.yr}</span></>}
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}

    <section class="big-cta">
      <div>
        <span class="cta-kicker">Hledáte konkrétní model?</span>
        <h2>{brand.name} {seriesNameClean} v Agro bazaru<br />— inzeráty od soukromých prodejců i dealerů.</h2>
        <p>Filtrujte podle modelu, výkonu a roku. Kontakt přímo na prodejce, bez provize.</p>
        <div class="cta-actions">
          <a class="cta-btn primary" href={`/bazar/?brand=${encodeURIComponent(brand.slug)}&category=${category}&q=${encodeURIComponent(seriesNameClean)}`}>
            Otevřít bazar
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a class="cta-btn ghost" href="/bazar/novy/">Přidat vlastní inzerát</a>
        </div>
      </div>
      <div class="cta-right">
        <div class="cta-photo" style={`background-image:url('${heroPhoto}')`}></div>
      </div>
    </section>

  </div>
</Layout>

<style>
  .series-page{
    --yellow:#FFEA00;
    --yellow-soft:#FFF6A8;
    --yellow-glow:rgba(255,234,0,.35);
    --ink:#0A0A0B;
    --body:#1E1E22;
    --muted:#6B6B72;
    --muted-2:#9A9AA3;
    --line:#EAEAEC;
    --line-2:#DFDFE3;
    --bg-cream:#FBFAF4;
    --card:#FFFFFF;
    --green:#0B7A3B;
    --green-soft:#E3F3EA;
    --legacy:#7A6B0B;
    --legacy-soft:#F5EFC8;
    --r-xl:24px;
    --r-lg:18px;
    --r-md:12px;
    --sh-1:0 1px 2px rgba(10,10,12,.04), 0 0 0 1px rgba(10,10,12,.03);
    --sh-3:0 18px 40px -12px rgba(10,10,12,.18), 0 0 0 1px rgba(10,10,12,.04);
    max-width:1280px;margin:0 auto;padding:26px 24px 96px;
    color:var(--body);
  }

  .series-page .breadcrumb{display:flex;gap:8px;align-items:center;font-size:13px;color:var(--muted);margin-bottom:22px;flex-wrap:wrap}
  .series-page .breadcrumb a{color:var(--muted);text-decoration:none;transition:color .15s}
  .series-page .breadcrumb a:hover{color:#000}
  .series-page .breadcrumb svg{width:14px;height:14px;color:var(--muted-2);flex-shrink:0}
  .series-page .breadcrumb .current{color:#000;font-weight:600}

  .series-page .hero{
    position:relative;overflow:hidden;color:#fff;border-radius:var(--r-xl);
    background:
      radial-gradient(600px 300px at 15% 20%, rgba(255,234,0,.18), transparent 60%),
      radial-gradient(700px 400px at 90% 90%, color-mix(in srgb, var(--brand-c1) 36%, transparent), transparent 60%),
      linear-gradient(135deg, #0E0E10 0%, #1C1C20 60%, #2A2A2F 100%);
    padding:44px 44px 38px;margin-bottom:22px;
    box-shadow:var(--sh-3);
    display:grid;grid-template-columns:1.35fr 1fr;gap:32px;align-items:center;
  }
  .series-page .hero::before{
    content:"";position:absolute;inset:0;pointer-events:none;opacity:.35;
    background-image:linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
    background-size:48px 48px;
    mask-image:radial-gradient(600px 400px at 70% 100%, black, transparent 70%);
  }
  .series-page .hero-left{position:relative;z-index:2}

  .series-page .hero-tags{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px}
  .series-page .tag{
    display:inline-flex;align-items:center;gap:6px;
    font:600 11px/1 'Chakra Petch',sans-serif;letter-spacing:.14em;text-transform:uppercase;
    padding:6px 11px;border-radius:6px;
  }
  .series-page .tag-brand{background:var(--yellow);color:#0A0A0B}
  .series-page .tag-cat{background:rgba(255,255,255,.1);color:#fff;border:1px solid rgba(255,255,255,.16)}
  .series-page .tag-fam{background:rgba(255,255,255,.06);color:#c8c8d0;border:1px solid rgba(255,255,255,.12)}
  .series-page .tag-current{background:rgba(11,180,90,.16);color:#5cdc8c;border:1px solid rgba(11,180,90,.4)}
  .series-page .tag-current .dot{width:7px;height:7px;background:#5cdc8c;border-radius:50%;box-shadow:0 0 0 3px rgba(92,220,140,.18)}
  .series-page .tag-legacy{background:rgba(180,160,80,.16);color:#dccc78;border:1px solid rgba(180,160,80,.32)}

  .series-page .hero h1{
    font-family:'Chakra Petch',sans-serif;font-weight:700;
    font-size:clamp(2.1rem,4.6vw,3.6rem);color:#fff;line-height:.98;letter-spacing:-.025em;margin:0;
  }
  .series-page .hero-year{
    margin-top:8px;font:500 16px 'Chakra Petch',sans-serif;color:var(--yellow);letter-spacing:.04em;
  }
  .series-page .hero-lede{max-width:580px;font-size:15.5px;color:#c8c8d0;margin:14px 0 22px;line-height:1.6}

  .series-page .hero-stats{display:flex;gap:24px;flex-wrap:wrap;margin-bottom:22px;font-family:'Chakra Petch',sans-serif}
  .series-page .hero-stats .s{display:flex;flex-direction:column;gap:3px;min-width:0}
  .series-page .hero-stats .n{font-size:24px;font-weight:700;color:#fff;line-height:1;letter-spacing:-.02em}
  .series-page .hero-stats .n-text{font-size:14px;font-weight:600;line-height:1.2;max-width:200px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .series-page .hero-stats .l{font-size:11px;color:#8a8a92;letter-spacing:.14em;text-transform:uppercase;font-weight:500}
  .series-page .hero-stats .s + .s{padding-left:24px;border-left:1px solid rgba(255,255,255,.12)}

  .series-page .hero-actions{display:flex;gap:10px;flex-wrap:wrap}
  .series-page .cta-primary{
    display:inline-flex;align-items:center;gap:10px;
    background:var(--yellow);color:#0A0A0B;
    padding:13px 18px;border-radius:12px;text-decoration:none;
    font:700 14px 'Chakra Petch',sans-serif;letter-spacing:.02em;
    transition:transform .15s, box-shadow .15s;
    box-shadow:0 14px 40px -10px var(--yellow-glow);
  }
  .series-page .cta-primary:hover{transform:translateY(-1px);box-shadow:0 20px 50px -8px var(--yellow-glow)}
  .series-page .cta-secondary{
    display:inline-flex;align-items:center;gap:8px;
    color:#c8c8d0;background:rgba(255,255,255,.06);
    border:1px solid rgba(255,255,255,.12);
    padding:13px 16px;border-radius:12px;text-decoration:none;
    font:500 13px 'Chakra Petch',sans-serif;letter-spacing:.02em;
    transition:.15s;
  }
  .series-page .cta-secondary:hover{background:rgba(255,255,255,.1);color:#fff;border-color:rgba(255,255,255,.2)}

  .series-page .hero-right{position:relative;z-index:1;min-height:280px;display:flex;align-items:center;justify-content:center}
  .series-page .hero-photo{
    width:100%;height:100%;min-height:280px;
    background-size:cover;background-position:center;
    border-radius:18px;
    box-shadow:0 30px 60px -20px rgba(0,0,0,.5), 0 0 0 1px rgba(255,255,255,.08);
    position:relative;overflow:hidden;
  }
  .series-page .hero-photo::after{
    content:"";position:absolute;inset:0;
    background:linear-gradient(135deg, rgba(14,14,16,.1) 0%, transparent 40%, color-mix(in srgb, var(--brand-c1) 24%, transparent) 100%);
  }
  .series-page .hero-photo-badge{
    position:absolute;left:16px;bottom:16px;z-index:2;
    background:rgba(10,10,11,.72);backdrop-filter:blur(10px);
    border:1px solid rgba(255,255,255,.1);
    color:#fff;padding:9px 13px;border-radius:10px;
    font:500 12px 'Chakra Petch',sans-serif;
  }
  .series-page .hero-photo-badge .n{font-weight:700;color:var(--yellow)}
  .series-page .hero-photo-credit{
    position:absolute;right:12px;bottom:12px;z-index:2;
    background:rgba(10,10,11,.6);backdrop-filter:blur(8px);
    border:1px solid rgba(255,255,255,.08);
    color:rgba(255,255,255,.78);text-decoration:none;
    padding:5px 9px;border-radius:7px;
    font:500 10.5px/1 'Chakra Petch',sans-serif;letter-spacing:.02em;
    max-width:60%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;
    transition:.15s;
  }
  .series-page .hero-photo-credit:hover{background:rgba(10,10,11,.85);color:#fff;border-color:rgba(255,255,255,.18)}

  .series-page .models-section{
    margin:24px 0;background:var(--card);border:1px solid var(--line);
    border-radius:var(--r-xl);padding:24px 24px 22px;
    box-shadow:var(--sh-1);
  }
  .series-page .ms-head{display:flex;justify-content:space-between;align-items:flex-end;gap:18px;margin-bottom:18px;flex-wrap:wrap}
