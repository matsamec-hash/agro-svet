---
export const prerender = true;
import Layout from '../../../../layouts/Layout.astro';
import { getAllBrands, getSeries, type StrojKategorie } from '../../../../lib/stroje';

export async function getStaticPaths() {
  const paths: { params: { brand: string; series: string } }[] = [];
  for (const brand of getAllBrands()) {
    for (const cat of Object.values(brand.categories || {})) {
      for (const s of cat.series || []) {
        paths.push({ params: { brand: brand.slug, series: s.slug } });
      }
    }
  }
  return paths;
}

const { brand: brandSlug, series: seriesSlug } = Astro.params;
const found = getSeries(brandSlug!, seriesSlug!);
if (!found) return Astro.redirect('/stroje/');
const { brand, category, series } = found;

const categoryLabels: Record<StrojKategorie, string> = {
  traktory: 'Traktory',
  kombajny: 'Kombajny',
};

const yr = series.year_from ? (series.year_to ? `${series.year_from}–${series.year_to}` : `${series.year_from}–dosud`) : '';
const hpValues = series.models.map((m) => m.power_hp).filter((x): x is number => x !== null);
const hpRange = hpValues.length ? (Math.min(...hpValues) === Math.max(...hpValues) ? `${Math.min(...hpValues)} k` : `${Math.min(...hpValues)}–${Math.max(...hpValues)} k`) : '—';

const sortedModels = [...series.models].sort((a, b) => (a.power_hp ?? 0) - (b.power_hp ?? 0));

function modelUrlPart(slug: string): string {
  return slug.startsWith(brand.slug + '-') ? slug.slice(brand.slug.length + 1) : slug;
}
---

<Layout
  title={`${brand.name} ${series.name} — všechny modely`}
  description={`Přehled všech modelů řady ${brand.name} ${series.name}. Výkony ${hpRange}, roky výroby ${yr}.`}
>
  <div style="max-width:1280px; margin:0 auto; padding:48px 32px 80px;">
    <div style="margin-bottom:8px; font-size:13px; color:#666;">
      <a href="/stroje/" style="color:#666; text-decoration:none;">Katalog</a>
      <span style="margin:0 6px;">/</span>
      <a href={`/stroje/${brand.slug}/`} style="color:#666; text-decoration:none;">{brand.name}</a>
      <span style="margin:0 6px;">/</span>
      <span style="color:#1a1a1a;">{series.name}</span>
    </div>

    <div style="margin-bottom:32px; padding-bottom:24px; border-bottom:1px solid #e8e8e8;">
      <span style="background:#FFFF00; color:#000; font-family:'Chakra Petch',sans-serif; font-size:11px; padding:3px 8px; border-radius:3px; text-transform:uppercase; letter-spacing:1px;">
        {brand.name} · {categoryLabels[category]}
      </span>
      <h1 style="font-family:'Chakra Petch',sans-serif; font-size:clamp(1.8rem,4.5vw,2.8rem); font-weight:700; letter-spacing:-1px; color:#1a1a1a; margin-top:10px; margin-bottom:14px;">
        {series.name}
      </h1>
      <div style="display:flex; gap:20px; flex-wrap:wrap; font-size:14px; color:#666; margin-bottom:14px;">
        <span style="display:inline-flex; align-items:center; gap:6px;">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
          {yr}
        </span>
        <span style="display:inline-flex; align-items:center; gap:6px;">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          {hpRange}
        </span>
        <span style="display:inline-flex; align-items:center; gap:6px;">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" y1="9" x2="20" y2="9"/><line x1="4" y1="15" x2="20" y2="15"/><line x1="10" y1="3" x2="8" y2="21"/><line x1="16" y1="3" x2="14" y2="21"/></svg>
          {series.models.length} modelů
        </span>
      </div>
      {series.description && <p style="font-size:15px; color:#444; max-width:820px; line-height:1.65;">{series.description}</p>}
    </div>

    <div style="overflow-x:auto; border:1px solid #e8e8e8; border-radius:18px; background:#fff;">
      <table style="width:100%; border-collapse:collapse; font-size:14px;">
        <thead>
          <tr style="background:#fafafa; text-align:left;">
            <th style="padding:14px 16px; font-weight:500; color:#333; border-bottom:1px solid #e8e8e8;">Model</th>
            <th style="padding:14px 16px; font-weight:500; color:#333; border-bottom:1px solid #e8e8e8;">Výkon</th>
            <th style="padding:14px 16px; font-weight:500; color:#333; border-bottom:1px solid #e8e8e8;">Roky výroby</th>
            {category === 'kombajny' && <th style="padding:14px 16px; font-weight:500; color:#333; border-bottom:1px solid #e8e8e8;">Bunkr</th>}
            <th style="padding:14px 16px; font-weight:500; color:#333; border-bottom:1px solid #e8e8e8;">Motor</th>
            <th style="padding:14px 16px; border-bottom:1px solid #e8e8e8;"></th>
          </tr>
        </thead>
        <tbody>
          {sortedModels.map((m) => {
            const mYr = m.year_from ? (m.year_to ? `${m.year_from}–${m.year_to}` : `${m.year_from}–dosud`) : '—';
            return (
              <tr style="border-bottom:1px solid #f0f0f0;" class="row-hover">
                <td style="padding:14px 16px;">
                  <a href={`/stroje/${brand.slug}/${series.slug}/${modelUrlPart(m.slug)}/`} style="color:#1a1a1a; text-decoration:none; font-family:'Chakra Petch',sans-serif; font-weight:700; font-size:16px;">
                    {m.name}
                  </a>
                </td>
                <td style="padding:14px 16px;">
                  {m.power_hp ? <>
                    <strong>{m.power_hp} k</strong>
                    {m.power_kw && <span style="color:#666; font-size:12px;"> ({m.power_kw} kW)</span>}
                  </> : '—'}
                </td>
                <td style="padding:14px 16px; color:#666;">{mYr}</td>
                {category === 'kombajny' && (
                  <td style="padding:14px 16px; color:#666;">
                    {m.grain_tank_l ? `${m.grain_tank_l.toLocaleString('cs-CZ')} l` : '—'}
                  </td>
                )}
                <td style="padding:14px 16px; color:#666; font-size:13px;">{m.engine ?? '—'}</td>
                <td style="padding:14px 16px; text-align:right;">
                  <a href={`/stroje/${brand.slug}/${series.slug}/${modelUrlPart(m.slug)}/`} style="font-size:12px; color:#666; text-decoration:none; border:1px solid #ddd; padding:6px 10px; border-radius:6px;">
                    Detail →
                  </a>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>

    <div style="margin-top:32px; text-align:center;">
      <a href={`/bazar/?znacka=${encodeURIComponent(brand.name)}`} style="display:inline-block; background:#FFFF00; color:#000; padding:14px 24px; border-radius:10px; text-decoration:none; font-family:'Chakra Petch',sans-serif; font-weight:700; font-size:14px;">
        Hledat {brand.name} v bazaru →
      </a>
    </div>
  </div>

  <style>
    .row-hover:hover { background: #fafafa; }
  </style>
</Layout>
