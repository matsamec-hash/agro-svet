---
export const prerender = true;
import Layout from '../../../layouts/Layout.astro';
import { getAllBrands, getBrand, type StrojKategorie } from '../../../lib/stroje';

export async function getStaticPaths() {
  return getAllBrands().map((b) => ({ params: { brand: b.slug } }));
}

const { brand: brandSlug } = Astro.params;
const brand = getBrand(brandSlug!);
if (!brand) return Astro.redirect('/stroje/');

const categoryLabels: Record<StrojKategorie, string> = {
  traktory: 'Traktory',
  kombajny: 'Kombajny',
};

function formatRange(values: (number | null | undefined)[]): string {
  const vs = values.filter((x): x is number => typeof x === 'number');
  if (vs.length === 0) return '—';
  const min = Math.min(...vs);
  const max = Math.max(...vs);
  return min === max ? String(min) : `${min}–${max}`;
}
---

<Layout
  title={`${brand.name} — katalog strojů`}
  description={`Kompletní přehled traktorů a kombajnů značky ${brand.name}. Všechny řady a modely s výkony a roky výroby.`}
>
  <div style="max-width:1280px; margin:0 auto; padding:48px 32px 80px;">
    <div style="margin-bottom:8px;">
      <a href="/stroje/" style="font-size:13px; color:#666; text-decoration:none;">← Katalog strojů</a>
    </div>

    <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:24px; flex-wrap:wrap; margin-bottom:32px; padding-bottom:24px; border-bottom:1px solid #e8e8e8;">
      <div>
        <h1 style="font-family:'Chakra Petch',sans-serif; font-size:clamp(2rem,5vw,3.2rem); font-weight:700; letter-spacing:-1px; color:#1a1a1a; margin-bottom:10px;">
          {brand.name}
        </h1>
        <div style="display:flex; gap:16px; flex-wrap:wrap; font-size:14px; color:#666; margin-bottom:12px;">
          <span>🌍 {brand.country}</span>
          <span>📅 Založeno {brand.founded}</span>
          {brand.website && <a href={brand.website} target="_blank" rel="noopener" style="color:#1a1a1a; text-decoration:underline;">🔗 {brand.website.replace(/^https?:\/\//, '')}</a>}
        </div>
        {brand.description && <p style="font-size:15px; color:#444; max-width:720px; line-height:1.6;">{brand.description}</p>}
      </div>
      <a href={`/bazar/?znacka=${encodeURIComponent(brand.name)}`} style="background:#FFFF00; color:#000; padding:12px 20px; border-radius:10px; text-decoration:none; font-family:'Chakra Petch',sans-serif; font-weight:700; font-size:14px; white-space:nowrap;">
        Hledat v bazaru →
      </a>
    </div>

    {(Object.entries(brand.categories) as [StrojKategorie, typeof brand.categories[StrojKategorie]][]).map(([catKey, cat]) => (
      <section style="margin-bottom:48px;">
        <h2 style="font-family:'Chakra Petch',sans-serif; font-size:28px; font-weight:700; color:#1a1a1a; margin-bottom:20px; display:flex; align-items:center; gap:12px;">
          <span>{categoryLabels[catKey] ?? cat.name}</span>
          <span style="font-size:14px; font-weight:400; color:#888;">{cat.series.reduce((acc, s) => acc + s.models.length, 0)} modelů</span>
        </h2>

        <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(320px,1fr)); gap:16px;">
          {cat.series.map((series) => {
            const seriesHp = series.models.map((m) => m.power_hp);
            const yr = series.year_from ? (series.year_to ? `${series.year_from}–${series.year_to}` : `${series.year_from}–dosud`) : '';
            return (
              <a href={`/stroje/${brand.slug}/${series.slug}/`} style="display:block; text-decoration:none; color:inherit; background:#fff; border:1px solid #e8e8e8; border-radius:18px; padding:20px; transition:box-shadow .2s, transform .2s; border-color:#e8e8e8;" class="series-card">
                <div style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:8px; gap:8px;">
                  <h3 style="font-family:'Chakra Petch',sans-serif; font-size:20px; font-weight:700; color:#1a1a1a;">{series.name}</h3>
                  <span style="font-size:12px; color:#888; white-space:nowrap;">{yr}</span>
                </div>
                <div style="display:flex; gap:12px; font-size:13px; color:#555; margin-bottom:12px;">
                  <span>⚡ {formatRange(seriesHp)} k</span>
                  <span>· {series.models.length} modelů</span>
                </div>
                {series.description && <p style="font-size:13px; color:#666; line-height:1.5; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">{series.description}</p>}
              </a>
            );
          })}
        </div>
      </section>
    ))}
  </div>

  <style>
    .series-card:hover { box-shadow: 0 6px 20px rgba(0,0,0,.08); transform: translateY(-2px); border-color: #FFFF00; }
  </style>
</Layout>
