---
export const prerender = true;
import Layout from '../../../layouts/Layout.astro';
import { getAllBrands, getBrand, seriesFamily, familyLabel, type StrojKategorie } from '../../../lib/stroje';

export async function getStaticPaths() {
  return getAllBrands().map((b) => ({ params: { brand: b.slug } }));
}

const { brand: brandSlug } = Astro.params;
const brand = getBrand(brandSlug!);
if (!brand) return Astro.redirect('/stroje/');

const categoryLabels: Record<StrojKategorie, string> = {
  traktory: 'Traktory',
  kombajny: 'Kombajny',
};

function buildFamilyTiles(catKey: StrojKategorie) {
  const cat = brand.categories?.[catKey];
  if (!cat) return [];
  type Tile = {
    family: string;
    label: string;
    modelCount: number;
    seriesCount: number;
    seriesNames: string[];
    minHp: number | null;
    maxHp: number | null;
    minYear: number | null;
    maxYear: number | null;
  };
  const byFamily = new Map<string, Tile>();
  for (const s of cat.series ?? []) {
    const fam = seriesFamily(s.slug);
    let t = byFamily.get(fam);
    if (!t) {
      t = {
        family: fam,
        label: familyLabel(fam),
        modelCount: 0,
        seriesCount: 0,
        seriesNames: [],
        minHp: null,
        maxHp: null,
        minYear: null,
        maxYear: null,
      };
      byFamily.set(fam, t);
    }
    t.seriesCount += 1;
    t.seriesNames.push(s.name);
    for (const m of s.models ?? []) {
      t.modelCount += 1;
      if (m.power_hp !== null) {
        t.minHp = t.minHp === null ? m.power_hp : Math.min(t.minHp, m.power_hp);
        t.maxHp = t.maxHp === null ? m.power_hp : Math.max(t.maxHp, m.power_hp);
      }
      if (m.year_from !== null) {
        t.minYear = t.minYear === null ? m.year_from : Math.min(t.minYear, m.year_from);
      }
      if (m.year_to !== null) {
        t.maxYear = t.maxYear === null ? m.year_to : Math.max(t.maxYear, m.year_to);
      } else if (m.year_from !== null) {
        // Still in production
        t.maxYear = null;
      }
    }
  }
  return [...byFamily.values()].sort((a, b) => {
    const aDigit = /^\d+$/.test(a.family);
    const bDigit = /^\d+$/.test(b.family);
    if (aDigit && bDigit) return parseInt(a.family) - parseInt(b.family);
    if (aDigit) return -1;
    if (bDigit) return 1;
    return a.family.localeCompare(b.family, 'cs');
  });
}

const categoriesData = (Object.entries(brand.categories ?? {}) as [StrojKategorie, any][]).map(([catKey, cat]) => ({
  slug: catKey,
  name: categoryLabels[catKey] ?? cat.name,
  tiles: buildFamilyTiles(catKey),
  totalModels: (cat.series ?? []).reduce((acc: number, s: any) => acc + (s.models?.length ?? 0), 0),
}));

const totalModels = categoriesData.reduce((acc, c) => acc + c.totalModels, 0);
---

<Layout
  title={`${brand.name} — katalog strojů`}
  description={`Přehled modelových řad značky ${brand.name}. Dlaždice pro každou řadu s počtem modelů a rozsahem výkonů.`}
>
  <div style="max-width:1280px; margin:0 auto; padding:48px 32px 80px;">
    <div style="margin-bottom:8px;">
      <a href="/stroje/" style="font-size:13px; color:#666; text-decoration:none;">← Katalog strojů</a>
    </div>

    <!-- Brand hero -->
    <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:24px; flex-wrap:wrap; margin-bottom:32px; padding-bottom:24px; border-bottom:1px solid #e8e8e8;">
      <div>
        <h1 style="font-family:'Chakra Petch',sans-serif; font-size:clamp(2rem,5vw,3.2rem); font-weight:700; letter-spacing:-1px; color:#1a1a1a; margin-bottom:10px;">
          {brand.name}
        </h1>
        <div style="display:flex; gap:16px; flex-wrap:wrap; font-size:14px; color:#666; margin-bottom:12px;">
          <span style="display:inline-flex; align-items:center; gap:6px;">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            {brand.country}
          </span>
          <span style="display:inline-flex; align-items:center; gap:6px;">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
            Založeno {brand.founded}
          </span>
          <span style="display:inline-flex; align-items:center; gap:6px;">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" y1="9" x2="20" y2="9"/><line x1="4" y1="15" x2="20" y2="15"/><line x1="10" y1="3" x2="8" y2="21"/><line x1="16" y1="3" x2="14" y2="21"/></svg>
            {totalModels} modelů v katalogu
          </span>
          {brand.website && (
            <a href={brand.website} target="_blank" rel="noopener noreferrer" style="display:inline-flex; align-items:center; gap:6px; color:#1a1a1a; text-decoration:underline;">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
              {brand.website.replace(/^https?:\/\//, '')}
            </a>
          )}
        </div>
        {brand.description && <p style="font-size:15px; color:#444; max-width:720px; line-height:1.6;">{brand.description}</p>}
      </div>
      <a href={`/bazar/?brand=${encodeURIComponent(brand.slug)}`} style="background:#FFFF00; color:#000; padding:12px 20px; border-radius:10px; text-decoration:none; font-family:'Chakra Petch',sans-serif; font-weight:700; font-size:14px; white-space:nowrap;">
        Hledat v bazaru →
      </a>
    </div>

    {categoriesData.map((cat) => (
      <section style="margin-bottom:48px;">
        <header style="display:flex; justify-content:space-between; align-items:baseline; gap:12px; margin-bottom:20px;">
          <h2 style="font-family:'Chakra Petch',sans-serif; font-size:26px; font-weight:700; color:#1a1a1a;">
            {cat.name}
          </h2>
          <div style="font-size:13px; color:#666;">
            <span>{cat.totalModels} modelů</span>
            <span style="margin:0 6px;">·</span>
            <span>{cat.tiles.length} řad</span>
          </div>
        </header>

        <div class="family-grid">
          {cat.tiles.map((tile) => {
            const hpStr = tile.minHp !== null && tile.maxHp !== null
              ? (tile.minHp === tile.maxHp ? `${tile.minHp} k` : `${tile.minHp}–${tile.maxHp} k`)
              : '';
            const yrStr = tile.minYear !== null
              ? (tile.maxYear === null ? `${tile.minYear}–dosud` : `${tile.minYear}–${tile.maxYear}`)
              : '';
            return (
              <a href={`/stroje/${brand.slug}/rada/${cat.slug}/${tile.family}/`} class="family-tile">
                <div class="family-tile-img" aria-hidden="true">
                  <div class="family-tile-placeholder">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                      {cat.slug === 'traktory' ? (
                        <>
                          <circle cx="7" cy="17" r="2"/>
                          <circle cx="18" cy="17" r="3"/>
                          <path d="M4 17H3v-4l2-2h4l3-4h5v10h-2"/>
                        </>
                      ) : (
                        <>
                          <rect x="3" y="9" width="18" height="9" rx="1"/>
                          <path d="M3 9V7c0-1 1-2 2-2h14c1 0 2 1 2 2v2"/>
                          <circle cx="7" cy="18" r="2"/>
                          <circle cx="17" cy="18" r="2"/>
                        </>
                      )}
                    </svg>
                  </div>
                </div>
                <div class="family-tile-body">
                  <h3 class="family-tile-title">{tile.label}</h3>
                  <div class="family-tile-meta">
                    <span>{tile.modelCount} {tile.modelCount === 1 ? 'model' : tile.modelCount < 5 ? 'modely' : 'modelů'}</span>
                    {hpStr && (
                      <>
                        <span>·</span>
                        <span style="display:inline-flex; align-items:center; gap:4px;">
                          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                          {hpStr}
                        </span>
                      </>
                    )}
                  </div>
                  {yrStr && <div class="family-tile-year">{yrStr}</div>}
                  {tile.seriesCount > 1 && (
                    <div class="family-tile-series">{tile.seriesCount} generací</div>
                  )}
                </div>
              </a>
            );
          })}
        </div>
      </section>
    ))}
  </div>

  <style>
    .family-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 16px;
    }
    .family-tile {
      display: block;
      background: #fff;
      border: 1px solid #e8e8e8;
      border-radius: 18px;
      overflow: hidden;
      text-decoration: none;
      color: inherit;
      transition: border-color .2s, box-shadow .2s, transform .1s;
    }
    .family-tile:hover {
      border-color: #FFFF00;
      box-shadow: 0 8px 24px rgba(0,0,0,.08);
      transform: translateY(-2px);
    }
    .family-tile-img {
      aspect-ratio: 4 / 3;
      background: linear-gradient(135deg, #fafafa 0%, #f0f0f0 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      color: #bbb;
    }
    .family-tile:hover .family-tile-img {
      background: linear-gradient(135deg, #fffcd9 0%, #FFFF00 100%);
      color: #1a1a1a;
    }
    .family-tile-placeholder {
      opacity: .6;
    }
    .family-tile:hover .family-tile-placeholder { opacity: 1; }
    .family-tile-body {
      padding: 16px 18px 18px;
    }
    .family-tile-title {
      font-family: 'Chakra Petch', sans-serif;
      font-size: 22px;
      font-weight: 700;
      color: #1a1a1a;
      margin-bottom: 8px;
    }
    .family-tile-meta {
      display: flex;
      gap: 6px;
      font-size: 13px;
      color: #555;
      flex-wrap: wrap;
      margin-bottom: 4px;
    }
    .family-tile-meta span { color: #555; }
    .family-tile-year {
      font-size: 12px;
      color: #666;
    }
    .family-tile-series {
      margin-top: 8px;
      font-size: 11px;
      letter-spacing: .05em;
      text-transform: uppercase;
      color: #666;
      background: #fafafa;
      padding: 4px 8px;
      border-radius: 6px;
      display: inline-block;
    }
  </style>
</Layout>
