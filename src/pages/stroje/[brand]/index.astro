<script>
  const pills = document.querySelectorAll<HTMLAnchorElement>('.brand-page .cat-pills .pill');
  const sections = document.querySelectorAll<HTMLElement>('.brand-page .cat[id]');
  if (pills.length && sections.length && 'IntersectionObserver' in window) {
    const byId = new Map<string, HTMLAnchorElement>();
    pills.forEach((p) => {
      const href = p.getAttribute('href') || '';
      if (href.startsWith('#')) byId.set(href.slice(1), p);
    });
    const io = new IntersectionObserver((entries) => {
      let topMost: { id: string; top: number } | null = null;
      entries.forEach((e) => {
        if (e.isIntersecting) {
          const target = e.target as HTMLElement;
          const top = e.boundingClientRect.top;
          if (!topMost || top < topMost.top) topMost = { id: target.id, top };
        }
      });
      if (topMost) {
        pills.forEach((p) => p.classList.remove('active'));
        const t = topMost as { id: string; top: number };
        byId.get(t.id)?.classList.add('active');
      }
    }, { rootMargin: '-160px 0px -60% 0px', threshold: 0 });
    sections.forEach((s) => io.observe(s));
  }
</script>
