---
export const prerender = false;
import Layout from '../../../layouts/Layout.astro';
import { getAllBrands, getBrand, seriesFamily, familyLabel, type StrojKategorie } from '../../../lib/stroje';
import { createServerClient } from '../../../lib/supabase';

export async function getStaticPaths() {
  return getAllBrands().map((b) => ({ params: { brand: b.slug } }));
}

const { brand: brandSlug } = Astro.params;
const brand = getBrand(brandSlug!);
if (!brand) return Astro.redirect('/stroje/');

const categoryLabels: Record<StrojKategorie, string> = {
  traktory: 'Traktory',
  kombajny: 'Kombajny',
};
const categoryHero: Record<StrojKategorie, string> = {
  traktory: '/images/traktor.webp',
  kombajny: '/images/kombajn.webp',
};

const brandColors: Record<string, [string, string]> = {
  'john-deere': ['#4A9838', '#2E6B22'],
  fendt: ['#3FA85D', '#0E6730'],
  claas: ['#9C9532', '#65601A'],
  'deutz-fahr': ['#2BA84A', '#1a5e2a'],
  kubota: ['#FF6B1A', '#C24414'],
  'new-holland': ['#3874AC', '#1A4370'],
  'case-ih': ['#D62A2A', '#8F1818'],
  'massey-ferguson': ['#D62A2A', '#8F1818'],
  valtra: ['#1F1F1F', '#0A0A0A'],
  zetor: ['#E93A3A', '#A01818'],
};
function brandTone(slug: string): [string, string] {
  return brandColors[slug] ?? ['#2a2a30', '#0a0a0b'];
}

type Tile = {
  family: string;
  label: string;
  modelCount: number;
  seriesCount: number;
  minHp: number | null;
  maxHp: number | null;
  minYear: number | null;
  maxYear: number | null;
  hasCurrent: boolean;
  coverImage: string | null;
  coverCreditUrl: string | null;
  coverCreditAuthor: string | null;
  coverCreditLicense: string | null;
};

function buildTilesForCategory(catKey: StrojKategorie): Tile[] {
  const cat = brand.categories?.[catKey];
  if (!cat) return [];
  const byFamily = new Map<string, Tile>();
  for (const s of cat.series ?? []) {
    const fam = (s as any).family || seriesFamily(s.slug);
    const labelOverride = (s as any).family_label;
    let t = byFamily.get(fam);
    if (!t) {
      t = {
        family: fam,
        label: labelOverride || familyLabel(fam),
        modelCount: 0,
        seriesCount: 0,
        minHp: null,
        maxHp: null,
        minYear: null,
        maxYear: null,
        hasCurrent: false,
        coverImage: null,
        coverCreditUrl: null,
        coverCreditAuthor: null,
        coverCreditLicense: null,
      };
      byFamily.set(fam, t);
    }
    t.seriesCount += 1;
    if (labelOverride) t.label = labelOverride;
    if (!t.coverImage && (s as any).image_url) {
      t.coverImage = (s as any).image_url;
      t.coverCreditUrl = (s as any).image_credit_url || null;
      t.coverCreditAuthor = (s as any).image_credit || null;
      t.coverCreditLicense = (s as any).image_license || null;
    }
    for (const m of s.models ?? []) {
      t.modelCount += 1;
      if (m.power_hp !== null) {
        t.minHp = t.minHp === null ? m.power_hp : Math.min(t.minHp, m.power_hp);
        t.maxHp = t.maxHp === null ? m.power_hp : Math.max(t.maxHp, m.power_hp);
      }
      if (m.year_from !== null) {
        t.minYear = t.minYear === null ? m.year_from : Math.min(t.minYear, m.year_from);
      }
      if (m.year_to === null && m.year_from !== null) {
        t.hasCurrent = true;
      } else if (m.year_to !== null) {
        t.maxYear = t.maxYear === null ? m.year_to : Math.max(t.maxYear, m.year_to);
      }
    }
  }
  return [...byFamily.values()];
}

function tileSort(a: Tile, b: Tile): number {
  if (a.hasCurrent !== b.hasCurrent) return a.hasCurrent ? -1 : 1;
  const aMax = a.maxHp ?? 0;
  const bMax = b.maxHp ?? 0;
  if (aMax !== bMax) return bMax - aMax;
  if (a.modelCount !== b.modelCount) return b.modelCount - a.modelCount;
  return a.family.localeCompare(b.family, 'cs');
}

function familySublabel(family: string): string {
  if (/^\d+$/.test(family)) return `${family}. řada`;
  return '';
}

type CategorySection = {
  slug: StrojKategorie;
  name: string;
  totalModels: number;
  totalSeries: number;
  minHp: number | null;
  maxHp: number | null;
  currentTiles: Tile[];
  legacyTiles: Tile[];
  hpMaxForBar: number;
  heroFallback: string;
};

const categories: CategorySection[] = [];
for (const [catKey, cat] of Object.entries(brand.categories ?? {}) as [StrojKategorie, any][]) {
  const tiles = buildTilesForCategory(catKey);
  if (tiles.length === 0) continue;
  const sorted = [...tiles].sort(tileSort);
  const currentTiles = sorted.filter((t) => t.hasCurrent);
  // Display strongest-on-the-right (ASC by max hp) for natural left-to-right reading
  currentTiles.sort((a, b) => (a.maxHp ?? 0) - (b.maxHp ?? 0));
  const legacyTiles = sorted.filter((t) => !t.hasCurrent);
  legacyTiles.sort((a, b) => (b.minYear ?? 0) - (a.minYear ?? 0));

  const totalModels = (cat.series ?? []).reduce((acc: number, s: any) => acc + (s.models?.length ?? 0), 0);
  const totalSeries = (cat.series ?? []).length;
  const hpAll = tiles.flatMap((t) => [t.minHp, t.maxHp]).filter((x): x is number => x !== null);
  categories.push({
    slug: catKey,
    name: categoryLabels[catKey] ?? cat.name,
    totalModels,
    totalSeries,
    minHp: hpAll.length ? Math.min(...hpAll) : null,
    maxHp: hpAll.length ? Math.max(...hpAll) : null,
    currentTiles,
    legacyTiles,
    hpMaxForBar: catKey === 'traktory' ? 620 : 700,
    heroFallback: categoryHero[catKey],
  });
}

const totalModels = categories.reduce((acc, c) => acc + c.totalModels, 0);
const totalSeries = categories.reduce((acc, c) => acc + c.totalSeries, 0);
const allHp = categories.flatMap((c) => [c.minHp, c.maxHp]).filter((x): x is number => x !== null);
const minHp = allHp.length ? Math.min(...allHp) : null;
const maxHp = allHp.length ? Math.max(...allHp) : null;

// Pick the most prominent current series cover for hero (highest max hp tile that has cover)
let heroPhoto: string | null = null;
let heroCreditUrl: string | null = null;
let heroCreditAuthor: string | null = null;
let heroCreditLicense: string | null = null;
for (const c of categories) {
  for (const t of [...c.currentTiles].sort((a, b) => (b.maxHp ?? 0) - (a.maxHp ?? 0))) {
    if (t.coverImage) {
      heroPhoto = t.coverImage;
      heroCreditUrl = t.coverCreditUrl;
      heroCreditAuthor = t.coverCreditAuthor;
      heroCreditLicense = t.coverCreditLicense;
      break;
    }
  }
  if (heroPhoto) break;
}
if (!heroPhoto) heroPhoto = categories[0]?.heroFallback ?? '/images/traktor.webp';

function hpBar(min: number | null, max: number | null, hpMax: number): { from: number; span: number } {
  if (min === null || max === null) return { from: 0, span: 0 };
  const from = Math.max(0, Math.min(100, (min / hpMax) * 100));
  const to = Math.max(0, Math.min(100, (max / hpMax) * 100));
  return { from, span: Math.max(2, to - from) };
}

const [brandC1, brandC2] = brandTone(brand.slug);

const websiteHost = brand.website ? brand.website.replace(/^https?:\/\//, '').replace(/\/$/, '') : '';

// Live count inzerátů této značky v bazaru
let bazarCount = 0;
try {
  const supabase = createServerClient();
  const { count } = await supabase
    .from('bazar_listings')
    .select('id', { count: 'exact', head: true })
    .eq('status', 'active')
    .eq('brand', brand.slug);
  bazarCount = count ?? 0;
} catch {}

const brandUrl = `https://agro-svet.cz/stroje/${brand.slug}/`;
const sameAs: string[] = [];
if ((brand as any).wikipedia) sameAs.push((brand as any).wikipedia);
if ((brand as any).wikidata) sameAs.push((brand as any).wikidata);
if (brand.website) sameAs.push(brand.website);

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Domů', item: 'https://agro-svet.cz/' },
    { '@type': 'ListItem', position: 2, name: 'Technika', item: 'https://agro-svet.cz/stroje/' },
    { '@type': 'ListItem', position: 3, name: brand.name, item: brandUrl },
  ],
};
const brandJsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': ['Brand', 'Organization'],
  name: brand.name,
  url: brandUrl,
  ...(brand.logo && { logo: brand.logo.startsWith('http') ? brand.logo : `https://agro-svet.cz${brand.logo}` }),
  ...(brand.description && { description: brand.description }),
  ...(brand.founded && { foundingDate: String(brand.founded) }),
  ...(brand.country && {
    foundingLocation: { '@type': 'Place', name: brand.country },
  }),
  ...(sameAs.length > 0 && { sameAs }),
};
---

<Layout
  title={`${brand.name} — katalog modelů a řad`}
  description={`${brand.name} (${brand.country}, založeno ${brand.founded}) — kompletní přehled ${totalModels} modelů ve ${totalSeries} řadách. Aktuální produkce i historické modely pro bazarový průzkum.`}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(brandJsonLd)} />
  <div class="brand-page">

    <nav class="breadcrumb" aria-label="Cesta">
      <a href="/">Domů</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/stroje/">Technika</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <span class="current">{brand.name}</span>
    </nav>

    <section class="hero" style={`--brand-c1:${brandC1};--brand-c2:${brandC2};`}>
      <div class="hero-left">
        <span class="kicker"><span class="dot"></span>Značka · Technika</span>
        <h1>{brand.name} <em>katalog</em></h1>
        {brand.description && <p class="hero-lede">{brand.description}</p>}

        <div class="hero-stats">
          <div class="s"><span class="n">{totalModels}+</span><span class="l">modelů</span></div>
          <div class="s"><span class="n">{totalSeries}</span><span class="l">řad</span></div>
          {minHp !== null && maxHp !== null && (
            <div class="s"><span class="n">{minHp}–{maxHp} k</span><span class="l">výkon</span></div>
          )}
          <div class="s"><span class="n">{brand.founded}</span><span class="l">založeno · {brand.country}</span></div>
        </div>

        <div class="hero-actions">
          <a class="cta-primary" href={`/bazar/?brand=${encodeURIComponent(brand.slug)}`}>
            {bazarCount > 0 ? `${bazarCount} ${bazarCount === 1 ? 'inzerát' : bazarCount < 5 ? 'inzeráty' : 'inzerátů'} v bazaru` : `Hledat ${brand.name} v bazaru`}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          {brand.website && (
            <a class="cta-secondary" href={brand.website} target="_blank" rel="noopener noreferrer">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
              {websiteHost}
            </a>
          )}
        </div>
      </div>

      <div class="hero-right">
        <div class="hero-photo" style={`background-image:url('${heroPhoto}')`}>
          <div class="hero-photo-logo">
            <img src={`/images/stroje/brands/${brand.slug}.png`} alt={`${brand.name} logo`} loading="eager" />
          </div>
          <div class="hero-photo-badge"><span class="n">{totalModels}+</span> modelů v katalogu</div>
          {heroCreditAuthor && heroCreditUrl && (
            <a class="hero-photo-credit" href={heroCreditUrl} target="_blank" rel="noopener noreferrer"
               title={`Foto: ${heroCreditAuthor}${heroCreditLicense ? ` (${heroCreditLicense})` : ''} via Wikimedia Commons · upraveno (crop, konverze do WebP)`}>
              © {heroCreditAuthor}{heroCreditLicense ? ` · ${heroCreditLicense}` : ''} · upraveno
            </a>
          )}
        </div>
      </div>
    </section>

    {categories.length > 1 && (
      <div class="split-bar">
        <div class="split-inner">
          <nav class="cat-pills" aria-label="Kategorie">
            {categories.map((c, i) => (
              <a class:list={['pill', { active: i === 0 }]} href={`#${c.slug}`}>{c.name} <span class="c">{c.totalModels}</span></a>
            ))}
          </nav>
        </div>
      </div>
    )}

    {categories.map((cat) => (
      <section class="cat" id={cat.slug}>
        <div class="cat-head">
          <div class="cat-title">
            <h2>{cat.name}</h2>
            <div class="cat-meta">
              <strong>{cat.totalModels} modelů</strong> <span>v {cat.totalSeries} řadách</span>
              {cat.minHp !== null && cat.maxHp !== null && (<><span class="sep"></span><strong>{cat.minHp}–{cat.maxHp} k</strong></>)}
            </div>
          </div>
          <a class="cat-cta" href={`/stroje/${cat.slug}/`}>
            Všechny značky
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>

        {cat.currentTiles.length > 0 && (
          <>
            <div class="block-label">
              <span class="status current"><span class="dot"></span>Aktuální v prodeji</span>
            </div>
            <div class="family-grid">
              {cat.currentTiles.map((t) => {
                const bar = hpBar(t.minHp, t.maxHp, cat.hpMaxForBar);
                const yearStr = t.minYear !== null
                  ? (t.hasCurrent ? `${t.minYear}–dosud` : (t.maxYear ? `${t.minYear}–${t.maxYear}` : `${t.minYear}`))
                  : '';
                const sub = familySublabel(t.family);
                const hpStr = t.minHp !== null && t.maxHp !== null
                  ? (t.minHp === t.maxHp ? `${t.minHp} k` : `${t.minHp}–${t.maxHp} k`)
                  : '';
                const coverStyle = t.coverImage
                  ? `background-image:url('${t.coverImage}'); background-color:#FFFFFF; background-size:cover; background-position:center;`
                  : `background:linear-gradient(135deg, ${brandC1} 0%, ${brandC2} 100%)`;
                return (
                  <a class="family-tile" href={`/stroje/${brand.slug}/rada/${cat.slug}/${t.family}/`}>
                    <div class="ft-cover" data-has-photo={t.coverImage ? 'true' : 'false'} style={coverStyle}>
                      {!t.coverImage && (
                        <svg class="ft-silhouette" width="120" height="68" viewBox="0 0 140 80" fill="rgba(0,0,0,.18)" aria-hidden="true">
                          {cat.slug === 'traktory' ? (
                            <>
                              <circle cx="100" cy="58" r="16"/><circle cx="42" cy="60" r="11"/>
                              <path d="M26 54 Q32 28 54 26 L78 22 L86 12 L112 11 L120 22 L132 32 L132 54 Z"/>
                            </>
                          ) : (
                            <>
                              <rect x="20" y="42" width="100" height="22" rx="3"/>
                              <path d="M20 42 Q25 24 50 22 L110 22 Q120 24 120 42 Z"/>
                              <circle cx="40" cy="68" r="8"/><circle cx="100" cy="68" r="8"/>
                            </>
                          )}
                        </svg>
                      )}
                    </div>
                    <div class="ft-body">
                      <div class="ft-head">
                        <div>
                          <div class="ft-title">{t.label}</div>
                          {sub && <div class="ft-sub">{sub}</div>}
                        </div>
                        <span class="ft-count">{t.modelCount} {t.modelCount === 1 ? 'model' : t.modelCount < 5 ? 'modely' : 'modelů'}</span>
                      </div>
                      {hpStr && (
                        <div class="ft-bar-wrap">
                          <div class="ft-bar-row"><span>Výkon</span><span class="v">{hpStr}</span></div>
                          <div class="ft-bar" style={`--from:${bar.from}%;--span:${bar.span}%`}></div>
                        </div>
                      )}
                      <div class="ft-foot">
                        <span class="year">
                          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M3 10h18M8 2v4M16 2v4"/></svg>
                          {yearStr}
                        </span>
                        <span class="go">Řada →</span>
                      </div>
                    </div>
                  </a>
                );
              })}
            </div>
          </>
        )}

        {cat.legacyTiles.length > 0 && (
          <>
            <div class="block-label legacy-label">
              <span class="status legacy"><span class="dot"></span>Starší řady · historie</span>
            </div>
            <div class="family-grid family-grid-legacy">
              {cat.legacyTiles.map((t) => {
                const bar = hpBar(t.minHp, t.maxHp, cat.hpMaxForBar);
                const yearStr = t.minYear !== null
                  ? (t.maxYear ? `${t.minYear}–${t.maxYear}` : `${t.minYear}`)
                  : '';
                const sub = familySublabel(t.family);
                const hpStr = t.minHp !== null && t.maxHp !== null
                  ? (t.minHp === t.maxHp ? `${t.minHp} k` : `${t.minHp}–${t.maxHp} k`)
                  : '';
                const coverStyle = t.coverImage
                  ? `background-image:url('${t.coverImage}'); background-color:#FFFFFF; background-size:cover; background-position:center;`
                  : `background:linear-gradient(135deg, ${brandC1} 0%, ${brandC2} 100%)`;
                return (
                  <a class="family-tile is-legacy" href={`/stroje/${brand.slug}/rada/${cat.slug}/${t.family}/`}>
                    <div class="ft-cover" data-has-photo={t.coverImage ? 'true' : 'false'} style={coverStyle}>
                      {!t.coverImage && (
                        <svg class="ft-silhouette" width="120" height="68" viewBox="0 0 140 80" fill="rgba(0,0,0,.22)" aria-hidden="true">
                          {cat.slug === 'traktory' ? (
                            <>
                              <circle cx="100" cy="58" r="16"/><circle cx="42" cy="60" r="11"/>
                              <path d="M26 54 Q32 28 54 26 L78 22 L86 12 L112 11 L120 22 L132 32 L132 54 Z"/>
                            </>
                          ) : (
                            <>
                              <rect x="20" y="42" width="100" height="22" rx="3"/>
                              <path d="M20 42 Q25 24 50 22 L110 22 Q120 24 120 42 Z"/>
                              <circle cx="40" cy="68" r="8"/><circle cx="100" cy="68" r="8"/>
                            </>
                          )}
                        </svg>
                      )}
                    </div>
                    <div class="ft-body">
                      <div class="ft-head">
                        <div>
                          <div class="ft-title">{t.label}</div>
                          {sub && <div class="ft-sub">{sub}</div>}
                        </div>
                        <span class="ft-count">{t.modelCount} {t.modelCount === 1 ? 'model' : t.modelCount < 5 ? 'modely' : 'modelů'}</span>
                      </div>
                      {hpStr && (
                        <div class="ft-bar-wrap">
                          <div class="ft-bar-row"><span>Výkon</span><span class="v">{hpStr}</span></div>
                          <div class="ft-bar" style={`--from:${bar.from}%;--span:${bar.span}%`}></div>
                        </div>
                      )}
                      <div class="ft-foot">
                        <span class="year">
                          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M3 10h18M8 2v4M16 2v4"/></svg>
                          {yearStr}
                        </span>
                        <span class="go">Řada →</span>
                      </div>
                    </div>
                  </a>
                );
              })}
            </div>
          </>
        )}
      </section>
    ))}

    <section class="big-cta">
      <div>
        <span class="cta-kicker">Hledáte konkrétní model?</span>
        <h2>{brand.name} v Agro bazaru<br />— inzeráty od soukromých prodejců i dealerů.</h2>
        <p>Filtrujte podle řady, výkonu a roku. Kontakt přímo na prodejce, bez provize.</p>
        <div class="cta-actions">
          <a class="cta-btn primary" href={`/bazar/?brand=${encodeURIComponent(brand.slug)}`}>
            Otevřít bazar {brand.name}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a class="cta-btn ghost" href="/bazar/novy/">Přidat vlastní inzerát</a>
        </div>
      </div>
      <div class="cta-right">
        <div class="cta-photo" style={`background-image:url('${heroPhoto}')`}></div>
      </div>
    </section>

  </div>
</Layout>

<style>
  .brand-page{
    --yellow:#FFEA00;
    --yellow-soft:#FFF6A8;
    --yellow-glow:rgba(255,234,0,.35);
    --ink:#0A0A0B;
    --body:#1E1E22;
    --muted:#6B6B72;
    --muted-2:#9A9AA3;
    --line:#EAEAEC;
    --line-2:#DFDFE3;
    --bg-cream:#FBFAF4;
    --card:#FFFFFF;
    --green:#0B7A3B;
    --green-soft:#E3F3EA;
    --legacy:#7A6B0B;
    --legacy-soft:#F5EFC8;
    --r-xl:24px;
    --r-lg:18px;
    --r-md:12px;
    --sh-1:0 1px 2px rgba(10,10,12,.04), 0 0 0 1px rgba(10,10,12,.03);
    --sh-2:0 4px 14px rgba(10,10,12,.06), 0 0 0 1px rgba(10,10,12,.04);
    --sh-3:0 18px 40px -12px rgba(10,10,12,.18), 0 0 0 1px rgba(10,10,12,.04);
    max-width:1280px;margin:0 auto;padding:26px 24px 96px;
