---
export const prerender = true;
import Layout from '../../../layouts/Layout.astro';
import CategoryBrowse from '../../../components/stroje/CategoryBrowse.astro';
import { getAllBrands } from '../../../lib/stroje';
import { itemListSchema } from '../../../lib/structured-data';

const brandsWithKombajny = getAllBrands().filter((b) => (b.categories?.kombajny?.series?.length ?? 0) > 0);
const brandListJsonLd = brandsWithKombajny.length > 0
  ? itemListSchema(
      brandsWithKombajny.map((b) => ({
        url: `/stroje/${b.slug}/`,
        name: `${b.name} kombajny`,
      })),
      'Značky kombajnů',
    )
  : null;
---

<Layout
  title="Kombajny — katalog"
  description="Přehled kombajnů všech značek — John Deere, CLAAS, New Holland, Case IH, Fendt, Massey Ferguson, Deutz-Fahr a další. Konvenční, hybridní i rotorové mlátičky."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Domů', item: 'https://agro-svet.cz/' },
      { '@type': 'ListItem', position: 2, name: 'Technika', item: 'https://agro-svet.cz/stroje/' },
      { '@type': 'ListItem', position: 3, name: 'Kombajny', item: 'https://agro-svet.cz/stroje/kombajny/' },
    ],
  })} />
  {brandListJsonLd && <script type="application/ld+json" is:inline set:html={JSON.stringify(brandListJsonLd)} />}
  <CategoryBrowse category="kombajny" />
</Layout>
