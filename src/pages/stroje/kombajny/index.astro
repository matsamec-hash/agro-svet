>
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Domů', item: 'https://agro-svet.cz/' },
      { '@type': 'ListItem', position: 2, name: 'Technika', item: 'https://agro-svet.cz/stroje/' },
      { '@type': 'ListItem', position: 3, name: 'Kombajny', item: 'https://agro-svet.cz/stroje/kombajny/' },
    ],
  })} />
  <CategoryBrowse category="kombajny" />
