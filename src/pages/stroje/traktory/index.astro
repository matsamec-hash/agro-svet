---
export const prerender = true;
import Layout from '../../../layouts/Layout.astro';
import CategoryBrowse from '../../../components/stroje/CategoryBrowse.astro';
import { getAllBrands } from '../../../lib/stroje';
import { itemListSchema } from '../../../lib/structured-data';

const brandsWithTraktory = getAllBrands().filter((b) => (b.categories?.traktory?.series?.length ?? 0) > 0);
const brandListJsonLd = brandsWithTraktory.length > 0
  ? itemListSchema(
      brandsWithTraktory.map((b) => ({
        url: `/stroje/${b.slug}/`,
        name: `${b.name} traktory`,
      })),
      'Značky traktorů',
    )
  : null;
---

<Layout
  title="Traktory — katalog"
  description="Přehled traktorů všech značek — John Deere, Zetor, Fendt, New Holland, Case IH, CLAAS, Valtra, Massey Ferguson, Kubota, Deutz-Fahr. Modelové řady od 5. řady po 9. řadu."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Domů', item: 'https://agro-svet.cz/' },
      { '@type': 'ListItem', position: 2, name: 'Technika', item: 'https://agro-svet.cz/stroje/' },
      { '@type': 'ListItem', position: 3, name: 'Traktory', item: 'https://agro-svet.cz/stroje/traktory/' },
    ],
  })} />
  {brandListJsonLd && <script type="application/ld+json" is:inline set:html={JSON.stringify(brandListJsonLd)} />}
  <CategoryBrowse category="traktory" />
</Layout>
