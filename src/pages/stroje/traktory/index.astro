---
export const prerender = false;
import Layout from '../../../layouts/Layout.astro';
import CategoryBrowse from '../../../components/stroje/CategoryBrowse.astro';
import { getAllBrands } from '../../../lib/stroje';
import { itemListSchema } from '../../../lib/structured-data';
import { useTranslations } from '../../../i18n/utils';

const locale = Astro.locals.locale ?? 'cs';
const t = useTranslations(locale);

const brandsWithTraktory = getAllBrands().filter((b) => (b.categories?.traktory?.series?.length ?? 0) > 0);
const brandListJsonLd = brandsWithTraktory.length > 0
  ? itemListSchema(
      brandsWithTraktory.map((b) => ({
        url: `/stroje/${b.slug}/`,
        name: `${b.name} ${t('stroje.cat.traktory.itemSuffix')}`,
      })),
      t('stroje.cat.traktory.itemListName'),
    )
  : null;
---

<Layout
  title={t('stroje.cat.traktory.title')}
  description={t('stroje.cat.traktory.desc')}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: t('stroje.crumb.home'), item: 'https://agro-svet.cz/' },
      { '@type': 'ListItem', position: 2, name: t('stroje.crumb.tech'), item: 'https://agro-svet.cz/stroje/' },
      { '@type': 'ListItem', position: 3, name: t('stroje.cat.traktory.crumbName'), item: 'https://agro-svet.cz/stroje/traktory/' },
    ],
  })} />
  {brandListJsonLd && <script type="application/ld+json" is:inline set:html={JSON.stringify(brandListJsonLd)} />}
  <CategoryBrowse category="traktory" />
</Layout>
