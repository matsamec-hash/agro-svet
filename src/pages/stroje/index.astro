---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import { getAllBrands, getAllModels, type StrojKategorie } from '../../lib/stroje';

const brands = getAllBrands();
const models = getAllModels();

const kategorieLabel: Record<StrojKategorie, string> = {
  traktory: 'Traktory',
  kombajny: 'Kombajny',
};

const totalModels = models.length;
const totalSeries = new Set(models.map((m) => `${m.brand_slug}:${m.series_slug}`)).size;
const hpValues = models.map((m) => m.power_hp).filter((x): x is number => x !== null);
const minHp = hpValues.length ? Math.min(...hpValues) : 0;
const maxHp = hpValues.length ? Math.max(...hpValues) : 0;
const years = models.map((m) => m.year_from).filter((x): x is number => x !== null);
const minYear = years.length ? Math.min(...years) : 1990;

const traktoryCount = models.filter((m) => m.category === 'traktory').length;
const kombajnyCount = models.filter((m) => m.category === 'kombajny').length;

const modelsJson = JSON.stringify(
  models.map((m) => ({
    slug: m.slug,
    name: m.name,
    brand_slug: m.brand_slug,
    brand_name: m.brand_name,
    category: m.category,
    series_slug: m.series_slug,
    series_name: m.series_name,
    year_from: m.year_from,
    year_to: m.year_to,
    power_hp: m.power_hp,
    power_kw: m.power_kw,
    cutting_width_m: m.cutting_width_m ?? null,
  })),
);

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Domů', item: 'https://agro-svet.cz/' },
    { '@type': 'ListItem', position: 2, name: 'Technika', item: 'https://agro-svet.cz/stroje/' },
  ],
};

// Brand cards data
const brandCards = brands.map((b) => {
  const bModels = models.filter((m) => m.brand_slug === b.slug);
  const bHp = bModels.map((m) => m.power_hp).filter((x): x is number => x !== null);
  return {
    slug: b.slug,
    name: b.name,
    country: b.country,
    founded: b.founded,
    modelCount: bModels.length,
    traktoryCount: bModels.filter((m) => m.category === 'traktory').length,
    kombajnyCount: bModels.filter((m) => m.category === 'kombajny').length,
    minHp: bHp.length ? Math.min(...bHp) : null,
    maxHp: bHp.length ? Math.max(...bHp) : null,
  };
}).sort((a, b) => b.modelCount - a.modelCount);
---

<Layout
  title="Katalog zemědělských strojů"
  description="Kompletní databáze traktorů a kombajnů — John Deere, Zetor, Fendt, New Holland, Case IH, Valtra, CLAAS a další. Filtrujte podle značky, výkonu a roku výroby."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
  <div class="catalog-root">

    <nav class="breadcrumb" aria-label="Cesta">
      <a href="/">Domů</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <span class="current">Technika</span>
    </nav>

    <section class="hero">
      <div class="hero-left">
        <span class="kicker"><span class="dot"></span>Katalog · Technika</span>
        <h1>Zemědělská <em>technika</em></h1>
        <p class="hero-lede">
          Kompletní databáze {totalModels}+ modelů traktorů a kombajnů z {brands.length} značek
          od roku {minYear} až po současnost. Aktuální produkce i historické modely pro bazarový průzkum.
        </p>

        <div class="hero-stats">
          <div class="s"><span class="n">{totalModels}+</span><span class="l">modelů</span></div>
          <div class="s"><span class="n">{brands.length}</span><span class="l">značek</span></div>
          <div class="s"><span class="n">{totalSeries}</span><span class="l">řad</span></div>
          <div class="s"><span class="n">{minHp}–{maxHp} k</span><span class="l">výkon</span></div>
        </div>

        <div class="hero-actions">
          <a class="cta-primary" href="/stroje/traktory/">
            Traktory <span class="cta-c">{traktoryCount}</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a class="cta-primary" href="/stroje/kombajny/">
            Kombajny <span class="cta-c">{kombajnyCount}</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a class="cta-secondary" href="#znacky">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
            Značky
          </a>
        </div>
      </div>

      <div class="hero-right">
        <div class="hero-photo-stack">
          <div class="hsp-tile hsp-traktor" style="background-image:url('/images/traktor.webp')">
            <div class="hsp-label"><span>Traktory</span><span class="c">{traktoryCount}</span></div>
          </div>
          <div class="hsp-tile hsp-kombajn" style="background-image:url('/images/kombajn.webp')">
            <div class="hsp-label"><span>Kombajny</span><span class="c">{kombajnyCount}</span></div>
          </div>
        </div>
      </div>
    </section>

    <section class="filter-card" aria-labelledby="filter-title">
      <div class="fc-head">
        <h2 id="filter-title">Filtr katalogu</h2>
        <span class="fc-sub">Filtrujte podle kategorie, značky, výkonu a roku</span>
      </div>
      <div class="fc-grid">
        <label class="fc-field">
          <span class="fc-label">Kategorie</span>
          <select id="f-category">
            <option value="">Všechny kategorie</option>
            <option value="traktory">Traktory</option>
            <option value="kombajny">Kombajny</option>
          </select>
        </label>

        <label class="fc-field">
          <span class="fc-label">Značka</span>
          <select id="f-brand">
            <option value="">Všechny značky</option>
            {brands.map((b) => <option value={b.slug}>{b.name}</option>)}
          </select>
        </label>

        <label class="fc-field">
          <span class="fc-label">Výkon od (k)</span>
          <input id="f-hp-min" type="number" min="0" placeholder={`${minHp}`} />
        </label>

        <label class="fc-field">
          <span class="fc-label">Výkon do (k)</span>
          <input id="f-hp-max" type="number" min="0" placeholder={`${maxHp}`} />
        </label>

        <label class="fc-field">
          <span class="fc-label">Rok od</span>
          <input id="f-year-min" type="number" min="1950" max="2030" placeholder={`${minYear}`} />
        </label>

        <label class="fc-field">
          <span class="fc-label">Rok do</span>
          <input id="f-year-max" type="number" min="1950" max="2030" placeholder="2026" />
        </label>

        <label class="fc-field fc-field-search">
          <span class="fc-label">Hledat model</span>
          <input id="f-search" type="search" placeholder={`např. "Zetor Proxima 120"`} />
        </label>
      </div>
      <div class="fc-foot">
        <span id="result-count" class="fc-count"></span>
        <button id="f-reset" type="button">Resetovat filtry</button>
      </div>
    </section>

    <h2 id="znacky-heading" class="section-title">Značky <span class="section-title-c">{brands.length}</span></h2>
    <h2 id="results-heading" class="section-title results-heading">Výsledky <span id="results-heading-c" class="section-title-c"></span></h2>
    <div id="brand-grid" class="brand-grid">
      {brandCards.map((b) => (
        <a href={`/stroje/${b.slug}/`} class="brand-card">
          <div class="bc-head">
            <div class="bc-logo">
              <img src={`/images/stroje/brands/${b.slug}.png`} alt={`${b.name} logo`} loading="lazy" width="64" height="64" />
            </div>
            <div class="bc-title">
              <h3>{b.name}</h3>
              <span class="bc-meta-1">{b.country} · od <strong>{b.founded}</strong></span>
            </div>
          </div>
          <div class="bc-stats">
            <div class="bc-stat">
              <span class="bc-stat-n">{b.modelCount}</span>
              <span class="bc-stat-l">modelů</span>
            </div>
            {b.minHp !== null && b.maxHp !== null && (
              <div class="bc-stat">
                <span class="bc-stat-n">{b.minHp}–{b.maxHp} <em>k</em></span>
                <span class="bc-stat-l">výkon</span>
              </div>
            )}
          </div>
          <div class="bc-cats">
            {b.traktoryCount > 0 && <span class="bc-cat">Traktory <strong>{b.traktoryCount}</strong></span>}
            {b.kombajnyCount > 0 && <span class="bc-cat">Kombajny <strong>{b.kombajnyCount}</strong></span>}
          </div>
          <div class="bc-foot">
            <span>Detail značky</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </div>
        </a>
      ))}
    </div>

    <div id="results-grid" class="results-grid"></div>

    <section class="big-cta">
      <div>
        <span class="cta-kicker">Prodáváte techniku?</span>
        <h2>Inzerát v Agro bazaru<br />zdarma a bez provize.</h2>
        <p>30 dní inzerát · až 5 fotek · kontakt přímo na prodejce · žádný poplatek za zveřejnění.</p>
        <div class="cta-actions">
          <a class="cta-btn primary" href="/bazar/novy/">
            Přidat inzerát zdarma
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a class="cta-btn ghost" href="/bazar/">Procházet bazar</a>
        </div>
      </div>
      <div class="cta-right">
        <div class="cta-photo" style="background-image:url('/images/traktor.webp')"></div>
      </div>
    </section>

  </div>

  <script is:inline set:html={`window.__STROJE_DATA__ = ${modelsJson};`}></script>

  <script>
    type Model = {
      slug: string;
      name: string;
      brand_slug: string;
      brand_name: string;
      category: string;
      series_slug: string;
      series_name: string;
      year_from: number | null;
      year_to: number | null;
      power_hp: number | null;
      power_kw: number | null;
    };

    const MODELS: Model[] = (window as any).__STROJE_DATA__ ?? [];

    const el = {
      category: document.getElementById('f-category') as HTMLSelectElement,
      brand: document.getElementById('f-brand') as HTMLSelectElement,
      hpMin: document.getElementById('f-hp-min') as HTMLInputElement,
      hpMax: document.getElementById('f-hp-max') as HTMLInputElement,
      yearMin: document.getElementById('f-year-min') as HTMLInputElement,
      yearMax: document.getElementById('f-year-max') as HTMLInputElement,
      search: document.getElementById('f-search') as HTMLInputElement,
      reset: document.getElementById('f-reset') as HTMLButtonElement,
      count: document.getElementById('result-count') as HTMLElement,
      brandGrid: document.getElementById('brand-grid') as HTMLElement,
      resultsGrid: document.getElementById('results-grid') as HTMLElement,
      znackyHeading: document.getElementById('znacky-heading') as HTMLElement,
      resultsHeading: document.getElementById('results-heading') as HTMLElement,
      resultsHeadingCount: document.getElementById('results-heading-c') as HTMLElement,
    };

    function anyFilterActive(): boolean {
      return Boolean(
        el.category.value || el.brand.value || el.hpMin.value || el.hpMax.value ||
        el.yearMin.value || el.yearMax.value || el.search.value.trim(),
      );
    }

    function modelUrl(m: Model): string {
      const short = m.slug.startsWith(m.brand_slug + '-') ? m.slug.slice(m.brand_slug.length + 1) : m.slug;
      return `/stroje/${m.brand_slug}/${m.series_slug}/${short}/`;
    }

    function renderCard(m: Model): string {
      const hp = m.power_hp ? `${m.power_hp} k` : '—';
      const kw = m.power_kw ? ` · ${m.power_kw} kW` : '';
      const yr = m.year_from ? (m.year_to ? `${m.year_from}–${m.year_to}` : `${m.year_from}–dosud`) : '';
      const isCurrent = m.year_to === null && m.year_from !== null;
      return `
        <a href="${modelUrl(m)}" class="rc-card">
          <div class="rc-tags">
            <span class="rc-tag rc-tag-brand">${m.brand_name}</span>
            <span class="rc-tag rc-tag-cat">${m.category === 'traktory' ? 'Traktor' : 'Kombajn'}</span>
            ${isCurrent ? '<span class="rc-tag rc-tag-current"><span class="rc-dot"></span>Aktuální</span>' : ''}
          </div>
          <div class="rc-name">${m.name}</div>
          <div class="rc-series">${m.series_name}</div>
          <div class="rc-foot">
            <span class="rc-power"><strong>${hp}</strong>${kw}</span>
            <span class="rc-year">${yr}</span>
          </div>
        </a>
      `;
    }

    function syncUrl() {
      const params = new URLSearchParams();
      if (el.category.value) params.set('kategorie', el.category.value);
      if (el.brand.value) params.set('znacka', el.brand.value);
      if (el.hpMin.value) params.set('vykon_od', el.hpMin.value);
      if (el.hpMax.value) params.set('vykon_do', el.hpMax.value);
      if (el.yearMin.value) params.set('rok_od', el.yearMin.value);
      if (el.yearMax.value) params.set('rok_do', el.yearMax.value);
      if (el.search.value.trim()) params.set('q', el.search.value.trim());
      const qs = params.toString();
      const newUrl = window.location.pathname + (qs ? '?' + qs : '');
      window.history.replaceState(null, '', newUrl);
    }

    function applyFilters() {
      const cat = el.category.value;
      const brand = el.brand.value;
      const hpMin = parseInt(el.hpMin.value, 10);
      const hpMax = parseInt(el.hpMax.value, 10);
      const yearMin = parseInt(el.yearMin.value, 10);
      const yearMax = parseInt(el.yearMax.value, 10);
      const q = el.search.value.trim().toLowerCase();
      syncUrl();

      const filtered = MODELS.filter((m) => {
        if (cat && m.category !== cat) return false;
        if (brand && m.brand_slug !== brand) return false;
        if (!isNaN(hpMin) && (m.power_hp ?? 0) < hpMin) return false;
        if (!isNaN(hpMax) && (m.power_hp ?? 99999) > hpMax) return false;
        if (!isNaN(yearMin) && (m.year_to ?? m.year_from ?? 0) < yearMin) return false;
        if (!isNaN(yearMax) && (m.year_from ?? 99999) > yearMax) return false;
        if (q) {
          const hay = (m.name + ' ' + m.brand_name + ' ' + m.series_name).toLowerCase();
          if (!hay.includes(q)) return false;
        }
        return true;
      });

      const active = anyFilterActive();
      if (active) {
        el.brandGrid.style.display = 'none';
        el.resultsGrid.style.display = 'grid';
        el.znackyHeading.style.display = 'none';
        el.resultsHeading.style.display = 'inline-flex';
        const sorted = filtered.sort((a, b) => (b.power_hp ?? 0) - (a.power_hp ?? 0));
        el.resultsGrid.innerHTML = sorted.length > 0
          ? sorted.map(renderCard).join('')
          : '<div class="rg-empty">Žádné modely neodpovídají filtrům. Zkuste je rozvolnit nebo resetovat.</div>';
        el.count.textContent = `Nalezeno ${filtered.length} modelů`;
        el.resultsHeadingCount.textContent = String(filtered.length);
      } else {
        el.brandGrid.style.display = 'grid';
        el.resultsGrid.style.display = 'none';
        el.znackyHeading.style.display = 'inline-flex';
        el.resultsHeading.style.display = 'none';
        el.count.textContent = '';
      }
    }

    [el.category, el.brand, el.hpMin, el.hpMax, el.yearMin, el.yearMax, el.search].forEach((e) => {
      e.addEventListener('input', applyFilters);
      e.addEventListener('change', applyFilters);
    });
    el.reset.addEventListener('click', () => {
      el.category.value = '';
      el.brand.value = '';
      el.hpMin.value = '';
      el.hpMax.value = '';
      el.yearMin.value = '';
      el.yearMax.value = '';
      el.search.value = '';
      applyFilters();
    });

    const params = new URLSearchParams(window.location.search);
    if (params.get('kategorie')) el.category.value = params.get('kategorie')!;
    if (params.get('znacka')) el.brand.value = params.get('znacka')!;
    if (params.get('vykon_od')) el.hpMin.value = params.get('vykon_od')!;
    if (params.get('vykon_do')) el.hpMax.value = params.get('vykon_do')!;
    if (params.get('rok_od')) el.yearMin.value = params.get('rok_od')!;
    if (params.get('rok_do')) el.yearMax.value = params.get('rok_do')!;
    if (params.get('q')) el.search.value = params.get('q')!;
    applyFilters();
  </script>

  <style>
    .catalog-root{
      --yellow:#FFEA00;
      --yellow-soft:#FFF6A8;
      --yellow-glow:rgba(255,234,0,.35);
      --ink:#0A0A0B;
      --body:#1E1E22;
      --muted:#6B6B72;
      --muted-2:#9A9AA3;
      --line:#EAEAEC;
      --line-2:#DFDFE3;
      --bg-cream:#FBFAF4;
      --card:#FFFFFF;
      --green:#0B7A3B;
      --green-soft:#E3F3EA;
      --r-xl:24px;
      --r-lg:18px;
      --r-md:12px;
      --sh-1:0 1px 2px rgba(10,10,12,.04), 0 0 0 1px rgba(10,10,12,.03);
      --sh-3:0 18px 40px -12px rgba(10,10,12,.18), 0 0 0 1px rgba(10,10,12,.04);
      max-width:1280px;margin:0 auto;padding:26px 24px 96px;
      color:var(--body);
    }

    .catalog-root .breadcrumb{display:flex;gap:8px;align-items:center;font-size:13px;color:var(--muted);margin-bottom:22px}
    .catalog-root .breadcrumb a{color:var(--muted);text-decoration:none;transition:color .15s}
    .catalog-root .breadcrumb a:hover{color:#000}
    .catalog-root .breadcrumb svg{width:14px;height:14px;color:var(--muted-2)}
    .catalog-root .breadcrumb .current{color:#000;font-weight:600}

    .catalog-root .hero{
      position:relative;overflow:hidden;color:#fff;border-radius:var(--r-xl);
      background:radial-gradient(600px 300px at 15% 20%, rgba(255,234,0,.18), transparent 60%),
        radial-gradient(700px 400px at 90% 90%, rgba(80,80,90,.4), transparent 60%),
        linear-gradient(135deg, #0E0E10 0%, #1C1C20 60%, #2A2A2F 100%);
      padding:48px 48px 40px;margin-bottom:22px;
      box-shadow:var(--sh-3);
      display:grid;grid-template-columns:1.35fr 1fr;gap:32px;align-items:center;
    }
    .catalog-root .hero::before{
      content:"";position:absolute;inset:0;pointer-events:none;opacity:.35;
      background-image:linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
      background-size:48px 48px;
      mask-image:radial-gradient(600px 400px at 70% 100%, black, transparent 70%);
    }
    .catalog-root .hero-left{position:relative;z-index:2}
    .catalog-root .kicker{
      display:inline-flex;align-items:center;gap:10px;
      font:600 11px/1 'Chakra Petch',sans-serif;letter-spacing:.22em;text-transform:uppercase;
      color:var(--yellow);margin-bottom:18px;
      padding:8px 14px;border:1px solid rgba(255,234,0,.4);border-radius:999px;
      background:rgba(255,234,0,.06);
    }
    .catalog-root .kicker .dot{width:7px;height:7px;background:var(--yellow);border-radius:50%;box-shadow:0 0 0 3px rgba(255,234,0,.2)}
    .catalog-root .hero h1{
      font-family:'Chakra Petch',sans-serif;font-weight:700;
      font-size:clamp(2.4rem,5.5vw,4.4rem);color:#fff;line-height:.96;letter-spacing:-.03em;margin:0;
    }
    .catalog-root .hero h1 em{font-style:normal;color:var(--yellow);text-shadow:0 0 40px rgba(255,234,0,.5)}
    .catalog-root .hero-lede{max-width:580px;font-size:16px;color:#c8c8d0;margin:18px 0 22px;line-height:1.6}

    .catalog-root .hero-stats{display:flex;gap:24px;flex-wrap:wrap;margin-bottom:24px;font-family:'Chakra Petch',sans-serif}
    .catalog-root .hero-stats .s{display:flex;flex-direction:column;gap:3px}
    .catalog-root .hero-stats .n{font-size:24px;font-weight:700;color:#fff;line-height:1;letter-spacing:-.02em}
    .catalog-root .hero-stats .l{font-size:11px;color:#8a8a92;letter-spacing:.14em;text-transform:uppercase;font-weight:500}
    .catalog-root .hero-stats .s + .s{padding-left:24px;border-left:1px solid rgba(255,255,255,.12)}

    .catalog-root .hero-actions{display:flex;gap:10px;flex-wrap:wrap}
    .catalog-root .cta-primary{
      display:inline-flex;align-items:center;gap:8px;
      background:var(--yellow);color:#0A0A0B;padding:13px 18px;border-radius:12px;text-decoration:none;
      font:700 14px 'Chakra Petch',sans-serif;letter-spacing:.02em;
      transition:transform .15s, box-shadow .15s;
      box-shadow:0 14px 40px -10px var(--yellow-glow);
    }
    .catalog-root .cta-primary .cta-c{
      background:#0A0A0B;color:var(--yellow);font-size:11px;padding:2px 7px;border-radius:6px;letter-spacing:.06em;
    }
    .catalog-root .cta-primary:hover{transform:translateY(-1px);box-shadow:0 20px 50px -8px var(--yellow-glow)}
    .catalog-root .cta-secondary{
      display:inline-flex;align-items:center;gap:8px;
      color:#c8c8d0;background:rgba(255,255,255,.06);
      border:1px solid rgba(255,255,255,.12);
      padding:13px 16px;border-radius:12px;text-decoration:none;
      font:500 13px 'Chakra Petch',sans-serif;
      transition:.15s;
