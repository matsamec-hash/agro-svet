---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import { getAllBrands, getAllModels, type StrojKategorie } from '../../lib/stroje';
import { useTranslations, plural, tf, getLocaleFromUrl } from '../../i18n/utils';

const locale = Astro.locals.locale ?? getLocaleFromUrl(Astro.url);
const tr = useTranslations(locale);

const brands = getAllBrands();
const models = getAllModels();

const kategorieLabel: Record<StrojKategorie, string> = {
  traktory: 'Traktory',
  kombajny: 'Kombajny',
};

const totalModels = models.length;
const totalSeries = new Set(models.map((m) => `${m.brand_slug}:${m.series_slug}`)).size;
const hpValues = models.map((m) => m.power_hp).filter((x): x is number => x !== null);
const minHp = hpValues.length ? Math.min(...hpValues) : 0;
const maxHp = hpValues.length ? Math.max(...hpValues) : 0;
const years = models.map((m) => m.year_from).filter((x): x is number => x !== null);
const minYear = years.length ? Math.min(...years) : 1990;

const traktoryCount = models.filter((m) => m.category === 'traktory').length;
const kombajnyCount = models.filter((m) => m.category === 'kombajny').length;

// Models payload is loaded async from /stroje/data.json (prerendered, 24h CF cache).
// This keeps the HTML shell ~50KB instead of ~587KB and lets the brand grid + hero
// render instantly. Filter UI activates after fetch resolves.

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Domů', item: 'https://agro-svet.cz/' },
    { '@type': 'ListItem', position: 2, name: 'Technika', item: 'https://agro-svet.cz/stroje/' },
  ],
};

const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Katalog zemědělských strojů',
  description: 'Kompletní databáze traktorů a kombajnů od světových výrobců.',
  url: 'https://agro-svet.cz/stroje/',
  inLanguage: 'cs-CZ',
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: brands.length,
    itemListElement: brands.map((b, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `https://agro-svet.cz/stroje/${b.slug}/`,
      name: b.name,
    })),
  },
};

// Brand cards data
const brandCards = brands.map((b) => {
  const bModels = models.filter((m) => m.brand_slug === b.slug);
  const bHp = bModels.map((m) => m.power_hp).filter((x): x is number => x !== null);
  return {
    slug: b.slug,
    name: b.name,
    country: b.country,
    founded: b.founded,
    modelCount: bModels.length,
    traktoryCount: bModels.filter((m) => m.category === 'traktory').length,
    kombajnyCount: bModels.filter((m) => m.category === 'kombajny').length,
    minHp: bHp.length ? Math.min(...bHp) : null,
    maxHp: bHp.length ? Math.max(...bHp) : null,
  };
}).sort((a, b) => b.modelCount - a.modelCount);

// Strings consumed by the client-side filter script (renderCard, empty state,
// result count). Passed via a JSON island so the TS-typed <script> can read
// localized values without breaking under `define:vars`.
const js = {
  tagTraktor: tr('cat.s.tagTraktor'),
  tagKombajn: tr('cat.s.tagKombajn'),
  tagCurrent: tr('cat.s.tagCurrent'),
  yearToNow: tr('cat.s.yearToNow'),
  empty: tr('cat.s.empty'),
  foundPrefix: tr('cat.s.foundPrefix'),
  modelOne: tr('cat.tileModelOne'),
  modelFew: tr('cat.tileModelFew'),
  modelMany: tr('cat.tileModelMany'),
};

// Load-bearing newline: several CTA labels sat on their own indented source line,
// which Astro emitted as `\n<text>`. Replacing the text with an expression
// collapses that to a single space, so we re-inject the literal newline to keep
// the cs HTML byte-identical. (A literal `\n` inside an `.astro` `{...}` crashes
// esbuild, hence the frontmatter constant.)
const NL = '\n';
---

<Layout
  title={tr('cat.s.title')}
  description={tr('cat.s.desc')}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(collectionJsonLd)} />
  <div class="catalog-root">

    <nav class="breadcrumb" aria-label={tr('cat.bcAria')}>
      <a href="/">{tr('cat.bc.home')}</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <span class="current">{tr('cat.bc.tech')}</span>
    </nav>

    <section class="hero">
      <div class="hero-left">
        <span class="kicker"><span class="dot"></span>{tr('cat.heroKicker')}</span>
        <h1>{tr('cat.s.h1Lead')} <em>{tr('cat.s.h1Em')}</em></h1>
        <p class="hero-lede" set:html={tf(locale, 'cat.s.lede', { count: totalModels, brands: brands.length, minYear: Number.isFinite(minYear) ? minYear : '' })}></p>

        <div class="hero-stats">
          <div class="s"><span class="n">{totalModels}+</span><span class="l">{tr('cat.statModels')}</span></div>
          <div class="s"><span class="n">{brands.length}</span><span class="l">{tr('cat.statBrands')}</span></div>
          <div class="s"><span class="n">{totalSeries}</span><span class="l">{tr('cat.s.statSeries')}</span></div>
          <div class="s"><span class="n">{minHp}–{maxHp} k</span><span class="l">{tr('cat.statPower')}</span></div>
        </div>

        <div class="hero-actions">
          <a class="cta-primary" href="/stroje/traktory/">{NL}{tr('cat.label.traktory')} <span class="cta-c">{traktoryCount}</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a class="cta-primary" href="/stroje/kombajny/">{NL}{tr('cat.label.kombajny')} <span class="cta-c">{kombajnyCount}</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a class="cta-secondary" href="#znacky">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>{NL}{tr('cat.brandsAria')}{NL}</a>
        </div>
      </div>

      <div class="hero-right">
        <div class="hero-photo-stack">
          <a class="hsp-tile hsp-traktor" href="/stroje/traktory/" style="background-image:url('/images/traktor.webp')">
            <div class="hsp-label"><span>{tr('cat.label.traktory')}</span><span class="c">{traktoryCount}</span></div>
          </a>
          <a class="hsp-tile hsp-kombajn" href="/stroje/kombajny/" style="background-image:url('/images/kombajn.webp')">
            <div class="hsp-label"><span>{tr('cat.label.kombajny')}</span><span class="c">{kombajnyCount}</span></div>
          </a>
        </div>
      </div>
    </section>

    <section class="filter-card" aria-labelledby="filter-title">
      <div class="fc-head">
        <h2 id="filter-title">{tr('cat.s.filterTitle')}</h2>
        <span class="fc-sub">{tr('cat.s.filterSub')}</span>
      </div>
      <div class="fc-grid">
        <label class="fc-field">
          <span class="fc-label">{tr('cat.s.fCategory')}</span>
          <select id="f-category">
            <option value="">{tr('cat.s.allCategories')}</option>
            <option value="traktory">{tr('cat.label.traktory')}</option>
            <option value="kombajny">{tr('cat.label.kombajny')}</option>
          </select>
        </label>

        <label class="fc-field">
          <span class="fc-label">{tr('cat.s.fBrand')}</span>
          <select id="f-brand">
            <option value="">{tr('cat.s.allBrands')}</option>
            {brands.map((b) => <option value={b.slug}>{b.name}</option>)}
          </select>
        </label>

        <label class="fc-field">
          <span class="fc-label">{tr('cat.s.fHpFrom')}</span>
          <input id="f-hp-min" type="number" min="0" placeholder={`${minHp}`} />
        </label>

        <label class="fc-field">
          <span class="fc-label">{tr('cat.s.fHpTo')}</span>
          <input id="f-hp-max" type="number" min="0" placeholder={`${maxHp}`} />
        </label>

        <label class="fc-field">
          <span class="fc-label">{tr('cat.s.fYearFrom')}</span>
          <input id="f-year-min" type="number" min="1950" max="2030" placeholder={`${minYear}`} />
        </label>

        <label class="fc-field">
          <span class="fc-label">{tr('cat.s.fYearTo')}</span>
          <input id="f-year-max" type="number" min="1950" max="2030" placeholder="2026" />
        </label>

        <label class="fc-field fc-field-search">
          <span class="fc-label">{tr('cat.s.fSearch')}</span>
          <input id="f-search" type="search" placeholder={tr('cat.s.fSearchPlaceholder')} />
        </label>
      </div>
      <div class="fc-foot">
        <span id="result-count" class="fc-count"></span>
        <button id="f-reset" type="button">{tr('cat.s.fReset')}</button>
      </div>
    </section>

    <h2 id="znacky-heading" class="section-title">{tr('cat.brandsAria')} <span class="section-title-c">{brands.length}</span></h2>
    <h2 id="results-heading" class="section-title results-heading">{tr('cat.s.results')} <span id="results-heading-c" class="section-title-c"></span></h2>
    <div id="brand-grid" class="brand-grid">
      {brandCards.map((b) => (
        <a href={`/stroje/${b.slug}/`} class="brand-card">
          <div class="bc-head">
            <div class="bc-logo" data-letter={b.name.charAt(0).toUpperCase()}>
              <img src={`/images/stroje/brands/${b.slug}.png`} alt={tf(locale, 'cat.brandLogoAlt', { brand: b.name })} loading="lazy" width="64" height="64" onerror="this.remove()" />
            </div>
            <div class="bc-title">
              <h3>{b.name}</h3>
              <span class="bc-meta-1">{b.country} · {tr('cat.brandFoundedPrefix')} <strong>{b.founded}</strong></span>
            </div>
          </div>
          <div class="bc-stats">
            <div class="bc-stat">
              <span class="bc-stat-n">{b.modelCount}</span>
              <span class="bc-stat-l">{tr('cat.statModels')}</span>
            </div>
            {b.minHp !== null && b.maxHp !== null && (
              <div class="bc-stat">
                <span class="bc-stat-n">{b.minHp}–{b.maxHp} <em>k</em></span>
                <span class="bc-stat-l">{tr('cat.statPower')}</span>
              </div>
            )}
          </div>
          <div class="bc-cats">
            {b.traktoryCount > 0 && <span class="bc-cat">{tr('cat.label.traktory')} <strong>{b.traktoryCount}</strong></span>}
            {b.kombajnyCount > 0 && <span class="bc-cat">{tr('cat.label.kombajny')} <strong>{b.kombajnyCount}</strong></span>}
          </div>
          <div class="bc-foot">
            <span>{tr('cat.s.brandDetail')}</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </div>
        </a>
      ))}
    </div>

    <div id="results-grid" class="results-grid"></div>

    <section class="big-cta">
      <div>
        <span class="cta-kicker">{tr('cat.s.ctaKicker')}</span>
        <h2>{tr('cat.s.ctaH2a')}<br />{tr('cat.s.ctaH2b')}</h2>
        <p>{tr('cat.s.ctaP')}</p>
        <div class="cta-actions">
          <a class="cta-btn primary" href="/bazar/novy/">{NL}{tr('cat.s.ctaAdd')}{NL}<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a class="cta-btn ghost" href="/bazar/">{tr('cat.s.ctaBrowse')}</a>
        </div>
      </div>
      <div class="cta-right">
        <div class="cta-photo" style="background-image:url('/images/traktor.webp')"></div>
      </div>
    </section>

  </div>

  <script type="application/json" id="s-i18n" set:html={JSON.stringify(js)} />

  <script>
    type CompactModel = {
      s: string; n: string; b: string; bn: string; c: string;
      sr: string; srn: string;
      yf: number | null; yt: number | null;
      hp: number | null; kw: number | null;
    };
    type Model = {
      slug: string;
      name: string;
      brand_slug: string;
      brand_name: string;
      category: string;
      series_slug: string;
      series_name: string;
      year_from: number | null;
      year_to: number | null;
      power_hp: number | null;
      power_kw: number | null;
    };

    const i18nEl = document.getElementById('s-i18n');
    const I18N = i18nEl
      ? JSON.parse(i18nEl.textContent || '{}')
      : {
          tagTraktor: 'Traktor', tagKombajn: 'Kombajn', tagCurrent: 'Aktuální',
          yearToNow: '{from}–dosud',
          empty: 'Žádné modely neodpovídají filtrům. Zkuste je rozvolnit nebo resetovat.',
          foundPrefix: 'Nalezeno', modelOne: 'model', modelFew: 'modely', modelMany: 'modelů',
        };

    function pluralModel(n: number): string {
      const abs = Math.abs(n);
      if (abs === 1) return I18N.modelOne;
      if (abs >= 2 && abs <= 4) return I18N.modelFew;
      return I18N.modelMany;
    }

    let MODELS: Model[] = [];
    let modelsLoaded = false;

    async function loadModels(): Promise<Model[]> {
      if (modelsLoaded) return MODELS;
      try {
        const res = await fetch('/stroje/data.json');
        if (!res.ok) throw new Error('fetch_failed');
        const raw: CompactModel[] = await res.json();
        MODELS = raw.map((m) => ({
          slug: m.s, name: m.n, brand_slug: m.b, brand_name: m.bn, category: m.c,
          series_slug: m.sr, series_name: m.srn,
          year_from: m.yf, year_to: m.yt, power_hp: m.hp, power_kw: m.kw,
        }));
        modelsLoaded = true;
      } catch {
        MODELS = [];
        modelsLoaded = true;
      }
      return MODELS;
    }

    const el = {
      category: document.getElementById('f-category') as HTMLSelectElement,
      brand: document.getElementById('f-brand') as HTMLSelectElement,
      hpMin: document.getElementById('f-hp-min') as HTMLInputElement,
      hpMax: document.getElementById('f-hp-max') as HTMLInputElement,
      yearMin: document.getElementById('f-year-min') as HTMLInputElement,
      yearMax: document.getElementById('f-year-max') as HTMLInputElement,
      search: document.getElementById('f-search') as HTMLInputElement,
      reset: document.getElementById('f-reset') as HTMLButtonElement,
      count: document.getElementById('result-count') as HTMLElement,
      brandGrid: document.getElementById('brand-grid') as HTMLElement,
      resultsGrid: document.getElementById('results-grid') as HTMLElement,
      znackyHeading: document.getElementById('znacky-heading') as HTMLElement,
      resultsHeading: document.getElementById('results-heading') as HTMLElement,
      resultsHeadingCount: document.getElementById('results-heading-c') as HTMLElement,
    };

    function anyFilterActive(): boolean {
      return Boolean(
        el.category.value || el.brand.value || el.hpMin.value || el.hpMax.value ||
        el.yearMin.value || el.yearMax.value || el.search.value.trim(),
      );
    }

    function modelUrl(m: Model): string {
      const short = m.slug.startsWith(m.brand_slug + '-') ? m.slug.slice(m.brand_slug.length + 1) : m.slug;
      return `/stroje/${m.brand_slug}/${m.series_slug}/${short}/`;
    }

    function renderCard(m: Model): string {
      const hp = m.power_hp ? `${m.power_hp} k` : '—';
      const kw = m.power_kw ? ` · ${m.power_kw} kW` : '';
      const yr = m.year_from ? (m.year_to ? `${m.year_from}–${m.year_to}` : I18N.yearToNow.replace('{from}', String(m.year_from))) : '';
      const isCurrent = (m.year_to ?? null) === null;
      return `
        <a href="${modelUrl(m)}" class="rc-card">
          <div class="rc-tags">
            <span class="rc-tag rc-tag-brand">${m.brand_name}</span>
            <span class="rc-tag rc-tag-cat">${m.category === 'traktory' ? I18N.tagTraktor : I18N.tagKombajn}</span>
            ${isCurrent ? `<span class="rc-tag rc-tag-current"><span class="rc-dot"></span>${I18N.tagCurrent}</span>` : ''}
          </div>
          <div class="rc-name">${m.name}</div>
          <div class="rc-series">${m.series_name}</div>
          <div class="rc-foot">
            <span class="rc-power"><strong>${hp}</strong>${kw}</span>
            <span class="rc-year">${yr}</span>
          </div>
        </a>
      `;
    }

    function syncUrl() {
      const params = new URLSearchParams();
      if (el.category.value) params.set('kategorie', el.category.value);
      if (el.brand.value) params.set('znacka', el.brand.value);
      if (el.hpMin.value) params.set('vykon_od', el.hpMin.value);
      if (el.hpMax.value) params.set('vykon_do', el.hpMax.value);
      if (el.yearMin.value) params.set('rok_od', el.yearMin.value);
      if (el.yearMax.value) params.set('rok_do', el.yearMax.value);
      if (el.search.value.trim()) params.set('q', el.search.value.trim());
      const qs = params.toString();
      const newUrl = window.location.pathname + (qs ? '?' + qs : '');
      window.history.replaceState(null, '', newUrl);
    }

    async function applyFilters() {
      if (!modelsLoaded) await loadModels();
      const cat = el.category.value;
      const brand = el.brand.value;
      const hpMin = parseInt(el.hpMin.value, 10);
      const hpMax = parseInt(el.hpMax.value, 10);
      const yearMin = parseInt(el.yearMin.value, 10);
      const yearMax = parseInt(el.yearMax.value, 10);
      const q = el.search.value.trim().toLowerCase();
      syncUrl();

      const filtered = MODELS.filter((m) => {
        if (cat && m.category !== cat) return false;
        if (brand && m.brand_slug !== brand) return false;
        if (!isNaN(hpMin) && (m.power_hp ?? 0) < hpMin) return false;
        if (!isNaN(hpMax) && (m.power_hp ?? 99999) > hpMax) return false;
        if (!isNaN(yearMin) && (m.year_to ?? m.year_from ?? 0) < yearMin) return false;
        if (!isNaN(yearMax) && (m.year_from ?? 99999) > yearMax) return false;
        if (q) {
          const hay = (m.name + ' ' + m.brand_name + ' ' + m.series_name).toLowerCase();
          if (!hay.includes(q)) return false;
        }
        return true;
      });

      const active = anyFilterActive();
      if (active) {
        el.brandGrid.style.display = 'none';
        el.resultsGrid.style.display = 'grid';
        el.znackyHeading.style.display = 'none';
        el.resultsHeading.style.display = 'inline-flex';
        const sorted = filtered.sort((a, b) => (b.power_hp ?? 0) - (a.power_hp ?? 0));
        el.resultsGrid.innerHTML = sorted.length > 0
          ? sorted.map(renderCard).join('')
          : `<div class="rg-empty">${I18N.empty}</div>`;
        el.count.textContent = `${I18N.foundPrefix} ${filtered.length} ${pluralModel(filtered.length)}`;
        el.resultsHeadingCount.textContent = String(filtered.length);
      } else {
        el.brandGrid.style.display = 'grid';
        el.resultsGrid.style.display = 'none';
        el.znackyHeading.style.display = 'inline-flex';
        el.resultsHeading.style.display = 'none';
        el.count.textContent = '';
      }
    }

    [el.category, el.brand, el.hpMin, el.hpMax, el.yearMin, el.yearMax, el.search].forEach((e) => {
      e.addEventListener('input', applyFilters);
      e.addEventListener('change', applyFilters);
    });
    el.reset.addEventListener('click', () => {
      el.category.value = '';
      el.brand.value = '';
      el.hpMin.value = '';
      el.hpMax.value = '';
      el.yearMin.value = '';
      el.yearMax.value = '';
      el.search.value = '';
      applyFilters();
    });

    const params = new URLSearchParams(window.location.search);
    if (params.get('kategorie')) el.category.value = params.get('kategorie')!;
    if (params.get('znacka')) el.brand.value = params.get('znacka')!;
    if (params.get('vykon_od')) el.hpMin.value = params.get('vykon_od')!;
    if (params.get('vykon_do')) el.hpMax.value = params.get('vykon_do')!;
    if (params.get('rok_od')) el.yearMin.value = params.get('rok_od')!;
    if (params.get('rok_do')) el.yearMax.value = params.get('rok_do')!;
    if (params.get('q')) el.search.value = params.get('q')!;

    // If URL has filters, load immediately. Otherwise warm the cache on idle
    // (or first interaction) so the dataset is ready when user touches a filter.
    const hasParams = anyFilterActive();
    if (hasParams) {
      applyFilters();
    } else {
      const warm = () => { loadModels(); };
      if ('requestIdleCallback' in window) {
        (window as any).requestIdleCallback(warm, { timeout: 2000 });
      } else {
        setTimeout(warm, 600);
      }
      // Empty state — brand grid is visible, results hidden.
      el.brandGrid.style.display = 'grid';
      el.resultsGrid.style.display = 'none';
      el.znackyHeading.style.display = 'inline-flex';
      el.resultsHeading.style.display = 'none';
    }
  </script>

  <style>
    .catalog-root{
      --yellow:#FFEA00;
      --yellow-soft:#FFF6A8;
      --yellow-glow:rgba(255,234,0,.35);
      --ink:#0A0A0B;
      --body:#1E1E22;
      --muted:#6B6B72;
      --muted-2:#9A9AA3;
      --line:#EAEAEC;
      --line-2:#DFDFE3;
      --bg-cream:#FBFAF4;
      --card:#FFFFFF;
      --green:#0B7A3B;
      --green-soft:#E3F3EA;
      --r-xl:24px;
      --r-lg:18px;
      --r-md:12px;
      --sh-1:0 1px 2px rgba(10,10,12,.04), 0 0 0 1px rgba(10,10,12,.03);
      --sh-3:0 18px 40px -12px rgba(10,10,12,.18), 0 0 0 1px rgba(10,10,12,.04);
      max-width:1280px;margin:0 auto;padding:26px 24px 96px;
      color:var(--body);
    }

