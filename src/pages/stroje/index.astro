---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import { getAllBrands, getAllModels, type StrojKategorie } from '../../lib/stroje';

const brands = getAllBrands();
const models = getAllModels();

const kategorieLabel: Record<StrojKategorie, string> = {
  traktory: 'Traktory',
  kombajny: 'Kombajny',
};

const totalModels = models.length;
const totalSeries = new Set(models.map((m) => `${m.brand_slug}:${m.series_slug}`)).size;
const hpValues = models.map((m) => m.power_hp).filter((x): x is number => x !== null);
const minHp = hpValues.length ? Math.min(...hpValues) : 0;
const maxHp = hpValues.length ? Math.max(...hpValues) : 0;
const years = models.map((m) => m.year_from).filter((x): x is number => x !== null);
const minYear = years.length ? Math.min(...years) : 1990;

const modelsJson = JSON.stringify(
  models.map((m) => ({
    slug: m.slug,
    name: m.name,
    brand_slug: m.brand_slug,
    brand_name: m.brand_name,
    category: m.category,
    series_slug: m.series_slug,
    series_name: m.series_name,
    year_from: m.year_from,
    year_to: m.year_to,
    power_hp: m.power_hp,
    power_kw: m.power_kw,
    cutting_width_m: m.cutting_width_m ?? null,
  })),
);
---

<Layout
  title="Katalog zemědělských strojů"
  description="Kompletní databáze traktorů a kombajnů — John Deere, Zetor, Fendt, New Holland, Case IH, Valtra, CLAAS a další. Filtrujte podle značky, výkonu a roku výroby."
>
  <div style="max-width:1280px; margin:0 auto; padding:48px 32px 80px;">
    <div style="margin-bottom:32px;">
      <span class="section-label">Katalog strojů</span>
      <h1 style="font-family:'Chakra Petch',sans-serif; font-size:clamp(2rem,5vw,3.2rem); font-weight:700; letter-spacing:-1px; line-height:1.1; color:#1a1a1a; margin-bottom:16px;">
        Traktory a kombajny
      </h1>
      <p style="font-size:16px; color:#666; max-width:640px; line-height:1.6;">
        Databáze {totalModels}+ modelů zemědělské techniky z {brands.length} značek od roku {minYear} až po současnost.
        Filtrujte podle značky, výkonu, roku výroby a řady.
      </p>
    </div>

    <!-- Stats strip -->
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(150px,1fr)); gap:12px; margin-bottom:32px;">
      <div style="background:#1a1a1a; color:#fff; padding:20px; border-radius:18px;">
        <div style="font-family:'Chakra Petch',sans-serif; font-size:32px; font-weight:700; color:#FFFF00;">{totalModels}</div>
        <div style="font-size:13px; color:rgba(255,255,255,.6);">modelů v databázi</div>
      </div>
      <div style="background:#f5f5f5; padding:20px; border-radius:18px;">
        <div style="font-family:'Chakra Petch',sans-serif; font-size:32px; font-weight:700;">{brands.length}</div>
        <div style="font-size:13px; color:#666;">značek</div>
      </div>
      <div style="background:#f5f5f5; padding:20px; border-radius:18px;">
        <div style="font-family:'Chakra Petch',sans-serif; font-size:32px; font-weight:700;">{totalSeries}</div>
        <div style="font-size:13px; color:#666;">řad (serií)</div>
      </div>
      <div style="background:#f5f5f5; padding:20px; border-radius:18px;">
        <div style="font-family:'Chakra Petch',sans-serif; font-size:32px; font-weight:700;">{minHp}–{maxHp}</div>
        <div style="font-size:13px; color:#666;">k (rozsah výkonů)</div>
      </div>
    </div>

    <!-- Filter panel -->
    <div style="background:#fff; border:1px solid #e8e8e8; border-radius:18px; padding:20px; margin-bottom:24px;">
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:12px; margin-bottom:12px;">
        <label style="font-size:13px; color:#333;">
          <div style="margin-bottom:6px; font-weight:500;">Kategorie</div>
          <select id="f-category" style="width:100%; padding:10px 12px; border:1px solid #ddd; border-radius:10px; font-size:14px; background:#fff;">
            <option value="">Všechny kategorie</option>
            <option value="traktory">Traktory</option>
            <option value="kombajny">Kombajny</option>
          </select>
        </label>

        <label style="font-size:13px; color:#333;">
          <div style="margin-bottom:6px; font-weight:500;">Značka</div>
          <select id="f-brand" style="width:100%; padding:10px 12px; border:1px solid #ddd; border-radius:10px; font-size:14px; background:#fff;">
            <option value="">Všechny značky</option>
            {brands.map((b) => <option value={b.slug}>{b.name}</option>)}
          </select>
        </label>

        <label style="font-size:13px; color:#333;">
          <div style="margin-bottom:6px; font-weight:500;">Výkon od (k)</div>
          <input id="f-hp-min" type="number" min="0" placeholder={`${minHp}`} style="width:100%; padding:10px 12px; border:1px solid #ddd; border-radius:10px; font-size:14px;" />
        </label>

        <label style="font-size:13px; color:#333;">
          <div style="margin-bottom:6px; font-weight:500;">Výkon do (k)</div>
          <input id="f-hp-max" type="number" min="0" placeholder={`${maxHp}`} style="width:100%; padding:10px 12px; border:1px solid #ddd; border-radius:10px; font-size:14px;" />
        </label>

        <label style="font-size:13px; color:#333;">
          <div style="margin-bottom:6px; font-weight:500;">Rok od</div>
          <input id="f-year-min" type="number" min="1950" max="2030" placeholder={`${minYear}`} style="width:100%; padding:10px 12px; border:1px solid #ddd; border-radius:10px; font-size:14px;" />
        </label>

        <label style="font-size:13px; color:#333;">
          <div style="margin-bottom:6px; font-weight:500;">Rok do</div>
          <input id="f-year-max" type="number" min="1950" max="2030" placeholder="2026" style="width:100%; padding:10px 12px; border:1px solid #ddd; border-radius:10px; font-size:14px;" />
        </label>

        <label style="font-size:13px; color:#333;">
          <div style="margin-bottom:6px; font-weight:500;">Hledat model</div>
          <input id="f-search" type="search" placeholder="např. 8R 410" style="width:100%; padding:10px 12px; border:1px solid #ddd; border-radius:10px; font-size:14px;" />
        </label>
      </div>
      <div style="display:flex; justify-content:space-between; align-items:center; margin-top:8px;">
        <div id="result-count" style="font-size:13px; color:#666;"></div>
        <button id="f-reset" style="background:none; border:1px solid #ddd; padding:8px 16px; border-radius:10px; font-size:13px; cursor:pointer;">Resetovat filtry</button>
      </div>
    </div>

    <h2 id="znacky" style="font-family:'Chakra Petch',sans-serif; font-size:24px; font-weight:700; color:#1a1a1a; margin-bottom:14px;">Značky</h2>
    <!-- Brand grid (when no filters) -->
    <div id="brand-grid" style="display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:16px; margin-bottom:32px;">
      {brands.map((b) => {
        const brandModels = models.filter((m) => m.brand_slug === b.slug);
        const brandHp = brandModels.map((m) => m.power_hp).filter((x): x is number => x !== null);
        const traktoryCount = brandModels.filter((m) => m.category === 'traktory').length;
        const kombajnyCount = brandModels.filter((m) => m.category === 'kombajny').length;
        return (
          <a href={`/stroje/${b.slug}/`} style="display:block; text-decoration:none; color:inherit; background:#fff; border:1px solid #e8e8e8; border-radius:18px; padding:20px; transition:box-shadow .2s, transform .2s;" class="brand-card">
            <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:12px;">
              <h3 style="font-family:'Chakra Petch',sans-serif; font-size:22px; font-weight:700; color:#1a1a1a;">{b.name}</h3>
              <span style="font-size:12px; color:#767676;">{b.country}</span>
            </div>
            <div style="display:flex; gap:12px; font-size:13px; color:#666; margin-bottom:10px;">
              {traktoryCount > 0 && <span>🚜 {traktoryCount} traktorů</span>}
              {kombajnyCount > 0 && <span>🌾 {kombajnyCount} kombajnů</span>}
            </div>
            {brandHp.length > 0 && (
              <div style="font-size:12px; color:#666;">
                Výkon: {Math.min(...brandHp)}–{Math.max(...brandHp)} k
              </div>
            )}
          </a>
        );
      })}
    </div>

    <!-- Filtered results grid (hidden by default, shown when filters applied) -->
    <div id="results-grid" style="display:none; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:12px;"></div>
  </div>

  <script is:inline set:html={`window.__STROJE_DATA__ = ${modelsJson};`}></script>

  <script>
    type Model = {
      slug: string;
      name: string;
      brand_slug: string;
      brand_name: string;
      category: string;
      series_slug: string;
      series_name: string;
      year_from: number | null;
      year_to: number | null;
      power_hp: number | null;
      power_kw: number | null;
    };

    const MODELS: Model[] = (window as any).__STROJE_DATA__ ?? [];

    const el = {
      category: document.getElementById('f-category') as HTMLSelectElement,
      brand: document.getElementById('f-brand') as HTMLSelectElement,
      hpMin: document.getElementById('f-hp-min') as HTMLInputElement,
      hpMax: document.getElementById('f-hp-max') as HTMLInputElement,
      yearMin: document.getElementById('f-year-min') as HTMLInputElement,
      yearMax: document.getElementById('f-year-max') as HTMLInputElement,
      search: document.getElementById('f-search') as HTMLInputElement,
      reset: document.getElementById('f-reset') as HTMLButtonElement,
      count: document.getElementById('result-count') as HTMLElement,
      brandGrid: document.getElementById('brand-grid') as HTMLElement,
      resultsGrid: document.getElementById('results-grid') as HTMLElement,
    };

    function anyFilterActive(): boolean {
      return Boolean(
        el.category.value || el.brand.value || el.hpMin.value || el.hpMax.value ||
        el.yearMin.value || el.yearMax.value || el.search.value.trim(),
      );
    }

    function modelUrl(m: Model): string {
      const short = m.slug.startsWith(m.brand_slug + '-') ? m.slug.slice(m.brand_slug.length + 1) : m.slug;
      return `/stroje/${m.brand_slug}/${m.series_slug}/${short}/`;
    }

    function renderCard(m: Model): string {
      const hp = m.power_hp ? `${m.power_hp} k` : '—';
      const kw = m.power_kw ? ` (${m.power_kw} kW)` : '';
      const yr = m.year_from ? (m.year_to ? `${m.year_from}–${m.year_to}` : `${m.year_from}–dosud`) : '';
      return `
        <a href="${modelUrl(m)}" style="display:block; text-decoration:none; color:inherit; background:#fff; border:1px solid #e8e8e8; border-radius:14px; padding:16px; transition:box-shadow .2s, transform .2s;" class="model-card">
          <div style="display:flex; gap:6px; margin-bottom:8px; flex-wrap:wrap;">
            <span style="background:#FFFF00; color:#000; font-family:'Chakra Petch',sans-serif; font-size:10px; font-weight:400; padding:2px 6px; border-radius:3px; text-transform:uppercase; letter-spacing:.5px;">${m.brand_name}</span>
            <span style="background:#f0f0f0; color:#555; font-size:10px; padding:2px 6px; border-radius:3px; text-transform:uppercase; letter-spacing:.5px;">${m.category === 'traktory' ? 'Traktor' : 'Kombajn'}</span>
          </div>
          <div style="font-family:'Chakra Petch',sans-serif; font-size:18px; font-weight:700; color:#1a1a1a; margin-bottom:4px;">${m.name}</div>
          <div style="font-size:12px; color:#666; margin-bottom:8px;">${m.series_name}</div>
          <div style="display:flex; justify-content:space-between; font-size:13px; color:#555;">
            <span>⚡ ${hp}${kw}</span>
            <span>${yr}</span>
          </div>
        </a>
      `;
    }

    function applyFilters() {
      const cat = el.category.value;
      const brand = el.brand.value;
      const hpMin = parseInt(el.hpMin.value, 10);
      const hpMax = parseInt(el.hpMax.value, 10);
      const yearMin = parseInt(el.yearMin.value, 10);
      const yearMax = parseInt(el.yearMax.value, 10);
      const q = el.search.value.trim().toLowerCase();

      const filtered = MODELS.filter((m) => {
        if (cat && m.category !== cat) return false;
        if (brand && m.brand_slug !== brand) return false;
        if (!isNaN(hpMin) && (m.power_hp ?? 0) < hpMin) return false;
        if (!isNaN(hpMax) && (m.power_hp ?? 99999) > hpMax) return false;
        if (!isNaN(yearMin) && (m.year_to ?? m.year_from ?? 0) < yearMin) return false;
        if (!isNaN(yearMax) && (m.year_from ?? 99999) > yearMax) return false;
        if (q) {
          const hay = (m.name + ' ' + m.brand_name + ' ' + m.series_name).toLowerCase();
          if (!hay.includes(q)) return false;
        }
        return true;
      });

      const active = anyFilterActive();
      if (active) {
        el.brandGrid.style.display = 'none';
        el.resultsGrid.style.display = 'grid';
        const sorted = filtered.sort((a, b) => (b.power_hp ?? 0) - (a.power_hp ?? 0));
        el.resultsGrid.innerHTML = sorted.length > 0
          ? sorted.map(renderCard).join('')
          : '<div style="grid-column:1/-1; padding:48px; text-align:center; color:#767676;">Žádné modely neodpovídají filtrům.</div>';
        el.count.textContent = `Nalezeno ${filtered.length} modelů`;
      } else {
        el.brandGrid.style.display = 'grid';
        el.resultsGrid.style.display = 'none';
        el.count.textContent = '';
      }
    }

    [el.category, el.brand, el.hpMin, el.hpMax, el.yearMin, el.yearMax, el.search].forEach((e) => {
      e.addEventListener('input', applyFilters);
      e.addEventListener('change', applyFilters);
    });
    el.reset.addEventListener('click', () => {
      el.category.value = '';
      el.brand.value = '';
      el.hpMin.value = '';
      el.hpMax.value = '';
      el.yearMin.value = '';
      el.yearMax.value = '';
      el.search.value = '';
      applyFilters();
    });

    // Apply filters from URL query params on load
    const params = new URLSearchParams(window.location.search);
    if (params.get('kategorie')) el.category.value = params.get('kategorie')!;
    if (params.get('znacka')) el.brand.value = params.get('znacka')!;
    if (params.get('vykon_od')) el.hpMin.value = params.get('vykon_od')!;
    if (params.get('vykon_do')) el.hpMax.value = params.get('vykon_do')!;
    if (params.get('rok_od')) el.yearMin.value = params.get('rok_od')!;
    if (params.get('rok_do')) el.yearMax.value = params.get('rok_do')!;
    if (params.get('q')) el.search.value = params.get('q')!;
    applyFilters();
  </script>

  <style>
    .section-label {
      display: inline-block;
      font-family: 'Chakra Petch', sans-serif;
      font-size: 11px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: #1a1a1a;
      background: #FFFF00;
      padding: 4px 10px;
      border-radius: 3px;
      margin-bottom: 14px;
    }
    .brand-card:hover { box-shadow: 0 6px 20px rgba(0,0,0,.08); transform: translateY(-2px); border-color: #FFFF00; }
    .model-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,.08); transform: translateY(-2px); border-color: #FFFF00; }
  </style>
</Layout>
