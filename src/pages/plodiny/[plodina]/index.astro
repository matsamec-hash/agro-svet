---
export const prerender = true;
import Layout from '../../../layouts/Layout.astro';
import { listPlodiny, getPlodina, isOdrudaIndexable, SKUPINA_LABELS } from '../../../lib/plodiny';
import { chorobaChipsForPlodina } from '../../../lib/choroby';
import { breadcrumbSchema, howToSchema, faqPageSchema, itemListSchema } from '../../../lib/structured-data';
import OsivaLinks from '../../../components/OsivaLinks.astro';

export async function getStaticPaths() {
  return listPlodiny().map((p) => ({ params: { plodina: p.slug } }));
}

const { plodina: slug } = Astro.params;
const plodina = getPlodina(slug!);
if (!plodina) return Astro.rewrite('/404');

const base = `/plodiny/${plodina.slug}/`;
const breadcrumb = breadcrumbSchema([
  { name: 'Domů', url: '/' },
  { name: 'Plodiny', url: '/plodiny/' },
  { name: SKUPINA_LABELS[plodina.skupina], url: `/plodiny/skupina/${plodina.skupina}/` },
  { name: plodina.name, url: base },
]);

const howTo = plodina.osevni_postup && plodina.osevni_postup.length > 0
  ? howToSchema({
      name: `Osevní postup — ${plodina.name}`,
      description: `Jak pěstovat plodinu ${plodina.name.toLowerCase()}.`,
      url: base,
      steps: plodina.osevni_postup,
    })
  : null;
const faq = plodina.faq && plodina.faq.length > 0 ? faqPageSchema(plodina.faq) : null;
const chorobaChips = chorobaChipsForPlodina(plodina.slug);
const list = plodina.odrudy.length > 0
  ? itemListSchema(
      plodina.odrudy.map((o) => ({
        url: isOdrudaIndexable(o) ? `${base}${o.slug}/` : base,
        name: o.name,
      })),
      `Odrůdy — ${plodina.name}`,
    )
  : null;
---

<Layout
  title={`${plodina.name} — pěstování, odrůdy, agronomie`}
  description={`${plodina.name}: výsevek, hnojení, choroby, výnos a přehled ${plodina.odrudy.length} registrovaných odrůd.`}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumb)} />
  {howTo && <script type="application/ld+json" is:inline set:html={JSON.stringify(howTo)} />}
  {faq && <script type="application/ld+json" is:inline set:html={JSON.stringify(faq)} />}
  {list && <script type="application/ld+json" is:inline set:html={JSON.stringify(list)} />}

  <div class="pl-detail">

    <nav class="breadcrumb" aria-label="Drobečková navigace">
      <a href="/">Domů</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/plodiny/">Plodiny</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <a href={`/plodiny/skupina/${plodina.skupina}/`}>{SKUPINA_LABELS[plodina.skupina]}</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <span class="current">{plodina.name}</span>
    </nav>

    <section class="hero">
      <div class="hero-left">
        <span class="kicker"><span class="dot"></span>{SKUPINA_LABELS[plodina.skupina]} · Plodina</span>
        <h1>{plodina.name}</h1>
        <p class="hero-lede">{plodina.description}</p>
        <div class="hero-stats">
          {plodina.odrudy.length > 0 && (
            <div class="s"><span class="n">{plodina.odrudy.length}</span><span class="l">odrůd</span></div>
          )}
          {plodina.vynos_t_ha && (
            <div class="s"><span class="n">{plodina.vynos_t_ha}</span><span class="l">t/ha výnos</span></div>
          )}
          {plodina.osevni_postup && plodina.osevni_postup.length > 0 && (
            <div class="s"><span class="n">{plodina.osevni_postup.length}</span><span class="l">kroků pěstování</span></div>
          )}
        </div>
        <div class="hero-actions">
          <a class="cta-back" href="/plodiny/">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
            Všechny plodiny
          </a>
          <a class="cta-group" href={`/plodiny/skupina/${plodina.skupina}/`}>
            {SKUPINA_LABELS[plodina.skupina]}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
      </div>
      <div class="hero-right">
        <div class="hero-emoji-tile" aria-hidden="true">🌾</div>
      </div>
    </section>

    {(plodina.vysevek || plodina.hnojeni || plodina.vynos_t_ha || plodina.sklizen || plodina.vyuziti) && (
      <section class="card-section agro-facts">
        <h2 class="section-title">Agronomie</h2>
        <dl class="facts-dl">
          {plodina.vysevek && (
            <>
              <dt>Výsevek</dt>
              <dd>{plodina.vysevek}</dd>
            </>
          )}
          {plodina.hnojeni && (
            <>
              <dt>Hnojení</dt>
              <dd>{plodina.hnojeni}</dd>
            </>
          )}
          {plodina.vynos_t_ha && (
            <>
              <dt>Výnos</dt>
              <dd>{plodina.vynos_t_ha} t/ha</dd>
            </>
          )}
          {plodina.sklizen && (
            <>
              <dt>Sklizeň</dt>
              <dd>{plodina.sklizen}</dd>
            </>
          )}
          {plodina.vyuziti && (
            <>
              <dt>Využití</dt>
              <dd>{plodina.vyuziti}</dd>
            </>
          )}
        </dl>
      </section>
    )}

    {plodina.osevni_postup && plodina.osevni_postup.length > 0 && (
      <section class="card-section">
        <h2 class="section-title">Osevní postup</h2>
        <ol class="how-to-list">
          {plodina.osevni_postup.map((s, i) => (
            <li id={`krok-${i + 1}`} class="how-to-step">
              <span class="step-num">{i + 1}</span>
              <div class="step-body">
                <strong class="step-name">{s.name}</strong>
                <p class="step-text">{s.text}</p>
              </div>
            </li>
          ))}
        </ol>
      </section>
    )}

    {chorobaChips.length > 0 && (
      <section class="card-section">
        <h2 class="section-title">Choroby a škůdci</h2>
        <ul class="tag-list">
          {chorobaChips.map((c) => (
            c.slug
              ? <li class="tag-item"><a href={`/choroby/${c.slug}/`}>{c.chip}</a></li>
              : <li class="tag-item">{c.chip}</li>
          ))}
        </ul>
      </section>
    )}

    {plodina.body && (
      <section class="card-section prose" set:html={plodina.body} />
    )}

    {plodina.odrudy.length > 0 && (
      <section class="card-section odrudy-section">
        <h2 class="section-title">
          Odrůdy
          <span class="section-title-c">{plodina.odrudy.length}</span>
        </h2>
        <div class="table-wrap">
          <table class="odrudy-table">
            <thead>
              <tr>
                <th>Odrůda</th>
                <th>Typ</th>
                <th>Ranost</th>
                <th>Registrace</th>
                <th>Udržovatel</th>
              </tr>
            </thead>
            <tbody>
              {plodina.odrudy.map((o) => (
                <tr>
                  <td class="td-name">
                    {isOdrudaIndexable(o)
                      ? <a href={`${base}${o.slug}/`}>{o.name}</a>
                      : o.name}
                  </td>
                  <td>{o.typ ?? '—'}</td>
                  <td>{o.ranost ?? '—'}</td>
                  <td>{o.rok_registrace ?? '—'}</td>
                  <td>{o.udrzovatel ?? '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )}

    {plodina.faq && plodina.faq.length > 0 && (
      <section class="card-section faq-section">
        <h2 class="section-title">Časté dotazy</h2>
        <div class="faq-list">
          {plodina.faq.map((f) => (
            <div class="faq-item">
              <h3 class="faq-q">{f.q}</h3>
              <p class="faq-a">{f.a}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <div class="card-section osiva-wrap">
      <OsivaLinks plodina={plodina.name} skupina={plodina.skupina} />
    </div>

  </div>
</Layout>

<style>
  .pl-detail {
    --yellow: #FFEA00; --ink: #0A0A0B; --body: #1E1E22; --muted: #6B6B72;
    --muted-2: #9A9AA3; --line: #EAEAEC; --card: #FFFFFF; --green: #3c7a1a;
    --green-soft: #eaf4e0; --green-dark: #2a5a10;
    --r-xl: 24px; --r-lg: 18px; --r-md: 12px;
    --sh-1: 0 1px 2px rgba(10,10,12,.04), 0 0 0 1px rgba(10,10,12,.03);
    --sh-3: 0 18px 40px -12px rgba(10,10,12,.18), 0 0 0 1px rgba(10,10,12,.04);
    max-width: 1280px; margin: 0 auto; padding: 26px 24px 96px; color: var(--body);
  }

  /* ── Breadcrumb ── */
  .pl-detail .breadcrumb { display: flex; gap: 8px; align-items: center; font-size: 13px; color: var(--muted); margin-bottom: 22px; flex-wrap: wrap; }
  .pl-detail .breadcrumb a { color: var(--muted); text-decoration: none; }
  .pl-detail .breadcrumb a:hover { color: #000; }
  .pl-detail .breadcrumb svg { color: var(--muted-2); flex-shrink: 0; }
  .pl-detail .breadcrumb .current { color: #000; font-weight: 600; }

  /* ── Hero ── */
  .pl-detail .hero {
    position: relative; overflow: hidden; color: #fff; border-radius: var(--r-xl);
    background:
      radial-gradient(600px 300px at 15% 20%, rgba(255, 234, 0, .14), transparent 60%),
      radial-gradient(700px 400px at 90% 90%, rgba(60, 140, 40, .30), transparent 60%),
      linear-gradient(135deg, #0F1409 0%, #161F0E 60%, #1C2B10 100%);
    padding: 48px 48px 40px; margin-bottom: 26px; display: flex; gap: 32px; align-items: center;
    box-shadow: var(--sh-3);
  }
  .pl-detail .hero-left { flex: 1; min-width: 0; }
  .pl-detail .kicker { display: inline-flex; align-items: center; gap: 8px; font-size: 12.5px; font-weight: 600; letter-spacing: .04em; text-transform: uppercase; color: #D8EBC0; margin-bottom: 16px; }
  .pl-detail .kicker .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--yellow); }
  .pl-detail .hero h1 { font-size: clamp(28px, 4vw, 44px); line-height: 1.08; margin: 0 0 14px; font-weight: 800; }
  .pl-detail .hero-lede { font-size: 16.5px; line-height: 1.6; color: #E0ECDA; max-width: 60ch; margin: 0 0 22px; }
  .pl-detail .hero-stats { display: flex; gap: 28px; flex-wrap: wrap; margin-bottom: 22px; }
  .pl-detail .hero-stats .s { display: flex; flex-direction: column; }
  .pl-detail .hero-stats .n { font-size: 26px; font-weight: 800; color: #fff; }
  .pl-detail .hero-stats .l { font-size: 12.5px; color: #B2C9A8; }
  .pl-detail .hero-right { flex-shrink: 0; }
  .pl-detail .hero-emoji-tile { font-size: 92px; line-height: 1; filter: drop-shadow(0 8px 24px rgba(0,0,0,.4)); }
  .pl-detail .hero-actions { display: flex; gap: 10px; flex-wrap: wrap; }
  .pl-detail .cta-back {
    display: inline-flex; align-items: center; gap: 8px;
    color: #c8c8d0; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.12);
    padding: 11px 16px; border-radius: var(--r-md); text-decoration: none;
    font-size: 13.5px; font-weight: 500; transition: .15s;
  }
  .pl-detail .cta-back:hover { background: rgba(255,255,255,.12); color: #fff; border-color: rgba(255,255,255,.22); }
  .pl-detail .cta-group {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--yellow); color: #0A0A0B;
    padding: 11px 16px; border-radius: var(--r-md); text-decoration: none;
    font-size: 13.5px; font-weight: 700; transition: .15s;
  }
  .pl-detail .cta-group:hover { opacity: .9; }

  /* ── Section cards ── */
  .pl-detail .card-section {
    background: var(--card); border-radius: var(--r-lg); padding: 28px 32px;
    box-shadow: var(--sh-1); margin-bottom: 20px;
  }
  .pl-detail .section-title {
    font-size: 20px; font-weight: 800; color: var(--ink); margin: 0 0 20px;
    display: flex; align-items: center; gap: 10px;
  }
  .pl-detail .section-title-c {
    font-size: 13px; background: var(--green-soft); color: var(--green);
    font-weight: 700; padding: 3px 10px; border-radius: 999px;
  }

  /* ── Agronomie DL ── */
  .pl-detail .facts-dl {
    display: grid; grid-template-columns: max-content 1fr; gap: 0;
    border: 1px solid var(--line); border-radius: var(--r-md); overflow: hidden;
  }
  .pl-detail .facts-dl dt,
  .pl-detail .facts-dl dd {
    padding: 11px 16px; margin: 0; font-size: 14.5px; line-height: 1.5;
  }
  .pl-detail .facts-dl dt {
    font-weight: 700; color: var(--ink); background: #F7F7FA;
    border-bottom: 1px solid var(--line);
  }
  .pl-detail .facts-dl dd {
    color: var(--body); background: #fff; border-bottom: 1px solid var(--line);
  }
  .pl-detail .facts-dl dt:last-of-type,
  .pl-detail .facts-dl dd:last-child { border-bottom: none; }

  /* ── Osevní postup ── */
  .pl-detail .how-to-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 14px; }
  .pl-detail .how-to-step {
    display: flex; gap: 16px; align-items: flex-start;
    background: #F7F7FA; border-radius: var(--r-md); padding: 16px 20px;
    border-left: 4px solid var(--green);
  }
  .pl-detail .step-num {
    flex-shrink: 0; width: 30px; height: 30px;
    background: var(--green); color: #fff;
    border-radius: 50%; display: flex; align-items: center; justify-content: center;
    font-size: 13px; font-weight: 800; line-height: 1;
  }
  .pl-detail .step-body { flex: 1; min-width: 0; }
  .pl-detail .step-name { display: block; font-size: 15px; font-weight: 700; color: var(--ink); margin-bottom: 5px; }
  .pl-detail .step-text { margin: 0; font-size: 14px; line-height: 1.6; color: var(--body); }

  /* ── Choroby tag list ── */
  .pl-detail .tag-list { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 8px; }
  .pl-detail .tag-item {
    display: inline-block; font-size: 13.5px; font-weight: 600;
    color: #7a2a10; background: #fdf0ec; border: 1px solid #f5c6b8;
    padding: 5px 12px; border-radius: 999px;
  }
  .pl-detail .tag-item a { color: inherit; text-decoration: none; }
  .pl-detail .tag-item:has(a) { transition: .15s; }
  .pl-detail .tag-item:has(a):hover { background: #fbe2da; border-color: #ec9f88; }
  .pl-detail .tag-item a:hover { text-decoration: underline; }

  /* ── Prose body ── */
  .pl-detail .prose { font-size: 15px; line-height: 1.7; color: var(--body); }
  .pl-detail .prose h2 { font-size: 20px; font-weight: 800; color: var(--ink); margin: 1.4em 0 .6em; }
  .pl-detail .prose h3 { font-size: 17px; font-weight: 700; color: var(--ink); margin: 1.2em 0 .5em; }
  .pl-detail .prose p { margin: 0 0 1em; }
  .pl-detail .prose ul, .pl-detail .prose ol { padding-left: 1.4em; margin: 0 0 1em; }
  .pl-detail .prose li { margin-bottom: .4em; }
  .pl-detail .prose strong { font-weight: 700; color: var(--ink); }
  .pl-detail .prose a { color: var(--green); text-decoration: underline; }
  .pl-detail .prose a:hover { color: var(--green-dark); }
  .pl-detail .prose table { width: 100%; border-collapse: collapse; font-size: 14px; margin: 1em 0; }
  .pl-detail .prose th { background: #F7F7FA; font-weight: 700; padding: 10px 14px; border: 1px solid var(--line); text-align: left; }
  .pl-detail .prose td { padding: 10px 14px; border: 1px solid var(--line); }

  /* ── Odrůdy table ── */
  .pl-detail .table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; border-radius: var(--r-md); border: 1px solid var(--line); }
  .pl-detail .odrudy-table { width: 100%; border-collapse: collapse; font-size: 14px; }
  .pl-detail .odrudy-table thead tr { background: #F7F7FA; }
  .pl-detail .odrudy-table th {
    padding: 11px 14px; font-size: 12px; font-weight: 700; text-transform: uppercase;
    letter-spacing: .06em; color: var(--muted); text-align: left;
    border-bottom: 1px solid var(--line); white-space: nowrap;
  }
  .pl-detail .odrudy-table td {
    padding: 10px 14px; border-bottom: 1px solid var(--line);
    color: var(--body); vertical-align: top; font-size: 13.5px;
  }
  .pl-detail .odrudy-table tbody tr:last-child td { border-bottom: none; }
  .pl-detail .odrudy-table tbody tr:hover { background: #F7F7FA; }
  .pl-detail .td-name { font-weight: 600; color: var(--ink); }
  .pl-detail .td-name a { color: var(--green); text-decoration: none; font-weight: 700; }
  .pl-detail .td-name a:hover { text-decoration: underline; color: var(--green-dark); }

  /* ── FAQ ── */
  .pl-detail .faq-list { display: flex; flex-direction: column; gap: 16px; }
  .pl-detail .faq-item { border-left: 3px solid var(--green-soft); padding-left: 16px; }
  .pl-detail .faq-q { font-size: 16px; font-weight: 700; color: var(--ink); margin: 0 0 6px; }
  .pl-detail .faq-a { font-size: 14.5px; line-height: 1.65; color: var(--body); margin: 0; }

  /* ── Osiva wrapper (reset section card on inner component) ── */
  .pl-detail .osiva-wrap { border-top: 2px solid var(--green-soft); }

  /* ── Responsive ── */
  @media (max-width: 720px) {
    .pl-detail .hero { flex-direction: column; padding: 34px 26px; text-align: center; }
    .pl-detail .hero-stats { justify-content: center; }
    .pl-detail .hero-right { display: none; }
    .pl-detail .hero-actions { justify-content: center; }
    .pl-detail .card-section { padding: 22px 18px; }
    .pl-detail .facts-dl { grid-template-columns: 1fr; }
    .pl-detail .facts-dl dt { border-bottom: none; padding-bottom: 2px; }
    .pl-detail .facts-dl dd { border-bottom: 1px solid var(--line); padding-top: 2px; }
  }
  @media (max-width: 480px) {
    .pl-detail { padding: 20px 16px 60px; }
  }
</style>
