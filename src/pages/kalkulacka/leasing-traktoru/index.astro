---
// SSR (prerender:false) → middleware servíruje lokalizovanú /sk verziu cez
// locals.locale. cs výstup sémanticky identický.
export const prerender = false;
import Layout from '../../../layouts/Layout.astro';
import { breadcrumbSchema, faqPageSchema } from '../../../lib/structured-data';
import { SITE_URL } from '../../../lib/config';
import { content } from '../../../i18n/kalkulacka/leasing-traktoru';
import { crumbs } from '../../../i18n/kalkulacka/common';

const locale = Astro.locals.locale ?? 'cs';
const c = content[locale] ?? content.cs;
const cr = crumbs[locale] ?? crumbs.cs;

const canonical = `${SITE_URL}/kalkulacka/leasing-traktoru/`;
const faqItems = c.faq;
const providers = c.providers;
const calcCfg = { currency: c.currency, numberLocale: c.numberLocale, js: c.js, providers: c.providers };

const breadcrumbJsonLd = breadcrumbSchema([
  { name: cr.home, url: locale === 'cs' ? '/' : `/${locale}/` },
  { name: cr.hub, url: locale === 'cs' ? '/kalkulacka/' : `/${locale}/kalkulacka/` },
  { name: c.crumb, url: canonical },
]);
const faqJsonLd = faqPageSchema(faqItems);
---

<Layout
  title={c.title}
  description={c.metaDescription}
  canonical={locale === 'cs' ? canonical : undefined}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqJsonLd)} />

  <div class="calc-page" data-providers={JSON.stringify(providers)}>
    <nav class="breadcrumb" aria-label="Cesta">
      <a href={locale === 'cs' ? '/' : `/${locale}/`}>{cr.home}</a>
      <span class="sep" aria-hidden="true">›</span>
      <a href={locale === 'cs' ? '/kalkulacka/' : `/${locale}/kalkulacka/`}>{cr.hub}</a>
      <span class="sep" aria-hidden="true">›</span>
      <span class="current">{c.crumb}</span>
    </nav>

    <header class="hero">
      <span class="kicker">{c.kicker}</span>
      <h1>{c.h1}</h1>
      <p class="hero-lede">{c.lede}</p>
    </header>

    <div class="calc-layout">
      <form class="calc-form" id="calc-form" autocomplete="off">
        <div class="cf-group">
          <label for="price">{c.form.price}</label>
          <div class="cf-input-unit">
            <input type="number" id="price" min="100000" max="20000000" step="10000" value={c.currency === 'EUR' ? 100000 : 2500000} inputmode="numeric" />
            <span class="cf-unit">{c.currency === 'EUR' ? '€' : 'Kč'}</span>
          </div>
        </div>

        <div class="cf-group">
          <label for="downpayment">{c.form.downpayment}</label>
          <div class="cf-input-unit">
            <input type="number" id="downpayment" min="0" max="90" step="1" value="20" inputmode="numeric" />
            <span class="cf-unit">%</span>
          </div>
          <output class="cf-hint" id="downpayment-hint"></output>
        </div>

        <div class="cf-group">
          <label for="months">{c.form.months}</label>
          <div class="cf-input-unit">
            <input type="number" id="months" min="12" max="84" step="6" value="60" inputmode="numeric" />
            <span class="cf-unit">{c.form.monthsUnit}</span>
          </div>
        </div>

        <div class="cf-group">
          <label for="residual">{c.form.residual}</label>
          <div class="cf-input-unit">
            <input type="number" id="residual" min="0" max="50" step="1" value="0" inputmode="numeric" />
            <span class="cf-unit">%</span>
          </div>
          <output class="cf-hint" id="residual-hint"></output>
        </div>
      </form>

      <div class="calc-result" id="calc-result">
        <div class="cr-headline">
          <span class="cr-label">{c.result.headline}</span>
          <span class="cr-value" id="result-monthly">—</span>
        </div>
        <div class="cr-grid">
          <div class="cr-stat">
            <span class="crs-label">{c.result.financed}</span>
            <span class="crs-value" id="result-financed">—</span>
          </div>
          <div class="cr-stat">
            <span class="crs-label">{c.result.total}</span>
            <span class="crs-value" id="result-total">—</span>
          </div>
          <div class="cr-stat">
            <span class="crs-label">{c.result.interest}</span>
            <span class="crs-value" id="result-interest">—</span>
          </div>
          <div class="cr-stat">
            <span class="crs-label">{c.result.usedRate}</span>
            <span class="crs-value" id="result-apr">—</span>
          </div>
        </div>
      </div>
    </div>

    {c.providerSection && (
      <section class="provider-section" aria-labelledby="providers-h">
        <h2 id="providers-h">{c.providerSection.heading}</h2>
        <p class="provider-lede">{c.providerSection.lede}</p>
        <div class="provider-table" id="provider-table">
          <div class="pt-header">
            <div class="pt-th">{c.providerSection.thProvider}</div>
            <div class="pt-th">{c.providerSection.thRate}</div>
            <div class="pt-th">{c.providerSection.thMonthly}</div>
            <div class="pt-th">{c.providerSection.thTotal}</div>
          </div>
          {providers.map((p) => (
            <div class="pt-row" data-provider-id={p.id} data-apr={p.apr}>
              <div class="pt-cell pt-name">
                <strong>{p.name}</strong>
                <span class="pt-note">{p.note}</span>
              </div>
              <div class="pt-cell pt-apr">{p.apr.toLocaleString(c.numberLocale)} %</div>
              <div class="pt-cell pt-monthly">—</div>
              <div class="pt-cell pt-total">—</div>
            </div>
          ))}
        </div>
        <p class="provider-disclaimer">{c.providerSection.disclaimer}</p>
      </section>
    )}

    <section class="faq" aria-labelledby="faq-h">
      <h2 id="faq-h">Časté otázky</h2>
      <dl class="faq-list">
        {faqItems.map((qa) => (
          <div class="faq-item">
            <dt>{qa.q}</dt>
            <dd>{qa.a}</dd>
          </div>
        ))}
      </dl>
    </section>

    <section class="cross-cta">
      <div>
        <span class="cc-kicker">{c.cta.kicker}</span>
        <h2>{c.cta.heading}</h2>
        <div class="cc-actions">
          <a class="cc-btn primary" href={locale === 'cs' ? '/stroje/traktory/' : `/${locale}/stroje/traktory/`}>{c.cta.catalog}</a>
          <a class="cc-btn ghost" href={locale === 'cs' ? '/srovnani/' : `/${locale}/srovnani/`}>{c.cta.compare}</a>
          <a class="cc-btn ghost" href={locale === 'cs' ? '/kalkulacka/naklady-na-hektar/' : `/${locale}/kalkulacka/naklady-na-hektar/`}>{c.cta.costs}</a>
        </div>
      </div>
    </section>

    <script type="application/json" id="calc-cfg" set:html={JSON.stringify(calcCfg)}></script>
  </div>
</Layout>

<style>
  .calc-page {
    --yellow:#FFEA00; --yellow-soft:#FFF6A8; --yellow-glow:rgba(255,234,0,.35);
    --ink:#0A0A0B; --body:#1E1E22; --muted:#6B6B72; --muted-2:#9A9AA3;
    --line:#EAEAEC; --card:#FFFFFF; --bg-cream:#FBFAF4;
    --green:#0B7A3B; --green-soft:#E3F3EA;
    --sh-1:0 1px 2px rgba(10,10,12,.04), 0 0 0 1px rgba(10,10,12,.03);
    --sh-2:0 4px 14px rgba(10,10,12,.06), 0 0 0 1px rgba(10,10,12,.04);
    --sh-3:0 18px 40px -12px rgba(10,10,12,.18), 0 0 0 1px rgba(10,10,12,.04);
    max-width:1280px; margin:0 auto; padding:26px 24px 96px; color:var(--body);
  }
  .breadcrumb { display:flex; gap:8px; align-items:center; font-size:13px; color:var(--muted); margin-bottom:22px; flex-wrap:wrap; }
  .breadcrumb a { color:var(--muted); text-decoration:none; }
  .breadcrumb a:hover { color:#000; }
  .breadcrumb .current { color:#000; font-weight:600; }
  .breadcrumb .sep { color:var(--muted-2); }

  .hero { background:linear-gradient(135deg, #0E0E10 0%, #1C1C20 60%, #2A2A2F 100%); color:#fff; border-radius:24px; padding:40px 44px; margin-bottom:28px; box-shadow:var(--sh-3); position:relative; overflow:hidden; }
  .hero::before { content:""; position:absolute; inset:0; pointer-events:none; opacity:.3; background-image:linear-gradient(rgba(255,255,255,.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.05) 1px, transparent 1px); background-size:48px 48px; mask-image:radial-gradient(600px 400px at 70% 100%, black, transparent 70%); }
  .hero .kicker { display:inline-flex; font:600 11px 'Chakra Petch',sans-serif; letter-spacing:.2em; text-transform:uppercase; color:var(--yellow); background:rgba(255,234,0,.08); border:1px solid rgba(255,234,0,.3); padding:7px 13px; border-radius:999px; position:relative; z-index:2; }
  .hero h1 { font:700 clamp(2rem,5vw,3.4rem) 'Chakra Petch',sans-serif; color:#fff; letter-spacing:-.03em; margin:16px 0 0; line-height:1.05; position:relative; z-index:2; }
  .hero-lede { color:#c8c8d0; max-width:720px; font-size:15.5px; line-height:1.6; margin:14px 0 0; position:relative; z-index:2; }

  .calc-layout { display:grid; grid-template-columns:1fr 1fr; gap:18px; margin-bottom:32px; }
  .calc-form { background:var(--card); border:1px solid var(--line); border-radius:18px; padding:26px 28px; box-shadow:var(--sh-1); display:flex; flex-direction:column; gap:20px; }
  .cf-group { display:flex; flex-direction:column; gap:7px; }
  .cf-group label { font:600 12px 'Chakra Petch',sans-serif; letter-spacing:.06em; text-transform:uppercase; color:var(--muted); }
  .cf-input-unit { display:flex; align-items:stretch; border:1.5px solid var(--line); border-radius:10px; overflow:hidden; transition:.12s; }
  .cf-input-unit:focus-within { border-color:var(--yellow); box-shadow:0 0 0 3px rgba(255,234,0,.25); }
  .cf-input-unit input { flex:1; border:0; outline:0; padding:13px 14px; font:700 17px 'Chakra Petch',sans-serif; color:var(--ink); background:#fff; min-width:0; }
  .cf-unit { display:flex; align-items:center; padding:0 14px; background:var(--bg-cream); font:600 13px 'Chakra Petch',sans-serif; color:var(--muted); border-left:1px solid var(--line); }
  .cf-hint { font-size:12.5px; color:var(--muted); font-family:'Chakra Petch',sans-serif; }

  .calc-result { background:linear-gradient(135deg, #0E0E10 0%, #1C1C20 100%); color:#fff; border-radius:18px; padding:28px 30px; box-shadow:var(--sh-3); display:flex; flex-direction:column; gap:22px; }
  .cr-headline { display:flex; flex-direction:column; gap:6px; padding-bottom:20px; border-bottom:1px solid rgba(255,255,255,.12); }
  .cr-label { font:600 11px 'Chakra Petch',sans-serif; letter-spacing:.16em; text-transform:uppercase; color:#8a8a92; }
  .cr-value { font:700 clamp(2rem,5vw,3rem) 'Chakra Petch',sans-serif; color:var(--yellow); letter-spacing:-.02em; line-height:1; }
  .cr-grid { display:grid; grid-template-columns:1fr 1fr; gap:18px; }
  .cr-stat { display:flex; flex-direction:column; gap:4px; }
  .crs-label { font:500 11px 'Chakra Petch',sans-serif; letter-spacing:.1em; text-transform:uppercase; color:#8a8a92; }
  .crs-value { font:700 19px 'Chakra Petch',sans-serif; color:#fff; letter-spacing:-.01em; }

  .provider-section { margin-bottom:32px; }
  .provider-section h2 { font:700 26px 'Chakra Petch',sans-serif; letter-spacing:-.02em; color:var(--ink); margin:0 0 8px; }
  .provider-lede { font-size:14px; color:var(--muted); line-height:1.6; max-width:760px; margin:0 0 18px; }
  .provider-table { background:var(--card); border:1px solid var(--line); border-radius:18px; overflow:hidden; box-shadow:var(--sh-1); }
  .pt-header { display:grid; grid-template-columns:2fr 1fr 1.3fr 1.3fr; background:var(--bg-cream); border-bottom:1px solid var(--line); }
  .pt-th { padding:13px 18px; font:700 11px 'Chakra Petch',sans-serif; letter-spacing:.1em; text-transform:uppercase; color:var(--muted); }
  .pt-row { display:grid; grid-template-columns:2fr 1fr 1.3fr 1.3fr; border-bottom:1px solid var(--line); align-items:center; }
  .pt-row:last-child { border-bottom:0; }
  .pt-row.is-best { background:var(--green-soft); }
  .pt-cell { padding:14px 18px; font:600 14.5px 'Chakra Petch',sans-serif; color:var(--ink); }
  .pt-name { display:flex; flex-direction:column; gap:3px; }
  .pt-name strong { font-weight:700; font-size:15px; }
  .pt-note { font:500 12px 'Chakra Petch',sans-serif; color:var(--muted); line-height:1.4; }
  .pt-row.is-best .pt-name strong::after { content:" ★ nejnižší"; color:var(--green); font-size:11px; letter-spacing:.04em; }
  .pt-apr { color:var(--muted); }
  .pt-monthly { font-weight:700; }
  .provider-disclaimer { font-size:12px; color:var(--muted-2); line-height:1.55; margin:14px 4px 0; }

  .faq { margin-bottom:32px; }
  .faq h2 { font:700 26px 'Chakra Petch',sans-serif; letter-spacing:-.02em; color:var(--ink); margin:0 0 16px; }
  .faq-list { display:flex; flex-direction:column; gap:10px; }
  .faq-item { background:var(--card); border:1px solid var(--line); border-radius:14px; padding:18px 22px; }
  .faq-item dt { font:700 15.5px 'Chakra Petch',sans-serif; color:var(--ink); margin:0 0 7px; letter-spacing:-.005em; }
  .faq-item dd { font-size:14px; color:#3a3a40; line-height:1.6; margin:0; }

  .cross-cta { background:linear-gradient(135deg, var(--yellow) 0%, #FFD400 100%); border-radius:24px; padding:30px 34px; box-shadow:0 10px 30px -8px var(--yellow-glow); }
  .cross-cta h2 { font:700 23px 'Chakra Petch',sans-serif; letter-spacing:-.02em; color:#0A0A0B; margin:6px 0 14px; }
  .cc-kicker { display:inline-block; font:600 11px 'Chakra Petch',sans-serif; letter-spacing:.2em; text-transform:uppercase; color:#0A0A0B; background:rgba(0,0,0,.08); padding:5px 11px; border-radius:999px; }
  .cc-actions { display:flex; gap:8px; flex-wrap:wrap; }
  .cc-btn { padding:11px 18px; border-radius:10px; text-decoration:none; font:700 13px 'Chakra Petch',sans-serif; letter-spacing:.04em; transition:.15s; }
  .cc-btn.primary { background:#0A0A0B; color:#fff; }
  .cc-btn.primary:hover { transform:translateY(-1px); }
  .cc-btn.ghost { background:rgba(255,255,255,.5); color:#0A0A0B; border:1px solid rgba(0,0,0,.15); }
  .cc-btn.ghost:hover { background:rgba(255,255,255,.8); }

  @media (max-width:820px) {
    .calc-layout { grid-template-columns:1fr; }
    .pt-header { display:none; }
    .pt-row { grid-template-columns:1fr 1fr; gap:2px 0; padding:14px 0; }
    .pt-cell { padding:4px 18px; }
    .pt-name { grid-column:1 / -1; padding-bottom:8px; }
    .pt-apr::before { content:"Sazba: "; color:var(--muted); }
    .pt-monthly::before { content:"Splátka: "; color:var(--muted); font-weight:500; }
    .pt-total { grid-column:1 / -1; }
    .pt-total::before { content:"Celkem: "; color:var(--muted); font-weight:500; }
  }
  @media (max-width:600px) {
    .calc-page { padding:20px 16px 60px; }
    .hero { padding:30px 22px; }
    .cr-grid { grid-template-columns:1fr; }
  }
</style>

<script>
  // ── Leasing calculator — annuity formula ──────────────────────────────────
  const cfg = JSON.parse(document.getElementById('calc-cfg')?.textContent || '{}');
  const providers: { id: string; name: string; apr: number; note: string }[] = cfg.providers ?? [];
  const numberLocale: string = cfg.numberLocale ?? 'cs-CZ';
  const currency: string = cfg.currency ?? 'CZK';
  const js = cfg.js ?? {};
  const fmtMoney = (n: number) =>
    new Intl.NumberFormat(numberLocale, { style: 'currency', currency, maximumFractionDigits: 0 }).format(Math.round(n));

  const priceEl = document.getElementById('price') as HTMLInputElement;
  const downEl = document.getElementById('downpayment') as HTMLInputElement;
  const monthsEl = document.getElementById('months') as HTMLInputElement;
  const residualEl = document.getElementById('residual') as HTMLInputElement;
  const downHint = document.getElementById('downpayment-hint');
  const residualHint = document.getElementById('residual-hint');

  /**
   * Annuity payment with optional balloon (residual) payment.
   * financed = price - downpayment; the residual is paid at the end, so it is
   * carried as a future-value term that reduces the monthly annuity.
   */
  function monthlyPayment(financed: number, residual: number, aprPct: number, months: number): number {
    if (months <= 0) return 0;
    const r = aprPct / 100 / 12;
    if (r === 0) return (financed - residual) / months;
    const annuityFactor = (1 - Math.pow(1 + r, -months));
    // PV of residual discounted to today
    const residualPV = residual / Math.pow(1 + r, months);
    return ((financed - residualPV) * r) / annuityFactor;
  }

  function recalc() {
    const price = Math.max(0, parseFloat(priceEl.value) || 0);
    const downPct = Math.min(90, Math.max(0, parseFloat(downEl.value) || 0));
    const months = Math.max(1, parseFloat(monthsEl.value) || 1);
    const residualPct = Math.min(50, Math.max(0, parseFloat(residualEl.value) || 0));

    const downAmount = price * (downPct / 100);
    const financed = price - downAmount;
    const residualAmount = price * (residualPct / 100);

    if (downHint) downHint.textContent = downAmount > 0 ? `${js.downHintPrefix ?? '= '}${fmtMoney(downAmount)}` : '';
    if (residualHint) residualHint.textContent = residualAmount > 0 ? `${js.downHintPrefix ?? '= '}${fmtMoney(residualAmount)}${js.residualSuffix ?? ''}` : (js.noResidual ?? '');

    // Primary result uses the first provider's rate as the headline default.
    const headlineApr = providers[0]?.apr ?? 6.9;
    const monthly = monthlyPayment(financed, residualAmount, headlineApr, months);
    const totalPaid = downAmount + monthly * months + residualAmount;
    const interest = totalPaid - price;

    document.getElementById('result-monthly')!.textContent = fmtMoney(monthly);
    document.getElementById('result-financed')!.textContent = fmtMoney(financed);
    document.getElementById('result-total')!.textContent = fmtMoney(totalPaid);
    document.getElementById('result-interest')!.textContent = fmtMoney(interest);
    document.getElementById('result-apr')!.textContent = `${headlineApr.toLocaleString(numberLocale)}${js.perAnnum ?? ' % p.a.'}`;

    // Provider comparison table
    let bestMonthly = Infinity;
    const rows: { id: string; monthly: number; total: number }[] = [];
    for (const p of providers) {
      const m = monthlyPayment(financed, residualAmount, p.apr, months);
      const t = downAmount + m * months + residualAmount;
      rows.push({ id: p.id, monthly: m, total: t });
      if (m < bestMonthly) bestMonthly = m;
    }
    for (const row of rows) {
      const rowEl = document.querySelector<HTMLElement>(`.pt-row[data-provider-id="${row.id}"]`);
      if (!rowEl) continue;
      rowEl.querySelector('.pt-monthly')!.textContent = fmtMoney(row.monthly);
      rowEl.querySelector('.pt-total')!.textContent = fmtMoney(row.total);
      rowEl.classList.toggle('is-best', Math.abs(row.monthly - bestMonthly) < 0.5);
    }
  }

  [priceEl, downEl, monthsEl, residualEl].forEach((el) => el?.addEventListener('input', recalc));
  recalc();
</script>
