---
// SSR (prerender:false) → middleware servíruje lokalizovanú /sk verziu cez
// locals.locale. cs výstup sémanticky identický.
export const prerender = false;
import Layout from '../../../layouts/Layout.astro';
import { breadcrumbSchema, faqPageSchema } from '../../../lib/structured-data';
import { SITE_URL } from '../../../lib/config';
import { content } from '../../../i18n/kalkulacka/uspora-nafty';
import { crumbs } from '../../../i18n/kalkulacka/common';
import type { EmisniNorma } from '../../../lib/diesel-calc';

const locale = Astro.locals.locale ?? 'cs';
const c = content[locale] ?? content.cs;
const cr = crumbs[locale] ?? crumbs.cs;
const NORMA_ORDER: EmisniNorma[] = ['pre-tier2', 'tier3', 'stage3b', 'stage4', 'stage5'];
const normaOptions = NORMA_ORDER.map((value) => ({ value, label: c.normaLabels[value] }));
const canonical = `${SITE_URL}/kalkulacka/uspora-nafty/`;
const faqItems = c.faq;
const calcCfg = { currency: c.currency, numberLocale: c.numberLocale, js: c.js, normaLabels: c.normaLabels, hpUnit: c.hpUnit, fillAlert: c.js.alertFill };

const breadcrumbJsonLd = breadcrumbSchema([
  { name: cr.home, url: locale === 'cs' ? '/' : `/${locale}/` },
  { name: cr.hub, url: locale === 'cs' ? '/kalkulacka/' : `/${locale}/kalkulacka/` },
  { name: c.crumb, url: canonical },
]);
const faqJsonLd = faqPageSchema(faqItems);
---

<Layout
  title={c.title}
  description={c.metaDescription}
  canonical={locale === 'cs' ? canonical : undefined}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqJsonLd)} />

  <div class="dc-root">
    <nav class="breadcrumb" aria-label="Cesta">
      <a href={locale === 'cs' ? '/' : `/${locale}/`}>{cr.home}</a>
      <span aria-hidden="true">›</span>
      <a href={locale === 'cs' ? '/kalkulacka/' : `/${locale}/kalkulacka/`}>{cr.hub}</a>
      <span aria-hidden="true">›</span>
      <span class="current">{c.crumb}</span>
    </nav>

    <header class="dc-head">
      <span class="kicker">{c.kicker}</span>
      <h1>{c.h1}</h1>
      <p class="lede">
        {c.lede}
      </p>
    </header>

    <form class="dc-form" id="dc-form" autocomplete="off">
      <div class="dc-tractors">
        <fieldset class="dc-tractor">
          <legend>{c.form.tractorA}</legend>
          <label class="field">
            <span>{c.form.power} <strong class="req">*</strong></span>
            <input type="number" id="a-hp" name="aHp" min="1" max="900" step="1" placeholder={c.form.phPowerA} required />
          </label>
          <label class="field">
            <span>{c.form.norma}</span>
            <select id="a-norma" name="aNorma">
              {normaOptions.map((o) => <option value={o.value}>{o.label}</option>)}
            </select>
          </label>
          <label class="field">
            <span>{c.form.ownConsumption} <em>{c.form.ownConsumptionHint}</em></span>
            <input type="number" id="a-cons" name="aCons" min="0" step="0.1" placeholder={c.form.phOwnConsumption} />
          </label>
        </fieldset>

        <div class="dc-vs">vs</div>

        <fieldset class="dc-tractor dc-tractor-new">
          <legend>{c.form.tractorB}</legend>
          <label class="field">
            <span>{c.form.power} <strong class="req">*</strong></span>
            <input type="number" id="b-hp" name="bHp" min="1" max="900" step="1" placeholder={c.form.phPowerB} required />
          </label>
          <label class="field">
            <span>{c.form.norma}</span>
            <select id="b-norma" name="bNorma">
              {normaOptions.map((o) => <option value={o.value} selected={o.value === 'stage5'}>{o.label}</option>)}
            </select>
          </label>
          <label class="field">
            <span>{c.form.ownConsumption} <em>{c.form.ownConsumptionHint}</em></span>
            <input type="number" id="b-cons" name="bCons" min="0" step="0.1" placeholder={c.form.phOwnConsumption} />
          </label>
        </fieldset>
      </div>

      <fieldset class="dc-context">
        <legend>{c.form.contextLegend}</legend>
        <div class="dc-context-grid">
          <label class="field">
            <span>{c.form.hours} <strong class="req">*</strong></span>
            <input type="number" id="hours" name="hours" min="1" max="5000" step="50" placeholder={c.form.phHours} required value={c.defaults.hours} />
          </label>
          <label class="field">
            <span>{c.form.price} <strong class="req">*</strong></span>
            <input type="number" id="price" name="price" min="1" step="0.10" placeholder={c.form.phPrice} required value={c.defaults.price} />
          </label>
          <label class="field">
            <span>{c.form.investDiff} <em>{c.form.ownConsumptionHint}</em></span>
            <input type="number" id="invest" name="invest" min="0" step="10000" placeholder={c.form.phInvest} />
          </label>
        </div>
      </fieldset>

      <button type="submit" class="dc-btn">{c.form.submit}</button>
    </form>

    <div id="dc-result" class="dc-result" hidden>
      <header class="dc-result-head">
        <span class="dc-result-kicker">{c.result.yearlyKicker}</span>
        <div class="dc-result-total" id="dc-result-yearly">—</div>
        <div class="dc-result-sub" id="dc-result-pct">—</div>
      </header>

      <div class="dc-comparison">
        <div class="dc-card dc-card-a">
          <span class="dc-card-label">{c.result.tractorACard}</span>
          <strong id="dc-a-label">—</strong>
          <div class="dc-stat">
            <span>{c.result.consumption}</span><strong id="dc-a-cons">—</strong>
          </div>
          <div class="dc-stat">
            <span>{c.result.yearly}</span><strong id="dc-a-yearly">—</strong>
          </div>
          <div class="dc-stat dc-stat-czk">
            <span>{c.result.costs}</span><strong id="dc-a-czk">—</strong>
          </div>
        </div>
        <div class="dc-card dc-card-b">
          <span class="dc-card-label">{c.result.tractorBCard}</span>
          <strong id="dc-b-label">—</strong>
          <div class="dc-stat">
            <span>{c.result.consumption}</span><strong id="dc-b-cons">—</strong>
          </div>
          <div class="dc-stat">
            <span>{c.result.yearly}</span><strong id="dc-b-yearly">—</strong>
          </div>
          <div class="dc-stat dc-stat-czk">
            <span>{c.result.costs}</span><strong id="dc-b-czk">—</strong>
          </div>
        </div>
      </div>

      <div class="dc-projection">
        <div>
          <span class="dc-proj-label">{c.result.fiveYear}</span>
          <strong id="dc-5y">—</strong>
        </div>
        <div id="dc-payback-wrap" hidden>
          <span class="dc-proj-label">{c.result.payback}</span>
          <strong id="dc-payback">—</strong>
        </div>
      </div>

      <div class="dc-disclaimer">
        {c.disclaimer}
      </div>
    </div>

    <section class="info">
      <h2>{c.howItWorks.heading}</h2>
      <p set:html={c.howItWorks.intro} />
      <ul>
        {c.howItWorks.bullets.map((b) => <li><strong>{b.strong}</strong>{b.rest}</li>)}
      </ul>
      <p>{c.howItWorks.outro}</p>

      <h2>{locale === 'cs' ? 'Časté dotazy' : 'Časté otázky'}</h2>
      <div class="faqs">
        {faqItems.map((item) => (
          <details class="faq">
            <summary>{item.q}</summary>
            <p>{item.a}</p>
          </details>
        ))}
      </div>

      <h2>{c.related.heading}</h2>
      <ul class="info-links">
        {c.related.links.map((l) => (
          <li><a href={locale === 'cs' ? l.href : `/${locale}${l.href}`}>{l.label}</a></li>
        ))}
      </ul>
    </section>

    <script type="application/json" id="calc-cfg" set:html={JSON.stringify(calcCfg)}></script>
  </div>

  <script>
    import { compareDiesel } from '../../../lib/diesel-calc';
    import type { EmisniNorma } from '../../../lib/diesel-calc';

    const cfg = JSON.parse(document.getElementById('calc-cfg')?.textContent || '{}');
    const numberLocale: string = cfg.numberLocale ?? 'cs-CZ';
    const currency: string = cfg.currency ?? 'CZK';
    const js = cfg.js ?? {};
    const fmtMoney = (n: number) =>
      new Intl.NumberFormat(numberLocale, { style: 'currency', currency, maximumFractionDigits: 0 }).format(Math.abs(Math.round(n)));
    const fmtNum = (n: number) => n.toLocaleString(numberLocale);

    const form = document.getElementById('dc-form') as HTMLFormElement;
    const result = document.getElementById('dc-result') as HTMLElement;

    function $(id: string): HTMLElement { return document.getElementById(id)!; }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const aHp = parseFloat(String(data.get('aHp') ?? '')) || 0;
      const bHp = parseFloat(String(data.get('bHp') ?? '')) || 0;
      const aCons = parseFloat(String(data.get('aCons') ?? '')) || 0;
      const bCons = parseFloat(String(data.get('bCons') ?? '')) || 0;
      const hours = parseFloat(String(data.get('hours') ?? '')) || 0;
      const price = parseFloat(String(data.get('price') ?? '')) || 0;
      const invest = parseFloat(String(data.get('invest') ?? '')) || 0;

      if (aHp <= 0 || bHp <= 0 || hours <= 0 || price <= 0) {
        alert(cfg.fillAlert ?? 'Vyplňte výkon obou traktorů, roční využití a cenu nafty.');
        return;
      }

      const r = compareDiesel({
        tractorA: { powerHp: aHp, norma: data.get('aNorma') as EmisniNorma, consumptionLh: aCons || undefined },
        tractorB: { powerHp: bHp, norma: data.get('bNorma') as EmisniNorma, consumptionLh: bCons || undefined },
        hoursPerYear: hours,
        naftaPriceCzk: price,
        investmentDiffCzk: invest || undefined,
        normaLabels: cfg.normaLabels,
        hpUnit: cfg.hpUnit,
      });

      const yearlyEl = $('dc-result-yearly');
      const pctEl = $('dc-result-pct');
      yearlyEl.textContent = (r.yearlySavingCzk >= 0 ? '−' : '+') + fmtMoney(r.yearlySavingCzk) + (js.perYear ?? ' / rok');
      yearlyEl.style.color = r.yearlySavingCzk > 0 ? '#0B7A3B' : r.yearlySavingCzk < 0 ? '#C8102E' : '#0A0A0B';
      pctEl.textContent = `${r.savingPct >= 0 ? '−' : '+'}${Math.abs(r.savingPct).toFixed(1)} %${js.vsA ?? ' proti A'}`;

      $('dc-a-label').textContent = r.a.label;
      $('dc-a-cons').textContent = `${r.a.consumptionLh.toFixed(1)} ${js.unitLh ?? 'l/h'}`;
      $('dc-a-yearly').textContent = `${fmtNum(r.a.yearlyL)} ${js.unitL ?? 'l'}`;
      $('dc-a-czk').textContent = fmtMoney(r.a.yearlyCzk) + (js.perYear ?? ' / rok');

      $('dc-b-label').textContent = r.b.label;
      $('dc-b-cons').textContent = `${r.b.consumptionLh.toFixed(1)} ${js.unitLh ?? 'l/h'}`;
      $('dc-b-yearly').textContent = `${fmtNum(r.b.yearlyL)} ${js.unitL ?? 'l'}`;
      $('dc-b-czk').textContent = fmtMoney(r.b.yearlyCzk) + (js.perYear ?? ' / rok');

      $('dc-5y').textContent = (r.fiveYearSavingCzk >= 0 ? '−' : '+') + fmtMoney(r.fiveYearSavingCzk);

      const paybackWrap = $('dc-payback-wrap');
      if (r.paybackYears !== undefined && r.paybackYears > 0) {
        $('dc-payback').textContent = r.paybackYears < 1
          ? `${(r.paybackYears * 12).toFixed(0)} ${js.months ?? 'měsíců'}`
          : `${r.paybackYears.toFixed(1)} ${js.years ?? 'let'}`;
        paybackWrap.hidden = false;
      } else {
        paybackWrap.hidden = true;
      }

      result.hidden = false;
      result.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>

  <style>
    .dc-root { max-width: 920px; margin: 0 auto; padding: 32px 24px 80px; }
    .breadcrumb { display: flex; gap: 8px; align-items: center; font-size: 13px; color: #666; margin-bottom: 20px; flex-wrap: wrap; }
    .breadcrumb a { color: #666; text-decoration: none; }
    .breadcrumb a:hover { color: #000; }
    .breadcrumb .current { color: #000; font-weight: 600; }

    .dc-head { margin-bottom: 32px; max-width: 720px; }
    .kicker {
      display: inline-block; background: #FFEA00; color: #0A0A0B; font-size: 12px; font-weight: 700;
      padding: 4px 12px; border-radius: 4px; text-transform: uppercase; letter-spacing: 1px;
    }
    h1 { font-size: clamp(2rem, 4vw, 2.8rem); font-weight: 800; letter-spacing: -1px; line-height: 1.1; margin: 12px 0 12px; color: #1a1a1a; }
    .lede { font-size: 16px; color: #444; line-height: 1.6; margin: 0; }

    .dc-form {
      background: #fff; border: 1.5px solid #eaeaec; border-radius: 14px;
      padding: 24px; margin-bottom: 24px;
    }
    .dc-tractors { display: grid; grid-template-columns: 1fr auto 1fr; gap: 16px; align-items: center; margin-bottom: 24px; }
    .dc-tractor {
      border: 1.5px solid #eaeaec; border-radius: 12px; padding: 16px;
      background: #fafafa; margin: 0;
    }
    .dc-tractor-new { background: #fffef8; border-color: #FFEA00; }
    .dc-tractor legend {
      font-size: 13px; text-transform: uppercase; letter-spacing: 1px; font-weight: 700;
      color: #0A0A0B; padding: 0 6px;
    }
    .dc-vs {
      font-size: 18px; font-weight: 800; color: #999; font-family: 'Chakra Petch', sans-serif;
    }

    .dc-context { border: none; padding: 0; margin: 0; }
    .dc-context legend {
      font-size: 13px; text-transform: uppercase; letter-spacing: 1px; font-weight: 700;
      color: #0A0A0B; margin-bottom: 12px; padding: 0;
    }
    .dc-context-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 14px; }

    .field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 10px; }
    .field span { font-size: 13px; color: #333; font-weight: 600; }
    .field span em { color: #888; font-style: normal; font-weight: 400; }
    .field input, .field select {
      padding: 10px 12px; border: 1.5px solid #DFDFE3; border-radius: 8px;
      font-size: 15px; background: #fff;
    }
    .field input:focus, .field select:focus {
      outline: none; border-color: #FFEA00;
      box-shadow: 0 0 0 3px rgba(255, 234, 0, 0.2);
    }
    .req { color: #C8102E; }

    .dc-btn {
      width: 100%; margin-top: 20px; padding: 14px; background: #0A0A0B; color: #FFEA00;
      border: none; border-radius: 10px; font-size: 15px; font-weight: 700; cursor: pointer;
      transition: background .15s;
    }
    .dc-btn:hover { background: #2a2a2f; }

    .dc-result {
      background: #fff; border: 2px solid #FFEA00; border-radius: 14px;
      padding: 24px; margin-bottom: 32px;
    }
    .dc-result-head { margin-bottom: 20px; text-align: center; }
    .dc-result-kicker { font-size: 12px; text-transform: uppercase; letter-spacing: 1.5px; color: #6B6B72; font-weight: 700; }
    .dc-result-total {
      font-size: clamp(2rem, 5vw, 3rem); font-weight: 800;
      margin: 8px 0 4px; font-family: 'Chakra Petch', sans-serif; letter-spacing: -1px;
    }
    .dc-result-sub { font-size: 14px; color: #666; }

    .dc-comparison { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 20px; }
    .dc-card { padding: 16px; border-radius: 10px; background: #fafafa; }
    .dc-card-b { background: #fffef8; border: 1px solid #FFEA00; }
    .dc-card-label { font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: #6B6B72; font-weight: 700; }
    .dc-card strong:first-of-type { display: block; font-size: 14px; color: #0A0A0B; margin: 4px 0 10px; }
    .dc-stat { display: flex; justify-content: space-between; align-items: center; font-size: 13px; color: #555; margin-bottom: 6px; }
    .dc-stat strong { color: #0A0A0B; font-weight: 700; }
    .dc-stat-czk strong { color: #0B7A3B; font-size: 14px; }

    .dc-projection {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px;
      padding: 16px; background: #fafafa; border-radius: 10px; margin-bottom: 16px;
    }
    .dc-projection > div { display: flex; flex-direction: column; gap: 4px; }
    .dc-proj-label { font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: #6B6B72; font-weight: 700; }
    .dc-projection strong { font-size: 20px; font-weight: 800; color: #0A0A0B; font-family: 'Chakra Petch', sans-serif; }

    .dc-disclaimer {
      padding: 12px 16px; background: #fffbeb; border-left: 3px solid #FCD34D;
      border-radius: 0 6px 6px 0; font-size: 13px; color: #555; line-height: 1.5;
    }

    .info { margin-top: 40px; }
    .info h2 { font-size: 22px; margin: 32px 0 12px; font-weight: 700; color: #0A0A0B; }
    .info p { font-size: 15px; line-height: 1.6; color: #444; margin: 0 0 14px; }
    .info ul { padding-left: 22px; margin: 0 0 16px; }
    .info ul li { font-size: 15px; line-height: 1.7; color: #444; }
    .info-links li a { color: #0B7A3B; text-decoration: underline; }
    .faqs { display: flex; flex-direction: column; gap: 8px; }
    .faq { background: #fafafa; border: 1px solid #eaeaec; border-radius: 8px; padding: 14px 16px; }
    .faq summary { cursor: pointer; font-weight: 600; color: #0A0A0B; font-size: 14px; }
    .faq p { margin-top: 10px; font-size: 14px; color: #444; line-height: 1.6; }

    @media (max-width: 640px) {
      .dc-tractors { grid-template-columns: 1fr; }
      .dc-vs { text-align: center; padding: 8px 0; }
      .dc-comparison { grid-template-columns: 1fr; }
    }
  </style>
</Layout>
