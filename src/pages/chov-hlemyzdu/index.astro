---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import { SITE_URL } from '../../lib/config';
import {
  getAllHlemyzdi,
  getPillar,
  getHlemyzdiByGroup,
  HLEMYZDI_GROUPS,
} from '../../lib/hlemyzdi';

const all = getAllHlemyzdi();
const pillar = getPillar();
const groups = HLEMYZDI_GROUPS.map((g) => ({ ...g, items: getHlemyzdiByGroup(g.key) }));

const title = 'Chov hlemýžďů: kompletní průvodce, produkty i farmy v ČR';
const description =
  'Vše o chovu hlemýžďů na jednom místě: druhy, vybavení, krmení, legislativa a ekonomika, produkty (sliz, maso, kaviár, ulity) i přehled českých šnečích farem.';

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Domů', item: `${SITE_URL}/` },
    { '@type': 'ListItem', position: 2, name: 'Chov hlemýžďů', item: `${SITE_URL}/chov-hlemyzdu/` },
  ],
};

const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  url: `${SITE_URL}/chov-hlemyzdu/`,
  inLanguage: 'cs-CZ',
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: all.length,
    itemListElement: all.map((a, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `${SITE_URL}/chov-hlemyzdu/${a.slug}/`,
      name: a.title,
    })),
  },
};
---

<Layout title={title} description={description} ogImage={pillar.featured_image_url}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(collectionJsonLd)} />

  <div class="hl-hub">
    <nav class="breadcrumb" aria-label="Cesta">
      <a href="/">Domů</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <span class="current">Chov hlemýžďů</span>
    </nav>

    <section class="hero">
      <div class="hero-left">
        <span class="kicker"><span class="dot"></span>Průvodce · Chov hlemýžďů</span>
        <h1>Vše o <em>chovu hlemýžďů</em></h1>
        <p class="hero-lede">Od výběru druhu a vybavení přes legislativu a ekonomiku až po čtyři produkty, které chov dává — sliz, maso, kaviár a ulity. Plus přehled českých šnečích farem.</p>
        <div class="hero-stats">
          <div class="s"><span class="n">{all.length}</span><span class="l">článků</span></div>
          <div class="s"><span class="n">4</span><span class="l">produkty ze šneků</span></div>
          <div class="s"><span class="n">3</span><span class="l">ověřené farmy v ČR</span></div>
        </div>
      </div>
      <div class="hero-right">
        <div class="hero-emoji-tile" aria-hidden="true">🐌</div>
      </div>
    </section>

    <a href={`/chov-hlemyzdu/${pillar.slug}/`} class="pillar-card">
      <div class="pc-tag">Začněte tady</div>
      <div class="pc-title">{pillar.title}</div>
      <p class="pc-desc">{pillar.perex}</p>
      <span class="pc-cta">Otevřít kompletního průvodce
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </span>
    </a>

    {groups.map((g) => (
      <section class="group">
        <div class="group-head">
          <h2 class="section-title">{g.label} <span class="section-title-c">{g.items.length}</span></h2>
          <p class="group-desc">{g.desc}</p>
        </div>
        <div class="hub-grid">
          {g.items.map((a) => (
            <a href={`/chov-hlemyzdu/${a.slug}/`} class="hub-card">
              <div class="hc-body">
                <div class="hc-title">{a.title}</div>
                <p class="hc-desc">{a.perex}</p>
              </div>
              <svg class="hc-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</Layout>

<style>
  .hl-hub {
    --yellow: #FFEA00; --ink: #0A0A0B; --body: #1E1E22; --muted: #6B6B72;
    --muted-2: #9A9AA3; --line: #EAEAEC; --card: #FFFFFF;
    --r-xl: 24px; --r-lg: 18px; --r-md: 12px;
    --sh-1: 0 1px 2px rgba(10,10,12,.04), 0 0 0 1px rgba(10,10,12,.03);
    --sh-3: 0 18px 40px -12px rgba(10,10,12,.18), 0 0 0 1px rgba(10,10,12,.04);
    max-width: 1280px; margin: 0 auto; padding: 26px 24px 96px; color: var(--body);
  }
  .hl-hub .breadcrumb { display: flex; gap: 8px; align-items: center; font-size: 13px; color: var(--muted); margin-bottom: 22px; flex-wrap: wrap; }
  .hl-hub .breadcrumb a { color: var(--muted); text-decoration: none; }
  .hl-hub .breadcrumb a:hover { color: #000; }
  .hl-hub .breadcrumb .current { color: #000; font-weight: 600; }

  .hl-hub .hero {
    position: relative; overflow: hidden; color: #fff; border-radius: var(--r-xl);
    background: radial-gradient(600px 300px at 15% 20%, rgba(255, 234, 0, .14), transparent 60%),
      radial-gradient(700px 400px at 90% 90%, rgba(0, 160, 130, .30), transparent 60%),
      linear-gradient(135deg, #11140F 0%, #15211C 60%, #16302A 100%);
    padding: 48px 48px 40px; margin-bottom: 26px; display: flex; gap: 32px; align-items: center;
  }
  .hl-hub .hero-left { flex: 1; min-width: 0; }
  .hl-hub .kicker { display: inline-flex; align-items: center; gap: 8px; font-size: 12.5px; font-weight: 600; letter-spacing: .04em; text-transform: uppercase; color: #CFE9E2; margin-bottom: 16px; }
  .hl-hub .kicker .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--yellow); }
  .hl-hub .hero h1 { font-size: clamp(28px, 4vw, 44px); line-height: 1.08; margin: 0 0 14px; font-weight: 800; }
  .hl-hub .hero h1 em { font-style: normal; color: var(--yellow); }
  .hl-hub .hero-lede { font-size: 16.5px; line-height: 1.6; color: #E7EFEC; max-width: 60ch; margin: 0 0 22px; }
  .hl-hub .hero-stats { display: flex; gap: 28px; flex-wrap: wrap; }
  .hl-hub .hero-stats .s { display: flex; flex-direction: column; }
  .hl-hub .hero-stats .n { font-size: 26px; font-weight: 800; color: #fff; }
  .hl-hub .hero-stats .l { font-size: 12.5px; color: #B7C9C3; }
  .hl-hub .hero-right { flex-shrink: 0; }
  .hl-hub .hero-emoji-tile { font-size: 92px; line-height: 1; filter: drop-shadow(0 8px 24px rgba(0,0,0,.4)); }

  .hl-hub .pillar-card {
    display: block; text-decoration: none; color: var(--body); background: var(--card);
    border-radius: var(--r-lg); padding: 28px 30px; margin-bottom: 36px; box-shadow: var(--sh-3);
    border-left: 5px solid var(--yellow);
  }
  .hl-hub .pillar-card:hover { transform: translateY(-2px); transition: transform .15s; }
  .hl-hub .pc-tag { display: inline-block; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; color: #00695C; background: #E0F2F1; padding: 4px 10px; border-radius: 999px; margin-bottom: 12px; }
  .hl-hub .pc-title { font-size: 22px; font-weight: 800; color: var(--ink); margin-bottom: 8px; }
  .hl-hub .pc-desc { font-size: 15px; line-height: 1.6; color: var(--muted); margin: 0 0 14px; }
  .hl-hub .pc-cta { display: inline-flex; align-items: center; gap: 6px; font-weight: 700; color: var(--ink); }

  .hl-hub .group { margin-bottom: 38px; }
  .hl-hub .group-head { margin-bottom: 16px; }
  .hl-hub .section-title { font-size: 20px; font-weight: 800; color: var(--ink); margin: 0 0 4px; }
  .hl-hub .section-title-c { color: var(--muted-2); font-weight: 600; }
  .hl-hub .group-desc { font-size: 14px; color: var(--muted); margin: 0; }

  .hl-hub .hub-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
  .hl-hub .hub-card {
    display: flex; align-items: flex-start; gap: 12px; text-decoration: none; color: var(--body);
    background: var(--card); border-radius: var(--r-md); padding: 18px 20px; box-shadow: var(--sh-1);
    transition: box-shadow .15s, transform .15s;
  }
  .hl-hub .hub-card:hover { box-shadow: var(--sh-3); transform: translateY(-2px); }
  .hl-hub .hc-body { flex: 1; min-width: 0; }
  .hl-hub .hc-title { font-size: 15.5px; font-weight: 700; color: var(--ink); margin-bottom: 5px; line-height: 1.3; }
  .hl-hub .hc-desc { font-size: 13.5px; line-height: 1.55; color: var(--muted); margin: 0; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .hl-hub .hc-arrow { color: var(--muted-2); flex-shrink: 0; margin-top: 3px; }
  .hl-hub .hub-card:hover .hc-arrow { color: var(--ink); }

  @media (max-width: 720px) {
    .hl-hub .hero { flex-direction: column; padding: 34px 26px; text-align: center; }
    .hl-hub .hero-stats { justify-content: center; }
  }
</style>
