---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import { SITE_URL } from '../../lib/config';
import { t } from '../../i18n/utils';
import { ORG_ID, WEBSITE_ID } from '../../lib/structured-data';
import { getAllHlemyzdi, getHlemyzdiBySlug, getRelatedHlemyzdi } from '../../lib/hlemyzdi';

export function getStaticPaths() {
  return getAllHlemyzdi().map((a) => ({ params: { slug: a.slug } }));
}

const { slug } = Astro.params;
const article = getHlemyzdiBySlug(slug!);
if (!article) return Astro.rewrite('/404');

const locale = 'cs';
const PUBLISHED = '2026-06-05';
const canonical = `${SITE_URL}/chov-hlemyzdu/${article.slug}/`;
const related = getRelatedHlemyzdi(article.slug);

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Domů', item: `${SITE_URL}/` },
    { '@type': 'ListItem', position: 2, name: 'Chov hlemýžďů', item: `${SITE_URL}/chov-hlemyzdu/` },
    { '@type': 'ListItem', position: 3, name: article.title, item: canonical },
  ],
};

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title,
  description: article.seo_description || article.perex,
  ...(article.featured_image_url && {
    image: { '@type': 'ImageObject', url: article.featured_image_url, width: 1600, height: 900 },
  }),
  datePublished: PUBLISHED,
  dateModified: PUBLISHED,
  url: canonical,
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  isPartOf: { '@id': WEBSITE_ID },
  author: { '@type': 'Organization', name: 'Redakce agro-svět.cz', url: `${SITE_URL}/redakce/` },
  publisher: { '@id': ORG_ID },
  inLanguage: 'cs-CZ',
  articleSection: 'Chov hlemýžďů',
};
---

<Layout
  title={article.seo_title || article.title}
  description={article.seo_description || article.perex}
  ogImage={article.featured_image_url}
  canonical={canonical}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(articleJsonLd)} />

  <article class="hl-article">
    <nav class="breadcrumb" aria-label="Cesta">
      <a href="/">Domů</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/chov-hlemyzdu/">Chov hlemýžďů</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <span class="current">{article.title}</span>
    </nav>

    <h1>{article.title}</h1>

    <div class="byline">
      <span>{t(locale, 'nov.byline')} <a href="/redakce/" class="byline-link">{t(locale, 'nov.editorial')}</a></span>
    </div>

    {article.featured_image_url && (
      <img class="hero" src={article.featured_image_url} alt={article.featured_image_alt} width="1200" height="627" loading="eager" />
    )}

    <p class="lead">{article.perex}</p>

    <div class="prose" set:html={article.content} />

    {related.length > 0 && (
      <section class="related">
        <h2>Pokračujte v sekci Chov hlemýžďů</h2>
        <ul>
          {related.map((r) => (
            <li><a href={`/chov-hlemyzdu/${r.slug}/`}>{r.title}</a></li>
          ))}
          <li><a href="/chov-hlemyzdu/">← Zpět na rozcestník Chov hlemýžďů</a></li>
        </ul>
      </section>
    )}
  </article>
</Layout>

<style>
  .hl-article { max-width: 760px; margin: 0 auto; padding: 26px 24px 96px; }
  .hl-article .breadcrumb { display: flex; gap: 8px; align-items: center; font-size: 13px; color: #6B6B72; margin-bottom: 22px; flex-wrap: wrap; }
  .hl-article .breadcrumb a { color: #6B6B72; text-decoration: none; }
  .hl-article .breadcrumb a:hover { color: #000; }
  .hl-article .breadcrumb .current { color: #000; font-weight: 600; }
  .hl-article h1 { font-size: clamp(26px, 4vw, 38px); line-height: 1.15; font-weight: 800; color: #0A0A0B; margin: 0 0 16px; }
  .hl-article .byline { display: flex; gap: 10px; align-items: center; font-size: 13.5px; color: #5a5a62; margin-bottom: 24px; }
  .hl-article .byline-link { color: #0A0A0B; font-weight: 600; text-decoration: underline; text-decoration-color: #FFEA00; text-decoration-thickness: 2px; text-underline-offset: 3px; }
  .hl-article .hero { width: 100%; height: auto; border-radius: 16px; margin-bottom: 28px; aspect-ratio: 1200 / 627; object-fit: cover; }
  .hl-article .lead { font-size: 18px; color: #555; line-height: 1.6; margin-bottom: 36px; border-bottom: 1px solid #ebebeb; padding-bottom: 28px; }
  .hl-article .related { margin-top: 48px; padding-top: 28px; border-top: 1px solid #ebebeb; }
  .hl-article .related h2 { font-size: 1.3rem; font-weight: 700; margin: 0 0 14px; }
  .hl-article .related ul { list-style: none; padding: 0; margin: 0; display: grid; gap: 10px; }
  .hl-article .related a { color: #0A0A0B; text-decoration: underline; text-decoration-color: #FFEA00; text-decoration-thickness: 2px; text-underline-offset: 3px; font-weight: 600; }
</style>
