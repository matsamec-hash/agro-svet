---
// SSR (prerender:false): middleware servíruje /sk verzi přes locals.locale.
// sk čte z 'encyklopedieSk' (přeložená overlay kolekce); cs render = dnešní
// literály VERBATIM (byte-identita). Locale jen z Astro.locals.locale (po rewritu
// je Astro.url cs cesta) s fallbackem na getLocaleFromUrl.
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { SITE_URL } from '../../lib/config';
import { breadcrumbSchema } from '../../lib/structured-data';
import { useTranslations, getLocaleFromUrl, localizePath, tf } from '../../i18n/utils';

const locale = Astro.locals.locale ?? getLocaleFromUrl(Astro.url);
const isSk = locale === 'sk';
const t = useTranslations(locale);
const base = isSk ? '/sk' : '';
Astro.response.headers.set('Cache-Control', 'public, max-age=600, s-maxage=3600, stale-while-revalidate=86400');

const items = await getCollection(isSk ? 'encyklopedieSk' : 'encyklopedie');
const sorted = items.sort((a, b) => a.data.name.localeCompare(b.data.name, isSk ? 'sk' : 'cs'));

const kategLabels: Record<string, string> = {
  traktor: t('enc.kat.traktor'), kombajn: t('enc.kat.kombajn'), stroj: t('enc.kat.stroj'), 'puda-technika': t('enc.kat.puda-technika'),
};

const breadcrumbJsonLd = breadcrumbSchema([
  { name: t('cat.bc.home'), url: `${base}/` },
  { name: t('enc.crumb'), url: `${base}/encyklopedie/` },
]);
const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: t('enc.list.collName'),
  description: t('enc.list.collDesc'),
  url: `${SITE_URL}${base}/encyklopedie/`,
  inLanguage: isSk ? 'sk-SK' : 'cs-CZ',
  numberOfItems: sorted.length,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: sorted.length,
    itemListElement: sorted.slice(0, 100).map((item, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `${SITE_URL}${base}/encyklopedie/${item.id}/`,
      name: item.data.name,
    })),
  },
};
---

<Layout title={t('enc.list.title')} description={t('enc.list.description')}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(collectionJsonLd)} />
  <div style="max-width:1280px; margin:0 auto; padding:48px 32px 80px;">

    <div style="margin-bottom:48px;">
      <span style="" class="section-label" style="">{t('enc.list.label')}</span>
      <h1 style="font-size:clamp(2rem,5vw,3.2rem); font-weight:900; letter-spacing:-1px; line-height:1.1; color:#1a1a1a; margin-bottom:16px;">
        {t('enc.list.h1')}
      </h1>
      {isSk ? (
        <p style="font-size:16px; color:#666; max-width:680px; line-height:1.6;">
          {tf(locale, 'enc.list.introA', { count: sorted.length })}
          <a href={localizePath(locale, '/slovnik/')} style="color:#2d7a3e; font-weight:600; text-decoration:none;">{t('enc.list.introSlovnik')}</a>;
          {t('enc.list.introMid')} <a href={localizePath(locale, '/stroje/')} style="color:#2d7a3e; font-weight:600; text-decoration:none;">{t('enc.list.introKatalog')}</a>{t('enc.list.introEnd')}
        </p>
      ) : (
        <p style="font-size:16px; color:#666; max-width:680px; line-height:1.6;">
          Encyklopedie agro-svět shromažďuje {sorted.length} traktorů, kombajnů a další zemědělské techniky
          s technickými parametry, popisem a výkonem. Hledáte vysvětlení pojmů? Zamiřte do
          <a href="/slovnik/" style="color:#2d7a3e; font-weight:600; text-decoration:none;">zemědělského slovníku</a>;
          pro řazení a srovnání strojů do <a href="/stroje/" style="color:#2d7a3e; font-weight:600; text-decoration:none;">katalogu strojů</a>.
          Databáze průběžně roste.
        </p>
      )}
    </div>

    <div class="enc-grid">
      {sorted.map(item => (
        <a href={localizePath(locale, `/encyklopedie/${item.id}/`)} class="enc-card" data-kat={item.data.kategorie}>
          {item.data.heroImage && (
            <div class="enc-img">
              <img
                src={item.data.heroImage}
                alt={`${item.data.name} — ${kategLabels[item.data.kategorie] ?? item.data.kategorie}, ${item.data.rok_uvedeni}`}
                loading="lazy"
                decoding="async"
                width="600"
                height="360"
              />
            </div>
          )}
          <div class="enc-body">
            <div class="enc-meta">
              <span class="enc-chip">{kategLabels[item.data.kategorie] ?? item.data.kategorie}</span>
              <span class="enc-year">{item.data.rok_uvedeni}</span>
            </div>
            <h3 class="enc-title">{item.data.name}</h3>
            <p class="enc-desc">{item.data.popis}</p>
            <div class="enc-foot">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              {item.data.vykon}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>

<style>
  .enc-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:20px; }
  .enc-card {
    display:block;
    text-decoration:none;
    color:inherit;
    border:none;
    border-radius:14px;
    overflow:hidden;
    background:#fff;
    box-shadow:0 0 10px rgba(0,0,0,.12);
    transition:box-shadow .2s, transform .2s;
  }
  .enc-card:hover { box-shadow:0 6px 20px rgba(0,0,0,.09); transform:translateY(-2px); }
  .enc-img { height:180px; overflow:hidden; }
  .enc-img img { width:100%; height:100%; object-fit:cover; }
  .enc-body { padding:20px; }
  .enc-meta { display:flex; align-items:center; gap:8px; margin-bottom:10px; }
  .enc-chip {
    background:#FFFF00;
    color:#000;
    font-family:'Chakra Petch',sans-serif;
    font-weight:400;
    font-size:10px;
    padding:2px 8px;
    border-radius:3px;
    text-transform:uppercase;
    letter-spacing:.5px;
  }
  .enc-year { font-size:12px; color:#767676; }
  .enc-title { font-size:17px; font-weight:400; color:#1a1a1a; margin-bottom:6px; }
  .enc-desc {
    font-size:13px;
    color:#666;
    margin-bottom:14px;
    line-height:1.5;
    display:-webkit-box;
    -webkit-line-clamp:2;
    -webkit-box-orient:vertical;
    overflow:hidden;
  }
  .enc-foot {
    display:inline-flex;
    align-items:center;
    gap:5px;
    font-size:13px;
    color:#555;
    font-weight:400;
  }
</style>
