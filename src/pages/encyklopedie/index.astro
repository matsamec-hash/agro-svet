---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { SITE_URL } from '../../lib/config';
import { breadcrumbSchema } from '../../lib/structured-data';

const items = await getCollection('encyklopedie');
const sorted = items.sort((a, b) => a.data.name.localeCompare(b.data.name, 'cs'));

const kategLabels: Record<string, string> = {
  traktor: 'Traktor', kombajn: 'Kombajn', stroj: 'Stroj', 'puda-technika': 'Půdní technika',
};

const breadcrumbJsonLd = breadcrumbSchema([
  { name: 'Domů', url: '/' },
  { name: 'Encyklopedie', url: '/encyklopedie/' },
]);
const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Encyklopedie zemědělských strojů',
  description: 'Databáze zemědělských strojů — traktory, kombajny, sklízecí mlátičky.',
  url: `${SITE_URL}/encyklopedie/`,
  inLanguage: 'cs-CZ',
  numberOfItems: sorted.length,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: sorted.length,
    itemListElement: sorted.slice(0, 100).map((item, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `${SITE_URL}/encyklopedie/${item.id}/`,
      name: item.data.name,
    })),
  },
};
---

<Layout title="Encyklopedie strojů" description="Databáze zemědělských strojů — traktory, kombajny, sklízecí mlátičky a stroje. Technické parametry, popis a srovnání.">
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(collectionJsonLd)} />
  <div style="max-width:1280px; margin:0 auto; padding:48px 32px 80px;">

    <div style="margin-bottom:48px;">
      <span style="" class="section-label" style="">Encyklopedie</span>
      <h1 style="font-size:clamp(2rem,5vw,3.2rem); font-weight:900; letter-spacing:-1px; line-height:1.1; color:#1a1a1a; margin-bottom:16px;">
        Databáze strojů
      </h1>
      <p style="font-size:16px; color:#666; max-width:560px; line-height:1.6;">
        Technické parametry, popisy a srovnání traktorů, kombajnů a zemědělských strojů. Databáze průběžně roste.
      </p>
    </div>

    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:20px;">
      {sorted.map(item => (
        <a href={`/encyklopedie/${item.id}/`} style="display:block; text-decoration:none; color:inherit; border:none; border-radius:14px; overflow:hidden; background:#fff; box-shadow:0 0 10px rgba(0,0,0,.12); transition:box-shadow .2s, transform .2s;" class="enc-card">
          {item.data.heroImage && (
            <div style="height:180px; overflow:hidden;">
              <img src={item.data.heroImage} alt={item.data.name} loading="lazy" style="width:100%; height:100%; object-fit:cover;" />
            </div>
          )}
          <div style="padding:20px;">
            <div style="display:flex; align-items:center; gap:8px; margin-bottom:10px;">
              <span style="background:#FFFF00; color:#000; font-family:'Chakra Petch',sans-serif; font-weight:400; font-size:10px; padding:2px 8px; border-radius:3px; text-transform:uppercase; letter-spacing:.5px;">
                {kategLabels[item.data.kategorie] ?? item.data.kategorie}
              </span>
              <span style="font-size:12px; color:#767676;">{item.data.rok_uvedeni}</span>
            </div>
            <h3 style="font-size:17px; font-weight:400; color:#1a1a1a; margin-bottom:6px;">{item.data.name}</h3>
            <p style="font-size:13px; color:#666; margin-bottom:14px; line-height:1.5; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">{item.data.popis}</p>
            <div style="display:inline-flex; align-items:center; gap:5px; font-size:13px; color:#555; font-weight:400;">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              {item.data.vykon}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>

<style>
  .enc-card:hover { box-shadow:0 6px 20px rgba(0,0,0,.09); transform:translateY(-2px); }
</style>
