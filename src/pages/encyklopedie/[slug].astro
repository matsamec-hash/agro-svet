  .related-link { display:inline-flex; align-items:center; gap:6px; font-size:14px; font-weight:600; color:#1a1a1a; text-decoration:none; padding:10px 16px; border:2px solid #1a1a1a; border-radius:8px; transition:background .15s, color .15s; }
  .related-link:hover { background:#1a1a1a; color:#fff; }

  .trust-bar { margin-top:32px; display:flex; gap:18px; flex-wrap:wrap; padding:14px 18px; background:#f8f8f8; border-radius:10px; font-size:13px; color:#555; }
  .trust-bar .trust-item { display:inline-flex; align-items:center; gap:6px; color:#555; text-decoration:none; }
  .trust-bar .trust-link { color:#1a1a1a; font-weight:600; text-decoration:none; }
