---
// SSR (prerender:false): middleware servíruje /sk a /uk verzi přes locals.locale.
// sk čte z 'encyklopedieSk', uk z 'encyklopedieUk' (přeložené overlay kolekce)
// BEZ cs fallbacku — chybějící sk/uk slug = 404 (žádný cs leak).
// cs render = dnešní literály VERBATIM.
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { getCollection, getEntry, render } from 'astro:content';
import { SITE_URL } from '../../lib/config';
import { breadcrumbSchema, machineProductSchema, faqPageSchema, videoObjectSchema, expertReviewSchema } from '../../lib/structured-data';
import { useTranslations, getLocaleFromUrl, localizePath, tf } from '../../i18n/utils';

const locale = Astro.locals.locale ?? getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const ENC_COLLECTION = { cs: 'encyklopedie', sk: 'encyklopedieSk', uk: 'encyklopedieUk' } as const;
const coll = ENC_COLLECTION[locale];
const base = locale === 'cs' ? '' : `/${locale}`;
const bcp47 = ({ cs: 'cs-CZ', sk: 'sk-SK', uk: 'uk-UA' } as const)[locale];
Astro.response.headers.set('Cache-Control', 'public, max-age=600, s-maxage=3600, stale-while-revalidate=86400');

const { slug } = Astro.params;
const item = slug ? await getEntry(coll, slug) : undefined;
if (!item) return Astro.rewrite('/404'); // žádný cs fallback — chybějící uk/sk slug = 404
// Hledání souvisejících/related čte z lokalizované kolekce (overlay má stejné slug+znacka+kategorie).
const items = await getCollection(coll);
const { Content } = await render(item);
// Existuje-li redakční profil značky (historie), nabídneme odkaz.
const znackyHubs = await getCollection('znacky');
const hasBrandHub = znackyHubs.some((z) => z.id === item.data.znacka);
// Render content body with auto-link injection (slovník, žebříčky, modely).
import { renderMarkdownWithLinks } from '../../lib/markdown-with-links';
const contentHtml = await renderMarkdownWithLinks(item.body ?? '', `${base}/encyklopedie/${slug}/`, locale);

// Related encyklopedie items: same znacka first, then same kategorie.
const relatedSameZnacka = items.filter((i) => i.id !== item.id && i.data.znacka === item.data.znacka);
const relatedSameCat = items.filter((i) => i.id !== item.id && i.data.znacka !== item.data.znacka && i.data.kategorie === item.data.kategorie);
const relatedItems = [...relatedSameZnacka, ...relatedSameCat].slice(0, 4);
// Preferuj skutečný název značky (např. "John Deere") před kapitalizací slugu ("John-deere").
const brandPrettyForLinks = znackyHubs.find((z) => z.id === item.data.znacka)?.data.name
  ?? (item.data.znacka.charAt(0).toUpperCase() + item.data.znacka.slice(1));

const kategLabels: Record<string, string> = {
  traktor: t('enc.kat.traktor'), kombajn: t('enc.kat.kombajn'), stroj: t('enc.kat.stroj'), 'puda-technika': t('enc.kat.puda-technika'),
};
// Map narrative singular categories to schema-helper plural slugs (Vehicle vs Product).
const schemaCategory: Record<string, string> = {
  traktor: 'traktory',
  kombajn: 'kombajny',
  stroj: 'zemedelske-stroje',
  'puda-technika': 'zemedelske-stroje',
};

const pageUrl = `${SITE_URL}${base}/encyklopedie/${slug}/`;
const heroImageAbs = item.data.heroImage
  ? (item.data.heroImage.startsWith('http') ? item.data.heroImage : `${SITE_URL}${item.data.heroImage}`)
  : undefined;
// Pregenerated build-time OG image. Always exists for encyklopedie items
// (scripts/build-og-images.mjs runs in `prebuild`).
const ogImageAbs = `${SITE_URL}/og/encyklopedie-${slug}.png`;

const breadcrumbJsonLd = breadcrumbSchema([
  { name: t('cat.bc.home'), url: `${base}/` },
  { name: t('enc.crumb'), url: `${base}/encyklopedie/` },
  { name: item.data.name, url: pageUrl },
]);

// Vehicle/Product JSON-LD — entity-rich for AI Overviews and rich results.
const brandPretty = item.data.znacka.charAt(0).toUpperCase() + item.data.znacka.slice(1);
const productJsonLd = machineProductSchema({
  brandName: brandPretty,
  brandSlug: item.data.znacka,
  seriesName: item.data.seriesName ?? item.data.name,
  modelName: item.data.name,
  modelSlug: item.data.slug,
  category: schemaCategory[item.data.kategorie] ?? item.data.kategorie,
  url: pageUrl,
  description: item.data.popis,
  imageUrl: heroImageAbs,
  powerHp: item.data.powerHp ?? null,
  powerKw: item.data.powerKw ?? null,
  weightKg: item.data.weightKg ?? null,
  yearFrom: item.data.rok_uvedeni,
  yearTo: item.data.yearTo ?? null,
  engine: item.data.engine,
  transmission: item.data.transmission,
  lang: bcp47,
});

const faqJsonLd = item.data.faq && item.data.faq.length > 0 ? faqPageSchema(item.data.faq) : null;

const lastVerifiedFmt = item.data.lastVerified
  ? new Intl.DateTimeFormat(bcp47, { day: 'numeric', month: 'long', year: 'numeric' }).format(item.data.lastVerified)
  : null;
const lastVerifiedIso = item.data.lastVerified ? item.data.lastVerified.toISOString().slice(0, 10) : null;

// Editorial review (volitelné, frontmatter recenze). Vyplnit jen pokud redakce
// model skutečně posoudila — nelegitimní hvězdičky by uškodily důvěryhodnosti.
const reviewJsonLd = item.data.recenze
  ? expertReviewSchema({
      url: pageUrl,
      itemName: `${brandPretty} ${item.data.name}`.replace(`${brandPretty} ${brandPretty}`, brandPretty),
      itemUrl: pageUrl,
      itemImageUrl: heroImageAbs,
      itemBrand: brandPretty,
      itemCategory: kategLabels[item.data.kategorie] ?? item.data.kategorie,
      rating: item.data.recenze.hodnoceni,
      verdict: item.data.recenze.verdikt,
      pros: item.data.recenze.plusy,
      cons: item.data.recenze.minusy,
      datePublished: item.data.recenze.datum
        ? item.data.recenze.datum.toISOString().slice(0, 10)
        : (lastVerifiedIso ?? undefined),
      dateModified: lastVerifiedIso ?? undefined,
    })
  : null;

// VideoObject JSON-LD only when an encyklopedie entry references a YouTube video.
const videoJsonLd = item.data.youtubeId
  ? videoObjectSchema({
      youtubeId: item.data.youtubeId,
      name: item.data.youtubeTitle ?? `${item.data.name} — video`,
      description: item.data.popis,
      pageUrl,
      uploadDate: item.data.lastVerified ? item.data.lastVerified.toISOString().slice(0, 10) : undefined,
    })
  : null;

// Article schema with explicit author + dateModified — E-E-A-T signal.
// Lives alongside Vehicle/Product schema (entity-rich); Google handles multiple types.
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: item.data.name,
  description: item.data.popis,
  ...(heroImageAbs && { image: heroImageAbs }),
  author: {
    '@type': 'Organization',
    name: 'Redakce agro-svět.cz',
    url: 'https://agro-svet.cz/redakce/',
  },
  publisher: {
    '@type': 'Organization',
    name: 'agro-svět.cz',
    url: 'https://agro-svet.cz',
    logo: { '@type': 'ImageObject', url: 'https://agro-svet.cz/icon-512.png' },
  },
  ...(lastVerifiedIso && { dateModified: lastVerifiedIso, datePublished: lastVerifiedIso }),
  mainEntityOfPage: { '@type': 'WebPage', '@id': pageUrl },
  inLanguage: bcp47,
};
---

<Layout title={item.data.name} description={item.data.popis} canonical={locale === 'cs' ? pageUrl : undefined} ogType="product" ogImage={ogImageAbs}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(productJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(articleJsonLd)} />
  {faqJsonLd && <script type="application/ld+json" is:inline set:html={JSON.stringify(faqJsonLd)} />}
  {videoJsonLd && <script type="application/ld+json" is:inline set:html={JSON.stringify(videoJsonLd)} />}
  {reviewJsonLd && <script type="application/ld+json" is:inline set:html={JSON.stringify(reviewJsonLd)} />}

  {item.data.heroImage && (
    <div style="width:100%; height:clamp(260px,40vh,480px); overflow:hidden; position:relative;">
      <img
        src={item.data.heroImage}
        alt={`${item.data.name} — ${kategLabels[item.data.kategorie] ?? item.data.kategorie}${item.data.powerHp ? `, ${item.data.powerHp} ${t('enc.alt.koni')}` : ''}, ${t('enc.alt.hero')}`}
        width="1200"
        height="600"
        fetchpriority="high"
        decoding="async"
        style="width:100%; height:100%; object-fit:cover;"
      />
      <div style="position:absolute; inset:0; background:linear-gradient(to bottom, transparent 50%, rgba(0,0,0,.4));"></div>
    </div>
  )}

  <div style="max-width:980px; margin:0 auto; padding:48px 32px 96px;">

    <div style="font-size:13px; color:#666; margin-bottom:28px;">
      <a href={localizePath(locale, '/encyklopedie/')} style="color:#666; text-decoration:none;">{t('enc.crumb')}</a>
      <span style="margin:0 8px;">›</span>
      <span>{item.data.name}</span>
    </div>

    <div style="display:flex; align-items:center; gap:10px; margin-bottom:16px; flex-wrap:wrap;">
      <span style="background:#FFFF00; color:#000; font-family:'Chakra Petch',sans-serif; font-weight:400; font-size:11px; padding:3px 10px; border-radius:4px; text-transform:uppercase;">{kategLabels[item.data.kategorie] ?? item.data.kategorie}</span>
      <span style="font-size:13px; color:#767676;">{item.data.znacka.toUpperCase()} · {t('enc.kategorieOd')} {item.data.rok_uvedeni}</span>
    </div>

    <h1 style="font-size:clamp(2rem,5vw,3rem); font-weight:900; letter-spacing:-1px; line-height:1.1; color:#1a1a1a; margin-bottom:12px;">{item.data.name}</h1>

    <!-- Author byline (E-E-A-T signal above the fold) -->
    <div class="byline" style="display:flex; gap:12px; align-items:center; font-size:13.5px; color:#5a5a62; margin-bottom:32px; padding-bottom:16px; border-bottom:1px solid #ebebeb; flex-wrap:wrap;">
      <span>
        {t('enc.byline.pre')} <a href={localizePath(locale, '/redakce/')} style="color:#0A0A0B; font-weight:600; text-decoration:underline; text-decoration-color:#FFEA00; text-decoration-thickness:2px; text-underline-offset:3px;">{t('enc.byline.redakce')}</a>
      </span>
      {lastVerifiedFmt && (
        <>
          <span style="color:#c0c0c8;" aria-hidden="true">·</span>
          <span>{t('enc.byline.verified')} <time datetime={lastVerifiedIso}>{lastVerifiedFmt}</time></span>
        </>
      )}
    </div>

    <!-- Spec grid -->
    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:12px; margin-bottom:40px;">
      <div style="background:#f8f8f8; border-radius:10px; padding:18px;">
        <div style="font-size:11px; text-transform:uppercase; letter-spacing:.8px; color:#666; margin-bottom:6px;">{t('enc.spec.vykon')}</div>
        <div style="font-size:20px; font-weight:400; color:#1a1a1a;">{item.data.vykon}</div>
      </div>
      <div style="background:#f8f8f8; border-radius:10px; padding:18px;">
        <div style="font-size:11px; text-transform:uppercase; letter-spacing:.8px; color:#666; margin-bottom:6px;">{t('enc.spec.hmotnost')}</div>
        <div style="font-size:20px; font-weight:400; color:#1a1a1a;">{item.data.hmotnost}</div>
      </div>
      <div style="background:#f8f8f8; border-radius:10px; padding:18px;">
        <div style="font-size:11px; text-transform:uppercase; letter-spacing:.8px; color:#666; margin-bottom:6px;">{t('enc.spec.rok')}</div>
        <div style="font-size:20px; font-weight:400; color:#1a1a1a;">{item.data.rok_uvedeni}</div>
      </div>
    </div>

    <!-- Highlights -->
    {item.data.highlights?.length > 0 && (
      <div style="background:#1a1a1a; border-radius:14px; padding:24px 28px; margin-bottom:40px;">
        <div style="font-size:12px; text-transform:uppercase; letter-spacing:1px; color:#666; margin-bottom:16px;">{t('enc.highlights')}</div>
        <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:10px;">
          {item.data.highlights.map(h => (
            <li style="display:flex; align-items:flex-start; gap:12px; font-size:15px; color:#f0f0f0; line-height:1.5;">
              <span style="background:#FFFF00; color:#000; width:6px; height:6px; border-radius:50%; flex-shrink:0; margin-top:7px; display:block;"></span>
              {h}
            </li>
          ))}
        </ul>
      </div>
    )}

    {/* Editorial verdict card — pouze pokud frontmatter má recenze. Pro user trust + Review JSON-LD parity. */}
    {item.data.recenze && (() => {
      const rec = item.data.recenze;
      const fullStars = Math.floor(rec.hodnoceni);
      const hasHalf = rec.hodnoceni - fullStars >= 0.25 && rec.hodnoceni - fullStars < 0.75;
      const fullCount = hasHalf ? fullStars : Math.round(rec.hodnoceni);
      const ratingFmt = rec.hodnoceni.toFixed(1).replace('.', ',');
      return (
        <aside aria-labelledby="verdict-heading" style="margin:0 0 40px; padding:24px 28px; border:2px solid #FFFF00; border-radius:14px; background:linear-gradient(180deg, #fffce0 0%, #fffaa8 100%); color:#0A0A0B;">
          <div style="display:flex; align-items:center; justify-content:space-between; gap:16px; flex-wrap:wrap; margin-bottom:14px;">
            <div style="display:flex; align-items:center; gap:10px;">
              <span style="font-size:12px; text-transform:uppercase; letter-spacing:1.5px; font-weight:700; color:#0A0A0B;">{t('enc.verdict.label')}</span>
            </div>
            <div style="display:flex; align-items:center; gap:10px;">
              <span aria-hidden="true" style="font-size:18px; letter-spacing:2px; color:#B58A00;">
                {'★'.repeat(fullCount)}{hasHalf ? '½' : ''}{'☆'.repeat(5 - fullCount - (hasHalf ? 1 : 0))}
              </span>
              <strong style="font-size:20px; color:#0A0A0B;">{ratingFmt} / 5</strong>
            </div>
          </div>
          <h2 id="verdict-heading" style="font-size:18px; font-weight:700; margin:0 0 8px; color:#0A0A0B;">{t('enc.verdict.h')}</h2>
          <p style="font-size:15px; line-height:1.6; margin:0 0 18px; color:#1a1a1a;">{rec.verdikt}</p>
          {((rec.plusy && rec.plusy.length > 0) || (rec.minusy && rec.minusy.length > 0)) && (
            <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:16px;">
              {rec.plusy && rec.plusy.length > 0 && (
                <div>
                  <div style="font-size:13px; text-transform:uppercase; letter-spacing:1px; font-weight:700; color:#0B7A3B; margin-bottom:6px;">{t('enc.verdict.plusy')}</div>
                  <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:4px; font-size:14px;">
                    {rec.plusy.map((p) => <li style="display:flex; gap:8px;"><span aria-hidden="true" style="color:#0B7A3B; font-weight:700;">+</span><span>{p}</span></li>)}
                  </ul>
                </div>
              )}
              {rec.minusy && rec.minusy.length > 0 && (
                <div>
                  <div style="font-size:13px; text-transform:uppercase; letter-spacing:1px; font-weight:700; color:#C8102E; margin-bottom:6px;">{t('enc.verdict.minusy')}</div>
                  <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:4px; font-size:14px;">
                    {rec.minusy.map((m) => <li style="display:flex; gap:8px;"><span aria-hidden="true" style="color:#C8102E; font-weight:700;">−</span><span>{m}</span></li>)}
                  </ul>
                </div>
              )}
            </div>
          )}
          <p style="margin:14px 0 0; font-size:12px; color:#5a5a5a;">{t('enc.verdict.note')}</p>
        </aside>
      );
    })()}

    <!-- Body -->
    <div class="prose">
      <div set:html={contentHtml} />
    </div>

    {item.data.youtubeId && (
      <section class="video" aria-labelledby="video-heading">
        <h2 id="video-heading">{t('enc.video.h')} — {item.data.youtubeTitle ?? `${item.data.name}`}</h2>
        <div
          class="yt-facade"
          data-yt-id={item.data.youtubeId}
          data-yt-title={item.data.youtubeTitle ?? item.data.name}
          role="button"
          tabindex="0"
          aria-label={`${t('enc.video.play')}: ${item.data.youtubeTitle ?? item.data.name}`}
        >
          <img
            src={`https://i.ytimg.com/vi/${item.data.youtubeId}/hqdefault.jpg`}
            alt={`${t('enc.video.preview')}: ${item.data.youtubeTitle ?? item.data.name}`}
            width="1280"
            height="720"
            loading="lazy"
            decoding="async"
          />
          <div class="yt-play" aria-hidden="true">
            <svg viewBox="0 0 68 48" width="68" height="48"><path d="M66.52 7.74A8.02 8.02 0 0 0 60.96 2.18C56.06.83 34 .83 34 .83s-22.06 0-26.96 1.35A8.02 8.02 0 0 0 1.48 7.74C.13 12.64.13 24 .13 24s0 11.36 1.35 16.26a8.02 8.02 0 0 0 5.56 5.56C11.94 47.17 34 47.17 34 47.17s22.06 0 26.96-1.35a8.02 8.02 0 0 0 5.56-5.56C67.87 35.36 67.87 24 67.87 24s0-11.36-1.35-16.26z" fill="#ff0000"/><path d="M27.2 33.6L45.6 24 27.2 14.4z" fill="#fff"/></svg>
          </div>
        </div>
        <p class="video-note">{t('enc.video.note')}</p>
      </section>
    )}

    {item.data.faq && item.data.faq.length > 0 && (
      <section class="faq" aria-labelledby="faq-heading">
        <h2 id="faq-heading">{t('enc.faq.h')}</h2>
        <dl class="faq-list">
          {item.data.faq.map((qa) => (
            <div class="faq-item">
              <dt>{qa.q}</dt>
              <dd>{qa.a}</dd>
            </div>
          ))}
        </dl>
      </section>
    )}

    {relatedItems.length > 0 && (
      <section class="related" aria-labelledby="related-heading">
        <h2 id="related-heading">{t('enc.related.h')}</h2>
        <div class="related-grid">
          {relatedItems.map((r) => (
            <a href={localizePath(locale, `/encyklopedie/${r.id}/`)} class="related-card">
              <div class="related-brand">{r.data.znacka.toUpperCase()}</div>
              <div class="related-name">{r.data.name}</div>
              <div class="related-meta">{r.data.vykon}{r.data.rok_uvedeni ? ` · ${r.data.rok_uvedeni}` : ''}</div>
            </a>
          ))}
        </div>
        <div class="related-cta">
          <a href={localizePath(locale, `/stroje/${item.data.znacka}/`)} class="related-link">
            {tf(locale, 'enc.related.catalog', { brand: brandPrettyForLinks })}
          </a>
          {hasBrandHub && (
            <a href={localizePath(locale, `/znacky/${item.data.znacka}/`)} class="related-link">
              {tf(locale, 'enc.related.history', { brand: brandPrettyForLinks })}
            </a>
          )}
        </div>
      </section>
    )}

    <aside class="trust-bar" aria-label={t('enc.trust.label')}>
      <span class="trust-item">
        {t('enc.byline.pre')} <a href={localizePath(locale, '/redakce/')} class="trust-link">{t('enc.byline.redakce')}</a>
      </span>
      {lastVerifiedFmt && (
        <span class="trust-item">
          {t('enc.trust.verified')} <time datetime={lastVerifiedIso}>{lastVerifiedFmt}</time>
        </span>
      )}
      {item.data.sourceUrl && (
        <a class="trust-item trust-link" href={item.data.sourceUrl} target="_blank" rel="noopener nofollow">
          {t('enc.trust.source')}
        </a>
      )}
    </aside>

    <div style="margin-top:48px;">
      <a href={localizePath(locale, '/encyklopedie/')} style="display:inline-flex; align-items:center; gap:8px; color:#1a1a1a; font-weight:400; font-size:14px; text-decoration:none; border:2px solid #1a1a1a; padding:10px 18px; border-radius:8px;">
        {t('enc.back')}
      </a>
    </div>
  </div>
</Layout>

<style>
  .prose :global(h2) { font-size:1.5rem; font-weight:400; margin:2em 0 .75em; letter-spacing:-.3px; color:#1a1a1a; }
  .prose :global(h3) { font-size:1.15rem; font-weight:400; margin:1.5em 0 .5em; color:#1a1a1a; }
  .prose :global(p) { font-size:17px; line-height:1.75; color:#333; margin-bottom:1.25em; }
  .prose :global(ul), .prose :global(ol) { padding-left:1.5em; margin-bottom:1.25em; }
  .prose :global(li) { font-size:16px; line-height:1.7; color:#333; margin-bottom:.4em; }
  .prose :global(strong) { font-weight:700; color:#1a1a1a; }
  .prose :global(table) { width:100%; border-collapse:collapse; margin-bottom:1.5em; font-size:15px; }
  .prose :global(th) { background:#f5f5f5; font-weight:600; padding:10px 14px; border:1px solid #e0e0e0; text-align:left; }
  .prose :global(td) { padding:9px 14px; border:1px solid #ebebeb; }
  .prose :global(a) { color:#0A0A0B; text-decoration:underline; text-decoration-color:#FFEA00; text-decoration-thickness:2px; text-underline-offset:3px; transition:background .15s; }
  .prose :global(a:hover) { background:#FFEA00; }
  .prose :global(.auto-link) { text-decoration-color:#EAEAEC; text-decoration-style:dotted; }
  .prose :global(.auto-link:hover) { background:#FFEA00; text-decoration-color:#0A0A0B; }
  .prose :global(.auto-link-external)::after { content:" ↗"; font-size:0.85em; opacity:0.55; }

  .faq { margin-top:48px; padding-top:32px; border-top:1px solid #ebebeb; }
  .faq h2 { font-size:1.5rem; font-weight:700; margin:0 0 20px; letter-spacing:-.3px; color:#1a1a1a; }
  .faq-list { margin:0; padding:0; }
  .faq-item { padding:18px 0; border-bottom:1px dashed #e8e8e8; }
  .faq-item:last-child { border-bottom:none; }
  .faq-item dt { font-size:17px; font-weight:600; color:#1a1a1a; margin-bottom:8px; line-height:1.4; }
  .faq-item dd { font-size:16px; line-height:1.7; color:#333; margin:0; }

  .related { margin-top:48px; padding-top:32px; border-top:1px solid #ebebeb; }
  .related h2 { font-size:1.5rem; font-weight:700; margin:0 0 20px; letter-spacing:-.3px; color:#1a1a1a; }
  .related-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:12px; margin-bottom:18px; }
  .related-card { display:block; text-decoration:none; color:inherit; background:#fff; border:1px solid #ebebeb; border-radius:10px; padding:14px 16px; transition:transform .15s, box-shadow .15s, border-color .15s; }
  .related-card:hover { transform:translateY(-2px); box-shadow:0 4px 14px rgba(0,0,0,.06); border-color:#FFE600; }
  .related-brand { font-size:11px; font-weight:600; letter-spacing:.14em; text-transform:uppercase; color:#888; margin-bottom:6px; }
