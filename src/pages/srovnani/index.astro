---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import { topComparisonPairs, modelDisplayName, pairCombo } from '../../lib/comparator';
import { getAllModels, getAllBrands } from '../../lib/stroje';
import { breadcrumbSchema, itemListSchema } from '../../lib/structured-data';
import { SITE_URL } from '../../lib/config';

const pairs = topComparisonPairs(220);

// Custom picker data: all eligible models for the dropdowns. Cap fields to keep
// payload small (one row per option). Frontend filters brand → models.
const allBrands = getAllBrands();
const allModelsForPicker = getAllModels()
  .filter((m) => m.category === 'traktory' || m.category === 'kombajny')
  .map((m) => ({
    slug: m.slug,
    name: m.name,
    brand_slug: m.brand_slug,
    brand_name: m.brand_name,
    category: m.category,
    power_hp: m.power_hp,
    year_from: m.year_from,
    year_to: m.year_to,
  }))
  .sort((a, b) => a.brand_name.localeCompare(b.brand_name, 'cs') || (b.power_hp ?? 0) - (a.power_hp ?? 0));
const pickerJson = JSON.stringify(allModelsForPicker);
const brandsForPicker = allBrands
  .map((b) => ({ slug: b.slug, name: b.name, count: allModelsForPicker.filter((m) => m.brand_slug === b.slug).length }))
  .filter((b) => b.count > 0)
  .sort((a, b) => a.name.localeCompare(b.name, 'cs'));

// Group by category for browse-friendly hub layout.
const tractorPairs = pairs.filter((p) => p.a.category === 'traktory');
const combinePairs = pairs.filter((p) => p.a.category === 'kombajny');

// Group by brand combos for "by brand" browse
const byBrandPair = new Map<string, typeof pairs>();
for (const p of pairs) {
  const key = [p.a.brand_slug, p.b.brand_slug].sort().join(' × ');
  if (!byBrandPair.has(key)) byBrandPair.set(key, []);
  byBrandPair.get(key)!.push(p);
}
const brandComboList = [...byBrandPair.entries()]
  .map(([key, items]) => ({ key, count: items.length, items }))
  .sort((a, b) => b.count - a.count)
  .slice(0, 12);

const breadcrumbJsonLd = breadcrumbSchema([
  { name: 'Domů', url: '/' },
  { name: 'Srovnání', url: '/srovnani/' },
]);

const itemListJsonLd = itemListSchema(
  pairs.slice(0, 50).map((p) => ({
    url: `/srovnani/${p.combo}/`,
    name: `${modelDisplayName(p.a)} vs ${modelDisplayName(p.b)}`,
  })),
  'Srovnání zemědělských strojů',
);

const canonical = `${SITE_URL}/srovnani/`;
---

<Layout
  title="Srovnání traktorů a kombajnů — boční porovnání parametrů"
  description={`Boční srovnání ${pairs.length} kombinací traktorů a kombajnů. Výkon, motor, převodovka, hmotnost a další parametry vedle sebe — pro výběr stroje na míru.`}
  canonical={canonical}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(itemListJsonLd)} />

  <div class="hub">

    <nav class="breadcrumb" aria-label="Cesta">
      <a href="/">Domů</a>
      <span class="sep" aria-hidden="true">›</span>
      <span class="current">Srovnání</span>
    </nav>

    <header class="hero">
      <span class="kicker">Boční srovnání · cross-brand</span>
      <h1>Srovnání zemědělských strojů</h1>
      <p class="hero-lede">
        Vyber dvě modely vedle sebe — výkon, motor, převodovka, hmotnost. Cílí podobné výkonnostní třídy
        napříč značkami, takže porovnáváš srovnatelné stroje. {pairs.length} kombinací předem připravených.
      </p>
      <div class="hero-stats">
        <div class="hs"><span class="n">{tractorPairs.length}</span><span class="l">srovnání traktorů</span></div>
        <div class="hs"><span class="n">{combinePairs.length}</span><span class="l">srovnání kombajnů</span></div>
        <div class="hs"><span class="n">{brandComboList.length}+</span><span class="l">kombinací značek</span></div>
      </div>
      <div style="margin-top:18px; display:flex; gap:10px; flex-wrap:wrap; position:relative; z-index:2;">
        <a href="/zebricky/" style="display:inline-flex; align-items:center; gap:6px; padding:10px 16px; background:#FFEA00; color:#0A0A0B; font-weight:700; font-size:13px; border-radius:8px; text-decoration:none;">
          ⭐ Žebříčky top modelů →
        </a>
        <a href="#picker" style="display:inline-flex; align-items:center; gap:6px; padding:10px 16px; background:rgba(255,255,255,.08); color:#fff; font-weight:700; font-size:13px; border-radius:8px; text-decoration:none; border:1px solid rgba(255,255,255,.2);">
          🛠 Postavit vlastní srovnání →
        </a>
      </div>
    </header>

    <section id="picker" class="picker-section" aria-labelledby="picker-heading">
      <header class="picker-head">
        <h2 id="picker-heading">Postavit vlastní srovnání</h2>
        <p>Vyberte dva libovolné modely z katalogu — z různých kategorií i značek. Odkaz vás zavede na detailní srovnání s parametry vedle sebe.</p>
      </header>

      <form class="picker-form" id="picker-form">
        <div class="picker-grid">
          <fieldset class="pck-side pck-side-a">
            <legend>Model A</legend>
            <label class="pck-field">
              <span>Značka</span>
              <select id="pck-a-brand">
                <option value="">— Vyberte —</option>
                {brandsForPicker.map((b) => <option value={b.slug}>{b.name} ({b.count})</option>)}
              </select>
            </label>
            <label class="pck-field">
              <span>Model</span>
              <select id="pck-a-model" disabled>
                <option value="">— Nejdřív vyberte značku —</option>
              </select>
            </label>
          </fieldset>

          <div class="pck-vs" aria-hidden="true">VS</div>

          <fieldset class="pck-side pck-side-b">
            <legend>Model B</legend>
            <label class="pck-field">
              <span>Značka</span>
              <select id="pck-b-brand">
                <option value="">— Vyberte —</option>
                {brandsForPicker.map((b) => <option value={b.slug}>{b.name} ({b.count})</option>)}
              </select>
            </label>
            <label class="pck-field">
              <span>Model</span>
              <select id="pck-b-model" disabled>
                <option value="">— Nejdřív vyberte značku —</option>
              </select>
            </label>
          </fieldset>
        </div>

        <div class="pck-controls">
          <label class="pck-cat-toggle">
            <input type="checkbox" id="pck-same-cat" checked />
            <span>Jen stejnou kategorii (traktor vs traktor, kombajn vs kombajn)</span>
          </label>
          <button type="submit" class="pck-btn" id="pck-btn" disabled>Porovnat →</button>
        </div>
        <p id="pck-error" class="pck-error" hidden></p>
      </form>
    </section>

    {tractorPairs.length > 0 && (
      <section class="grid-section">
        <div class="gs-head">
          <h2>Traktory</h2>
          <span class="gs-count">{tractorPairs.length} srovnání</span>
        </div>
        <div class="card-grid">
          {tractorPairs.slice(0, 30).map((p) => (
            <a href={`/srovnani/${p.combo}/`} class="cmp-card">
              <div class="cc-models">
                <div class="cc-model">
                  <div class="cc-brand">{p.a.brand_name}</div>
                  <div class="cc-name">{p.a.name}</div>
                  {p.a.power_hp !== null && <div class="cc-hp">{p.a.power_hp} k</div>}
                </div>
                <div class="cc-vs" aria-hidden="true">VS</div>
                <div class="cc-model">
                  <div class="cc-brand">{p.b.brand_name}</div>
                  <div class="cc-name">{p.b.name}</div>
                  {p.b.power_hp !== null && <div class="cc-hp">{p.b.power_hp} k</div>}
                </div>
              </div>
              <div class="cc-cta">Porovnat →</div>
            </a>
          ))}
        </div>
        {tractorPairs.length > 30 && (
          <p class="gs-more">Zobrazeno 30 z {tractorPairs.length}. Další srovnání naleznete na stránkách jednotlivých modelů.</p>
        )}
      </section>
    )}

    {combinePairs.length > 0 && (
      <section class="grid-section">
        <div class="gs-head">
          <h2>Kombajny</h2>
          <span class="gs-count">{combinePairs.length} srovnání</span>
        </div>
        <div class="card-grid">
          {combinePairs.slice(0, 24).map((p) => (
            <a href={`/srovnani/${p.combo}/`} class="cmp-card">
              <div class="cc-models">
                <div class="cc-model">
                  <div class="cc-brand">{p.a.brand_name}</div>
                  <div class="cc-name">{p.a.name}</div>
                  {p.a.power_hp !== null && <div class="cc-hp">{p.a.power_hp} k</div>}
                </div>
                <div class="cc-vs" aria-hidden="true">VS</div>
                <div class="cc-model">
                  <div class="cc-brand">{p.b.brand_name}</div>
                  <div class="cc-name">{p.b.name}</div>
                  {p.b.power_hp !== null && <div class="cc-hp">{p.b.power_hp} k</div>}
                </div>
              </div>
              <div class="cc-cta">Porovnat →</div>
            </a>
          ))}
        </div>
      </section>
    )}

  </div>

  <script is:inline define:vars={{ pickerJson }}>
    (function () {
      const models = JSON.parse(pickerJson);
      const PAIR_DELIMITER = '-vs-';

      const aBrand = document.getElementById('pck-a-brand');
      const aModel = document.getElementById('pck-a-model');
      const bBrand = document.getElementById('pck-b-brand');
      const bModel = document.getElementById('pck-b-model');
      const sameCat = document.getElementById('pck-same-cat');
      const btn = document.getElementById('pck-btn');
      const errEl = document.getElementById('pck-error');
      const form = document.getElementById('picker-form');
      if (!aBrand || !bBrand || !aModel || !bModel || !btn || !form) return;

      function populateModels(brandSel, modelSel, opposite) {
        const slug = brandSel.value;
        const cat = sameCat.checked ? oppositeCategory() : '';
        modelSel.innerHTML = '';
        if (!slug) {
          modelSel.disabled = true;
          modelSel.innerHTML = '<option value="">— Nejdřív vyberte značku —</option>';
          return;
        }
        const filtered = models.filter((m) => {
          if (m.brand_slug !== slug) return false;
          if (cat && m.category !== cat) return false;
          return true;
        });
        if (filtered.length === 0) {
          modelSel.disabled = true;
          modelSel.innerHTML = '<option value="">— Žádné modely —</option>';
          return;
        }
        modelSel.disabled = false;
        modelSel.innerHTML = '<option value="">— Vyberte model —</option>';
        // Group: in production first
        const inProd = filtered.filter((m) => m.year_to === null);
        const old = filtered.filter((m) => m.year_to !== null);
        if (inProd.length > 0) {
          const og = document.createElement('optgroup');
          og.label = 'Aktuálně vyráběné';
          for (const m of inProd) {
            const o = document.createElement('option');
            o.value = m.slug;
            o.textContent = `${m.name}${m.power_hp ? ' · ' + m.power_hp + ' k' : ''}`;
            og.appendChild(o);
          }
          modelSel.appendChild(og);
        }
        if (old.length > 0) {
          const og = document.createElement('optgroup');
          og.label = 'Starší / nevyráběné';
          for (const m of old) {
            const o = document.createElement('option');
            o.value = m.slug;
            o.textContent = `${m.name}${m.power_hp ? ' · ' + m.power_hp + ' k' : ''}${m.year_to ? ' (do ' + m.year_to + ')' : ''}`;
            og.appendChild(o);
          }
          modelSel.appendChild(og);
        }
      }

      function oppositeCategory() {
        // If picker A model is set, return its category to restrict B; otherwise empty.
        if (aModel.value) {
          const m = models.find((mm) => mm.slug === aModel.value);
          return m?.category ?? '';
        }
        if (bModel.value) {
          const m = models.find((mm) => mm.slug === bModel.value);
          return m?.category ?? '';
        }
        return '';
      }

      function refresh() {
        populateModels(aBrand, aModel, bModel);
        populateModels(bBrand, bModel, aModel);
        validate();
      }

      function validate() {
        const aSlug = aModel.value;
        const bSlug = bModel.value;
        errEl.hidden = true;
        errEl.textContent = '';
        if (!aSlug || !bSlug) {
          btn.disabled = true;
          return;
        }
        if (aSlug === bSlug) {
          btn.disabled = true;
          errEl.hidden = false;
          errEl.textContent = 'Vyberte dva různé modely.';
          return;
        }
        btn.disabled = false;
      }

      aBrand.addEventListener('change', refresh);
      bBrand.addEventListener('change', refresh);
      aModel.addEventListener('change', validate);
      bModel.addEventListener('change', validate);
      sameCat.addEventListener('change', refresh);

      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const a = aModel.value;
        const b = bModel.value;
        if (!a || !b || a === b) return;
        const [first, second] = a < b ? [a, b] : [b, a];
        const combo = first + PAIR_DELIMITER + second;
        window.location.href = '/srovnani/' + combo + '/';
      });
    })();
  </script>
</Layout>

<style>
  .hub {
    --yellow:#FFEA00; --yellow-soft:#FFF6A8; --yellow-glow:rgba(255,234,0,.35);
    --ink:#0A0A0B; --body:#1E1E22; --muted:#6B6B72; --muted-2:#9A9AA3;
    --line:#EAEAEC; --card:#FFFFFF; --bg-cream:#FBFAF4;
    --sh-1:0 1px 2px rgba(10,10,12,.04), 0 0 0 1px rgba(10,10,12,.03);
    --sh-3:0 18px 40px -12px rgba(10,10,12,.18), 0 0 0 1px rgba(10,10,12,.04);
    max-width:1280px; margin:0 auto; padding:26px 24px 96px; color:var(--body);
  }
  .breadcrumb { display:flex; gap:8px; align-items:center; font-size:13px; color:var(--muted); margin-bottom:22px; }
  .breadcrumb a { color:var(--muted); text-decoration:none; }
  .breadcrumb a:hover { color:#000; }
  .breadcrumb .current { color:#000; font-weight:600; }
  .breadcrumb .sep { color:var(--muted-2); }

  .hero { background:linear-gradient(135deg, #0E0E10 0%, #1C1C20 60%, #2A2A2F 100%); color:#fff; border-radius:24px; padding:44px 48px; margin-bottom:32px; position:relative; overflow:hidden; box-shadow:var(--sh-3); }
  .hero::before { content:""; position:absolute; inset:0; pointer-events:none; opacity:.3; background-image:linear-gradient(rgba(255,255,255,.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.05) 1px, transparent 1px); background-size:48px 48px; mask-image:radial-gradient(600px 400px at 70% 100%, black, transparent 70%); }
  .hero .kicker { display:inline-flex; font:600 11px 'Chakra Petch',sans-serif; letter-spacing:.2em; text-transform:uppercase; color:var(--yellow); background:rgba(255,234,0,.08); border:1px solid rgba(255,234,0,.3); padding:7px 13px; border-radius:999px; position:relative; z-index:2; }
  .hero h1 { font:700 clamp(2.2rem,5vw,3.6rem) 'Chakra Petch',sans-serif; color:#fff; letter-spacing:-.03em; margin:18px 0 0; position:relative; z-index:2; line-height:1.05; }
  .hero-lede { color:#c8c8d0; max-width:680px; font-size:16px; line-height:1.6; margin:14px 0 22px; position:relative; z-index:2; }
  .hero-stats { display:flex; gap:28px; flex-wrap:wrap; position:relative; z-index:2; font-family:'Chakra Petch',sans-serif; }
  .hero-stats .hs { display:flex; flex-direction:column; gap:3px; }
  .hero-stats .n { font-size:26px; font-weight:700; color:#fff; letter-spacing:-.02em; }
  .hero-stats .l { font-size:11px; color:#8a8a92; letter-spacing:.14em; text-transform:uppercase; }
  .hero-stats .hs + .hs { padding-left:28px; border-left:1px solid rgba(255,255,255,.12); }

  .grid-section { margin-bottom:40px; }
  .gs-head { display:flex; justify-content:space-between; align-items:baseline; margin-bottom:18px; gap:18px; flex-wrap:wrap; }
  .gs-head h2 { font:700 28px 'Chakra Petch',sans-serif; letter-spacing:-.02em; color:var(--ink); margin:0; }
  .gs-count { font:600 12px 'Chakra Petch',sans-serif; color:var(--muted); background:var(--bg-cream); padding:5px 11px; border-radius:8px; }
  .gs-more { font-size:13px; color:var(--muted); margin:14px 0 0; }

  .card-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:12px; }
  .cmp-card { display:flex; flex-direction:column; gap:10px; background:var(--card); border:1px solid var(--line); border-radius:14px; padding:16px 18px; text-decoration:none; color:inherit; transition:.18s; box-shadow:var(--sh-1); }
  .cmp-card:hover { transform:translateY(-2px); border-color:var(--yellow); box-shadow:0 10px 30px -10px rgba(10,10,12,.18); }
  .cc-models { display:grid; grid-template-columns:1fr 32px 1fr; gap:8px; align-items:center; }
  .cc-model { display:flex; flex-direction:column; gap:2px; }
  .cc-brand { font:700 10px 'Chakra Petch',sans-serif; letter-spacing:.14em; text-transform:uppercase; color:var(--muted); }
  .cc-name { font:700 15px 'Chakra Petch',sans-serif; color:var(--ink); letter-spacing:-.005em; line-height:1.15; }
  .cc-hp { font:600 11.5px 'Chakra Petch',sans-serif; color:var(--ink); background:var(--yellow-soft); padding:2px 7px; border-radius:5px; align-self:flex-start; }
  .cc-vs { font:800 13px 'Chakra Petch',sans-serif; color:var(--muted-2); text-align:center; letter-spacing:.04em; }
  .cc-cta { font:700 12px 'Chakra Petch',sans-serif; color:var(--ink); letter-spacing:.04em; text-align:right; }

  @media (max-width:600px) {
    .hub { padding:20px 16px 60px; }
    .hero { padding:32px 24px; }
    .hero-stats .hs + .hs { padding-left:0; border-left:0; }
  }

  /* Custom picker */
  .picker-section {
    background: linear-gradient(135deg, #fff 0%, #fffef8 100%);
    border: 2px solid #FFEA00;
    border-radius: 16px;
    padding: 28px;
    margin: 32px 0 40px;
    scroll-margin-top: 100px;
  }
  .picker-head h2 {
    font-size: 22px;
    font-weight: 800;
    color: #0A0A0B;
    margin: 0 0 8px;
    letter-spacing: -0.3px;
  }
  .picker-head p {
    font-size: 14px;
    color: #555;
    line-height: 1.6;
    margin: 0 0 20px;
    max-width: 620px;
  }
  .picker-form { display: flex; flex-direction: column; gap: 18px; }
  .picker-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 16px;
    align-items: center;
  }
  .pck-side {
    background: #fff;
    border: 1.5px solid #eaeaec;
    border-radius: 12px;
    padding: 16px;
    margin: 0;
  }
  .pck-side-b { background: #fafafa; }
  .pck-side legend {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 700;
    color: #0A0A0B;
    padding: 0 6px;
  }
  .pck-field { display: flex; flex-direction: column; gap: 4px; margin-bottom: 10px; }
  .pck-field span { font-size: 12px; color: #6B6B72; font-weight: 600; }
  .pck-field select {
    padding: 9px 12px;
    border: 1.5px solid #DFDFE3;
    border-radius: 8px;
    font-size: 14px;
    background: #fff;
    width: 100%;
  }
  .pck-field select:focus {
    outline: none;
    border-color: #FFEA00;
    box-shadow: 0 0 0 3px rgba(255, 234, 0, 0.2);
  }
  .pck-field select:disabled { background: #f5f5f5; color: #999; }
  .pck-vs {
    font-size: 24px;
    font-weight: 800;
    color: #FFEA00;
    text-shadow: -1px -1px 0 #0A0A0B, 1px -1px 0 #0A0A0B, -1px 1px 0 #0A0A0B, 1px 1px 0 #0A0A0B;
    font-family: 'Chakra Petch', sans-serif;
    text-align: center;
  }
  .pck-controls {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .pck-cat-toggle {
    display: flex;
    gap: 8px;
    align-items: center;
    font-size: 13px;
    color: #444;
    cursor: pointer;
  }
  .pck-cat-toggle input { width: 16px; height: 16px; accent-color: #0B7A3B; cursor: pointer; }
  .pck-btn {
    padding: 12px 24px;
    background: #0A0A0B;
    color: #FFEA00;
    border: none;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    transition: background .15s, opacity .15s;
  }
  .pck-btn:hover:not(:disabled) { background: #2a2a2f; }
  .pck-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .pck-error {
    margin: 0;
    padding: 10px 14px;
    background: #fef2f2;
    border: 1px solid #fca5a5;
    color: #991b1b;
    border-radius: 8px;
    font-size: 13px;
  }

  @media (max-width: 640px) {
    .picker-grid { grid-template-columns: 1fr; }
    .pck-vs { padding: 6px 0; }
    .pck-controls { flex-direction: column; align-items: stretch; }
    .pck-btn { width: 100%; }
  }
</style>
