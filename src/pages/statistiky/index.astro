---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import {
  getCommodityStats,
  getLatestFuelPrices,
  getLivestockStats,
  getCropProduction,
  getCropAreas,
  getFertilizerPrices,
  getCommodityTimeSeries,
  getFuelTimeSeries,
  getFertilizerTimeSeries,
  getRegionalCropData,
} from '../../lib/czso';

const [commodities, fuels, livestock, crops, areas, fertilizers, commodityTS, fuelTS, fertTS, regionalCrops] = await Promise.all([
  getCommodityStats(),
  getLatestFuelPrices(),
  getLivestockStats(),
  getCropProduction(),
  getCropAreas(),
  getFertilizerPrices(),
  getCommodityTimeSeries(18),
  getFuelTimeSeries(52),
  getFertilizerTimeSeries(),
  getRegionalCropData(),
]);

const latestCropYear = crops.length ? crops[crops.length - 1].year : '2023';
const latestCrops = crops.filter(c => c.year === latestCropYear);
const prevCrops = crops.filter(c => c.year === String(Number(latestCropYear) - 1));

const allAreaYears = [...new Set(areas.map(a => a.year))].sort();
const latestAreaYear = allAreaYears[allAreaYears.length - 1] || '2025';
const latestAreas = areas.filter(a => a.year === latestAreaYear && a.crop !== 'Celkem');
const totalArea = areas.find(a => a.year === latestAreaYear && a.crop === 'Celkem');

const latestLivestock: typeof livestock = [];
const seen = new Set<string>();
for (let i = livestock.length - 1; i >= 0; i--) {
  if (!seen.has(livestock[i].animal)) {
    seen.add(livestock[i].animal);
    latestLivestock.unshift(livestock[i]);
  }
}

const allFertYears = [...new Set(fertilizers.map(f => f.year))].sort();
const latestFertYear = allFertYears[allFertYears.length - 1] || '2024';
const prevFertYear = allFertYears[allFertYears.length - 2] || '2023';
const latestFerts = fertilizers.filter(f => f.year === latestFertYear);
const prevFerts = fertilizers.filter(f => f.year === prevFertYear);

function fmt(n: number): string { return n.toLocaleString('cs-CZ'); }
function fmtChange(c: number | null): string {
  if (c === null) return '—';
  return `${c > 0 ? '+' : ''}${c.toFixed(1)}%`;
}

const nafta = fuels.find(f => f.fuel === 'Nafta');
const nat95 = fuels.find(f => f.fuel === 'Natural 95');
const lpg = fuels.find(f => f.fuel === 'LPG');

const COLORS = {
  yellow: '#FFFF00',
  green: '#22a355',
  red: '#d63031',
  gray: '#888',
};

const CHART_COLORS = ['#FFFF00', '#4ecdc4', '#ff6b6b', '#a29bfe', '#fd79a8', '#00b894'];
---

<Layout title="Statistiky | agro-svět.cz">
  <section class="sp">

    <div class="sp-header">
      <div class="sp-badge">LIVE DATA</div>
      <h1>Zemědělské statistiky ČR</h1>
      <p>Aktuální data z Českého statistického úřadu. Ceny komodit, sklizeň, osevní plochy, pohonné hmoty, stavy zvířat a hnojiva.</p>
    </div>

    <!-- ═══ FUEL TICKER ═══ -->
    <div class="ticker">
      {[nafta && { n: 'Nafta', p: nafta.price, u: 'Kč/l' },
        nat95 && { n: 'Natural 95', p: nat95.price, u: 'Kč/l' },
        lpg && { n: 'LPG', p: lpg.price, u: 'Kč/l' }
      ].filter(Boolean).map(f => (
        <div class="ticker-item">
          <span class="ticker-dot"></span>
          <span class="ticker-name">{f!.n}</span>
          <span class="ticker-val">{f!.p.toFixed(2)}</span>
          <span class="ticker-unit">{f!.u}</span>
        </div>
      ))}
      {nafta && <span class="ticker-date">{nafta.week}</span>}
    </div>

    <!-- ═══ INTERACTIVE MAP ═══ -->
    <div class="map-section">
      <div class="block-head">
        <h2>Sklizeň podle krajů</h2>
        <span class="block-sub">Klikněte na kraj pro detail</span>
      </div>

      <div class="map-controls">
        <button class="map-btn active" data-crop="Obiloviny na zrno">Obiloviny</button>
        <button class="map-btn" data-crop="Pšenice">Pšenice</button>
        <button class="map-btn" data-crop="Ječmen">Ječmen</button>
        <button class="map-btn" data-crop="Řepka">Řepka</button>
        <button class="map-btn" data-crop="Brambory">Brambory</button>
        <button class="map-btn" data-crop="Řepa cukrová">Cukrovka</button>
      </div>

      <div class="map-layout">
        <div class="map-container">
          <!-- Legend -->
          <div class="map-legend">
            <span class="legend-lo">nízká</span>
            <div class="legend-bar"></div>
            <span class="legend-hi">vysoká</span>
