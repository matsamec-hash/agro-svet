    <!-- ═══ COMMODITY CARDS + CHART ═══ -->
    <div class="block">
      <div class="block-head">
        <h2>Ceny komodit</h2>
        <span class="block-sub">Měsíční průměry výrobců v ČR</span>
      </div>

      <div class="comm-grid">
        {commodities.map(c => {
          const isUp = c.change !== null && c.change > 0;
          const isDown = c.change !== null && c.change < 0;
          return (
            <div class="comm-card">
              <div class="comm-top">
                <span class="comm-name">{c.name}</span>
                {c.change !== null && (
                  <span class={`comm-arrow ${isUp ? 'up' : 'down'}`}>
                    {isUp ? '▲' : '▼'} {fmtChange(c.change)}
                  </span>
                )}
              </div>
              <div class="comm-price">{fmt(c.price)}</div>
              <div class="comm-unit">{c.unit} · {c.month}</div>
            </div>
          );
        })}
      </div>

      <div class="chart-wrap">
        <h3>Vývoj cen obilovin (18 měsíců)</h3>
        <canvas id="commodityChart" height="220"></canvas>
      </div>
    </div>

    <!-- Expand button -->
    <div class="expand-section" id="expandBtn">
      <button class="expand-btn" onclick="document.getElementById('moreStats').style.display='block'; this.parentElement.style.display='none'; setTimeout(()=>window._initMoreCharts&&window._initMoreCharts(),100);">
        Zobrazit další statistiky
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
      </button>
    </div>

    <div id="moreStats" style="display:none">

    <!-- ═══ FUEL CHART ═══ -->
    <div class="block">
      <div class="block-head">
        <h2>Nafta — vývoj ceny</h2>
        <span class="block-sub">Týdenní průměr, posledních 52 týdnů</span>
      </div>
      <div class="chart-wrap compact">
        <canvas id="fuelChart" height="160"></canvas>
      </div>
    </div>

    <!-- ═══ CROP PRODUCTION + DONUT ═══ -->
    <div class="two-col">
      <div class="block">
        <div class="block-head">
          <h2>Sklizeň {latestCropYear}</h2>
          <span class="block-sub">Produkce v tunách</span>
        </div>
        <div class="chart-wrap">
          <canvas id="cropChart" height="200"></canvas>
        </div>
      </div>

      <div class="block">
        <div class="block-head">
          <h2>Osevní plochy {latestAreaYear}</h2>
          {totalArea && <span class="block-sub">Celkem {fmt(totalArea.hectares)} ha</span>}
        </div>
        <div class="chart-wrap donut-wrap">
          <canvas id="areaChart" height="200"></canvas>
        </div>
      </div>
    </div>

    <!-- ═══ LIVESTOCK ═══ -->
    <div class="block">
      <div class="block-head">
        <h2>Stavy hospodářských zvířat</h2>
        <span class="block-sub">Pololetní data ČSÚ</span>
      </div>
      <div class="live-row">
        {latestLivestock.map(l => (
          <div class="live-card">
            <div class="live-emoji">{l.animal === 'Skot' ? '🐄' : '🐖'}</div>
            <div class="live-info">
              <div class="live-name">{l.animal}</div>
              <div class="live-num">{fmt(l.count)}</div>
              <div class="live-date">{l.date}</div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- ═══ FERTILIZERS + CHART ═══ -->
    <div class="block">
      <div class="block-head">
        <h2>Ceny hnojiv</h2>
        <span class="block-sub">Roční průměr v Kč/t</span>
      </div>

      <div class="fert-row">
        {latestFerts.map(f => {
          const prev = prevFerts.find(p => p.name === f.name);
          const ch = prev ? Math.round((f.price / prev.price - 1) * 1000) / 10 : null;
          const isUp = ch !== null && ch > 0;
          return (
            <div class="fert-card">
              <div class="fert-name">{f.name}</div>
              <div class="fert-price">{fmt(f.price)}</div>
              {ch !== null && (
                <div class={`fert-ch ${isUp ? 'up' : 'down'}`}>{fmtChange(ch)}</div>
              )}
            </div>
          );
        })}
      </div>

      <div class="chart-wrap">
        <h3>Vývoj cen hnojiv (2011–{latestFertYear})</h3>
        <canvas id="fertChart" height="220"></canvas>
      </div>
    </div>

    </div><!-- /moreStats -->

    <div class="source">
      Zdroj: <a href="https://data.csu.gov.cz" target="_blank" rel="noopener">Český statistický úřad</a> — DataStat API
    </div>

  </section>
</Layout>

<!-- Chart data -->
<script type="application/json" id="chartData" set:html={JSON.stringify({ commodityTS, fuelTS, latestCrops, latestAreas, fertTS, regionalCrops })}></script>

<!-- Chart.js -->
<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>

<script is:inline>
  const _raw = JSON.parse(document.getElementById('chartData').textContent);
  const commodityTS = _raw.commodityTS;
  const fuelTS = _raw.fuelTS;
  const latestCrops = _raw.latestCrops;
  const latestAreas = _raw.latestAreas;
  const fertTS = _raw.fertTS;

  const COLORS = ['#FFFF00','#4ecdc4','#ff6b6b','#a29bfe','#fd79a8','#00b894','#636e72','#e17055'];
  const gridColor = 'rgba(0,0,0,.06)';
  const fontFamily = "'Chakra Petch', sans-serif";

  Chart.defaults.font.family = fontFamily;
  Chart.defaults.font.size = 12;
  Chart.defaults.color = '#888';

  // ── Commodity line chart ──
  const commCtx = document.getElementById('commodityChart');
  if (commCtx && commodityTS.length) {
    const labels = commodityTS[0].data.map(d => d.label);
    new Chart(commCtx, {
      type: 'line',
      data: {
        labels,
        datasets: commodityTS.map((s, i) => ({
          label: s.name,
          data: s.data.map(d => d.value),
          borderColor: COLORS[i],
          backgroundColor: COLORS[i] + '18',
          borderWidth: 2.5,
          pointRadius: 0,
          pointHoverRadius: 5,
          tension: .35,
          fill: false,
        })),
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: { position: 'top', labels: { usePointStyle: true, padding: 16, font: { size: 13 } } },
          tooltip: {
            backgroundColor: '#1a1a1a',
            titleFont: { size: 13 },
            bodyFont: { size: 13 },
            padding: 12,
            cornerRadius: 10,
            callbacks: { label: ctx => `${ctx.dataset.label}: ${ctx.parsed.y.toLocaleString('cs-CZ')} Kč/t` },
          },
        },
        scales: {
          x: { grid: { display: false }, ticks: { maxRotation: 45, font: { size: 11 } } },
          y: { grid: { color: gridColor }, ticks: { callback: v => v.toLocaleString('cs-CZ') } },
        },
      },
    });
  }

  // ── Lazy charts (rendered when "Zobrazit další" clicked) ──
  window._initMoreCharts = function() {
    if (window._moreChartsInit) return;
    window._moreChartsInit = true;

  // ── Fuel line chart ──
  const fuelCtx = document.getElementById('fuelChart');
  if (fuelCtx && fuelTS.length) {
    new Chart(fuelCtx, {
      type: 'line',
      data: {
        labels: fuelTS.map(d => d.label),
        datasets: [{
          label: 'Nafta (Kč/l)',
          data: fuelTS.map(d => d.value),
          borderColor: '#ff6b6b',
          backgroundColor: 'rgba(255,107,107,.08)',
          borderWidth: 2,
          pointRadius: 0,
          pointHoverRadius: 4,
          tension: .3,
          fill: true,
        }],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: '#1a1a1a',
            padding: 12,
            cornerRadius: 10,
            callbacks: { label: ctx => `${ctx.parsed.y.toFixed(2)} Kč/l` },
          },
        },
        scales: {
          x: { grid: { display: false }, ticks: { maxTicksLimit: 12, font: { size: 10 } } },
          y: { grid: { color: gridColor }, ticks: { callback: v => v + ' Kč' } },
        },
      },
    });
  }

  // ── Crop production horizontal bar ──
  const cropCtx = document.getElementById('cropChart');
  if (cropCtx && latestCrops.length) {
    const sorted = [...latestCrops].sort((a, b) => b.tonnes - a.tonnes);
    new Chart(cropCtx, {
      type: 'bar',
      data: {
        labels: sorted.map(c => c.crop),
        datasets: [{
          data: sorted.map(c => c.tonnes),
          backgroundColor: sorted.map((_, i) => COLORS[i % COLORS.length] + 'cc'),
          borderRadius: 6,
          barThickness: 28,
        }],
      },
      options: {
        indexAxis: 'y',
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: '#1a1a1a',
            padding: 12,
            cornerRadius: 10,
            callbacks: { label: ctx => `${ctx.parsed.x.toLocaleString('cs-CZ')} t` },
          },
        },
        scales: {
          x: { grid: { color: gridColor }, ticks: { callback: v => (v / 1e6).toFixed(1) + 'M t' } },
          y: { grid: { display: false }, ticks: { font: { size: 13 } } },
        },
      },
    });
  }

  // ── Crop areas donut ──
  const areaCtx = document.getElementById('areaChart');
  if (areaCtx && latestAreas.length) {
    new Chart(areaCtx, {
      type: 'doughnut',
      data: {
        labels: latestAreas.map(a => a.crop),
        datasets: [{
          data: latestAreas.map(a => a.hectares),
          backgroundColor: latestAreas.map((_, i) => COLORS[i % COLORS.length]),
          borderWidth: 0,
          hoverOffset: 8,
        }],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: '60%',
        plugins: {
          legend: { position: 'bottom', labels: { usePointStyle: true, padding: 14, font: { size: 12 } } },
          tooltip: {
            backgroundColor: '#1a1a1a',
            padding: 12,
            cornerRadius: 10,
            callbacks: { label: ctx => `${ctx.label}: ${ctx.parsed.toLocaleString('cs-CZ')} ha` },
          },
        },
      },
    });
  }

  // ── Fertilizer line chart ──
  const fertCtx = document.getElementById('fertChart');
  if (fertCtx && fertTS.length) {
    const years = fertTS[0].data.map(d => d.year);
    new Chart(fertCtx, {
      type: 'line',
      data: {
        labels: years,
        datasets: fertTS.map((s, i) => ({
          label: s.name,
          data: s.data.map(d => d.price),
          borderColor: COLORS[i % COLORS.length],
          borderWidth: 2,
          pointRadius: 2,
          pointHoverRadius: 5,
          tension: .3,
          fill: false,
        })),
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: { position: 'top', labels: { usePointStyle: true, padding: 14, font: { size: 11 } } },
          tooltip: {
            backgroundColor: '#1a1a1a',
            padding: 12,
            cornerRadius: 10,
            callbacks: { label: ctx => `${ctx.dataset.label}: ${ctx.parsed.y.toLocaleString('cs-CZ')} Kč/t` },
          },
        },
        scales: {
          x: { grid: { display: false } },
          y: { grid: { color: gridColor }, ticks: { callback: v => (v / 1000).toFixed(0) + ' tis' } },
        },
      },
    });
  }

  }; // end _initMoreCharts

  // ── Interactive Map ──
  const regionalCrops = _raw.regionalCrops;
  const mapPaths = document.querySelectorAll('#czMap path');

  // Accessibility: add <title>, role=button, tabindex to region paths
  mapPaths.forEach(path => {
    const region = path.getAttribute('data-region');
    if (!region) return;
    const titleEl = document.createElementNS('http://www.w3.org/2000/svg', 'title');
    titleEl.textContent = region;
    path.appendChild(titleEl);
    path.setAttribute('role', 'button');
    path.setAttribute('tabindex', '0');
    path.setAttribute('aria-label', region);
    path.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        path.dispatchEvent(new MouseEvent('click', { bubbles: true }));
      }
    });
  });

  const tooltip = document.getElementById('mapTooltip');
  const detailPanel = document.getElementById('detailContent');
  const detailPlaceholder = document.querySelector('.detail-placeholder');
  const detailName = document.getElementById('detailName');
  const detailStat = document.getElementById('detailStat');
  let detailChartInstance = null;
  let selectedCrop = 'Obiloviny na zrno';
  let selectedRegion = null;

  // Color scale
  function getColor(val, min, max) {
    if (max === min) return '#81c784';
    const t = (val - min) / (max - min);
    // Light green → dark green
    const r = Math.round(232 - t * 186);
    const g = Math.round(245 - t * 120);
    const b = Math.round(233 - t * 183);
    return `rgb(${r},${g},${b})`;
  }

  function colorMap() {
    const data = regionalCrops.filter(d => d.crop === selectedCrop && d.year === '2023');
    const valMap = {};
    data.forEach(d => { valMap[d.region] = d.tonnes; });
    const vals = Object.values(valMap).filter(v => v > 0);
    const min = Math.min(...vals);
    const max = Math.max(...vals);

    mapPaths.forEach(path => {
      const region = path.getAttribute('data-region');
      const val = valMap[region];
      if (val !== undefined && val > 0) {
        path.style.fill = getColor(val, min, max);
      } else {
        path.style.fill = '#e8e8e8';
      }
    });
  }

  // Tooltip
  mapPaths.forEach(path => {
    path.addEventListener('mouseenter', e => {
      const region = path.getAttribute('data-region');
      const data = regionalCrops.filter(d => d.crop === selectedCrop && d.year === '2023' && d.region === region);
      const val = data.length ? data[0].tonnes : 0;
      tooltip.innerHTML = `<strong>${region}</strong><br>${selectedCrop}: <b>${val.toLocaleString('cs-CZ')}</b> t`;
      tooltip.style.display = 'block';
      path.style.strokeWidth = '2';
      path.style.stroke = '#1a1a1a';
    });

    path.addEventListener('mousemove', e => {
      const rect = document.getElementById('czMap').closest('.map-container').getBoundingClientRect();
      tooltip.style.left = (e.clientX - rect.left + 12) + 'px';
      tooltip.style.top = (e.clientY - rect.top - 40) + 'px';
    });

    path.addEventListener('mouseleave', () => {
      tooltip.style.display = 'none';
    });

    // Click → show detail
    path.addEventListener('click', () => {
      const region = path.getAttribute('data-region');
      selectedRegion = region;

      // Reset all selections
      mapPaths.forEach(p => p.classList.remove('selected'));
      path.classList.add('selected');

      // Show detail
      detailPlaceholder.style.display = 'none';
      detailPanel.style.display = 'block';
      detailName.textContent = region;

      // Get all crops for this region in 2023
      const regionData = regionalCrops.filter(d => d.region === region && d.year === '2023');
      const statHtml = regionData.map(d =>
        `<div class="detail-row"><span>${d.crop}</span><span>${d.tonnes.toLocaleString('cs-CZ')} t</span></div>`
      ).join('');
      detailStat.innerHTML = statHtml;

      // Chart: selected crop over years for this region
      const yearData = regionalCrops
        .filter(d => d.region === region && d.crop === selectedCrop)
        .sort((a, b) => parseInt(a.year) - parseInt(b.year));

      if (detailChartInstance) detailChartInstance.destroy();
      const ctx = document.getElementById('detailChart');
      detailChartInstance = new Chart(ctx, {
        type: 'bar',
        data: {
          labels: yearData.map(d => d.year),
          datasets: [{
            label: selectedCrop,
            data: yearData.map(d => d.tonnes),
            backgroundColor: '#66bb6acc',
            borderRadius: 4,
            barThickness: 20,
          }],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: {
              backgroundColor: '#1a1a1a', padding: 10, cornerRadius: 8,
              callbacks: { label: ctx => ctx.parsed.y.toLocaleString('cs-CZ') + ' t' },
            },
          },
          scales: {
            x: { grid: { display: false } },
            y: { grid: { color: 'rgba(0,0,0,.06)' }, ticks: { callback: v => (v/1e6).toFixed(1)+'M' } },
          },
        },
      });
    });
  });

  // Crop selector buttons
  document.querySelectorAll('.map-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.map-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      selectedCrop = btn.getAttribute('data-crop');
      colorMap();
      if (selectedRegion) {
        document.querySelector(`[data-region="${selectedRegion}"]`).click();
      }
    });
  });

  // Initial color
  colorMap();
</script>

<style>
