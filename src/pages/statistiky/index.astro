---
// src/pages/statistiky/index.astro
// prerender=false (SSR): launchnuté SK sekce servíruje middleware rewrite, který
// prerendered routy nepokrývá → tato stránka musí být SSR. Locale ber JEN z
// Astro.locals.locale (po rewrite je Astro.url cs cesta). Data jsou precomputed
// v src/data/agro-stats{,-sk}.json — žádný runtime fetch, čistý render JSONu.
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { useTranslations, localizePath } from '../../i18n/utils';
import { statTakeaways, scissorsInsightText, livestockInsightText } from '../../lib/agro-derived';
// AGRO_EVENTS moved to /statistiky/commodity-data*.json endpoints — loaded
// client-side by the chart, no longer needed at SSR time on this page.
import statsCs from '../../data/agro-stats.json';
import statsSk from '../../data/agro-stats-sk.json';

import DataSegmentNav from '../../components/DataSegmentNav.astro';
import HomeWeather from '../../components/HomeWeather.astro';
import Hero from '../../components/statistiky/Hero.astro';
import SparklineTicker from '../../components/statistiky/SparklineTicker.astro';
import AutoTakeaways from '../../components/statistiky/AutoTakeaways.astro';
import PillsNav from '../../components/statistiky/PillsNav.astro';
import CommodityChart from '../../components/statistiky/CommodityChart.astro';
import InputsBlock from '../../components/statistiky/InputsBlock.astro';
import PriceScissors from '../../components/statistiky/PriceScissors.astro';
import ProductionBlock from '../../components/statistiky/ProductionBlock.astro';
import HexMap from '../../components/statistiky/HexMap.astro';
import LivestockSlope from '../../components/statistiky/LivestockSlope.astro';
import StoryCards from '../../components/statistiky/StoryCards.astro';
import MethodologyFooter from '../../components/statistiky/MethodologyFooter.astro';
import BottomCTA from '../../components/statistiky/BottomCTA.astro';
import StatistikyUk from '../../components/statistiky/StatistikyUk.astro';

const locale = Astro.locals.locale ?? 'cs';
const t = useTranslations(locale);
const statsData = locale === 'sk' ? statsSk : statsCs;

// Žádný runtime fetch — čistý render importovaného JSONu → bezpečně cachovatelné na edge.
Astro.response.headers.set('Cache-Control', 'public, max-age=600, s-maxage=86400, stale-while-revalidate=604800');

const numLocale = locale === 'sk' ? 'sk-SK' : 'cs-CZ';

const {
  commodityStats,
  latestFuels,
  livestock,
  livestockHistorical,
  crops,
  areas,
  fertilizers,
  commodityFull,
  fuelSeries,
  fertSeries,
  regional,
  scissorsPoints,
  scissorsBaseYear: BASE_YEAR,
} = statsData;

// Hero stats — datasetCount: počet neprázdných datových bloků (cs = 7: 6 hlavních + regional).
const datasetCount = [
  commodityFull.length > 0,
  fuelSeries.length > 0,
  fertSeries.length > 0,
  scissorsPoints.length > 0,
  crops.length > 0,
  livestockHistorical.length > 0,
  regional.length > 0,
].filter(Boolean).length;
const yearsCovered = (() => {
  const allYears = commodityFull.flatMap(s => s.data.map(d => d.label.split(' ')[1])).map(Number).filter(n => !isNaN(n));
  return allYears.length ? new Date().getFullYear() - Math.min(...allYears) + 1 : 14;
})();
const lastUpdated = new Date().toLocaleDateString(numLocale, { day: 'numeric', month: 'long', year: 'numeric' });

// Sparkline ticker — locale-aware metriky
const SPARK = locale === 'sk'
  ? { wheat: 'Pšenica', rapeseed: 'Repka', third: 'Kukurica', diesel: 'Nafta', fertilizer: null as string | null }
  : { wheat: 'Pšenice', rapeseed: 'Řepka', third: 'Mléko', diesel: 'Nafta', fertilizer: 'NPK 15-15-15' as string | null };
const fuelUnit = locale === 'sk' ? 'EUR/l' : 'Kč/l';

function sparklineFor(name: string, months = 12): { label: string; value: number; sortKey: number }[] {
  const series = commodityFull.find(s => s.name === name)?.data ?? [];
  return series.slice(-months);
}
const psenice = commodityStats.find(s => s.name === SPARK.wheat);
const repka = commodityStats.find(s => s.name === SPARK.rapeseed);
const third = commodityStats.find(s => s.name === SPARK.third);
const nafta = latestFuels.find(f => f.fuel === SPARK.diesel);
const npk = (() => {
  if (!SPARK.fertilizer) return null;
  const last = fertSeries.find(f => f.name === SPARK.fertilizer);
  if (!last || last.data.length < 2) return null;
  const ll = last.data[last.data.length - 1];
  const prev = last.data[last.data.length - 2];
  const ch = prev.price > 0 ? ((ll.price / prev.price) - 1) * 100 : null;
  return { name: SPARK.fertilizer, price: ll.price, year: ll.year, change: ch };
})();

const sparkMetrics = [
  psenice && { name: SPARK.wheat, value: psenice.price, unit: psenice.unit, changePct: psenice.change, series: sparklineFor(SPARK.wheat), anchor: '#trh' },
  repka && { name: SPARK.rapeseed, value: repka.price, unit: repka.unit, changePct: repka.change, series: sparklineFor(SPARK.rapeseed), anchor: '#trh' },
  third && { name: SPARK.third, value: third.price, unit: third.unit, changePct: third.change, series: sparklineFor(SPARK.third), anchor: '#trh' },
  nafta && { name: SPARK.diesel, value: nafta.price, unit: fuelUnit, changePct: null, series: fuelSeries.slice(-12).map(p => ({ label: p.label, value: p.value, sortKey: p.sortKey })), anchor: '#vstupy' },
  npk && { name: npk.name, value: npk.price, unit: 'Kč/t', changePct: npk.change, series: (fertSeries.find(f => f.name === npk.name)?.data ?? []).slice(-12).map((d, i) => ({ label: d.year, value: d.price, sortKey: i })), anchor: '#vstupy' },
].filter(Boolean) as any[];

// Auto-takeaways — locale-aware próza (helper reprodukuje cs verbatim)
const takeaways = statTakeaways({ commodityStats, fertilizers, livestock }, locale);

// Cenové nůžky — scissorsPoints precomputed v agro-stats.json
const scissorsInsight = scissorsInsightText(scissorsPoints, locale);

// Latest year for production
const latestCropYear = (() => {
  const ys = [...new Set(crops.map(c => c.year))].sort();
  return ys[ys.length - 1] ?? '2023';
})();

// Livestock insight (z plné historické řady)
const livestockInsight = livestockInsightText(livestockHistorical, locale);
const livestockFromYear = (() => {
  const dates = livestockHistorical.map(l => parseInt(l.date.match(/\d{4}/)?.[0] ?? '0')).filter(n => n > 1900);
  return dates.length ? Math.min(...dates) : null;
})();

const PILLS = [
  { label: t('stat.pills.trh'), href: '#trh' },
  { label: t('stat.pills.vstupy'), href: '#vstupy' },
  { label: t('stat.pills.scissors'), href: '#cenove-nuzky' },
  { label: t('stat.pills.produkce'), href: '#produkce' },
  ...(regional.length > 0 ? [{ label: t('stat.pills.regiony'), href: '#regiony' }] : []),
  { label: t('stat.pills.zvirata'), href: '#zvirata' },
  ...(locale === 'cs' ? [{ label: t('stat.pills.pribehy'), href: '#pribehy' }] : []),
];
---

{locale === 'uk' ? <StatistikyUk /> : (
<Fragment>
<Layout
  title={t('stat.meta.title')}
  description={t('stat.meta.description')}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: t('stat.bc.home'), item: `https://agro-svet.cz${localizePath(locale, '/')}` },
      { '@type': 'ListItem', position: 2, name: t('stat.bc.current'), item: `https://agro-svet.cz${localizePath(locale, '/statistiky/')}` },
    ],
  })} />

  <main class="sp-page">
    <DataSegmentNav active="komodity" />
    <Hero
      datasetCount={datasetCount}
      yearsCovered={yearsCovered}
      regionCount={regional.length}
      lastUpdated={lastUpdated}
    />

    <SparklineTicker metrics={sparkMetrics} />

    <AutoTakeaways takeaways={takeaways} />

    {locale === 'cs' && <HomeWeather mode="commodity" />}

    <PillsNav items={PILLS} />

    {commodityFull.length > 0 && (
      <CommodityChart commodityNames={commodityFull.map((s: { name: string }) => s.name)} dataBase={locale === 'sk' ? '-sk' : ''} numLocale={locale === 'sk' ? 'sk-SK' : 'cs-CZ'} locale={locale} />
    )}

    {fuelSeries.length > 0 && <InputsBlock fuelSeries={fuelSeries} fertSeries={fertSeries} />}

    {scissorsPoints.length > 0 && <PriceScissors points={scissorsPoints} insight={scissorsInsight} baseYear={BASE_YEAR} />}

    {crops.length > 0 && <ProductionBlock crops={crops} areas={areas} latestYear={latestCropYear} />}

    {regional.length > 0 && <HexMap data={regional} />}

    {livestockHistorical.length > 0 && <LivestockSlope livestock={livestockHistorical} insight={livestockInsight} fromYear={livestockFromYear} />}

    {locale === 'cs' && <StoryCards />}

    <MethodologyFooter lastUpdated={lastUpdated} />

    <BottomCTA />
  </main>

  <script type="application/json" id="statI18n" set:html={JSON.stringify({
    numLocale,
    animals: { Skot: t('stat.animal.cattle'), Prasata: t('stat.animal.pigs') },
    fuelLabel:     locale === 'sk' ? 'Nafta (EUR/l)'          : 'Nafta (Kč/l)',
    fuelTooltip:   locale === 'sk' ? 'EUR/l'                  : 'Kč/l',
    fuelAxis:      locale === 'sk' ? '€'                      : 'Kč',
    commodityUnit: locale === 'sk' ? 'EUR/t'                  : 'Kč/t',
    scissorsInput: locale === 'sk' ? 'Index vstupných cien'  : 'Vstupy (nafta + NPK)',
    scissorsOutput:locale === 'sk' ? 'Index výstupných cien' : 'Výstupy (4 komodity)',
    scissorsAxis:  `Index ${locale === 'sk' ? 'cien' : 'cen'} (${BASE_YEAR} = 100)`,
    yearLabel: 'Rok',
    total:     locale === 'sk' ? 'spolu'    : 'celkem',
    thousTons: locale === 'sk' ? 'tis. ton' : 'tis. tun',
  })}></script>
</Layout>

<!-- Chart.js + annotation plugin from CDN -->
<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/chartjs-plugin-annotation@3"></script>

<script is:inline>
  // ── Defaults ──
  Chart.defaults.font.family = "'Chakra Petch', sans-serif";
  Chart.defaults.font.size = 12;
  Chart.defaults.color = '#6B6B72';
  if (window['chartjs-plugin-annotation']) {
    Chart.register(window['chartjs-plugin-annotation']);
  }
  const YELLOW = '#FFEA00';
  const INK = '#0A0A0B';
  const RED = '#C24414';
  const GREEN = '#0B7A3B';
  const COLORS = [YELLOW, '#4ecdc4', '#ff6b6b', '#a29bfe', '#fd79a8', '#00b894', '#636e72', '#e17055', '#74b9ff'];

  // ── Helper: parse "Led 2024" → sortable index
  const SHORT_MONTHS = ['Led','Úno','Bře','Dub','Kvě','Čvn','Čvc','Srp','Zář','Říj','Lis','Pro'];
  function labelToIndex(label) {
    const [m, y] = label.split(' ');
    return parseInt(y) * 12 + SHORT_MONTHS.indexOf(m);
  }
  function indexToLabel(idx) {
    return `${SHORT_MONTHS[idx % 12]} ${Math.floor(idx / 12)}`;
  }

  // ──────────── COMMODITY CHART ────────────
  // Init přesunut do komponenty CommodityChart.astro (self-contained, funguje i mimo /statistiky/)

  // ──────────── INPUTS BLOCK ────────────
  (function initInputs() {
    const I18N = JSON.parse(document.getElementById('statI18n')?.textContent || '{}');
    const NUM = I18N.numLocale || 'cs-CZ';
    const dataEl = document.getElementById('inputsData');
    if (!dataEl) return;
    const { fuelSeries, fertSeries } = JSON.parse(dataEl.textContent);

    const fuelEl = document.getElementById('fuelLongChart');
    if (fuelEl && fuelSeries.length) {
      new Chart(fuelEl, {
        type: 'line',
        data: {
          labels: fuelSeries.map(d => d.label),
          datasets: [{
            label: I18N.fuelLabel,
            data: fuelSeries.map(d => d.value),
            borderColor: RED,
            backgroundColor: 'rgba(194,68,20,.08)',
            borderWidth: 2,
            pointRadius: 0,
            tension: 0.3,
            fill: true,
          }],
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: { backgroundColor: INK, padding: 12, cornerRadius: 10,
              callbacks: { label: ctx => `${ctx.parsed.y.toFixed(2)} ${I18N.fuelTooltip}` } },
          },
          scales: {
            x: { grid: { display: false }, ticks: { maxTicksLimit: 12, font: { size: 10 } } },
            y: { grid: { color: 'rgba(10,10,12,.06)' }, ticks: { callback: v => v + ' ' + I18N.fuelAxis } },
          },
        },
      });
    }

    const fertEl = document.getElementById('fertLongChart');
    if (fertEl && fertSeries.length) {
      const years = fertSeries[0].data.map(d => d.year);
      new Chart(fertEl, {
        type: 'line',
        data: {
          labels: years,
          datasets: fertSeries.map((s, i) => ({
            label: s.name,
            data: s.data.map(d => d.price),
            borderColor: COLORS[i % COLORS.length],
            borderWidth: 2,
            pointRadius: 2,
            tension: 0.3,
            fill: false,
          })),
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          plugins: {
            legend: { position: 'top', labels: { usePointStyle: true, padding: 10, font: { size: 11 }, boxWidth: 10 } },
            tooltip: { backgroundColor: INK, padding: 12, cornerRadius: 10,
              callbacks: { label: ctx => `${ctx.dataset.label}: ${ctx.parsed.y.toLocaleString(NUM)} ${I18N.commodityUnit}` } },
          },
          scales: {
            x: { grid: { display: false } },
            y: { grid: { color: 'rgba(10,10,12,.06)' }, ticks: { callback: v => (v / 1000).toFixed(0) + ' tis' } },
          },
        },
      });
    }
  })();

  // ──────────── PRICE SCISSORS ────────────
  (function initScissors() {
    const I18N = JSON.parse(document.getElementById('statI18n')?.textContent || '{}');
    const dataEl = document.getElementById('scissorsData');
    const el = document.getElementById('scissorsChart');
    if (!dataEl || !el) return;
    const { points } = JSON.parse(dataEl.textContent);
    if (!points.length) return;

    // Sort by year asc — points jsou už sortované, ale safety
    points.sort((a, b) => a.year - b.year);
    const labels = points.map(p => String(p.year));
    const inputs = points.map(p => p.x);
    const outputs = points.map(p => p.y);
    // Difference area: zelená když výstupy >= vstupy (zisk), červená když < (ztráta)
    // Vyplníme oblast mezi linkami
    const RED = '#C24414';
    const GREEN = '#0B7A3B';

    new Chart(el, {
      type: 'line',
      data: {
        labels,
        datasets: [
          {
            label: I18N.scissorsInput,
            data: inputs,
            borderColor: RED,
            backgroundColor: 'rgba(194,68,20,.20)',
            borderWidth: 2.5,
            pointRadius: 4,
            pointHoverRadius: 7,
            tension: 0.25,
            fill: '+1', // fill mezi inputs a další dataset (outputs)
          },
          {
            label: I18N.scissorsOutput,
            data: outputs,
            borderColor: GREEN,
            backgroundColor: 'rgba(11,122,59,.10)',
            borderWidth: 2.5,
            pointRadius: 4,
            pointHoverRadius: 7,
            tension: 0.25,
            fill: false,
          },
        ],
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: { display: false }, // používáme custom legendu nahoře
          tooltip: {
            backgroundColor: INK, padding: 12, cornerRadius: 10,
            callbacks: {
              title: ctx => `${I18N.yearLabel} ${ctx[0].label}`,
              label: ctx => `${ctx.dataset.label}: ${ctx.parsed.y.toFixed(0)}`,
              afterBody: ctx => {
                if (ctx.length < 2) return '';
                const ins = ctx.find(c => c.dataset.label.startsWith('Vstupy') || c.dataset.label.startsWith('Index vstup'))?.parsed.y;
                const outs = ctx.find(c => c.dataset.label.startsWith('Výstupy') || c.dataset.label.startsWith('Index výstup'))?.parsed.y;
                if (ins == null || outs == null) return '';
                const diff = outs - ins;
                const sign = diff >= 0 ? '+' : '';
                const txt = diff >= 0 ? 'farmář vydělává' : 'farmář ztrácí na marži';
                return `\nMarže: ${sign}${diff.toFixed(0)} bodů — ${txt}`;
              },
            },
          },
        },
        scales: {
          x: { grid: { display: false }, ticks: { font: { size: 12 } } },
          y: {
            beginAtZero: false,
            title: { display: true, text: I18N.scissorsAxis, font: { size: 12 } },
            grid: { color: 'rgba(10,10,12,.06)' },
            ticks: { callback: v => v },
          },
        },
      },
    });
  })();

  // ──────────── PRODUCTION BLOCK ────────────
  (function initProduction() {
    const I18N = JSON.parse(document.getElementById('statI18n')?.textContent || '{}');
    const NUM = I18N.numLocale || 'cs-CZ';
    const dataEl = document.getElementById('productionData');
    if (!dataEl) return;
    const { latestCrops, latestAreas } = JSON.parse(dataEl.textContent);

    const cropEl = document.getElementById('cropProductionChart');
    if (cropEl && latestCrops.length) {
      const sorted = [...latestCrops].sort((a, b) => b.tonnes - a.tonnes);
      new Chart(cropEl, {
        type: 'bar',
        data: {
          labels: sorted.map(c => c.crop),
          datasets: [{
            data: sorted.map(c => c.tonnes),
            backgroundColor: sorted.map((_, i) => COLORS[i % COLORS.length] + 'cc'),
            borderRadius: 6, barThickness: 26,
          }],
        },
        options: {
          indexAxis: 'y', responsive: true, maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            tooltip: { backgroundColor: INK, padding: 12, cornerRadius: 10,
              callbacks: { label: ctx => `${ctx.parsed.x.toLocaleString(NUM)} t` } },
          },
          scales: {
            x: { grid: { color: 'rgba(10,10,12,.06)' }, ticks: { callback: v => (v / 1e6).toFixed(1) + 'M t' } },
            y: { grid: { display: false }, ticks: { font: { size: 13 } } },
          },
        },
      });
    }

    const areaEl = document.getElementById('cropAreasChart');
    if (areaEl && latestAreas.length) {
      new Chart(areaEl, {
        type: 'doughnut',
        data: {
          labels: latestAreas.map(a => a.crop),
          datasets: [{
            data: latestAreas.map(a => a.hectares),
            backgroundColor: latestAreas.map((_, i) => COLORS[i % COLORS.length]),
            borderWidth: 0, hoverOffset: 8,
          }],
        },
        options: {
          responsive: true, maintainAspectRatio: false, cutout: '62%',
          plugins: {
            legend: { position: 'bottom', labels: { usePointStyle: true, padding: 12, font: { size: 12 } } },
            tooltip: { backgroundColor: INK, padding: 12, cornerRadius: 10,
              callbacks: { label: ctx => `${ctx.label}: ${ctx.parsed.toLocaleString(NUM)} ha` } },
          },
        },
      });
    }
  })();

  // ──────────── HEX MAP ────────────
  (function initHexMap() {
    const I18N = JSON.parse(document.getElementById('statI18n')?.textContent || '{}');
    const dataEl = document.getElementById('hexMapData');
    const svg = document.querySelector('.sp-hex-svg');
    if (!dataEl || !svg) return;
    const { data, defaultYear } = JSON.parse(dataEl.textContent);

    let currentCrop = 'Obiloviny na zrno';
    let currentYear = defaultYear;
    let selectedRegion = null;

    function getColor(t) {
      // light → dark green: rgb(227,243,234) → rgb(11,122,59)
      const r = Math.round(227 - t * 216);
      const g = Math.round(243 - t * 121);
      const b = Math.round(234 - t * 175);
      return `rgb(${r},${g},${b})`;
    }

    function colorMap() {
      const filtered = data.filter(d => d.crop === currentCrop && d.year === currentYear);
      const valByRegion = {};
      filtered.forEach(d => { valByRegion[d.region] = d.tonnes; });
      const vals = Object.values(valByRegion).filter(v => v > 0);
      const min = vals.length ? Math.min(...vals) : 0;
      const max = vals.length ? Math.max(...vals) : 1;
      const range = max - min || 1;

      svg.querySelectorAll('.hex-cell').forEach(cell => {
        const region = cell.dataset.region;
        const v = valByRegion[region] ?? 0;
        const t = v > 0 ? (v - min) / range : 0;
        const shape = cell.querySelector('.hex-shape');
        if (shape) shape.style.fill = v > 0 ? getColor(t) : '#F4F2E9';
        const valEl = cell.querySelector('.hex-value');
        if (valEl) valEl.textContent = v > 0 ? (v / 1000).toFixed(0) : '–';
        const bar = cell.querySelector('.hex-bar-fill');
        if (bar) bar.setAttribute('width', String(60 * t));
      });
    }

    function showDetail(region) {
      const panel = document.getElementById('hexDetail');
      if (!panel) return;
      const regionData = data.filter(d => d.region === region && d.year === currentYear);
      if (regionData.length === 0) {
        panel.innerHTML = `<div class="placeholder"><span class="placeholder-icon">⚠️</span><p>Pro ${region} nejsou data v ${currentYear}.</p></div>`;
        return;
      }
      const sorted = [...regionData].sort((a, b) => b.tonnes - a.tonnes);
      const total = sorted.reduce((s, d) => s + d.tonnes, 0);
      const rows = sorted.map(d => `
        <li class="d-row">
          <span class="d-crop">${d.crop}</span>
          <span class="d-bar"><span style="width:${(d.tonnes/total*100).toFixed(0)}%"></span></span>
          <span class="d-val">${(d.tonnes/1000).toFixed(0)} tis. t</span>
        </li>`).join('');
      panel.innerHTML = `
        <h3>${region}</h3>
        <p class="d-meta">${currentYear} · ${I18N.total} ${(total/1000).toFixed(0)} ${I18N.thousTons}</p>
        <ul class="d-list">${rows}</ul>
      `;
    }

    svg.querySelectorAll('.hex-cell').forEach(cell => {
      cell.addEventListener('click', () => {
        svg.querySelectorAll('.hex-cell').forEach(c => c.classList.remove('selected'));
        cell.classList.add('selected');
        selectedRegion = cell.dataset.region;
        showDetail(selectedRegion);
      });
      cell.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          cell.dispatchEvent(new MouseEvent('click', { bubbles: true }));
        }
      });
    });

    document.querySelectorAll('.sp-mini-pill[data-crop]').forEach(b => {
      b.addEventListener('click', () => {
        document.querySelectorAll('.sp-mini-pill[data-crop]').forEach(x => x.classList.remove('active'));
        b.classList.add('active');
        currentCrop = b.dataset.crop;
        colorMap();
        if (selectedRegion) showDetail(selectedRegion);
      });
    });
    document.querySelectorAll('.sp-year-btn').forEach(b => {
      b.addEventListener('click', () => {
        document.querySelectorAll('.sp-year-btn').forEach(x => x.classList.remove('active'));
        b.classList.add('active');
        currentYear = b.dataset.year;
        colorMap();
        if (selectedRegion) showDetail(selectedRegion);
      });
    });

    colorMap();
  })();

  // ──────────── LIVESTOCK SLOPE ────────────
  (function initLivestock() {
    const I18N = JSON.parse(document.getElementById('statI18n')?.textContent || '{}');
    const NUM = I18N.numLocale || 'cs-CZ';
    const dataEl = document.getElementById('livestockData');
    const el = document.getElementById('livestockSlopeChart');
    if (!dataEl || !el) return;
    const { livestock } = JSON.parse(dataEl.textContent);
    if (!livestock.length) return;

    const byAnimal = {};
    livestock.forEach(l => {
      if (!byAnimal[l.animal]) byAnimal[l.animal] = [];
      byAnimal[l.animal].push(l);
    });

    function dateToYear(d) {
      const m = d.match(/(\d{4})/);
      return m ? parseInt(m[1]) : 0;
    }

    Object.values(byAnimal).forEach(arr => arr.sort((a, b) => a.date.localeCompare(b.date)));
    const labels = [...new Set(livestock.map(l => l.date))].sort();

    const datasets = Object.entries(byAnimal).map(([animal, arr], i) => ({
      label: I18N.animals?.[animal] || animal,
      data: labels.map(d => {
        const found = arr.find(l => l.date === d);
        return found ? found.count : null;
      }),
      borderColor: animal === 'Skot' ? '#0B7A3B' : RED,
      backgroundColor: animal === 'Skot' ? 'rgba(11,122,59,.08)' : 'rgba(194,68,20,.08)',
      borderWidth: 2.5,
      pointRadius: 3,
      pointHoverRadius: 6,
      tension: 0.25,
      fill: false,
      spanGaps: true,
    }));

    new Chart(el, {
      type: 'line',
      data: { labels, datasets },
      options: {
        responsive: true, maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: { position: 'top', labels: { usePointStyle: true, padding: 14, font: { size: 12 } } },
          tooltip: { backgroundColor: INK, padding: 12, cornerRadius: 10,
            callbacks: { label: ctx => `${ctx.dataset.label}: ${ctx.parsed.y.toLocaleString(NUM)} ks` } },
        },
        scales: {
          x: { grid: { display: false }, ticks: { maxTicksLimit: 10, font: { size: 11 } } },
          y: { grid: { color: 'rgba(10,10,12,.06)' }, ticks: { callback: v => (v / 1e6).toFixed(1) + ' M' } },
        },
      },
    });
  })();
</script>
</Fragment>
)}

