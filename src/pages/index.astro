---
import Layout from '../layouts/Layout.astro';
import ImageAccordion from '../components/ImageAccordion.astro';
import Newsletter from '../components/Newsletter.astro';
import CommodityChart from '../components/statistiky/CommodityChart.astro';
import HomeWeather from '../components/HomeWeather.astro';
import LatestArticles from '../components/home/LatestArticles.astro';
import { createAnonClient } from '../lib/supabase';
import { COMMODITY_NAMES } from '../lib/commodity-names';
import { AGRO_SVET_SITE_ID as SITE_ID, SITE_URL } from '../lib/config';
import { imgSrcset } from '../lib/image-variants';
import { getLocaleFromUrl, localizeInternalHref } from '../i18n/utils';

const locale = Astro.locals.locale ?? getLocaleFromUrl(Astro.url);

// Edge cache: 5min s-maxage + 30min SWR. Většina requestů HIT na CF edge,
// nový článek se objeví do ~5min (akceptovatelný trade-off vs 0 Worker
// invocations). Po publikaci článku ručně `npm run purge` pokud potřeba okamžitě.
Astro.response.headers.set('cache-control', 'public, s-maxage=300, stale-while-revalidate=1800');

const supabase = createAnonClient();

const { data: articles } = await supabase
  .from('articles')
  .select('id, title, slug, perex, featured_image_url, focal_point, category, tags, published_at, featured')
  .eq('site_id', SITE_ID)
  .eq('status', 'published')
  .order('featured', { ascending: false })
  .order('published_at', { ascending: false })
  .limit(11);

const sorted = articles ?? [];

// Hero: first article as featured + next 4 (above-fold only). Articles 6-11
// rendrují deferred v <LatestArticles> islandu — vlastní supabase query.
const featured = sorted[0];
const heroRight = sorted.slice(1, 5);

// Commodity chart loads its data client-side from /statistiky/commodity-data-recent.json
// (eager, ~85 KB) and /statistiky/commodity-data.json (lazy on "Vše"). The homepage
// only needs the 9 commodity names for the button row — bundling the full 256 KB
// commodities.json into the Worker chunk would be pure waste.

const homeDescription = 'Zemědělská technika, encyklopedie traktorů a kombajnů, plemena hospodářských zvířat, bazar agro strojů zdarma a aktuální novinky ze světa zemědělství.';

// WebSite + Organization entita se teď emituje sitewide z Layout.astro
// (siteSchemaGraph) — homepage už ji neduplikuje.

// ItemList of the homepage article grid — helps Google Discover surface the hub
// and understand which articles are currently "above the fold" on the site.
// Pouze above-fold hero (featured + heroRight) — below-fold listy se rendrují
// jako server:defer islands a Google je čte přes individuální article URLs.
const homepageItems = [
  ...(featured ? [featured] : []),
  ...heroRight,
];
const itemListJsonLd = homepageItems.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'agro-svět.cz — aktuální články',
  numberOfItems: homepageItems.length,
  itemListElement: homepageItems.map((a, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${SITE_URL}/novinky/${a.slug}/`,
    name: a.title,
  })),
} : null;
---

<Layout
  title="agro-svět.cz — zemědělská technika, bazar a novinky"
  description={homeDescription}
  preloadHeroImage={featured?.featured_image_url ?? undefined}
  preloadHeroSizes="(max-width: 900px) 100vw, 800px"
  preloadHeroMaxWidth={800}
>
  {itemListJsonLd && <script type="application/ld+json" is:inline set:html={JSON.stringify(itemListJsonLd)} />}

  <h1 class="visually-hidden">agro-svět.cz — zemědělská technika, bazar a novinky</h1>

  <!-- Hero — featured articles grid matching WP layout -->
  <section class="hero-section">
    <div class="hero-grid">
      <!-- Left: large featured card spanning 2 rows -->
      {featured && (
        <div class="hero-card hero-main hero-wrap">
          <a href={`/novinky/${featured.slug}/`} class="hero-link">
            {featured.featured_image_url && (() => {
              const v = imgSrcset(featured.featured_image_url, '(max-width: 900px) 100vw, 800px', 800);
              return <img src={v.src} srcset={v.srcset} sizes={v.sizes} alt={featured.title} width="800" height="600" fetchpriority="high" decoding="async" style={`object-position: ${featured.focal_point?.x ?? 50}% ${featured.focal_point?.y ?? 50}%;`} />;
            })()}
            <div class="hero-overlay"></div>
            <div class="hero-card-content">
              <h2>{featured.title}</h2>
            </div>
          </a>
          <div class="hero-tags">
            <a href={localizeInternalHref(locale, '/novinky/')} class="hero-tag">Novinky</a>
            {featured.category && <a href={`/novinky/kategorie/${featured.category}/`} class="hero-tag">{featured.category}</a>}
          </div>
        </div>
      )}

      <!-- Right: 4 small cards in 2x2 grid -->
      {heroRight.map(article => (
        <div class="hero-card hero-small hero-wrap">
          <a href={`/novinky/${article.slug}/`} class="hero-link">
            {article.featured_image_url
              ? (() => {
                  const v = imgSrcset(article.featured_image_url, '(max-width: 900px) 50vw, 400px');
                  return <img src={v.src} srcset={v.srcset} sizes={v.sizes} alt={article.title} width="400" height="300" loading="lazy" decoding="async" />;
                })()
              : <div class="hero-placeholder"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#bbb" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg></div>
            }
            <div class="hero-overlay"></div>
            <div class="hero-card-content">
              <h3>{article.title}</h3>
            </div>
          </a>
          <a href={article.category ? `/novinky/kategorie/${article.category}/` : '/novinky/'} class="hero-tag">
            {article.category ?? 'Novinky'}
          </a>
        </div>
      ))}
    </div>
  </section>

  <!-- Accordion sekce -->
  <section style="padding:28px 0 0;">
    <ImageAccordion />
  </section>

  <!-- Latest novinky — server:defer odlité v islandu, vlastní supabase query -->
  <LatestArticles server:defer>
    <div slot="fallback" style="min-height:520px;"></div>
  </LatestArticles>
  <!-- (CommodityChart, HomeWeather, Newsletter undeferred — simulátor penalizoval island scripty více než vyhrávalo HTML shrink) -->

  <style is:inline>
    .link-cta {
      display:inline-flex; align-items:center; gap:8px;
      font:700 14px 'Chakra Petch',sans-serif; letter-spacing:.02em;
      color:#0A0A0B; text-decoration:none;
      background:#FFFF00;
      padding:10px 18px; border-radius:12px;
      border:1.5px solid #0A0A0B;
      transition:transform .15s, box-shadow .15s, background .15s;
      box-shadow:3px 3px 0 #0A0A0B;
      white-space:nowrap;
    }
    .link-cta:hover {
      transform:translate(-2px,-2px);
      box-shadow:5px 5px 0 #0A0A0B;
      background:#FFEA00;
    }
    .link-cta:active {
      transform:translate(0,0);
      box-shadow:0 0 0 #0A0A0B;
    }
  </style>

  <!-- Data: Zemědělská půda — Open-Meteo card s nadpisem (lazy, klient-side) -->
  <section style="max-width:1280px; margin:0 auto; padding:24px 32px;">
    <div style="display:flex; align-items:flex-end; justify-content:space-between; margin-bottom:28px; flex-wrap:wrap; gap:12px;">
      <div>
        <h2 style="font-size:clamp(1.6rem,3.5vw,2.2rem);">Data: Zemědělská půda</h2>
      </div>
      <a href={localizeInternalHref(locale, '/puda/')} class="link-cta">Zobrazit celou sekci →</a>
    </div>
    <HomeWeather mode="puda" />
  </section>

  <!-- Data — Trhy a komodity (pod Půdou) -->
  <section style="max-width:1280px; margin:0 auto; padding:24px 32px 48px;">
    <div style="display:flex; align-items:flex-end; justify-content:space-between; margin-bottom:28px; flex-wrap:wrap; gap:12px;">
      <div>
        <h2 style="font-size:clamp(1.6rem,3.5vw,2.2rem);">Data: Trhy a komodity</h2>
      </div>
      <a href={localizeInternalHref(locale, '/statistiky/')} class="link-cta">Zobrazit celou sekci →</a>
    </div>
    <CommodityChart commodityNames={COMMODITY_NAMES} />
  </section>

  {/* Fresh bazar listings dočasně skryto (2026-06-09) — bazar schován z webu
      do nasazení custom SMTP. Vrátit i import FreshBazarListings. */}

  <!-- Počasí pro pole — strip (lazy klient-side) -->
  <div style="padding:32px 32px 0;">
    <HomeWeather mode="strip" />
  </div>

  <!-- Newsletter signup (always last before footer) -->
  <Newsletter />

</Layout>

<style>
  /* ===== Hero grid — matches WP layout ===== */
  /*
   *  [  main (2 rows)  ] [ small ] [ small ]
   *  [                  ] [    bottom       ]
   */
  .hero-section {
    max-width: 1280px;
    margin: 0 auto;
    padding: 28px 32px 16px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 5fr 2fr 2fr;
    grid-template-rows: 1fr 1fr;
    gap: 14px;
    height: min(38vh, 340px);
  }

  /* Shared card base */
  .hero-card {
    position: relative;
    border-radius: 22px;
    overflow: hidden;
    background: #e8e8e8;
    box-shadow: 0 0 10px rgba(0, 0, 0, .12);
  }
  .hero-link {
    display: block;
    position: absolute;
    inset: 0;
    text-decoration: none;
    color: inherit;
    z-index: 0;
  }

  .hero-card img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1s cubic-bezier(.4, 0, .2, 1);
  }

  .hero-card:hover img {
    transform: scale(1.06);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,.6) 0%, rgba(0,0,0,.05) 55%, transparent 100%);
    transition: background .8s;
  }

  .hero-card:hover .hero-overlay {
    background: linear-gradient(to top, rgba(0,0,0,.75) 0%, rgba(0,0,0,.2) 55%, rgba(0,0,0,.08) 100%);
  }

  .hero-card-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 20px;
    z-index: 1;
  }

  .hero-tags {
    position: absolute;
    top: 20px;
    left: 20px;
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    z-index: 2;
  }

  .hero-tag {
    position: absolute;
    top: 20px;
    left: 20px;
    z-index: 2;
    display: inline-block;
    background: #FFFF00;
    color: #000;
    font-family: 'Chakra Petch', sans-serif;
    font-size: 9px;
    font-weight: 400;
    padding: 4px 10px;
    border-radius: 6px;
    text-transform: uppercase;
    text-decoration: none;
    transition: background .15s, color .15s;
  }
  .hero-tags .hero-tag {
    position: static;
  }
  .hero-tag:hover {
    background: #1a1a1a;
    color: #FFFF00;
  }

  .hero-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Large card — spans 2 rows, left column */
  .hero-main {
    grid-column: 1;
    grid-row: 1 / 3;
  }

  .hero-main .hero-card-content {
    padding: 28px;
  }

  .hero-card-content h2 {
    color: #fff;
    font-family: 'Chakra Petch', sans-serif;
    font-size: 17px;
    font-weight: 300;
    line-height: 1.35;
    margin: 0;
    text-shadow: 0 1px 6px rgba(0,0,0,.35);
  }

  /* Small cards */
  .hero-small .hero-card-content h3 {
    color: #fff;
    font-family: 'Chakra Petch', sans-serif;
    font-size: 14px;
    font-weight: 300;
    line-height: 1.35;
    margin: 0;
    text-shadow: 0 1px 4px rgba(0,0,0,.35);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .hero-small .hero-card-content {
    padding: 14px;
  }

  .hero-small .hero-tag {
    margin-bottom: 6px;
  }

  /* ===== Mobile ===== */
  @media (max-width: 768px) {
    .hero-section { padding: 20px 16px 0; }
    .hero-grid {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 220px auto;
      height: auto;
    }
    .hero-main { grid-column: 1 / 3; }
    .hero-small { height: 140px; }
  }

  @media (max-width: 480px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-main { grid-column: 1; height: 220px; }
    .hero-small { height: 130px; }
  }
</style>
