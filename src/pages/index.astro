---
import Layout from '../layouts/Layout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import ImageAccordion from '../components/ImageAccordion.astro';
import Newsletter from '../components/Newsletter.astro';
import CommodityChart from '../components/statistiky/CommodityChart.astro';
import AgroWeather from '../components/AgroWeather.astro';
import { createAnonClient } from '../lib/supabase';
import { getCommodityFullSeries, getCommodityPrices } from '../lib/czso';
import { fiveYearAverage } from '../lib/agro-derived';
import { AGRO_EVENTS } from '../data/agro-events';
import { AGRO_SVET_SITE_ID as SITE_ID } from '../lib/config';
import { organizationSchema } from '../lib/structured-data';

const supabase = createAnonClient();

const [{ data: articles }, commodityFull, commodityPrices] = await Promise.all([
  supabase
    .from('articles')
    .select('id, title, slug, perex, featured_image_url, focal_point, category, tags, published_at, featured')
    .eq('site_id', SITE_ID)
    .eq('status', 'published')
    .order('featured', { ascending: false })
    .order('published_at', { ascending: false })
    .limit(20),
  getCommodityFullSeries(),
  getCommodityPrices(),
]);

const sorted = articles ?? [];

// Hero: first article as featured + next 4
const featured = sorted[0];
const heroRight = sorted.slice(1, 5);
const latest = sorted.slice(5, 11);

// 5letý průměr per komodita pro CommodityChart (stejná logika jako /statistiky/)
const fiveYearAvgs: Record<string, { label: string; avg: number }[] | null> = {};
for (const s of commodityFull) {
  const points: { label: string; avg: number }[] = [];
  for (const d of s.data) {
    const original = commodityPrices.find(p => p.name === s.name && (() => {
      const SHORT2LONG: Record<string, string> = {
        'Led':'leden','Úno':'únor','Bře':'březen','Dub':'duben','Kvě':'květen','Čvn':'červen',
        'Čvc':'červenec','Srp':'srpen','Zář':'září','Říj':'říjen','Lis':'listopad','Pro':'prosinec'
      };
      const [shortM, year] = d.label.split(' ');
      return p.month.startsWith(SHORT2LONG[shortM] ?? '') && p.month.endsWith(year);
    })());
    if (original) {
      const avg = fiveYearAverage(commodityPrices.filter(p => p.name === s.name), original.month);
      if (avg !== null) points.push({ label: d.label, avg });
    }
  }
  fiveYearAvgs[s.name] = points.length > 0 ? points : null;
}

// Fresh bazar listings (latest 6; when topování lands, featured go first)
const { data: freshListings } = await supabase
  .from('bazar_listings')
  .select('id, title, price, location, category, brand, year_of_manufacture, power_hp, created_at, bazar_images(storage_path, position)')
  .eq('status', 'active')
  .order('created_at', { ascending: false })
  .limit(6);

function getListingImage(listing: any): string | null {
  const images = listing?.bazar_images;
  if (!images || images.length === 0) return null;
  const first = [...images].sort((a: any, b: any) => a.position - b.position)[0];
  const { data } = supabase.storage.from('bazar-images').getPublicUrl(first.storage_path);
  return data.publicUrl;
}

import { CATEGORIES as BAZAR_CATEGORIES } from '../lib/bazar-constants';
const bazarCatLabels = Object.fromEntries(BAZAR_CATEGORIES.map((c) => [c.value, c.label]));

const homeDescription = 'Zemědělská technika, encyklopedie traktorů a kombajnů, plemena hospodářských zvířat, bazar agro strojů zdarma a aktuální novinky ze světa zemědělství.';

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'agro-svět.cz',
  alternateName: 'agro-svet.cz',
  url: 'https://agro-svet.cz/',
  inLanguage: 'cs-CZ',
  description: homeDescription,
  publisher: {
    '@type': 'Organization',
    name: 'agro-svět.cz',
    url: 'https://agro-svet.cz/',
  },
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: 'https://agro-svet.cz/hledat/?q={search_term_string}',
    },
    'query-input': 'required name=search_term_string',
  },
};
---

<Layout
  title="agro-svět.cz — zemědělská technika, bazar a novinky"
  description={homeDescription}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(websiteJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(organizationSchema())} />

  <h1 class="visually-hidden">agro-svět.cz — zemědělská technika, bazar a novinky</h1>

  <!-- Hero — featured articles grid matching WP layout -->
  <section class="hero-section">
    <div class="hero-grid">
      <!-- Left: large featured card spanning 2 rows -->
      {featured && (
        <div class="hero-card hero-main hero-wrap">
          <a href={`/novinky/${featured.slug}/`} class="hero-link">
            {featured.featured_image_url && <img src={featured.featured_image_url} alt={featured.title} width="800" height="600" fetchpriority="high" decoding="async" style={`object-position: ${featured.focal_point?.x ?? 50}% ${featured.focal_point?.y ?? 50}%;`} />}
            <div class="hero-overlay"></div>
            <div class="hero-card-content">
              <h2>{featured.title}</h2>
            </div>
          </a>
          <div class="hero-tags">
            <a href="/novinky/" class="hero-tag">Novinky</a>
            {featured.category && <a href={`/novinky/kategorie/${featured.category}/`} class="hero-tag">{featured.category}</a>}
          </div>
        </div>
      )}

      <!-- Right: 4 small cards in 2x2 grid -->
      {heroRight.map(article => (
        <div class="hero-card hero-small hero-wrap">
          <a href={`/novinky/${article.slug}/`} class="hero-link">
            {article.featured_image_url
              ? <img src={article.featured_image_url} alt={article.title} width="400" height="300" loading="lazy" decoding="async" />
              : <div class="hero-placeholder"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#bbb" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg></div>
            }
            <div class="hero-overlay"></div>
            <div class="hero-card-content">
              <h3>{article.title}</h3>
            </div>
          </a>
          <a href={article.category ? `/novinky/kategorie/${article.category}/` : '/novinky/'} class="hero-tag">
            {article.category ?? 'Novinky'}
          </a>
        </div>
      ))}
    </div>
  </section>

  <!-- Accordion sekce -->
  <section style="padding:28px 0 0;">
    <ImageAccordion />
  </section>

  <!-- Latest novinky -->
  <section style="max-width:1280px; margin:0 auto; padding:72px 32px 48px;">
    <div style="display:flex; align-items:flex-end; justify-content:space-between; margin-bottom:28px; flex-wrap:wrap; gap:12px;">
      <div>
        <h2 style="font-size:clamp(1.6rem,3.5vw,2.2rem);">Novinky</h2>
      </div>
      <a href="/novinky/" class="link-cta">Všechny novinky →</a>
    </div>
    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:20px;">
      {latest.map(article => (
        <ArticleCard
          title={article.title}
          description={article.perex}
          slug={article.slug}
          publishDate={new Date(article.published_at)}
          category={article.category}
          heroImage={article.featured_image_url}
        />
      ))}
    </div>
  </section>

  <!-- Data: Zemědělská půda — Open-Meteo card s nadpisem -->
  <section style="max-width:1280px; margin:0 auto; padding:24px 32px;">
    <div style="display:flex; align-items:flex-end; justify-content:space-between; margin-bottom:28px; flex-wrap:wrap; gap:12px;">
      <div>
        <h2 style="font-size:clamp(1.6rem,3.5vw,2.2rem);">Data: Zemědělská půda</h2>
      </div>
      <a href="/puda/" class="link-cta">Zobrazit celou sekci →</a>
    </div>
    <AgroWeather mode="puda" />
  </section>

  <style is:inline>
    .link-cta {
      display:inline-flex; align-items:center; gap:8px;
      font:700 14px 'Chakra Petch',sans-serif; letter-spacing:.02em;
      color:#0A0A0B; text-decoration:none;
      background:#FFFF00;
      padding:10px 18px; border-radius:12px;
      border:1.5px solid #0A0A0B;
      transition:transform .15s, box-shadow .15s, background .15s;
      box-shadow:3px 3px 0 #0A0A0B;
      white-space:nowrap;
    }
    .link-cta:hover {
      transform:translate(-2px,-2px);
      box-shadow:5px 5px 0 #0A0A0B;
      background:#FFEA00;
    }
    .link-cta:active {
      transform:translate(0,0);
      box-shadow:0 0 0 #0A0A0B;
    }
  </style>

  <!-- Data — Trhy a komodity (pod Půdou) -->
  <section style="max-width:1280px; margin:0 auto; padding:24px 32px 48px;">
    <div style="display:flex; align-items:flex-end; justify-content:space-between; margin-bottom:28px; flex-wrap:wrap; gap:12px;">
      <div>
        <h2 style="font-size:clamp(1.6rem,3.5vw,2.2rem);">Data: Trhy a komodity</h2>
      </div>
      <a href="/statistiky/" class="link-cta">Zobrazit celou sekci →</a>
    </div>
    <CommodityChart
      series={commodityFull}
      events={AGRO_EVENTS}
      fiveYearAvg={fiveYearAvgs}
    />
  </section>

  <!-- Fresh bazar listings -->
  {freshListings && freshListings.length > 0 && (
    <section style="background:#fafafa; padding:56px 0;">
      <div style="max-width:1280px; margin:0 auto; padding:0 32px;">
        <div style="display:flex; align-items:flex-end; justify-content:space-between; margin-bottom:24px; flex-wrap:wrap; gap:12px;">
          <div>
            <span class="section-label">Agro bazar</span>
            <h2 style="font-size:clamp(1.6rem,3.5vw,2.2rem); margin-top:10px;">Čerstvé v bazaru</h2>
          </div>
          <a href="/bazar/" class="link-cta">Všechny inzeráty →</a>
        </div>
        <div class="fresh-grid">
          {freshListings.map((l: any) => {
            const img = getListingImage(l);
            const priceText = l.price ? `${l.price.toLocaleString('cs-CZ')} Kč` : 'Dohodou';
            const catLabel = bazarCatLabels[l.category] ?? l.category;
            return (
              <a href={`/bazar/${l.id}/`} class="fresh-card">
                <div class="fresh-img">
                  {img
                    ? <img src={img} alt={l.title} loading="lazy" width="320" height="240" />
                    : <div class="fresh-placeholder">
                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5">
                          <rect x="3" y="3" width="18" height="18" rx="2"/>
                          <circle cx="8.5" cy="8.5" r="1.5"/>
                          <path d="m21 15-5-5L5 21"/>
                        </svg>
                      </div>
                  }
                  <span class="fresh-badge">{catLabel}</span>
                </div>
                <div class="fresh-body">
                  <h3>{l.title}</h3>
                  <div class="fresh-meta">
                    {l.year_of_manufacture && <span>{l.year_of_manufacture}</span>}
                    {l.power_hp && (
                      <span style="display:inline-flex; align-items:center; gap:4px;">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                        {l.power_hp} k
                      </span>
                    )}
                  </div>
                  <div class="fresh-bottom">
                    <span class="fresh-price">{priceText}</span>
                    <span class="fresh-location">{l.location}</span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
        <div style="margin-top:20px; text-align:center;">
          <a href="/bazar/novy/" class="btn-primary">+ Přidat inzerát</a>
        </div>
      </div>
    </section>
  )}

  <!-- Počasí pro pole — strip (pod bazar) -->
  <div style="padding:32px 32px 0;">
    <AgroWeather mode="strip" />
  </div>

  <!-- Newsletter signup (always last before footer) -->
  <Newsletter />

</Layout>

<style>
  /* ===== Hero grid — matches WP layout ===== */
  /*
   *  [  main (2 rows)  ] [ small ] [ small ]
   *  [                  ] [    bottom       ]
   */
  .hero-section {
    max-width: 1280px;
    margin: 0 auto;
    padding: 28px 32px 16px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 5fr 2fr 2fr;
    grid-template-rows: 1fr 1fr;
    gap: 14px;
    height: min(38vh, 340px);
  }

  /* Shared card base */
  .hero-card {
    position: relative;
    border-radius: 22px;
    overflow: hidden;
    background: #e8e8e8;
    box-shadow: 0 0 10px rgba(0, 0, 0, .12);
  }
  .hero-link {
    display: block;
    position: absolute;
    inset: 0;
    text-decoration: none;
    color: inherit;
    z-index: 0;
  }

  .hero-card img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1s cubic-bezier(.4, 0, .2, 1);
  }

  .hero-card:hover img {
    transform: scale(1.06);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,.6) 0%, rgba(0,0,0,.05) 55%, transparent 100%);
    transition: background .8s;
  }

  .hero-card:hover .hero-overlay {
    background: linear-gradient(to top, rgba(0,0,0,.75) 0%, rgba(0,0,0,.2) 55%, rgba(0,0,0,.08) 100%);
  }

  .hero-card-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 20px;
    z-index: 1;
  }

  .hero-tags {
    position: absolute;
    top: 20px;
    left: 20px;
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    z-index: 2;
  }

  .hero-tag {
    position: absolute;
    top: 20px;
    left: 20px;
    z-index: 2;
    display: inline-block;
    background: #FFFF00;
    color: #000;
    font-family: 'Chakra Petch', sans-serif;
    font-size: 9px;
    font-weight: 400;
    padding: 4px 10px;
    border-radius: 6px;
    text-transform: uppercase;
    text-decoration: none;
    transition: background .15s, color .15s;
  }
  .hero-tags .hero-tag {
    position: static;
  }
  .hero-tag:hover {
    background: #1a1a1a;
    color: #FFFF00;
  }

  /* Fresh listings grid */
  .fresh-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 14px;
  }
  .fresh-card {
    display: block;
    text-decoration: none;
    color: inherit;
    background: #fff;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid transparent;
    box-shadow: 0 0 10px rgba(0,0,0,.06);
    transition: border-color .15s, transform .15s, box-shadow .15s;
  }
  .fresh-card:hover {
    border-color: #FFFF00;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,0,0,.08);
  }
  .fresh-img {
    position: relative;
    width: 100%;
    height: 140px;
    background: #f5f5f5;
    overflow: hidden;
  }
  .fresh-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .fresh-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .fresh-badge {
    position: absolute;
    top: 8px;
    left: 8px;
    background: #FFFF00;
    color: #000;
    font-family: 'Chakra Petch', sans-serif;
    font-size: 10px;
    font-weight: 400;
    padding: 3px 8px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: .04em;
  }
  .fresh-body {
    padding: 12px 14px 14px;
  }
  .fresh-body h3 {
    font-family: 'Chakra Petch', sans-serif;
    font-size: 15px;
    font-weight: 700;
    line-height: 1.3;
    color: #1a1a1a;
    margin-bottom: 6px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 40px;
  }
  .fresh-meta {
    display: flex;
    gap: 10px;
    font-size: 12px;
    color: #666;
    margin-bottom: 8px;
  }
  .fresh-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 8px;
    border-top: 1px solid #f0f0f0;
  }
  .fresh-price {
    font-family: 'Chakra Petch', sans-serif;
    font-weight: 700;
    font-size: 15px;
    color: #1a1a1a;
  }
  .fresh-location {
    font-size: 11px;
    color: #767676;
    text-align: right;
  }

  .hero-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Large card — spans 2 rows, left column */
  .hero-main {
    grid-column: 1;
    grid-row: 1 / 3;
  }

  .hero-main .hero-card-content {
    padding: 28px;
  }

  .hero-card-content h2 {
    color: #fff;
    font-family: 'Chakra Petch', sans-serif;
    font-size: 17px;
    font-weight: 300;
    line-height: 1.35;
    margin: 0;
    text-shadow: 0 1px 6px rgba(0,0,0,.35);
  }

  /* Small cards */
  .hero-small .hero-card-content h3 {
    color: #fff;
    font-family: 'Chakra Petch', sans-serif;
    font-size: 14px;
    font-weight: 300;
    line-height: 1.35;
    margin: 0;
    text-shadow: 0 1px 4px rgba(0,0,0,.35);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .hero-small .hero-card-content {
    padding: 14px;
  }

  .hero-small .hero-tag {
    margin-bottom: 6px;
  }

  /* ===== Mobile ===== */
  @media (max-width: 768px) {
    .hero-section { padding: 20px 16px 0; }
    .hero-grid {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 220px auto;
      height: auto;
    }
    .hero-main { grid-column: 1 / 3; }
    .hero-small { height: 140px; }
  }

  @media (max-width: 480px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-main { grid-column: 1; height: 220px; }
    .hero-small { height: 130px; }
  }
</style>
