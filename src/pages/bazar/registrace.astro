---
import Layout from '../../layouts/Layout.astro';
import { getPublicSupabaseConfig } from '../../lib/supabase';

let error = '';
let success = '';
const { url: supabaseUrl, anonKey: supabaseKey } = getPublicSupabaseConfig();

// E-mailová registrace je DOČASNĚ VYPNUTÁ (2026-06-09): vestavěné Supabase SMTP
// má vyčerpaný rate limit → potvrzovací e-maily neodcházejí ("email rate limit
// exceeded" / "Database error saving new user"). Registrace přes Google funguje
// (OAuth žádný e-mail neposílá). Server guard pro případ přímého POST.
// VRÁTIT po nasazení custom SMTP (Resend): obnovit signUp logiku + e-mailový
// formulář níže + importy createAnonClient/createServerClient/LocationInput/SITE_URL.
if (Astro.request.method === 'POST') {
  error = 'Registrace přes e-mail je dočasně nedostupná. Použijte prosím „Registrace přes Google".';
}
---

<Layout title="Registrace — Agro bazar">
  <div style="max-width:500px; margin:0 auto; padding:64px 24px 96px;">
    <span class="section-label">Agro bazar</span>
    <h1 style="font-size:clamp(1.8rem,4vw,2.5rem); margin-bottom:32px;">Registrace</h1>

    {error && <div class="form-error">{error}</div>}
    {success && <div class="form-success">{success}</div>}

    {!success && (
      <>
      <button type="button" id="google-btn" class="btn-google">
        <svg width="18" height="18" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
        Registrace přes Google
      </button>
      <p style="text-align:center; color:#666; font-size:14px; margin-top:20px; line-height:1.6;">
        Registrace přes e-mail je dočasně nedostupná.<br />
        Zaregistruj se prosím tlačítkem <strong>Registrace přes Google</strong> výše.
      </p>
      </>
    )}

    <p style="text-align:center; margin-top:24px; font-size:14px; color:#666;">
      Už máte účet? <a href="/bazar/prihlaseni/" class="link-underline">Přihlásit se</a>
    </p>
  </div>

  <style>
    .btn-google {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      width: 100%;
      height: 46px;
      padding: 0 16px;
      background: #fff;
      border: 1px solid #d9d9d9;
      border-radius: 10px;
      font-family: inherit;
      font-size: 15px;
      font-weight: 500;
      color: #1a1a1a;
      cursor: pointer;
      transition: background .15s, border-color .15s;
      margin-bottom: 20px;
    }
    .btn-google:hover { background: #f9f9f9; border-color: #666; }
    .divider { display: flex; align-items: center; gap: 12px; color: #767676; font-size: 12px; text-transform: uppercase; letter-spacing: .1em; margin: 0 0 20px; white-space: nowrap; }
    .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: #e4e4e4; }
    .field-hint { font-size: 12px; color: #666; margin: 6px 0 0; line-height: 1.5; }
    .field-hint a { color: #0B7A3B; text-decoration: underline; }
    .consent-group { margin-top: 8px; }
    .consent-label { display: flex; align-items: flex-start; gap: 10px; font-size: 13px; line-height: 1.5; color: #333; cursor: pointer; }
    .consent-label input[type="checkbox"] { margin-top: 3px; flex-shrink: 0; width: 16px; height: 16px; cursor: pointer; }
    .consent-label a { color: #0B7A3B; text-decoration: underline; }
  </style>

  <script type="module" define:vars={{ supabaseUrl, supabaseKey }}>
    const { createClient } = await import('https://esm.sh/@supabase/supabase-js@2.48.1');
    const supabase = createClient(supabaseUrl, supabaseKey, {
      auth: { flowType: 'pkce', persistSession: true, detectSessionInUrl: true },
    });
    document.getElementById('google-btn')?.addEventListener('click', async () => {
      await supabase.auth.signInWithOAuth({
        provider: 'google',
        options: { redirectTo: `${location.origin}/bazar/auth/callback/` },
      });
    });
  </script>
</Layout>
