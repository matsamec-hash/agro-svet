---
import Layout from '../../layouts/Layout.astro';
import BazarSidebar from '../../components/bazar/BazarSidebar.astro';
import BazarListingRow from '../../components/bazar/BazarListingRow.astro';
import BazarPagination from '../../components/bazar/BazarPagination.astro';
import BazarFeaturedGrid from '../../components/bazar/BazarFeaturedGrid.astro';
import { CATEGORIES } from '../../lib/bazar-constants';
import { createServerClient } from '../../lib/supabase';
import { isFeaturedActive } from '../../lib/bazar-featured';
import { getModelBySlug } from '../../lib/stroje';
import { SITE_URL } from '../../lib/config';
import { breadcrumbSchema } from '../../lib/structured-data';

const PER_PAGE = 20;

const url = Astro.url;
const query = url.searchParams.get('q') ?? '';
const category = url.searchParams.get('category') ?? '';
const subcategory = url.searchParams.get('subcategory') ?? '';
const brand = url.searchParams.get('brand') ?? '';
const location = url.searchParams.get('location') ?? '';
const priceFrom = url.searchParams.get('price_from') ?? '';
const priceTo = url.searchParams.get('price_to') ?? '';
const yearFrom = url.searchParams.get('year_from') ?? '';
const yearTo = url.searchParams.get('year_to') ?? '';
const powerFrom = url.searchParams.get('power_from') ?? '';
const powerTo = url.searchParams.get('power_to') ?? '';
const zaberFrom = url.searchParams.get('zaber_from') ?? '';
const zaberTo = url.searchParams.get('zaber_to') ?? '';
const nosnostFrom = url.searchParams.get('nosnost_from') ?? '';
const nosnostTo = url.searchParams.get('nosnost_to') ?? '';
const objemFrom = url.searchParams.get('objem_from') ?? '';
const objemTo = url.searchParams.get('objem_to') ?? '';
const modelSlug = url.searchParams.get('model') ?? '';
const page = Math.max(1, parseInt(url.searchParams.get('page') ?? '1'));

const supabase = createServerClient();

// Build query
let dbQuery = supabase
  .from('bazar_listings')
  .select('id, title, price, location, category, subcategory, brand, created_at, views, model_slug, year_of_manufacture, power_hp, hours_operated, featured, featured_until, pracovni_zaber_m, nosnost_kg, objem_nadrze_l, bazar_images(storage_path, position)', { count: 'exact' })
  .eq('status', 'active')
  .order('featured', { ascending: false })
  .order('created_at', { ascending: false })
  .range((page - 1) * PER_PAGE, page * PER_PAGE - 1);

if (query) dbQuery = dbQuery.ilike('title', `%${query}%`);
if (category) dbQuery = dbQuery.eq('category', category);
if (subcategory) dbQuery = dbQuery.eq('subcategory', subcategory);
if (brand) dbQuery = dbQuery.eq('brand', brand);
if (location) dbQuery = dbQuery.ilike('location', `%${location}%`);
if (priceFrom) dbQuery = dbQuery.gte('price', parseInt(priceFrom));
if (priceTo) dbQuery = dbQuery.lte('price', parseInt(priceTo));
if (yearFrom) dbQuery = dbQuery.gte('year_of_manufacture', parseInt(yearFrom));
if (yearTo) dbQuery = dbQuery.lte('year_of_manufacture', parseInt(yearTo));
if (powerFrom) dbQuery = dbQuery.gte('power_hp', parseInt(powerFrom));
if (powerTo) dbQuery = dbQuery.lte('power_hp', parseInt(powerTo));
if (zaberFrom) dbQuery = dbQuery.gte('pracovni_zaber_m', parseFloat(zaberFrom));
if (zaberTo) dbQuery = dbQuery.lte('pracovni_zaber_m', parseFloat(zaberTo));
if (nosnostFrom) dbQuery = dbQuery.gte('nosnost_kg', parseInt(nosnostFrom));
if (nosnostTo) dbQuery = dbQuery.lte('nosnost_kg', parseInt(nosnostTo));
if (objemFrom) dbQuery = dbQuery.gte('objem_nadrze_l', parseInt(objemFrom));
if (objemTo) dbQuery = dbQuery.lte('objem_nadrze_l', parseInt(objemTo));
if (modelSlug) {
  // Model matchujeme z katalogu (model_slug) NEBO podle názvu — seedované inzeráty
  // z Bazoše mají model jen v titulku (model_slug=null). Do PostgREST .or() jde
  // název jen když je „bezpečný" (bez čárek/závorek, které syntaxi .or rozbijí);
  // jinak spadneme na čistý model_slug match.
  const modelName = getModelBySlug(modelSlug)?.name ?? '';
  const safeName = modelName && !/[,().*]/.test(modelName) ? modelName : '';
  dbQuery = safeName
    ? dbQuery.or(`model_slug.eq.${modelSlug},title.ilike.*${safeName}*`)
    : dbQuery.eq('model_slug', modelSlug);
}

const { data: listings, count } = await dbQuery;

const totalPages = Math.ceil((count ?? 0) / PER_PAGE);

const hasFilters = Boolean(
  query || category || brand || location ||
  priceFrom || priceTo || yearFrom || yearTo ||
  powerFrom || powerTo || modelSlug
);
const isDefaultView = page === 1 && !hasFilters;

// Edge-cache the default unfiltered landing — it's what 80% of visitors hit.
// 60s s-maxage with 5min SWR keeps new listings near-realtime while collapsing
// the per-request Supabase fan-out into a handful of cache misses per minute.
// Filtered views get cookie/uncacheable response because every filter combo
// is a unique cache key and we'd just waste edge storage.
if (isDefaultView) {
  Astro.response.headers.set('Cache-Control', 'public, s-maxage=60, stale-while-revalidate=300');
} else {
  Astro.response.headers.set('Cache-Control', 'private, max-age=0, must-revalidate');
}

let featuredListings: any[] = [];
if (isDefaultView) {
  const nowIso = new Date().toISOString();
  const { data: featured } = await supabase
    .from('bazar_listings')
    .select('id, title, price, location, featured_until, bazar_images(storage_path, position)')
    .eq('status', 'active')
    .eq('featured', true)
    .gt('featured_until', nowIso)
    .order('featured_until', { ascending: false })
    .limit(4);
  featuredListings = featured ?? [];
}

const featuredIds = new Set(featuredListings.map((f: any) => f.id));
const displayedListings = isDefaultView
  ? (listings ?? []).filter((l: any) => !featuredIds.has(l.id))
  : (listings ?? []);

function getImageUrl(listing: any): string | null {
  const images = listing.bazar_images;
  if (!images || images.length === 0) return null;
  const sorted = [...images].sort((a: any, b: any) => a.position - b.position);
  const { data } = supabase.storage.from('bazar-images').getPublicUrl(sorted[0].storage_path);
  return data.publicUrl;
}

// JSON-LD: BreadcrumbList + ItemList of visible listings (first page only —
// avoid duplicate ItemList signals across paginated views).
const breadcrumbJsonLd = breadcrumbSchema([
  { name: 'Domů', url: '/' },
  { name: 'Agro bazar', url: '/bazar/' },
]);
const itemListJsonLd = page === 1 && displayedListings.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Aktuální inzeráty agro bazaru',
  numberOfItems: count ?? displayedListings.length,
  itemListElement: displayedListings.slice(0, 30).map((l: any, i: number) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${SITE_URL}/bazar/${l.id}/`,
    name: l.title,
  })),
} : null;
---

<Layout title={isDefaultView ? "Bazar zemědělské techniky — traktory, stroje, pozemky a zvířata" : "Agro bazar — inzeráty"} description="Inzerce zemědělských strojů, techniky, pozemků a zvířat. Inzeráty traktorů a kombajnů přímo od majitelů, bez provize. Vložte inzerát zdarma.">
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
  {itemListJsonLd && <script type="application/ld+json" is:inline set:html={JSON.stringify(itemListJsonLd)} />}
  <div style="max-width:1280px; margin:0 auto; padding:32px 32px 80px;">

    <div style="display:flex; align-items:flex-end; justify-content:space-between; margin-bottom:24px; flex-wrap:wrap; gap:12px;">
      <div>
        <span class="section-label">Agro bazar</span>
        <h1 style="font-size:clamp(1.8rem,4vw,2.5rem);">{isDefaultView ? 'Bazar zemědělské techniky' : 'Inzeráty'}</h1>
        {isDefaultView && (
          <p style="color:#666; font-size:14px; margin-top:4px; max-width:640px;">Inzerce zemědělských strojů, traktorů a kombajnů, ale i pozemků a zvířat — přímo od majitelů, bez provize.</p>
        )}
        {count !== null && count !== undefined && (
          <p style="color:#666; font-size:14px; margin-top:4px;">Nalezeno {count.toLocaleString('cs-CZ')} inzerátů</p>
        )}
      </div>
      <div style="display:flex; gap:8px; flex-wrap:wrap; align-items:center;">
        <a href="/bazar/mapa/" class="btn-secondary" style="display:inline-flex; align-items:center; gap:6px; padding:9px 14px; border:1.5px solid #DFDFE3; border-radius:8px; font-size:13px; font-weight:700; color:#0A0A0B; text-decoration:none; background:transparent;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 20l-5.447-2.724A1 1 0 0 1 3 16.382V5.618a1 1 0 0 1 1.447-.894L9 7l6-3 6 3-6 3"/><path d="M9 7v13"/><path d="M15 4v9"/></svg>
          Zobrazit na mapě
        </a>
        <a
          id="follow-filter-btn"
          href={`/bazar/sledovani/${Astro.url.search ? '?prefill=' + encodeURIComponent(Astro.url.search.slice(1)) : ''}`}
          class="btn-secondary"
          style="display:inline-flex; align-items:center; gap:6px; padding:9px 14px; border:1.5px solid #FFEA00; border-radius:8px; font-size:13px; font-weight:700; color:#0A0A0B; text-decoration:none; background:#fffef8;"
          data-active={Astro.url.search ? 'true' : 'false'}
        >
          🔔 {Astro.url.search ? 'Sledovat tento filtr' : 'Sledovat nové'}
        </a>
        <a href="/bazar/novy/" class="btn-primary">
          + Přidat inzerát
        </a>
      </div>
    </div>

    {isDefaultView && (
      <nav class="bazar-cat-nav" aria-label="Kategorie bazaru">
        {CATEGORIES.map((c) => (
          <a href={`/bazar/kategorie/${c.value}/`} class="bazar-cat-link">{c.label}</a>
        ))}
      </nav>
    )}

    <div class="bazar-grid">
      <BazarSidebar query={query} category={category} brand={brand} modelSlug={modelSlug} location={location} priceFrom={priceFrom} priceTo={priceTo} yearFrom={yearFrom} yearTo={yearTo} powerFrom={powerFrom} powerTo={powerTo} zaberFrom={zaberFrom} zaberTo={zaberTo} nosnostFrom={nosnostFrom} nosnostTo={nosnostTo} objemFrom={objemFrom} objemTo={objemTo} />

      <div class="bazar-main">
        {isDefaultView && featuredListings.length > 0 && (
          <BazarFeaturedGrid
            listings={featuredListings.map((f: any) => ({
              id: f.id,
              title: f.title,
              price: f.price,
              location: f.location,
              imageUrl: getImageUrl(f),
            }))}
          />
        )}

        {displayedListings && displayedListings.length > 0 ? (
          <div style="border:1px solid #e8e8e8; border-radius:14px; overflow:hidden; background:#fff;">
            {displayedListings.map((listing: any) => (
              <BazarListingRow
                id={listing.id}
                title={listing.title}
                price={listing.price}
                location={listing.location}
                category={listing.category}
                brand={listing.brand}
                imageUrl={getImageUrl(listing)}
                createdAt={listing.created_at}
                views={listing.views}
                featured={isFeaturedActive(listing)}
                pracovniZaberM={listing.pracovni_zaber_m}
                nosnostKg={listing.nosnost_kg}
                objemNadrzeL={listing.objem_nadrze_l}
              />
            ))}
          </div>
        ) : featuredListings.length === 0 && (
          <div style="text-align:center; padding:64px 0; color:#666; background:#fafafa; border-radius:14px;">
            <p style="font-size:18px;">Žádné inzeráty nenalezeny.</p>
            <p style="font-size:14px; margin-top:8px;">Zkuste změnit filtry nebo <a href="/bazar/novy/" class="link-underline">vložte první inzerát</a>.</p>
          </div>
        )}

        <BazarPagination currentPage={page} totalPages={totalPages} baseUrl={url.toString()} />
      </div>
    </div>
  </div>
</Layout>

<style>
  .bazar-cat-nav {
    display: flex; flex-wrap: wrap; gap: 8px;
    margin: 0 0 24px;
  }
  .bazar-cat-link {
    display: inline-block; padding: 7px 14px;
    background: #fafafa; border: 1px solid #eaeaec; border-radius: 999px;
    font-size: 13px; font-weight: 600; color: #0A0A0B; text-decoration: none;
    transition: border-color .15s, background .15s;
  }
  .bazar-cat-link:hover { border-color: #FFEA00; background: #fff; }

  .bazar-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 24px;
    align-items: start;
  }
  .bazar-main { min-width: 0; }
  @media (max-width: 900px) {
    .bazar-grid { grid-template-columns: 1fr; }
  }
</style>
