---
import Layout from '../../layouts/Layout.astro';
import BazarGallery from '../../components/bazar/BazarGallery.astro';
import { CATEGORIES, BRANDS } from '../../lib/bazar-constants';
import { createServerClient } from '../../lib/supabase';
import { resolveModelLabel } from '../../lib/bazar-catalog';
import { getAllPlemena } from '../../lib/plemena';

const { id } = Astro.params;
const supabase = createServerClient();

// Fetch listing with images and user
const { data: listing } = await supabase
  .from('bazar_listings')
  .select('*, bazar_images(storage_path, position), bazar_users(name)')
  .eq('id', id)
  .single();

if (!listing) {
  return Astro.redirect('/bazar/');
}

// Increment views (debounced — skip bots and recent visitors via cookie)
const cookieName = `bv_${id}`;
const userAgent = Astro.request.headers.get('user-agent') ?? '';
const isBot = /bot|crawler|spider|crawl|google|bing|yandex|duckduck|baidu|slurp|facebook/i.test(userAgent);
const recentlyViewed = Astro.cookies.has(cookieName);

if (!isBot && !recentlyViewed) {
  await supabase
    .from('bazar_listings')
    .update({ views: (listing.views ?? 0) + 1 })
    .eq('id', id);
  Astro.cookies.set(cookieName, '1', {
    maxAge: 60 * 30,
    httpOnly: true,
    sameSite: 'lax',
    path: '/',
  });
}

// Resolve image URLs
const images = (listing.bazar_images ?? []).map((img: any) => {
  const { data } = supabase.storage.from('bazar-images').getPublicUrl(img.storage_path);
  return { url: data.publicUrl, position: img.position };
});

const categoryLabel = CATEGORIES.find(c => c.value === listing.category)?.label ?? listing.category;
const brandLabel = BRANDS.find(b => b.value === listing.brand)?.label ?? listing.brand;
const date = new Intl.DateTimeFormat('cs-CZ', { day: 'numeric', month: 'long', year: 'numeric' }).format(new Date(listing.created_at));
const priceText = listing.price ? `${listing.price.toLocaleString('cs-CZ')} Kč` : 'Dohodou';
const sellerName = listing.bazar_users?.name ?? 'Neznámý';

// Resolve catalog link (model or plemeno)
const isMachine = listing.category === 'traktory' || listing.category === 'kombajny';
const isBreed = listing.category === 'zvirata';
let catalogLink: { label: string; url: string } | null = null;
if (listing.model_slug && !isBreed) {
  catalogLink = resolveModelLabel(listing.model_slug);
}
if (!catalogLink && isBreed && listing.model_slug) {
  const p = getAllPlemena().find((x) => x.slug === listing.model_slug);
  if (p) catalogLink = { label: p.name, url: `/plemena/${p.druh_slug}/${p.slug}/` };
}

// Machine-specific specs
const specItems: { label: string; value: string }[] = [];
if (listing.year_of_manufacture) specItems.push({ label: 'Rok výroby', value: `${listing.year_of_manufacture}` });
if (listing.power_hp) specItems.push({ label: 'Výkon', value: `${listing.power_hp} k` });
if (listing.hours_operated !== null && listing.hours_operated !== undefined) specItems.push({ label: 'Motohodiny', value: listing.hours_operated.toLocaleString('cs-CZ') });
if (listing.cutting_width_m) specItems.push({ label: 'Záběr', value: `${listing.cutting_width_m} m` });
if (listing.pracovni_zaber_m) specItems.push({ label: 'Pracovní záběr', value: `${listing.pracovni_zaber_m} m` });
if (listing.nosnost_kg) specItems.push({ label: 'Nosnost', value: `${listing.nosnost_kg.toLocaleString('cs-CZ')} kg` });
if (listing.objem_nadrze_l) specItems.push({ label: 'Objem nádrže', value: `${listing.objem_nadrze_l.toLocaleString('cs-CZ')} l` });
---

<Layout title={`${listing.title} — Agro bazar`}>
  <div style="max-width:1000px; margin:0 auto; padding:32px 24px 80px;">

    <!-- Breadcrumb -->
    <nav style="font-size:13px; color:#666; margin-bottom:20px;">
      <a href="/bazar/" style="color:#666; text-decoration:none;">Bazar</a>
      <span> &rarr; </span>
      <a href={`/bazar/?category=${listing.category}`} style="color:#666; text-decoration:none;">{categoryLabel}</a>
      <span> &rarr; </span>
      <span style="color:#555;">{listing.title}</span>
    </nav>

    <!-- Gallery -->
    <BazarGallery images={images} />

    <!-- Content -->
    <div class="detail-grid">
      <div class="detail-main">
        <h1 style="font-size:clamp(1.5rem,3vw,2rem); margin-bottom:12px;">{listing.title}</h1>

        <div style="display:flex; gap:10px; flex-wrap:wrap; margin-bottom:24px;">
          <span class="tag">{categoryLabel}</span>
          {brandLabel && <span class="tag">{brandLabel}</span>}
        </div>

        {specItems.length > 0 && (
          <div class="spec-strip">
            {specItems.map((s) => (
              <div class="spec-cell">
                <div class="spec-cell-label">{s.label}</div>
                <div class="spec-cell-value">{s.value}</div>
              </div>
            ))}
          </div>
        )}

        {catalogLink && (
          <a href={catalogLink.url} class="catalog-link-box">
            <div>
              <div style="font-size:11px; letter-spacing:1px; text-transform:uppercase; color:#666; margin-bottom:2px;">
                {isBreed ? 'Plemeno z katalogu' : 'Model z katalogu'}
              </div>
              <div style="font-family:'Chakra Petch',sans-serif; font-size:18px; font-weight:700; color:#1a1a1a;">
                {catalogLink.label}
              </div>
            </div>
            <span style="color:#1a1a1a; font-size:14px;">Detail →</span>
          </a>
        )}

        <div class="bazar-description">{listing.description}</div>
      </div>

      <aside class="detail-sidebar">
        <!-- Price -->
        <div class="sidebar-box">
          <div class="detail-price">{priceText}</div>
        </div>

        <!-- Contact (revealed on click — anti-spam) -->
        <div class="sidebar-box">
          <h3 style="font-size:14px; margin-bottom:12px;">Kontakt</h3>
          <p style="font-size:15px; margin-bottom:12px;"><strong>{sellerName}</strong></p>

          <button
            id="contact-reveal-btn"
            type="button"
            class="contact-reveal-btn"
            data-phone={listing.phone ? btoa(String(listing.phone)) : ''}
            data-email={listing.email ? btoa(unescape(encodeURIComponent(String(listing.email)))) : ''}
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            Zobrazit kontakt
          </button>

          <div id="contact-revealed" hidden style="margin-top:4px;">
            {listing.phone && (
              <p style="font-size:15px; margin-bottom:6px;">
                <a id="contact-phone-link" href="#" style="color:#1a1a1a; text-decoration:none;">
                  <strong>Tel:</strong> <span id="contact-phone-text"></span>
                </a>
              </p>
            )}
            {listing.email && (
              <p style="font-size:15px; word-break:break-all;">
                <a id="contact-email-link" href="#" style="color:#1a1a1a; text-decoration:none;">
                  <strong>Email:</strong> <span id="contact-email-text"></span>
                </a>
              </p>
            )}
          </div>
        </div>

        <!-- Info -->
        <div class="sidebar-box" style="font-size:13px; color:#666;">
          <p>Lokalita: {listing.location}</p>
          <p>Datum: {date}</p>
          <p>{listing.views ?? 0}x zobrazeno</p>
        </div>
      </aside>
    </div>
  </div>
</Layout>

<style>
  .detail-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 32px;
    align-items: start;
  }

  .sidebar-box {
    background: #fff;
    border: 1px solid #e8e8e8;
    border-radius: 18px;
    padding: 20px;
    margin-bottom: 12px;
  }

  .detail-price {
    font-family: 'Chakra Petch', sans-serif;
    font-size: 28px;
    font-weight: 700;
    color: #1a1a1a;
  }

  .spec-strip {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
    gap: 8px;
    margin-bottom: 24px;
    padding: 16px;
    background: #fafafa;
    border: 1px solid #e8e8e8;
    border-radius: 14px;
  }

  .spec-cell-label {
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #666;
    margin-bottom: 4px;
  }

  .spec-cell-value {
    font-family: 'Chakra Petch', sans-serif;
    font-size: 20px;
    font-weight: 700;
    color: #1a1a1a;
  }

  .bazar-description {
    font-size: 16px;
    line-height: 1.7;
    color: #333;
    white-space: pre-wrap;
    word-wrap: break-word;
    overflow-wrap: anywhere;
  }

  .contact-reveal-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    justify-content: center;
    padding: 12px 16px;
    background: #FFFF00;
    color: #1a1a1a;
    font-family: 'Chakra Petch', sans-serif;
    font-size: 14px;
    font-weight: 700;
    border: 0;
    border-radius: 10px;
    cursor: pointer;
    transition: background .15s, transform .1s;
  }
  .contact-reveal-btn:hover { background: #f0f000; }
  .contact-reveal-btn:active { transform: translateY(1px); }

  .catalog-link-box {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding: 16px 20px;
    background: #FFFF00;
    border-radius: 14px;
    text-decoration: none;
    color: inherit;
    margin-bottom: 24px;
    transition: transform .15s;
  }

  .catalog-link-box:hover {
    transform: translateY(-1px);
  }

  @media (max-width: 768px) {
    .detail-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const btn = document.getElementById('contact-reveal-btn') as HTMLButtonElement | null;
  const revealed = document.getElementById('contact-revealed');
  const phoneText = document.getElementById('contact-phone-text');
  const phoneLink = document.getElementById('contact-phone-link') as HTMLAnchorElement | null;
  const emailText = document.getElementById('contact-email-text');
  const emailLink = document.getElementById('contact-email-link') as HTMLAnchorElement | null;

  btn?.addEventListener('click', () => {
    const phoneB64 = btn.dataset.phone ?? '';
    const emailB64 = btn.dataset.email ?? '';
    if (phoneB64 && phoneText && phoneLink) {
      try {
        const phone = atob(phoneB64);
        phoneText.textContent = phone;
        phoneLink.href = `tel:${phone.replace(/\s+/g, '')}`;
      } catch {}
    }
    if (emailB64 && emailText && emailLink) {
      try {
        const email = decodeURIComponent(escape(atob(emailB64)));
        emailText.textContent = email;
        emailLink.href = `mailto:${email}`;
      } catch {}
    }
    if (revealed) revealed.hidden = false;
    btn.style.display = 'none';
  });
</script>
