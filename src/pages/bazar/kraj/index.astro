---
export const prerender = true;
import Layout from '../../../layouts/Layout.astro';
import { KRAJE } from '../../../lib/cap-dotace';
import { breadcrumbSchema, itemListSchema } from '../../../lib/structured-data';
import { SITE_URL } from '../../../lib/config';

const canonical = `${SITE_URL}/bazar/kraj/`;

const breadcrumbJsonLd = breadcrumbSchema([
  { name: 'Domů', url: '/' },
  { name: 'Bazar', url: '/bazar/' },
  { name: 'Podle kraje', url: canonical },
]);

const itemListJsonLd = itemListSchema(
  KRAJE.map((k) => ({ url: `${SITE_URL}/bazar/kraj/${k.slug}/`, name: k.name })),
  'Bazar zemědělské techniky podle kraje',
);
---

<Layout
  title="Bazar zemědělské techniky podle kraje"
  description="Inzeráty zemědělské techniky filtrované podle kraje ČR. 14 krajů, vždy aktuální nabídka traktorů, kombajnů, strojů a zvířat."
  canonical={canonical}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(itemListJsonLd)} />

  <div class="kraj-hub">
    <nav class="breadcrumb" aria-label="Cesta">
      <a href="/">Domů</a>
      <span aria-hidden="true">›</span>
      <a href="/bazar/">Bazar</a>
      <span aria-hidden="true">›</span>
      <span class="current">Podle kraje</span>
    </nav>

    <header class="hub-head">
      <span class="kicker">Lokální · 14 krajů</span>
      <h1>Bazar techniky podle kraje</h1>
      <p class="lede">
        Inzeráty filtrované podle kraje vašeho hospodářství. Kratší vzdálenost = nižší náklady na převoz, snazší prohlídka.
      </p>
    </header>

    <div class="grid">
      {KRAJE.map((k) => (
        <a href={`/bazar/kraj/${k.slug}/`} class="card">
          <h2>{k.name}</h2>
          <span class="cta">Inzeráty v kraji →</span>
        </a>
      ))}
    </div>

    <p class="foot">
      Nevidíte svůj kraj? Použijte <a href="/bazar/mapa/">mapu bazaru</a> nebo <a href="/bazar/">obecný listing</a>.
    </p>
  </div>
</Layout>

<style>
  .kraj-hub { max-width: 1080px; margin: 0 auto; padding: 32px 24px 80px; }
  .breadcrumb { display: flex; gap: 8px; align-items: center; font-size: 13px; color: #666; margin-bottom: 20px; flex-wrap: wrap; }
  .breadcrumb a { color: #666; text-decoration: none; }
  .breadcrumb a:hover { color: #000; }
  .breadcrumb .current { color: #000; font-weight: 600; }
  .hub-head { margin-bottom: 32px; max-width: 720px; }
  .kicker { display: inline-block; background: #FFEA00; color: #0A0A0B; font-size: 12px; font-weight: 700; padding: 4px 12px; border-radius: 4px; text-transform: uppercase; letter-spacing: 1px; }
  h1 { font-size: clamp(1.8rem, 4vw, 2.6rem); font-weight: 800; letter-spacing: -1px; line-height: 1.15; margin: 12px 0 8px; color: #1a1a1a; }
  .lede { font-size: 15px; color: #444; line-height: 1.6; margin: 0; }
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 12px; margin-bottom: 32px; }
  .card {
    display: block; padding: 18px 20px;
    background: #fff; border: 1.5px solid #eaeaec; border-radius: 12px;
    text-decoration: none; color: inherit;
    transition: border-color .15s, transform .15s, box-shadow .15s;
  }
  .card:hover { border-color: #FFEA00; transform: translateY(-2px); box-shadow: 0 6px 18px rgba(255, 234, 0, .15); }
  .card h2 { font-size: 16px; font-weight: 700; color: #0A0A0B; margin: 0 0 8px; line-height: 1.3; }
  .cta { font-size: 12px; font-weight: 700; color: #0B7A3B; }
  .foot { font-size: 14px; color: #666; text-align: center; }
  .foot a { color: #0B7A3B; text-decoration: underline; margin: 0 4px; }
</style>
