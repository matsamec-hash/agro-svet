---
import Layout from '../../layouts/Layout.astro';
import ImageUpload from '../../components/bazar/ImageUpload.astro';
import CascadingPicker from '../../components/bazar/CascadingPicker.astro';
import PhoneInput from '../../components/bazar/PhoneInput.astro';
import { CATEGORIES, BRANDS, BAZAR_TO_CATALOG_SUBCATEGORIES } from '../../lib/bazar-constants';
import LocationInput from '../../components/bazar/LocationInput.astro';
import { createServerClient, getPublicSupabaseConfig } from '../../lib/supabase';
import { getModelOptions, getPlemenoOptions } from '../../lib/bazar-catalog';
import { getModelBySlug } from '../../lib/stroje';

const user = Astro.locals.user!;
let error = '';

const modelOptions = getModelOptions();
const plemenoOptions = getPlemenoOptions();

const STROJE_CATEGORIES = Object.keys(BAZAR_TO_CATALOG_SUBCATEGORIES).filter(k => k !== 'traktory' && k !== 'kombajny');
const BRAND_VALUES = BRANDS.map(b => b.value).filter(v => v !== 'jina');

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const title = form.get('title')?.toString().trim() ?? '';
  const description = form.get('description')?.toString().trim() ?? '';
  const priceStr = form.get('price')?.toString().trim() ?? '';
  const category = form.get('category')?.toString() ?? '';
  const brand = form.get('brand')?.toString() || null;
  const location = form.get('location')?.toString().trim() ?? '';
  const postalCodeRaw = form.get('postal_code')?.toString().trim() ?? '';
  const postalCode = postalCodeRaw ? postalCodeRaw.replace(/\s+/g, '') : null;
  // Geocoded by client-side JS before submit. Hidden fields, fall back to server-side
  // geocode if missing (cheap local lookup; Nominatim only if there's a PSČ).
  const latStr = form.get('latitude')?.toString().trim() ?? '';
  const lngStr = form.get('longitude')?.toString().trim() ?? '';
  const phone = form.get('phone')?.toString().trim() ?? '';
  const email = form.get('email')?.toString().trim() ?? '';
  const imagePaths = JSON.parse(form.get('image_paths')?.toString() || '[]');

  // New catalog fields
  const modelSlug = form.get('model_slug')?.toString().trim() || null;
  const plemenoSlug = form.get('plemeno_slug')?.toString().trim() || null;
  const yearStr = form.get('year_of_manufacture')?.toString().trim() ?? '';
  const powerStr = form.get('power_hp')?.toString().trim() ?? '';
  const hoursStr = form.get('hours_operated')?.toString().trim() ?? '';
  const cutStr = form.get('cutting_width_m')?.toString().trim() ?? '';
  const zaberStr = form.get('pracovni_zaber_m')?.toString().trim() ?? '';
  const nosnostStr = form.get('nosnost_kg')?.toString().trim() ?? '';
  const objemStr = form.get('objem_nadrze_l')?.toString().trim() ?? '';

  const rulesAccepted = form.get('rules_accepted')?.toString() === 'on';

  if (!title || !category || !phone) {
    error = 'Vyplňte název, kategorii a telefon.';
  } else if (!rulesAccepted) {
    error = 'Pro vložení inzerátu je nutné potvrdit, že obsah neporušuje pravidla bazaru.';
  } else {
    const supabase = createServerClient();
    const price = priceStr ? parseInt(priceStr) : null;
    // model_slug is used for both machines and breeds (single text column in DB)
    const finalModelSlug = modelSlug || plemenoSlug || null;
    const year = yearStr ? parseInt(yearStr) : null;
    const power = powerStr ? parseInt(powerStr) : null;
    const hours = hoursStr ? parseInt(hoursStr) : null;
    const cuttingWidth = cutStr ? parseFloat(cutStr) : null;
    const pracovniZaber = zaberStr ? parseFloat(zaberStr) : null;
    // Migration 008 unified `cutting_width_m` (kombajny) and `pracovni_zaber_m` (stroje) into a single DB column.
    // The form shows one OR the other based on category, so take whichever is set.
    const zaberFinal = pracovniZaber ?? cuttingWidth;
    const nosnost = nosnostStr ? parseInt(nosnostStr) : null;
    const objemNadrze = objemStr ? parseInt(objemStr) : null;
    const subcategory = modelSlug ? (getModelBySlug(modelSlug)?.category ?? null) : null;

    // Resolve coords. Client should pre-fill hidden inputs from the local
    // lookup; if that fails (rare city not in CZ_LOCATIONS_GEO), do a
    // server-side fallback using PSČ if provided.
    let latitude: number | null = latStr ? parseFloat(latStr) : null;
    let longitude: number | null = lngStr ? parseFloat(lngStr) : null;
    if ((latitude === null || longitude === null) && (location || postalCode)) {
      try {
        const { geocode } = await import('../../lib/geocode');
        const geo = await geocode({ location, postalCode: postalCode ?? undefined });
        if (geo) { latitude = geo.lat; longitude = geo.lng; }
      } catch (e) {
        console.warn('[bazar/novy] geocode fallback failed', e);
      }
    }
    if (latitude !== null && (latitude < 48 || latitude > 52)) latitude = null;
    if (longitude !== null && (longitude < 11 || longitude > 19)) longitude = null;

    const { data: listing, error: insertErr } = await supabase
      .from('bazar_listings')
      .insert({
        user_id: user.id,
        title,
        description,
        price,
        category,
        brand,
        location,
        postal_code: postalCode,
        latitude,
        longitude,
        phone,
        email,
        status: 'active',
        model_slug: finalModelSlug,
        year_of_manufacture: year,
        power_hp: power,
        hours_operated: hours,
        pracovni_zaber_m: zaberFinal,
        nosnost_kg: nosnost,
        objem_nadrze_l: objemNadrze,
        subcategory,
      })
      .select('id')
      .single();

    if (insertErr) {
      console.error('[bazar/novy] insert error', insertErr);
      error = `Chyba při vkládání inzerátu: ${insertErr.message}`;
    } else if (listing) {
      if (imagePaths.length > 0) {
        const imageRows = imagePaths.map((path: string, idx: number) => ({
          listing_id: listing.id,
          storage_path: path,
          position: idx + 1,
        }));
        await supabase.from('bazar_images').insert(imageRows);
      }
      return Astro.redirect(`/bazar/${listing.id}/`);
    }
  }
}

// Pre-fill contact from profile
const supabase = createServerClient();
const { url: publicSupabaseUrl, anonKey: publicSupabaseKey } = getPublicSupabaseConfig();
const { data: profile } = await supabase
  .from('bazar_users')
  .select('phone, email, location')
  .eq('id', user.id)
  .single();
---

<Layout title="Nový inzerát — Agro bazar">
  <meta slot="head" name="supabase-url" content={publicSupabaseUrl} />
  <meta slot="head" name="supabase-key" content={publicSupabaseKey} />

  <div style="max-width:600px; margin:0 auto; padding:64px 24px 96px;">
    <span class="section-label">Agro bazar</span>
    <h1 style="font-size:clamp(1.8rem,4vw,2.5rem); margin-bottom:32px;">Nový inzerát</h1>

    {error && <div class="form-error">{error}</div>}

    <form method="POST">
      <div class="form-group">
        <label for="title">Název inzerátu *</label>
        <input type="text" id="title" name="title" class="form-input" required maxlength="120" />
      </div>

      <div class="form-group">
        <label for="category">Kategorie *</label>
        <select id="category" name="category" class="form-select" required>
          <option value="">Vyberte kategorii</option>
          {CATEGORIES.map(c => <option value={c.value}>{c.label}</option>)}
        </select>
      </div>

      <!-- Machine fields (shown for traktory / kombajny) -->
      <div id="machine-fields" style="display:none;">
        <CascadingPicker
          id="model-picker"
          name="model_slug"
          mode="stroje"
          label="Model z katalogu"
          options={modelOptions}
          category=""
        />

        <div class="form-group">
          <label for="year_of_manufacture">Rok výroby</label>
          <input type="number" id="year_of_manufacture" name="year_of_manufacture" class="form-input" min="1950" max="2030" placeholder="např. 2015" />
        </div>

        <div class="form-group">
          <label for="power_hp">Výkon (k)</label>
          <input type="number" id="power_hp" name="power_hp" class="form-input" min="0" placeholder="např. 120" />
        </div>

        <div class="form-group">
          <label for="hours_operated">Motohodiny</label>
          <input type="number" id="hours_operated" name="hours_operated" class="form-input" min="0" placeholder="např. 4500" />
        </div>

        <div class="form-group" id="cutting-width-group" style="display:none;">
          <label for="cutting_width_m">Záběr žacího stolu (m)</label>
          <input type="number" id="cutting_width_m" name="cutting_width_m" class="form-input" min="0" step="0.1" placeholder="např. 7.5" />
        </div>
      </div>

      <!-- Stroje spec fields (shown for non-traktor/kombajn machine categories) -->
      <div id="stroje-spec-fields" style="display:none;">
        <div class="form-group" data-categories="zpracovani-pudy,seti,ochrana-rostlin,sklizen-picnin">
          <label for="pracovni_zaber_m">Pracovní záběr (m)</label>
          <input type="number" id="pracovni_zaber_m" name="pracovni_zaber_m" class="form-input" step="0.1" min="0" max="50" placeholder="např. 4.5" />
        </div>

        <div class="form-group" data-categories="manipulace,doprava">
          <label for="nosnost_kg">Nosnost (kg)</label>
          <input type="number" id="nosnost_kg" name="nosnost_kg" class="form-input" step="100" min="0" placeholder="např. 3000" />
        </div>

        <div class="form-group" data-categories="hnojeni,ochrana-rostlin">
          <label for="objem_nadrze_l">Objem nádrže (l)</label>
          <input type="number" id="objem_nadrze_l" name="objem_nadrze_l" class="form-input" step="100" min="0" placeholder="např. 2000" />
        </div>
      </div>

      <!-- Breed fields (shown for zvirata) -->
      <div id="breed-fields" style="display:none;">
        <CascadingPicker
          id="breed-picker"
          name="plemeno_slug"
          mode="plemena"
          label="Plemeno z katalogu"
          options={plemenoOptions}
        />
      </div>

      <div class="form-group" id="brand-group">
        <label for="brand">Značka</label>
        <select id="brand" name="brand" class="form-select">
          <option value="">Bez značky</option>
          {BRANDS.map(b => <option value={b.value}>{b.label}</option>)}
        </select>
        <small id="brand-hint" style="display:none; font-size:12px; color:#666;"></small>
      </div>

      <div class="form-group">
        <label for="price">Cena (Kč) — prázdné = dohodou</label>
        <input type="number" id="price" name="price" class="form-input" min="0" />
      </div>

      <div class="form-group">
        <label for="description">Popis</label>
        <textarea id="description" name="description" class="form-input" rows="6" style="resize:vertical;"></textarea>
      </div>

      <div class="form-group">
        <label>Fotky (max 5)</label>
        <ImageUpload />
      </div>

      <div class="form-group">
        <label for="location">Lokalita *</label>
        <LocationInput id="location" name="location" value={profile?.location ?? ''} required />
        <small style="display:block; font-size:12px; color:#666; margin-top:6px;">
          Vyberte město nebo kraj — inzerát se zobrazí na <a href="/bazar/mapa/">mapě bazaru</a>.
        </small>
      </div>

      <div class="form-group">
        <label for="postal_code">PSČ <span style="color:#999; font-weight:400;">(volitelně)</span></label>
        <input type="text" id="postal_code" name="postal_code" class="form-input" maxlength="6" pattern="\d{3} ?\d{2}" placeholder="např. 387 11" inputmode="numeric" />
        <small style="display:block; font-size:12px; color:#666; margin-top:6px;">
          PSČ upřesní polohu pinu na mapě (jinak je v centru města).
        </small>
      </div>

      <!-- Hidden geocode outputs — vyplní klientský JS v <script> níže. -->
      <input type="hidden" name="latitude" id="latitude" />
      <input type="hidden" name="longitude" id="longitude" />

      <div class="form-group">
        <label for="phone">Telefon *</label>
        <PhoneInput id="phone" name="phone" value={profile?.phone ?? ''} required />
      </div>

      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" class="form-input" value={profile?.email ?? ''} />
      </div>

      <div class="form-group rules-notice">
        <p class="rules-notice-title">Před vložením inzerátu</p>
        <ul class="rules-notice-list">
          <li>Inzerujte <strong>konkrétní jednotlivou věc po kuse</strong>, ne sklady ani podnikatelskou činnost obecně.</li>
          <li>Jste-li <strong>podnikatel</strong> (OSVČ, firma, dealerství), uveďte v popisu inzerátu <strong>IČO</strong> a obchodní firmu.</li>
          <li>Vkládejte pouze <strong>vlastní fotografie</strong> nebo fotografie, ke kterým máte licenci.</li>
          <li>Některé kategorie (přípravky na ochranu rostlin, léčiva, zvířata, osiva, hnojiva, zbraně) mají <strong>zákonná omezení</strong> — viz <a href="/bazar/pravidla/" target="_blank" rel="noopener">pravidla bazaru</a>.</li>
        </ul>
      </div>

      <div class="form-group consent-group">
        <label class="consent-label">
          <input type="checkbox" id="rules_accepted" name="rules_accepted" required />
          <span>
            Prohlašuji, že obsah inzerátu je pravdivý, nabízená věc je v mém vlastnictví nebo
            mám oprávnění s ní disponovat, a že inzerát neporušuje
            <a href="/bazar/pravidla/" target="_blank" rel="noopener">pravidla bazaru</a>,
            <a href="/podminky-pouziti/" target="_blank" rel="noopener">podmínky použití</a>
            ani právní předpisy.
          </span>
        </label>
      </div>

      <button type="submit" class="btn-primary" style="width:100%; justify-content:center;">
        Vložit inzerát
      </button>
    </form>
  </div>

  <script is:inline define:vars={{ STROJE_CATEGORIES, BRAND_VALUES }}>
    (function() {
      const cat = document.getElementById('category');
      const machine = document.getElementById('machine-fields');
      const breed = document.getElementById('breed-fields');
      const cutting = document.getElementById('cutting-width-group');
      const strojeFields = document.getElementById('stroje-spec-fields');
      const modelPicker = document.querySelector('.cascading[data-picker-id="model-picker"]');
      const brandGroup = document.getElementById('brand-group');
      const brandSelect = document.getElementById('brand');
      const brandHint = document.getElementById('brand-hint');
      const powerInput = document.getElementById('power_hp');

      const BRANDS_SET = new Set(BRAND_VALUES);

      function sync() {
        const v = cat.value;
        const isMachine = v === 'traktory' || v === 'kombajny';
        const isBreed = v === 'zvirata';
        const isStroje = STROJE_CATEGORIES.includes(v);
        machine.style.display = isMachine ? 'block' : 'none';
        breed.style.display = isBreed ? 'block' : 'none';
        cutting.style.display = v === 'kombajny' ? 'block' : 'none';
        strojeFields.style.display = isStroje ? 'block' : 'none';
        strojeFields.querySelectorAll('.form-group[data-categories]').forEach((g) => {
          const cats = (g.getAttribute('data-categories') || '').split(',');
          g.style.display = cats.includes(v) ? '' : 'none';
        });

        // Legacy "Značka" dropdown is redundant when cascading picker
        // is present (traktory/kombajny) or irrelevant (zvířata).
        if (isMachine || isBreed) {
          brandGroup.style.display = 'none';
        } else {
          brandGroup.style.display = '';
          brandHint.style.display = 'none';
        }

        if (isMachine && modelPicker) {
          modelPicker.dispatchEvent(new CustomEvent('catalog-filter-change', {
            detail: { attr: 'category', val: v },
          }));
        }
      }

      cat.addEventListener('change', sync);
      sync();

      // Auto-fill from picked model
      document.addEventListener('catalog-picker-selected', (e) => {
        const opt = e.detail?.option;
        if (!opt) return;
        // Only machine picker carries brand_slug of an actual brand
        if (opt.brand_slug && BRANDS_SET.has(opt.brand_slug)) {
          brandSelect.value = opt.brand_slug;
          brandGroup.style.display = 'none';
          brandHint.style.display = 'block';
          brandHint.textContent = `Značka doplněna z katalogu: ${opt.brand_name}`;
        }
        if (opt.power_hp && powerInput && !powerInput.value) {
          powerInput.value = opt.power_hp;
        }
      });

      document.addEventListener('catalog-picker-cleared', () => {
        brandGroup.style.display = '';
        brandHint.style.display = 'none';
        brandSelect.value = '';
      });
    })();
  </script>

  <script>
    // Client-side geocoding for the map pin. Runs on (debounced) location +
    // PSČ change. Fills the hidden lat/lng inputs that the POST handler
    // persists. Fails silently — server fallback handles unmatched inputs.
    (function () {
      const locationInput = document.getElementById('location') as HTMLInputElement | null;
      const pscInput = document.getElementById('postal_code') as HTMLInputElement | null;
      const latInput = document.getElementById('latitude') as HTMLInputElement | null;
      const lngInput = document.getElementById('longitude') as HTMLInputElement | null;
      if (!locationInput || !latInput || !lngInput) return;

      let timer: ReturnType<typeof setTimeout> | null = null;
      let lastQuery = '';

      async function lookup(loc: string, psc: string) {
        const params = new URLSearchParams();
        if (loc) params.set('location', loc);
        if (psc) params.set('psc', psc.replace(/\s+/g, ''));
        const key = params.toString();
        if (!key || key === lastQuery) return;
        lastQuery = key;
        try {
          const r = await fetch(`/api/geocode/?${params}`);
          if (!r.ok) {
            latInput.value = '';
            lngInput.value = '';
            return;
          }
          const j = await r.json();
          if (typeof j.lat === 'number' && typeof j.lng === 'number') {
            latInput.value = String(j.lat);
            lngInput.value = String(j.lng);
          }
        } catch {
          // Network failure → leave empty, server-side will retry.
          latInput.value = '';
          lngInput.value = '';
        }
      }

      function schedule() {
        if (timer) clearTimeout(timer);
        const loc = locationInput.value.trim();
        const psc = pscInput?.value.trim() ?? '';
        timer = setTimeout(() => lookup(loc, psc), 400);
      }

      locationInput.addEventListener('change', schedule);
      locationInput.addEventListener('blur', schedule);
      pscInput?.addEventListener('change', schedule);
      pscInput?.addEventListener('blur', schedule);

      // Initial run if location was prefilled from the user profile.
      if (locationInput.value.trim()) schedule();
    })();
  </script>

  <style>
    .rules-notice {
      background: #fbfaf4;
      border: 1px solid #e8e4d2;
      border-radius: 8px;
      padding: 14px 18px;
      margin-top: 8px;
    }
    .rules-notice-title {
      font-family: 'Chakra Petch', sans-serif;
      font-weight: 600;
      font-size: 13px;
      letter-spacing: .04em;
      text-transform: uppercase;
      color: #555;
      margin: 0 0 8px;
    }
    .rules-notice-list {
      margin: 0;
      padding-left: 20px;
      font-size: 13px;
      line-height: 1.6;
      color: #444;
    }
    .rules-notice-list li { margin: 4px 0; }
    .rules-notice-list a { color: #0B7A3B; text-decoration: underline; }
    .consent-group { margin-top: 4px; }
    .consent-label {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: 13px;
      line-height: 1.55;
      color: #333;
      cursor: pointer;
    }
    .consent-label input[type="checkbox"] {
      margin-top: 3px;
      flex-shrink: 0;
      width: 16px;
      height: 16px;
      cursor: pointer;
    }
    .consent-label a { color: #0B7A3B; text-decoration: underline; }
  </style>
</Layout>
