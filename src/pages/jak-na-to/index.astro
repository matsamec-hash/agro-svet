---
// SSR (prerender:false): middleware servíruje /sk verzi přes locals.locale.
// sk čte z 'howtoSk' (přeložená overlay kolekce); cs render = dnešní literály
// VERBATIM (byte-identita). Locale jen z Astro.locals.locale (po rewritu je
// Astro.url cs cesta) s fallbackem na getLocaleFromUrl.
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { SITE_URL } from '../../lib/config';
import { breadcrumbSchema, itemListSchema } from '../../lib/structured-data';
import { useTranslations, getLocaleFromUrl, localizePath } from '../../i18n/utils';

const locale = Astro.locals.locale ?? getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const base = locale === 'cs' ? '' : `/${locale}`;
const bcp47 = ({ cs: 'cs-CZ', sk: 'sk-SK', uk: 'uk-UA' } as const)[locale];
Astro.response.headers.set('Cache-Control', 'public, max-age=600, s-maxage=3600, stale-while-revalidate=86400');

const HOWTO_COLLECTION = { cs: 'howto', sk: 'howtoSk', uk: 'howtoUk' } as const;
const items = await getCollection(HOWTO_COLLECTION[locale]);
const sorted = items.sort((a, b) => b.data.datePublished.getTime() - a.data.datePublished.getTime());

const breadcrumbJsonLd = breadcrumbSchema([
  { name: t('cat.bc.home'), url: `${base}/` },
  { name: t('howto.crumb'), url: `${base}/jak-na-to/` },
]);
const listJsonLd = itemListSchema(
  sorted.map((i) => ({ url: `${base}/jak-na-to/${i.id}/`, name: i.data.title })),
  t('howto.list.itemListName'),
);
const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: t('howto.list.collName'),
  description: t('howto.list.collDesc'),
  url: `${SITE_URL}${base}/jak-na-to/`,
  inLanguage: bcp47,
};
---

<Layout
  title={t('howto.list.title')}
  description={t('howto.list.description')}
  canonical={locale === 'cs' ? `${SITE_URL}/jak-na-to/` : undefined}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(listJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(collectionJsonLd)} />

  <div style="max-width:1100px; margin:0 auto; padding:48px 32px 80px;">

    <div style="margin-bottom:44px;">
      <span class="section-label">{t('howto.list.label')}</span>
      <h1 style="font-size:clamp(2rem,5vw,3rem); font-weight:900; letter-spacing:-1px; line-height:1.1; color:#1a1a1a; margin-bottom:16px;">
        {t('howto.list.h1')}
      </h1>
      <p style="font-size:16px; color:#666; max-width:600px; line-height:1.6;">
        {t('howto.list.intro')}
      </p>
    </div>

    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(320px,1fr)); gap:20px;">
      {sorted.map((item) => (
        <a href={localizePath(locale, `/jak-na-to/${item.id}/`)} class="howto-card">
          {item.data.heroImage && (
            <div style="height:170px; overflow:hidden;">
              <img
                src={item.data.heroImage}
                alt={item.data.title}
                loading="lazy"
                decoding="async"
                width="600"
                height="340"
                style="width:100%; height:100%; object-fit:cover;"
              />
            </div>
          )}
          <div style="padding:20px;">
            <div style="display:flex; align-items:center; gap:8px; margin-bottom:10px; flex-wrap:wrap;">
              <span style="background:#FFFF00; color:#000; font-family:'Chakra Petch',sans-serif; font-weight:400; font-size:10px; padding:2px 8px; border-radius:3px; text-transform:uppercase; letter-spacing:.5px;">
                {item.data.steps.length} {t('howto.kroku')}
              </span>
              {item.data.obtiznost && <span style="font-size:12px; color:#767676;">{item.data.obtiznost}</span>}
            </div>
            <h2 style="font-size:18px; font-weight:700; color:#1a1a1a; margin-bottom:8px; line-height:1.3;">{item.data.title}</h2>
            <p style="font-size:13.5px; color:#666; margin:0; line-height:1.55; display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden;">{item.data.description}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>

<style>
  .howto-card {
    display:block; text-decoration:none; color:inherit; border-radius:14px; overflow:hidden;
    background:#fff; box-shadow:0 0 10px rgba(0,0,0,.12); transition:box-shadow .2s, transform .2s;
  }
  .howto-card:hover { box-shadow:0 6px 20px rgba(0,0,0,.09); transform:translateY(-2px); }
</style>
