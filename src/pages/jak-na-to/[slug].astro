---
// SSR (prerender:false): middleware servíruje /sk verzi přes locals.locale.
// sk čte z 'howtoSk' (přeložená overlay kolekce) BEZ cs fallbacku —
// chybějící sk slug = 404 (žádný cs leak). cs render = dnešní literály VERBATIM.
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { SITE_URL } from '../../lib/config';
import { breadcrumbSchema, howToSchema, faqPageSchema } from '../../lib/structured-data';
import { useTranslations, getLocaleFromUrl, localizePath } from '../../i18n/utils';

const locale = Astro.locals.locale ?? getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const base = locale === 'cs' ? '' : `/${locale}`;
const bcp47 = ({ cs: 'cs-CZ', sk: 'sk-SK', uk: 'uk-UA' } as const)[locale];
Astro.response.headers.set('Cache-Control', 'public, max-age=600, s-maxage=3600, stale-while-revalidate=86400');

const { slug } = Astro.params;
const HOWTO_COLLECTION = { cs: 'howto', sk: 'howtoSk', uk: 'howtoUk' } as const;
const items = await getCollection(HOWTO_COLLECTION[locale]);
const item = items.find((i) => i.id === slug);
if (!item) return Astro.rewrite('/404');
const { Content } = await render(item);
import { renderMarkdownWithLinks } from '../../lib/markdown-with-links';
const contentHtml = await renderMarkdownWithLinks(item.body ?? '', `${base}/jak-na-to/${slug}/`);

const related = items.filter((i) => i.id !== item.id).slice(0, 3);

const pageUrl = `${SITE_URL}${base}/jak-na-to/${slug}/`;
const heroImageAbs = item.data.heroImage
  ? (item.data.heroImage.startsWith('http') ? item.data.heroImage : `${SITE_URL}${item.data.heroImage}`)
  : undefined;
const ogImageAbs = `${SITE_URL}/og/howto-${slug}.png`;

const breadcrumbJsonLd = breadcrumbSchema([
  { name: t('cat.bc.home'), url: `${base}/` },
  { name: t('howto.crumb'), url: `${base}/jak-na-to/` },
  { name: item.data.title, url: pageUrl },
]);

const howToJsonLd = howToSchema({
  name: item.data.title,
  description: item.data.description,
  url: pageUrl,
  imageUrl: heroImageAbs,
  totalTime: item.data.totalTime,
  tools: item.data.tools,
  supplies: item.data.supplies,
  steps: item.data.steps,
});

const faqJsonLd = item.data.faq && item.data.faq.length > 0 ? faqPageSchema(item.data.faq) : null;

const datePublishedIso = item.data.datePublished.toISOString().slice(0, 10);
const lastVerifiedIso = item.data.lastVerified ? item.data.lastVerified.toISOString().slice(0, 10) : null;
const lastVerifiedFmt = item.data.lastVerified
  ? new Intl.DateTimeFormat(bcp47, { day: 'numeric', month: 'long', year: 'numeric' }).format(item.data.lastVerified)
  : null;

// Article schema with explicit author + dateModified — E-E-A-T signal,
// lives alongside HowTo (Google handles multiple types per page).
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: item.data.title,
  description: item.data.description,
  ...(heroImageAbs && { image: heroImageAbs }),
  author: {
    '@type': 'Organization',
    name: 'Redakce agro-svět.cz',
    url: 'https://agro-svet.cz/redakce/',
  },
  publisher: {
    '@type': 'Organization',
    name: 'agro-svět.cz',
    url: 'https://agro-svet.cz',
    logo: { '@type': 'ImageObject', url: 'https://agro-svet.cz/icon-512.png' },
  },
  datePublished: datePublishedIso,
  dateModified: lastVerifiedIso ?? datePublishedIso,
  mainEntityOfPage: { '@type': 'WebPage', '@id': pageUrl },
  inLanguage: bcp47,
};
---

<Layout title={item.data.title} description={item.data.description} canonical={locale === 'cs' ? pageUrl : undefined} ogType="article" ogImage={ogImageAbs}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(howToJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(articleJsonLd)} />
  {faqJsonLd && <script type="application/ld+json" is:inline set:html={JSON.stringify(faqJsonLd)} />}

  {item.data.heroImage && (
    <div style="width:100%; height:clamp(240px,36vh,420px); overflow:hidden; position:relative;">
      <img
        src={item.data.heroImage}
        alt={item.data.title}
        width="1200"
        height="600"
        fetchpriority="high"
        decoding="async"
        style="width:100%; height:100%; object-fit:cover;"
      />
      <div style="position:absolute; inset:0; background:linear-gradient(to bottom, transparent 50%, rgba(0,0,0,.4));"></div>
    </div>
  )}

  <div style="max-width:860px; margin:0 auto; padding:48px 32px 96px;">

    <div style="font-size:13px; color:#666; margin-bottom:24px;">
      <a href={localizePath(locale, '/jak-na-to/')} style="color:#666; text-decoration:none;">{t('howto.crumb')}</a>
      <span style="margin:0 8px;">›</span>
      <span>{item.data.title}</span>
    </div>

    <div style="display:flex; align-items:center; gap:10px; margin-bottom:16px; flex-wrap:wrap;">
      <span style="background:#FFFF00; color:#000; font-family:'Chakra Petch',sans-serif; font-weight:400; font-size:11px; padding:3px 10px; border-radius:4px; text-transform:uppercase;">{t('howto.badge')}</span>
      {item.data.obtiznost && <span style="font-size:13px; color:#767676;">{t('howto.obtiznost')} {item.data.obtiznost}</span>}
    </div>

    <h1 style="font-size:clamp(1.9rem,4.5vw,2.8rem); font-weight:900; letter-spacing:-.6px; line-height:1.15; color:#1a1a1a; margin-bottom:12px;">{item.data.title}</h1>

    <div class="byline" style="display:flex; gap:12px; align-items:center; font-size:13.5px; color:#5a5a62; margin-bottom:28px; padding-bottom:16px; border-bottom:1px solid #ebebeb; flex-wrap:wrap;">
      <span>
        {t('enc.byline.pre')} <a href={localizePath(locale, '/redakce/')} style="color:#0A0A0B; font-weight:600; text-decoration:underline; text-decoration-color:#FFEA00; text-decoration-thickness:2px; text-underline-offset:3px;">{t('enc.byline.redakce')}</a>
      </span>
      {lastVerifiedFmt && (
        <>
          <span style="color:#c0c0c8;" aria-hidden="true">·</span>
          <span>{t('enc.byline.verified')} <time datetime={lastVerifiedIso}>{lastVerifiedFmt}</time></span>
        </>
      )}
    </div>

    <!-- Intro body -->
    <div class="prose">
      <div set:html={contentHtml} />
    </div>

    <!-- Meta box: time + tools + supplies -->
    {(item.data.totalTime || (item.data.tools && item.data.tools.length > 0) || (item.data.supplies && item.data.supplies.length > 0)) && (
      <div class="howto-meta">
        {item.data.totalTime && (
          <div class="hm-block">
            <div class="hm-label">{t('howto.meta.time')}</div>
            <div class="hm-value">{item.data.totalTime.replace('PT', '').replace('H', ' h ').replace('M', ' min').trim()}</div>
          </div>
        )}
        {item.data.tools && item.data.tools.length > 0 && (
          <div class="hm-block">
            <div class="hm-label">{t('howto.meta.tools')}</div>
            <ul class="hm-list">{item.data.tools.map((tool) => <li>{tool}</li>)}</ul>
          </div>
        )}
        {item.data.supplies && item.data.supplies.length > 0 && (
          <div class="hm-block">
            <div class="hm-label">{t('howto.meta.supplies')}</div>
            <ul class="hm-list">{item.data.supplies.map((s) => <li>{s}</li>)}</ul>
          </div>
        )}
      </div>
    )}

    <!-- Steps -->
    <section class="steps" aria-labelledby="steps-heading">
      <h2 id="steps-heading">{t('howto.steps.h')}</h2>
      <ol class="step-list">
        {item.data.steps.map((step, i) => (
          <li class="step-item" id={`krok-${i + 1}`}>
            <div class="step-num">{i + 1}</div>
            <div class="step-body">
              <h3>{step.name}</h3>
              <p>{step.text}</p>
            </div>
          </li>
        ))}
      </ol>
    </section>

    {item.data.relatedUrl && item.data.relatedLabel && (
      <a href={item.data.relatedUrl} class="related-tool-cta">
        {item.data.relatedLabel} →
      </a>
    )}

    {item.data.faq && item.data.faq.length > 0 && (
      <section class="faq" aria-labelledby="faq-heading">
        <h2 id="faq-heading">{t('enc.faq.h')}</h2>
        <dl class="faq-list">
          {item.data.faq.map((qa) => (
            <div class="faq-item">
              <dt>{qa.q}</dt>
              <dd>{qa.a}</dd>
            </div>
          ))}
        </dl>
      </section>
    )}

    {related.length > 0 && (
      <section class="related" aria-labelledby="related-heading">
        <h2 id="related-heading">{t('howto.related.h')}</h2>
        <div class="related-grid">
          {related.map((r) => (
            <a href={localizePath(locale, `/jak-na-to/${r.id}/`)} class="related-card">
              <div class="related-name">{r.data.title}</div>
              <div class="related-meta">{r.data.steps.length} {t('howto.kroku')}</div>
            </a>
          ))}
        </div>
      </section>
    )}

    <aside class="trust-bar" aria-label={t('enc.trust.label')}>
      <span class="trust-item">
        {t('enc.byline.pre')} <a href={localizePath(locale, '/redakce/')} class="trust-link">{t('enc.byline.redakce')}</a>
      </span>
      {lastVerifiedFmt && (
        <span class="trust-item">
          {t('enc.trust.verified')} <time datetime={lastVerifiedIso}>{lastVerifiedFmt}</time>
        </span>
      )}
    </aside>

    <div style="margin-top:48px;">
      <a href={localizePath(locale, '/jak-na-to/')} style="display:inline-flex; align-items:center; gap:8px; color:#1a1a1a; font-weight:400; font-size:14px; text-decoration:none; border:2px solid #1a1a1a; padding:10px 18px; border-radius:8px;">
        {t('howto.back')}
      </a>
    </div>
  </div>
</Layout>

<style>
  .prose :global(h2) { font-size:1.5rem; font-weight:400; margin:2em 0 .75em; letter-spacing:-.3px; color:#1a1a1a; }
  .prose :global(h3) { font-size:1.15rem; font-weight:400; margin:1.5em 0 .5em; color:#1a1a1a; }
  .prose :global(p) { font-size:17px; line-height:1.75; color:#333; margin-bottom:1.25em; }
  .prose :global(ul), .prose :global(ol) { padding-left:1.5em; margin-bottom:1.25em; }
  .prose :global(li) { font-size:16px; line-height:1.7; color:#333; margin-bottom:.4em; }
  .prose :global(strong) { font-weight:700; color:#1a1a1a; }

  .howto-meta {
    display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:16px;
    background:#f8f8f8; border-radius:14px; padding:24px 28px; margin:8px 0 40px;
  }
  .hm-label { font-size:11px; text-transform:uppercase; letter-spacing:.8px; color:#666; margin-bottom:8px; }
  .hm-value { font-size:18px; font-weight:700; color:#1a1a1a; }
  .hm-list { margin:0; padding-left:1.1em; }
  .hm-list li { font-size:14.5px; line-height:1.6; color:#333; margin-bottom:3px; }

  .steps { margin-top:8px; }
  .steps h2 { font-size:1.5rem; font-weight:700; margin:0 0 24px; letter-spacing:-.3px; color:#1a1a1a; }
  .step-list { list-style:none; margin:0; padding:0; counter-reset:none; }
  .step-item { display:flex; gap:18px; padding:0 0 28px; position:relative; }
  .step-item:not(:last-child)::before {
    content:''; position:absolute; left:17px; top:40px; bottom:6px; width:2px; background:#ececec;
  }
  .step-num {
    flex-shrink:0; width:36px; height:36px; border-radius:50%; background:#1a1a1a; color:#FFFF00;
    font-family:'Chakra Petch',sans-serif; font-weight:700; font-size:16px;
    display:flex; align-items:center; justify-content:center; z-index:1;
  }
  .step-body h3 { font-size:18px; font-weight:700; color:#1a1a1a; margin:6px 0 8px; line-height:1.35; }
  .step-body p { font-size:16px; line-height:1.7; color:#333; margin:0; }

  .related-tool-cta {
    display:inline-flex; margin-top:16px; align-items:center; gap:8px; font-size:14px; font-weight:700;
    font-family:'Chakra Petch',sans-serif; color:#1a1a1a; text-decoration:none;
    background:#FFFF00; padding:12px 20px; border-radius:8px; border:2px solid #1a1a1a;
  }
  .related-tool-cta:hover { background:#1a1a1a; color:#FFFF00; }

  .faq { margin-top:48px; padding-top:32px; border-top:1px solid #ebebeb; }
  .faq h2 { font-size:1.5rem; font-weight:700; margin:0 0 20px; letter-spacing:-.3px; color:#1a1a1a; }
  .faq-list { margin:0; padding:0; }
  .faq-item { padding:18px 0; border-bottom:1px dashed #e8e8e8; }
  .faq-item:last-child { border-bottom:none; }
  .faq-item dt { font-size:17px; font-weight:600; color:#1a1a1a; margin-bottom:8px; line-height:1.4; }
  .faq-item dd { font-size:16px; line-height:1.7; color:#333; margin:0; }

  .related { margin-top:48px; padding-top:32px; border-top:1px solid #ebebeb; }
  .related h2 { font-size:1.5rem; font-weight:700; margin:0 0 20px; letter-spacing:-.3px; color:#1a1a1a; }
  .related-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:12px; }
  .related-card { display:block; text-decoration:none; color:inherit; background:#fff; border:1px solid #ebebeb; border-radius:10px; padding:16px 18px; transition:transform .15s, box-shadow .15s, border-color .15s; }
  .related-card:hover { transform:translateY(-2px); box-shadow:0 4px 14px rgba(0,0,0,.06); border-color:#FFE600; }
  .related-name { font-size:15.5px; font-weight:700; color:#1a1a1a; margin-bottom:6px; line-height:1.3; }
  .related-meta { font-size:13px; color:#666; }

  .trust-bar { margin-top:32px; display:flex; gap:18px; flex-wrap:wrap; padding:14px 18px; background:#f8f8f8; border-radius:10px; font-size:13px; color:#555; }
  .trust-bar .trust-item { display:inline-flex; align-items:center; gap:6px; color:#555; }
  .trust-bar .trust-link { color:#1a1a1a; font-weight:600; text-decoration:none; }
  .trust-bar .trust-link:hover { text-decoration:underline; }
  .trust-bar time { color:#1a1a1a; font-weight:600; }
</style>
