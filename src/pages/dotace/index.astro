---
// SSR (prerender:false) → middleware servíruje lokalizovanú /sk verziu cez
// locals.locale. cs výstup sémanticky identický (Kč formátovanie zachované).
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { breadcrumbSchema, itemListSchema } from '../../lib/structured-data';
import { SITE_URL } from '../../lib/config';
import kolaCs from '../../data/dotace-kola.json';
import kolaSk from '../../data/dotace-kola-sk.json';
import { content } from '../../i18n/dotace';
import { linkBase, fmtMoney, fmtDate } from '../../lib/dotace-format';

const locale = Astro.locals.locale ?? 'cs';
const c = content[locale] ?? content.cs;

const tituly = (locale === 'sk' ? await getCollection('dotaceSk') : await getCollection('dotace')).sort(
  (a, b) => a.data.name.localeCompare(b.data.name, locale === 'sk' ? 'sk' : 'cs'),
);
const kolaData = locale === 'sk' ? kolaSk : kolaCs;
const kola = kolaData.kola;
const canonical = `${SITE_URL}/dotace/`;

const breadcrumbJsonLd = breadcrumbSchema([
  { name: c.crumbHome, url: `${linkBase(locale)}/` },
  { name: c.crumbSelf, url: `${linkBase(locale)}/dotace/` },
]);
const itemListJsonLd = itemListSchema(
  tituly.map((t) => ({ url: `${linkBase(locale)}/dotace/${t.data.slug}/`, name: t.data.name })),
  c.itemListName,
);

const statusLabel = c.statusLabel;
---

<Layout
  title={c.metaTitle}
  description={c.metaDescription}
  canonical={locale === 'cs' ? canonical : undefined}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(itemListJsonLd)} />

  <div class="dotace-page">
    <nav class="breadcrumb" aria-label="Cesta">
      <a href={`${linkBase(locale)}/`}>{c.crumbHome}</a>
      <span class="sep" aria-hidden="true">›</span>
      <span class="current">{c.crumbSelf}</span>
    </nav>

    <header class="hero">
      <span class="kicker">{c.kicker}</span>
      <h1>{c.h1}</h1>
      <p class="hero-lede" set:html={c.ledeHtml}></p>
    </header>

    <div class="disclaimer" set:html={c.disclaimerHtml}></div>

    <section class="titul-section" aria-labelledby="tituly-h">
      <h2 id="tituly-h">{c.titulyTitle}</h2>
      <div class="titul-grid">
        {tituly.map((t) => (
          <a href={`${linkBase(locale)}/dotace/${t.data.slug}/`} class="titul-card">
            <span class="tc-code">{t.data.intervence}</span>
            <h3>{t.data.name}</h3>
            <p>{t.data.popis}</p>
            <div class="tc-meta">
              {t.data.procentoZivocisna && (
                <span class="tc-pct">až {t.data.procentoZivocisna}{c.pctSuffix}</span>
              )}
              {t.data.stropDotace && (
                <span class="tc-strop">{c.stropPrefix}{fmtMoney(t.data.stropDotace, locale)}</span>
              )}
            </div>
            <span class="tc-cta">{c.detailCta}</span>
          </a>
        ))}
      </div>
    </section>

    <section class="kalendar-section" aria-labelledby="kalendar-h">
      <div class="ks-head">
        <h2 id="kalendar-h">{c.kalendarTitle}</h2>
        <a class="ks-link" href={`${linkBase(locale)}/dotace/kalendar-kol/`}>{c.kalendarLink}</a>
      </div>
      <div class="kola-table">
        <div class="kt-header">
          <div class="kt-th">{c.thTitul}</div>
          <div class="kt-th">{c.thKolo}</div>
          <div class="kt-th">{c.thPrijem}</div>
          <div class="kt-th">{c.thStav}</div>
        </div>
        {kola.map((k) => (
          <div class="kt-row">
            <div class="kt-cell kt-titul"><strong>{k.intervence}</strong> {k.nazev}</div>
            <div class="kt-cell">{k.kolo}</div>
            <div class="kt-cell">{fmtDate(k.prijemOd, locale)} – {fmtDate(k.prijemDo, locale)}</div>
            <div class="kt-cell"><span class={`kt-status status-${k.status}`}>{statusLabel[k.status as keyof typeof statusLabel] ?? k.status}</span></div>
          </div>
        ))}
      </div>
      <p class="kt-note">{c.kalendarNote.replace('{date}', kolaData.aktualizovano)}</p>
    </section>

    <section class="cross-cta">
      <div>
        <span class="cc-kicker">{c.ctaKicker}</span>
        <h2>{c.ctaHeading}</h2>
        <div class="cc-actions">
          <a class="cc-btn primary" href={`${linkBase(locale)}/stroje/traktory/`}>{c.ctaTractors}</a>
          <a class="cc-btn ghost" href={`${linkBase(locale)}/srovnani/`}>{c.ctaCompare}</a>
          <a class="cc-btn ghost" href={`${linkBase(locale)}/kalkulacka/`}>{c.ctaCalc}</a>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .dotace-page {
    --yellow:#FFEA00; --yellow-soft:#FFF6A8; --yellow-glow:rgba(255,234,0,.35);
    --ink:#0A0A0B; --body:#1E1E22; --muted:#6B6B72; --muted-2:#9A9AA3;
    --line:#EAEAEC; --card:#FFFFFF; --bg-cream:#FBFAF4;
    --green:#0B7A3B; --green-soft:#E3F3EA; --amber:#7A6B0B; --amber-soft:#F5EFC8;
    --sh-1:0 1px 2px rgba(10,10,12,.04), 0 0 0 1px rgba(10,10,12,.03);
    --sh-3:0 18px 40px -12px rgba(10,10,12,.18), 0 0 0 1px rgba(10,10,12,.04);
    max-width:1280px; margin:0 auto; padding:26px 24px 96px; color:var(--body);
  }
  .breadcrumb { display:flex; gap:8px; align-items:center; font-size:13px; color:var(--muted); margin-bottom:22px; }
  .breadcrumb a { color:var(--muted); text-decoration:none; }
  .breadcrumb a:hover { color:#000; }
  .breadcrumb .current { color:#000; font-weight:600; }
  .breadcrumb .sep { color:var(--muted-2); }

  .hero { background:linear-gradient(135deg, #0E0E10 0%, #1C1C20 60%, #2A2A2F 100%); color:#fff; border-radius:24px; padding:44px 48px; margin-bottom:20px; box-shadow:var(--sh-3); position:relative; overflow:hidden; }
  .hero::before { content:""; position:absolute; inset:0; pointer-events:none; opacity:.3; background-image:linear-gradient(rgba(255,255,255,.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.05) 1px, transparent 1px); background-size:48px 48px; mask-image:radial-gradient(600px 400px at 70% 100%, black, transparent 70%); }
  .hero .kicker { display:inline-flex; font:600 11px 'Chakra Petch',sans-serif; letter-spacing:.2em; text-transform:uppercase; color:var(--yellow); background:rgba(255,234,0,.08); border:1px solid rgba(255,234,0,.3); padding:7px 13px; border-radius:999px; position:relative; z-index:2; }
  .hero h1 { font:700 clamp(2.2rem,5vw,3.6rem) 'Chakra Petch',sans-serif; color:#fff; letter-spacing:-.03em; margin:18px 0 0; line-height:1.05; position:relative; z-index:2; }
  .hero-lede { color:#c8c8d0; max-width:720px; font-size:16px; line-height:1.6; margin:14px 0 0; position:relative; z-index:2; }
  .hero-lede a { color:var(--yellow); text-decoration:none; }
  .hero-lede a:hover { text-decoration:underline; }

  .disclaimer { background:var(--amber-soft); border:1px solid #E0D38A; border-radius:12px; padding:14px 18px; font-size:13px; color:#5a4f12; line-height:1.6; margin-bottom:32px; }
  .disclaimer strong { color:var(--amber); }
  .disclaimer a { color:var(--amber); }

  .titul-section { margin-bottom:36px; }
  .titul-section h2 { font:700 28px 'Chakra Petch',sans-serif; letter-spacing:-.02em; color:var(--ink); margin:0 0 18px; }
  .titul-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(320px, 1fr)); gap:14px; }
  .titul-card { display:flex; flex-direction:column; gap:8px; background:var(--card); border:1px solid var(--line); border-radius:16px; padding:22px 24px; text-decoration:none; color:inherit; box-shadow:var(--sh-1); transition:.18s; }
  .titul-card:hover { border-color:var(--yellow); transform:translateY(-2px); box-shadow:0 12px 32px -12px rgba(10,10,12,.15); }
  .tc-code { align-self:flex-start; font:700 11px 'Chakra Petch',sans-serif; letter-spacing:.06em; background:var(--yellow-soft); color:var(--ink); padding:4px 9px; border-radius:6px; }
  .titul-card h3 { font:700 18px 'Chakra Petch',sans-serif; color:var(--ink); margin:0; letter-spacing:-.01em; line-height:1.2; }
  .titul-card p { font-size:13.5px; color:var(--muted); line-height:1.55; margin:0; flex:1; }
  .tc-meta { display:flex; gap:8px; flex-wrap:wrap; }
  .tc-pct, .tc-strop { font:600 12px 'Chakra Petch',sans-serif; padding:3px 9px; border-radius:6px; }
  .tc-pct { background:var(--green-soft); color:var(--green); }
  .tc-strop { background:#FBFAF4; color:var(--muted); }
  .tc-cta { font:700 12.5px 'Chakra Petch',sans-serif; color:var(--ink); letter-spacing:.04em; }

  .kalendar-section { margin-bottom:36px; }
  .ks-head { display:flex; justify-content:space-between; align-items:baseline; margin-bottom:16px; gap:18px; flex-wrap:wrap; }
  .ks-head h2 { font:700 28px 'Chakra Petch',sans-serif; letter-spacing:-.02em; color:var(--ink); margin:0; }
  .ks-link { font:700 13px 'Chakra Petch',sans-serif; color:var(--ink); text-decoration:none; }
  .ks-link:hover { text-decoration:underline; }
  .kola-table { background:var(--card); border:1px solid var(--line); border-radius:16px; overflow:hidden; box-shadow:var(--sh-1); }
  .kt-header { display:grid; grid-template-columns:2fr 1.2fr 1.5fr 1fr; background:var(--bg-cream); border-bottom:1px solid var(--line); }
  .kt-th { padding:12px 16px; font:700 11px 'Chakra Petch',sans-serif; letter-spacing:.1em; text-transform:uppercase; color:var(--muted); }
  .kt-row { display:grid; grid-template-columns:2fr 1.2fr 1.5fr 1fr; border-bottom:1px solid var(--line); align-items:center; }
  .kt-row:last-child { border-bottom:0; }
  .kt-cell { padding:13px 16px; font:500 13.5px 'Chakra Petch',sans-serif; color:var(--ink); }
  .kt-titul strong { font-weight:700; }
  .kt-status { font:700 11px 'Chakra Petch',sans-serif; padding:3px 9px; border-radius:999px; letter-spacing:.04em; }
  .status-ocekavane { background:var(--amber-soft); color:var(--amber); }
  .status-otevrene { background:var(--green-soft); color:var(--green); }
  .status-uzavrene { background:#f0f0f0; color:var(--muted); }
  .kt-note { font-size:12px; color:var(--muted); line-height:1.55; margin:12px 4px 0; }

  .cross-cta { background:linear-gradient(135deg, var(--yellow) 0%, #FFD400 100%); border-radius:24px; padding:30px 34px; box-shadow:0 10px 30px -8px var(--yellow-glow); }
  .cross-cta h2 { font:700 23px 'Chakra Petch',sans-serif; letter-spacing:-.02em; color:#0A0A0B; margin:6px 0 14px; }
  .cc-kicker { display:inline-block; font:600 11px 'Chakra Petch',sans-serif; letter-spacing:.2em; text-transform:uppercase; color:#0A0A0B; background:rgba(0,0,0,.08); padding:5px 11px; border-radius:999px; }
  .cc-actions { display:flex; gap:8px; flex-wrap:wrap; }
  .cc-btn { padding:11px 18px; border-radius:10px; text-decoration:none; font:700 13px 'Chakra Petch',sans-serif; letter-spacing:.04em; transition:.15s; }
  .cc-btn.primary { background:#0A0A0B; color:#fff; }
  .cc-btn.primary:hover { transform:translateY(-1px); }
  .cc-btn.ghost { background:rgba(255,255,255,.5); color:#0A0A0B; border:1px solid rgba(0,0,0,.15); }
  .cc-btn.ghost:hover { background:rgba(255,255,255,.8); }

  @media (max-width:720px) {
    .kt-header { display:none; }
    .kt-row { grid-template-columns:1fr; gap:2px; padding:12px 0; }
    .kt-cell { padding:3px 16px; }
    .kt-titul { padding-top:10px; font-weight:700; }
  }
  @media (max-width:600px) {
    .dotace-page { padding:20px 16px 60px; }
    .hero { padding:32px 24px; }
  }
</style>
