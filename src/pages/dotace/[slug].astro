---
// SSR (prerender:false) → middleware servíruje lokalizovanú /sk verziu cez
// locals.locale. sk číta z 'dotaceSk' (PPA SR výzvy), BEZ cs fallbacku —
// chýbajúci sk slug = 404 (nezobrazí cs obsah na /sk URL).
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { getEntry, render } from 'astro:content';
import { breadcrumbSchema, faqPageSchema } from '../../lib/structured-data';
import { SITE_URL } from '../../lib/config';
import { content } from '../../i18n/dotace';
import { linkBase, fmtMoney } from '../../lib/dotace-format';
import { resolveCrossLinks } from '../../lib/dotace-crosslinks';
import { renderMarkdownWithLinks } from '../../lib/markdown-with-links';

const locale = Astro.locals.locale ?? 'cs';
const loc = content[locale] ?? content.cs;
const c = loc.detail;
const { slug } = Astro.params;
const titul = slug
  ? locale === 'sk'
    ? await getEntry('dotaceSk', slug)
    : await getEntry('dotace', slug)
  : undefined;
if (!titul) return new Response(null, { status: 404 });

// processes remark/rehype plugins; body rendered via contentHtml
await render(titul);
const d = titul.data;
const base = linkBase(locale);
const contentHtml = await renderMarkdownWithLinks(titul.body ?? '', `${base}/dotace/${d.slug}/`, locale);
// Pre cs posielame explicitný absolútny canonical (byte-identické s pôvodným).
// Pre sk Layout doplní self-canonical z lokalizovanej cesty (/dotace je pre sk
// odomknuté a indexovateľné). base='' pre cs, '/sk' pre sk.
const canonical = `${SITE_URL}${base}/dotace/${d.slug}/`;

const aktualizovanoFmt = new Intl.DateTimeFormat(locale === 'sk' ? 'sk-SK' : 'cs-CZ', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(d.aktualizovano);
const aktualizovanoIso = d.aktualizovano.toISOString().slice(0, 10);

const breadcrumbJsonLd = breadcrumbSchema([
  { name: loc.crumbHome, url: `${base}/` },
  { name: loc.crumbSelf, url: `${base}/dotace/` },
  { name: d.name, url: canonical },
]);

// Article schema with explicit author + dateModified — E-E-A-T signal.
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: d.name,
  description: d.popis,
  author: { '@type': 'Organization', name: 'Redakce agro-svět.cz', url: 'https://agro-svet.cz/redakce/' },
  publisher: {
    '@type': 'Organization',
    name: 'agro-svět.cz',
    url: 'https://agro-svet.cz',
    logo: { '@type': 'ImageObject', url: 'https://agro-svet.cz/icon-512.png' },
  },
  dateModified: aktualizovanoIso,
  datePublished: aktualizovanoIso,
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  inLanguage: c.inLanguage,
};
const faqJsonLd = d.faq && d.faq.length > 0 ? faqPageSchema(d.faq) : null;
const crossLinks = resolveCrossLinks(d.relatedLinks, base, [
  { href: `${base}/stroje/traktory/`, label: c.ctaTractors, primary: true },
  { href: `${base}/srovnani/`, label: c.ctaCompare, primary: false },
  { href: `${base}/kalkulacka/leasing-traktoru/`, label: c.ctaLeasing, primary: false },
]);
---

<Layout
  title={`${d.name}${c.titleSuffix}`}
  description={d.popis}
  canonical={locale === 'cs' ? canonical : undefined}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(articleJsonLd)} />
  {faqJsonLd && <script type="application/ld+json" is:inline set:html={JSON.stringify(faqJsonLd)} />}

  <div class="titul-page">
    <nav class="breadcrumb" aria-label="Cesta">
      <a href={`${base}/`}>{loc.crumbHome}</a>
      <span class="sep" aria-hidden="true">›</span>
      <a href={`${base}/dotace/`}>{loc.crumbSelf}</a>
      <span class="sep" aria-hidden="true">›</span>
      <span class="current">{d.name}</span>
    </nav>

    <div class="tp-meta">
      <span class="tp-code">{d.intervence}</span>
      <span class="tp-updated">{c.updatedLabel} <time datetime={aktualizovanoIso}>{aktualizovanoFmt}</time></span>
    </div>
    <h1>{d.name}</h1>

    <div class="byline" set:html={c.bylineHtml}></div>

    <!-- Spec grid -->
    <div class="spec-grid">
      {d.procentoRostlinna && (
        <div class="spec-box">
          <span class="sb-label">{c.specRostlinna}</span>
          <span class="sb-value">{d.procentoRostlinna}{c.pctSuffix}</span>
        </div>
      )}
      {d.procentoZivocisna && (
        <div class="spec-box">
          <span class="sb-label">{c.specZivocisna}</span>
          <span class="sb-value">{d.procentoZivocisna}{c.pctSuffix}</span>
        </div>
      )}
      {d.stropDotace && (
        <div class="spec-box">
          <span class="sb-label">{c.specStrop}</span>
          <span class="sb-value">{fmtMoney(d.stropDotace, locale)}</span>
        </div>
      )}
      {d.minVydaje && (
        <div class="spec-box">
          <span class="sb-label">{c.specMinVydaje}</span>
          <span class="sb-value">{fmtMoney(d.minVydaje, locale)}</span>
        </div>
      )}
    </div>

    {d.strojeMax49 && (
      <div class="warn-box" set:html={c.warnBoxHtml}></div>
    )}

    <div class="prose">
      <div set:html={contentHtml} />
    </div>

    {d.faq && d.faq.length > 0 && (
      <section class="faq" aria-labelledby="faq-h">
        <h2 id="faq-h">{c.faqHeading}</h2>
        <dl class="faq-list">
          {d.faq.map((qa) => (
            <div class="faq-item">
              <dt>{qa.q}</dt>
              <dd>{qa.a}</dd>
            </div>
          ))}
        </dl>
      </section>
    )}

    <aside class="source-bar">
      <span>{c.sourceLabel}<a href={d.primarniZdroj} target="_blank" rel="noopener nofollow">{c.sourceLinkText}</a></span>
      <a href={`${base}/dotace/kalendar-kol/`} class="sb-link">{c.sourceCalendarLink}</a>
    </aside>

    <section class="cross-cta">
      <div>
        <span class="cc-kicker">{c.ctaKicker}</span>
        <h2>{c.ctaHeading}</h2>
        <div class="cc-actions">
          {crossLinks.map((l) => (
            <a class={`cc-btn ${l.primary ? 'primary' : 'ghost'}`} href={l.href}>{l.label}</a>
          ))}
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .titul-page {
    --yellow:#FFEA00; --yellow-soft:#FFF6A8; --yellow-glow:rgba(255,234,0,.35);
    --ink:#0A0A0B; --body:#1E1E22; --muted:#6B6B72; --muted-2:#9A9AA3;
    --line:#EAEAEC; --card:#FFFFFF; --bg-cream:#FBFAF4;
    --green:#0B7A3B; --green-soft:#E3F3EA; --amber:#7A6B0B; --amber-soft:#F5EFC8;
    --sh-1:0 1px 2px rgba(10,10,12,.04), 0 0 0 1px rgba(10,10,12,.03);
    --sh-glow:0 10px 30px -8px var(--yellow-glow);
    max-width:820px; margin:0 auto; padding:26px 24px 96px; color:var(--body);
  }
  .breadcrumb { display:flex; gap:8px; align-items:center; font-size:13px; color:var(--muted); margin-bottom:22px; flex-wrap:wrap; }
  .breadcrumb a { color:var(--muted); text-decoration:none; }
  .breadcrumb a:hover { color:#000; }
  .breadcrumb .current { color:#000; font-weight:600; }
  .breadcrumb .sep { color:var(--muted-2); }

  .tp-meta { display:flex; align-items:center; gap:12px; margin-bottom:10px; flex-wrap:wrap; }
  .tp-code { font:700 12px 'Chakra Petch',sans-serif; letter-spacing:.06em; background:var(--yellow-soft); color:var(--ink); padding:4px 10px; border-radius:6px; }
  .tp-updated { font-size:13px; color:var(--muted); }
  .titul-page h1 { font:900 clamp(1.8rem,4.5vw,2.6rem) 'Chakra Petch',sans-serif; letter-spacing:-.02em; line-height:1.15; color:var(--ink); margin:0 0 12px; }
  .byline { font-size:13.5px; color:#5a5a62; margin-bottom:28px; padding-bottom:16px; border-bottom:1px solid var(--line); }
  .byline a { color:var(--ink); font-weight:600; text-decoration:underline; text-decoration-color:var(--yellow); text-decoration-thickness:2px; text-underline-offset:3px; }

  .spec-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(170px, 1fr)); gap:12px; margin-bottom:24px; }
  .spec-box { background:var(--bg-cream); border:1px solid var(--line); border-radius:12px; padding:16px 18px; }
  .sb-label { display:block; font:600 11px 'Chakra Petch',sans-serif; letter-spacing:.08em; text-transform:uppercase; color:var(--muted); margin-bottom:6px; }
  .sb-value { display:block; font:700 22px 'Chakra Petch',sans-serif; color:var(--ink); letter-spacing:-.01em; }

  .warn-box { background:var(--amber-soft); border:1px solid #E0D38A; border-radius:12px; padding:16px 20px; font-size:14px; color:#5a4f12; line-height:1.6; margin-bottom:28px; }
  .warn-box strong { color:var(--amber); }

  .prose :global(h2) { font:700 1.5rem 'Chakra Petch',sans-serif; margin:1.8em 0 .6em; color:var(--ink); letter-spacing:-.01em; }
  .prose :global(h3) { font:700 1.15rem 'Chakra Petch',sans-serif; margin:1.4em 0 .5em; color:var(--ink); }
  .prose :global(p) { font-size:16px; line-height:1.75; color:#2a2a30; margin-bottom:1.1em; }
  .prose :global(ul) { padding-left:1.4em; margin-bottom:1.2em; }
  .prose :global(li) { font-size:15.5px; line-height:1.7; color:#2a2a30; margin-bottom:.4em; }
  .prose :global(strong) { font-weight:700; color:var(--ink); }
  .prose :global(blockquote) { border-left:4px solid #E0D38A; background:var(--amber-soft); padding:14px 20px; margin:1.4em 0; border-radius:0 8px 8px 0; font-size:13.5px; color:#5a4f12; line-height:1.6; }
  .prose :global(blockquote p) { font-size:13.5px; color:#5a4f12; margin:0; }
  .prose :global(a) { color:var(--green); text-decoration:underline; }

  .faq { margin:36px 0; }
  .faq h2 { font:700 24px 'Chakra Petch',sans-serif; letter-spacing:-.02em; color:var(--ink); margin:0 0 16px; }
  .faq-list { display:flex; flex-direction:column; gap:10px; }
  .faq-item { background:var(--card); border:1px solid var(--line); border-radius:14px; padding:18px 22px; }
  .faq-item dt { font:700 15.5px 'Chakra Petch',sans-serif; color:var(--ink); margin:0 0 7px; }
  .faq-item dd { font-size:14px; color:#3a3a40; line-height:1.6; margin:0; }

  .source-bar { display:flex; justify-content:space-between; align-items:center; gap:14px; flex-wrap:wrap; background:var(--bg-cream); border:1px solid var(--line); border-radius:12px; padding:14px 18px; font-size:13px; color:var(--muted); margin-bottom:28px; }
  .source-bar a { color:var(--ink); }
  .sb-link { font:700 13px 'Chakra Petch',sans-serif; text-decoration:none; }
  .sb-link:hover { text-decoration:underline; }

  .cross-cta { background:linear-gradient(135deg, var(--yellow) 0%, #FFD400 100%); border-radius:24px; padding:28px 30px; box-shadow:var(--sh-glow); }
  .cross-cta h2 { font:700 22px 'Chakra Petch',sans-serif; letter-spacing:-.02em; color:#0A0A0B; margin:6px 0 14px; }
  .cc-kicker { display:inline-block; font:600 11px 'Chakra Petch',sans-serif; letter-spacing:.2em; text-transform:uppercase; color:#0A0A0B; background:rgba(0,0,0,.08); padding:5px 11px; border-radius:999px; }
  .cc-actions { display:flex; gap:8px; flex-wrap:wrap; }
  .cc-btn { padding:11px 18px; border-radius:10px; text-decoration:none; font:700 13px 'Chakra Petch',sans-serif; letter-spacing:.04em; transition:.15s; }
  .cc-btn.primary { background:#0A0A0B; color:#fff; }
  .cc-btn.primary:hover { transform:translateY(-1px); }
  .cc-btn.ghost { background:rgba(255,255,255,.5); color:#0A0A0B; border:1px solid rgba(0,0,0,.15); }
  .cc-btn.ghost:hover { background:rgba(255,255,255,.8); }

  @media (max-width:600px) {
    .titul-page { padding:20px 16px 60px; }
  }
</style>
