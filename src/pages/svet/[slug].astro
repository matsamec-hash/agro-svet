---
// Statická data zemí (build-svet.mjs) → prerender s getStaticPaths.
// Bez prerender:true by se v output:'server' route servírovala jako SSR,
// kde se props z getStaticPaths nepředávají → profile=undefined → 500.
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import IndicatorRow from '../../components/svet/IndicatorRow.astro';
import RegionMap from '../../components/svet/RegionMap.astro';
import { groupByPackage, fmtNum, COUNTRY_LOCATIVE } from '../../lib/svet/render';
import { assertCountryProfile } from '../../lib/svet/types';
import { breadcrumbSchema, datasetSchema } from '../../lib/structured-data';
import { SITE_URL } from '../../lib/config';
import index from '../../data/svet/index.json';
import '../../styles/svet.css';

export async function getStaticPaths() {
  const mods = import.meta.glob('../../data/svet/*.json', { eager: true });
  const regionMods = import.meta.glob('../../data/svet/regions/*.json', { eager: true });
  return index.countries
    .filter((c) => !c.reference)
    .map((c) => {
      const profile = (mods[`../../data/svet/${c.slug}.json`] as any).default;
      const regionGeo = (regionMods[`../../data/svet/regions/${c.slug}-geo.json`] as any)?.default ?? null;
      const regionData = (regionMods[`../../data/svet/regions/${c.slug}.json`] as any)?.default ?? null;
      return { params: { slug: c.slug }, props: { profile, regionGeo, regionData } };
    });
}

const { profile, regionGeo, regionData } = Astro.props as { profile: any; regionGeo: any; regionData: any };
assertCountryProfile(profile);
const hasMap = regionGeo && regionData;

const refMods = import.meta.glob('../../data/svet/cesko.json', { eager: true });
const ref = (Object.values(refMods)[0] as any).default;
const refVal = (key: string) => ref.indicators[key]?.latest?.value;
const refSeries = (key: string) => ref.indicators[key]?.series ?? null;

const groups = groupByPackage(profile);
const heroKeys = ['ag_land', 'ag_output_value', 'farm_count', 'cattle_count'];
const heroKpis = heroKeys.map((k) => profile.indicators[k]).filter(Boolean);

const loc = COUNTRY_LOCATIVE[profile.slug] ?? `v ${profile.nameCs}`;
const title = `Zemědělství ${loc}`;
const description = `Aktuální zemědělská data: ${profile.nameCs} — produkce, půda, ekonomika a srovnání s ČR. Zdroje Eurostat a World Bank.`;
const pageUrl = `${SITE_URL}/svet/${profile.slug}/`;
const ogImage = `${SITE_URL}/og/svet-${profile.slug}.png`;

// ---- Strukturovaná data (JSON-LD) ----
const inds = Object.values(profile.indicators) as any[];
const years = inds.flatMap((i) => (i.series ?? []).map((p: any) => Number(p.period))).filter((y) => Number.isFinite(y));
const temporalCoverage = years.length ? `${Math.min(...years)}/${Math.max(...years)}` : undefined;
const SOURCE_URLS: Record<string, string> = {
  Eurostat: 'https://ec.europa.eu/eurostat',
  'World Bank': 'https://data.worldbank.org',
};
const sources = [...new Set(inds.map((i) => i.latest?.source).filter(Boolean))].map((name: string) => ({
  name, url: SOURCE_URLS[name],
}));
const breadcrumbJsonLd = breadcrumbSchema([
  { name: 'Domů', url: '/' },
  { name: 'Zemědělství ve světě', url: '/svet/' },
  { name: profile.nameCs, url: pageUrl },
]);
const datasetJsonLd = datasetSchema({
  name: `Zemědělská data — ${profile.nameCs}`,
  description,
  url: pageUrl,
  countryName: profile.nameCs,
  keywords: ['zemědělství', profile.nameCs, 'zemědělská statistika', 'produkce', 'srovnání s ČR', ...sources.map((s) => s.name)],
  temporalCoverage,
  dateModified: profile.generated,
  variables: inds.map((i) => ({ name: i.label, unitText: i.unit })),
  sources,
});
---
<Layout title={title} description={description} canonical={pageUrl} ogImage={ogImage} ogType="article">
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(datasetJsonLd)} />
  <main class="svet-page svet-profile">
    <nav class="svet-crumbs" aria-label="Drobečková navigace">
      <a href="/">Domů</a>
      <span aria-hidden="true">›</span>
      <a href="/svet/">Zemědělství ve světě</a>
      <span aria-hidden="true">›</span>
      <span aria-current="page">{profile.nameCs}</span>
    </nav>
    <header class="svet-hero">
      <div class="svet-hero-inner">
        <span class="svet-flag">{profile.flag}</span>
        <h1>{title}</h1>
        <p class="svet-lede">{description}</p>
      </div>
      {heroKpis.length > 0 && (
        <div class="svet-kpis">
          {heroKpis.map((k: any) => (
            <div class="svet-kpi">
              <div class="svet-kpi-val">{fmtNum(k.latest.value)} <span>{k.unit}</span></div>
              <div class="svet-kpi-lbl">{k.label}</div>
            </div>
          ))}
        </div>
      )}
    </header>

    {hasMap && <RegionMap geo={regionGeo} data={regionData} countryName={profile.nameCs} />}

    {groups.map((g) => (
      <section class="svet-section">
        <header class="svet-section-head"><h2>{g.label}</h2></header>
        <div class="svet-rows">
          {g.indicators.map((ind: any) => (
            <IndicatorRow indicator={ind} refValue={refVal(ind.key)} refSeries={refSeries(ind.key)} refName="ČR" countryName={profile.nameCs} />
          ))}
        </div>
      </section>
    ))}

    <section class="svet-section">
      <header class="svet-section-head"><h2>Zdroje a metodika</h2></header>
      <p class="svet-method">Data se stahují automaticky z oficiálních otevřených zdrojů (Eurostat, World Bank); u každého ukazatele je uvedeno období a odkaz na zdroj. Hodnoty jsou srovnatelné mezi zeměmi a „vs ČR" porovnává poslední dostupnou hodnotu s Českem. Aktualizováno {profile.generated}.</p>
      <p class="svet-method"><a href="/svet/srovnani/">Porovnat země vedle sebe →</a></p>
    </section>
  </main>
</Layout>
