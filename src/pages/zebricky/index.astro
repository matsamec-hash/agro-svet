---
export const prerender = true;

import Layout from '../../layouts/Layout.astro';
import { TIER_LISTS, rankForTierList } from '../../lib/tier-lists';
import { breadcrumbSchema, itemListSchema } from '../../lib/structured-data';
import { SITE_URL } from '../../lib/config';

const pageUrl = `${SITE_URL}/zebricky/`;

const tierCards = TIER_LISTS.map((t) => {
  const ranked = rankForTierList(t);
  return {
    config: t,
    count: ranked.length,
    topModel: ranked[0]?.model,
  };
});

const breadcrumbJsonLd = breadcrumbSchema([
  { name: 'Domů', url: '/' },
  { name: 'Žebříčky', url: pageUrl },
]);

const itemListJsonLd = itemListSchema(
  TIER_LISTS.map((t) => ({
    url: `${SITE_URL}/zebricky/${t.slug}/`,
    name: t.title,
  })),
  'Žebříčky strojů a kombajnů',
);

const traktoryCards = tierCards.filter((c) => c.config.category === 'traktory');
const kombajnyCards = tierCards.filter((c) => c.config.category === 'kombajny');
---

<Layout
  title="Žebříčky strojů — top traktory a kombajny 2026"
  description="Kurátorované žebříčky aktuálně vyráběných traktorů a kombajnů podle výkonu. Top modely v každém segmentu od 80 koní po 700 koní."
  canonical={pageUrl}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(itemListJsonLd)} />

  <div class="hub-root">
    <nav class="breadcrumb" aria-label="Cesta">
      <a href="/">Domů</a>
      <span aria-hidden="true">›</span>
      <span class="current">Žebříčky</span>
    </nav>

    <header class="hub-head">
      <span class="kicker">Žebříčky · {TIER_LISTS.length} segmentů</span>
      <h1>Top stroje v každém segmentu</h1>
      <p class="lede">
        Vybrali jsme nejvýznamnější aktuálně vyráběné modely v každém výkonovém segmentu. Žebříčky aktualizujeme s každým rozšířením katalogu.
      </p>
    </header>

    {traktoryCards.length > 0 && (
      <section aria-labelledby="trak-heading">
        <h2 id="trak-heading">Traktory</h2>
        <div class="hub-grid">
          {traktoryCards.map((c) => (
            <a class="hub-card" href={`/zebricky/${c.config.slug}/`}>
              <span class="hub-count">{c.count} modelů</span>
              <h3>{c.config.title}</h3>
              <p>{c.config.description}</p>
              {c.topModel && <span class="hub-cta">#1 {c.topModel.brand_name} {c.topModel.name} →</span>}
            </a>
          ))}
        </div>
      </section>
    )}

    {kombajnyCards.length > 0 && (
      <section aria-labelledby="komb-heading">
        <h2 id="komb-heading">Kombajny</h2>
        <div class="hub-grid">
          {kombajnyCards.map((c) => (
            <a class="hub-card" href={`/zebricky/${c.config.slug}/`}>
              <span class="hub-count">{c.count} modelů</span>
              <h3>{c.config.title}</h3>
              <p>{c.config.description}</p>
              {c.topModel && <span class="hub-cta">#1 {c.topModel.brand_name} {c.topModel.name} →</span>}
            </a>
          ))}
        </div>
      </section>
    )}
  </div>

  <style>
    .hub-root { max-width: 1080px; margin: 0 auto; padding: 32px 24px 80px; }
    .breadcrumb { display:flex; gap:8px; align-items:center; font-size:13px; color:#666; margin-bottom:20px; }
    .breadcrumb a { color:#666; text-decoration:none; }
    .breadcrumb a:hover { color:#000; }
    .breadcrumb .current { color:#000; font-weight:600; }

    .hub-head { margin-bottom: 36px; }
    .kicker { display:inline-block; background:#FFEA00; color:#0A0A0B; font-weight:700; font-size:11px; padding:4px 10px; border-radius:4px; text-transform:uppercase; letter-spacing:.5px; }
    h1 { font-size: clamp(2rem, 4vw, 2.8rem); margin: 12px 0 12px; line-height: 1.1; letter-spacing: -0.5px; }
    .lede { font-size: 16px; line-height: 1.6; color: #444; max-width: 720px; margin: 0; }

    h2 { font-size: 24px; margin: 36px 0 16px; }
    .hub-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
    .hub-card {
      display: flex;
      flex-direction: column;
      padding: 18px 20px;
      background: #fff;
      border: 1px solid #eaeaec;
      border-radius: 12px;
      text-decoration: none;
      color: inherit;
      transition: border-color .15s, box-shadow .15s, transform .15s;
    }
    .hub-card:hover { border-color: #0A0A0B; box-shadow: 0 8px 24px rgba(10,10,12,.08); transform: translateY(-1px); }
    .hub-count { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: #0B7A3B; margin-bottom: 6px; }
    .hub-card h3 { font-size: 17px; font-weight: 700; line-height: 1.3; margin: 0 0 8px; color: #0A0A0B; }
    .hub-card p { font-size: 13px; line-height: 1.5; color: #666; margin: 0 0 12px; display:-webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
    .hub-cta { font-size: 12px; font-weight: 700; color: #0B7A3B; margin-top: auto; }
  </style>
</Layout>
