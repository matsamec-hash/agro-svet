<style>
  .legal-page {
    max-width: 760px;
    margin: 0 auto;
    padding: 40px 24px 80px;
    line-height: 1.7;
    color: #222;
  }
  .legal-page h1 {
    font-family: 'Chakra Petch', sans-serif;
    font-weight: 700;
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    margin: 0 0 12px;
    line-height: 1.2;
    letter-spacing: -.02em;
  }
  .legal-page .lead {
    font-size: 16px;
    color: #444;
    margin: 0 0 32px;
  }
  .legal-page h2 {
    font-family: 'Chakra Petch', sans-serif;
    font-weight: 700;
    font-size: 22px;
    margin: 32px 0 12px;
    letter-spacing: -.01em;
  }
  .legal-page h3 {
    font-family: 'Chakra Petch', sans-serif;
    font-weight: 600;
    font-size: 17px;
    margin: 20px 0 8px;
  }
  .legal-page ul {
    padding-left: 22px;
    margin: 8px 0 16px;
  }
  .legal-page li { margin: 4px 0; }
  .legal-page a {
    color: #0B7A3B;
    text-decoration: underline;
  }
  .legal-page a:hover { color: #066027; }
  .legal-page .legal-table {
    width: 100%;
    border-collapse: collapse;
    margin: 12px 0 20px;
    font-size: 14px;
  }
  .legal-page .legal-table th,
  .legal-page .legal-table td {
    text-align: left;
    padding: 10px 12px;
    border-bottom: 1px solid #eaeaec;
    vertical-align: top;
  }
  .legal-page .legal-table th {
    background: #fbfaf4;
    font-family: 'Chakra Petch', sans-serif;
    font-size: 12px;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: #555;
  }
  .legal-page .effective {
    margin-top: 36px;
    padding-top: 16px;
    border-top: 1px solid #eaeaec;
    font-size: 13px;
    color: #666;
