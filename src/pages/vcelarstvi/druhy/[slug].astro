---
export const prerender = true;
import Layout from '../../../layouts/Layout.astro';
import { getAllVcely, getVcela } from '../../../lib/vcelarstvi';
import { faqPageSchema } from '../../../lib/structured-data';
import { SITE_URL } from '../../../lib/config';

export function getStaticPaths() {
  return getAllVcely().map((v) => ({ params: { slug: v.slug } }));
}

const { slug } = Astro.params;
const vcela = getVcela(slug!);
if (!vcela) return Astro.rewrite('/404');

const canonical = `${SITE_URL}/vcelarstvi/druhy/${vcela.slug}/`;
const pageTitle = `${vcela.name} (${vcela.latinsky})`;
const pageDesc = vcela.vhodnost_cr.length > 160 ? vcela.vhodnost_cr.slice(0, 157) + '…' : vcela.vhodnost_cr;

type SpecRow = { label: string; value: string };
const specs: SpecRow[] = [
  { label: 'Latinský název', value: vcela.latinsky },
  { label: 'Původ', value: vcela.puvod },
  { label: 'Temperament', value: vcela.temperament },
  { label: 'Medný výnos', value: vcela.medny_vynos },
  { label: 'Rojivost', value: vcela.rojivost },
  { label: 'Zimuvzdornost', value: vcela.zimuvzdornost },
];
if (vcela.barva) specs.push({ label: 'Zbarvení', value: vcela.barva });
if (vcela.alternative_names && vcela.alternative_names.length > 0) {
  specs.push({ label: 'Jiné názvy', value: vcela.alternative_names.join(', ') });
}

const related = getAllVcely().filter((v) => v.slug !== vcela.slug).slice(0, 4);

// JSON-LD — same pattern as plemeno detail page
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Domů', item: `${SITE_URL}/` },
    { '@type': 'ListItem', position: 2, name: 'Včelařství', item: `${SITE_URL}/vcelarstvi/` },
    { '@type': 'ListItem', position: 3, name: 'Druhy včel', item: `${SITE_URL}/vcelarstvi/druhy/` },
    { '@type': 'ListItem', position: 4, name: vcela.name, item: canonical },
  ],
};

const propertyValues: Array<{ '@type': 'PropertyValue'; name: string; value: string }> = [
  { '@type': 'PropertyValue', name: 'Temperament', value: vcela.temperament },
  { '@type': 'PropertyValue', name: 'Medný výnos', value: vcela.medny_vynos },
  { '@type': 'PropertyValue', name: 'Rojivost', value: vcela.rojivost },
  { '@type': 'PropertyValue', name: 'Zimuvzdornost', value: vcela.zimuvzdornost },
];
if (vcela.barva) propertyValues.push({ '@type': 'PropertyValue', name: 'Zbarvení', value: vcela.barva });

const thingJsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Thing',
  name: vcela.name,
  description: vcela.description,
  url: canonical,
  inLanguage: 'cs-CZ',
  ...(vcela.alternative_names && vcela.alternative_names.length > 0 && { alternateName: vcela.alternative_names }),
  ...(vcela.image_url && { image: vcela.image_url.startsWith('http') ? vcela.image_url : `${SITE_URL}${vcela.image_url}` }),
  additionalProperty: propertyValues,
};

const sameAs: string[] = [];
if (vcela.wikipedia) sameAs.push(vcela.wikipedia);
if (vcela.wikidata) sameAs.push(vcela.wikidata);
if (sameAs.length > 0) thingJsonLd.sameAs = sameAs;

const faqItems = vcela.faq && vcela.faq.length >= 2 ? vcela.faq : null;
const faqJsonLd = faqItems ? faqPageSchema(faqItems) : null;
---

<Layout title={pageTitle} description={pageDesc} canonical={canonical}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(thingJsonLd)} />
  {faqJsonLd && <script type="application/ld+json" is:inline set:html={JSON.stringify(faqJsonLd)} />}

  <div class="vcela-page">

    <nav class="breadcrumb" aria-label="Cesta">
      <a href="/">Domů</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/vcelarstvi/">Včelařství</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/vcelarstvi/druhy/">Druhy včel</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <span class="current">{vcela.name}</span>
    </nav>

    <section class="hero">
      <div class="hero-left">
        <div class="hero-tags">
          <span class="tag tag-vcela">včela medonosná</span>
          <span class="tag tag-temperament">{vcela.temperament}</span>
          <span class="tag tag-vynos">{vcela.medny_vynos} výnos</span>
        </div>
        <h1>{vcela.name}</h1>
        <div class="hero-altnames">{vcela.latinsky}</div>
        <p class="hero-lede">{vcela.vhodnost_cr}</p>
        <div class="hero-actions">
          <a class="cta-secondary" href="/vcelarstvi/druhy/">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
            Všechny druhy včel
          </a>
        </div>
      </div>

      <div class="hero-right">
        {vcela.image_url ? (
          <figure class="hero-photo">
            <img src={vcela.image_url} alt={`${vcela.name} — ${vcela.latinsky}`} width="800" height="600" loading="eager" decoding="async" />
          </figure>
        ) : (
          <div class="hero-emoji-card">
            <div class="hec-emoji" aria-hidden="true">🐝</div>
            <div class="hec-name">{vcela.name}</div>
          </div>
        )}
      </div>
    </section>

    <div class="content-grid">
      <div class="content-main">

        <section class="spec-card">
          <div class="card-head">
            <h2>Charakteristika druhu</h2>
            <span class="card-head-meta">{specs.length} {specs.length === 1 ? 'parametr' : specs.length < 5 ? 'parametry' : 'parametrů'}</span>
          </div>
          <div class="spec-group">
            <div class="spec-group-label">Základní parametry</div>
            <dl class="spec-list">
              {specs.map((row) => (
                <div class="spec-item"><dt>{row.label}</dt><dd>{row.value}</dd></div>
              ))}
            </dl>
          </div>
        </section>

        <section class="body-card">
          <div class="prose" set:html={vcela.description.replace(/\n\n/g, '</p><p>').replace(/\n/g, '<br>').replace(/^(.+)$/, '<p>$1</p>')} />
        </section>

        {vcela.wikipedia && (
          <section class="spec-card">
            <div class="card-head">
              <h2>Zdroje</h2>
            </div>
            <p class="wiki-link">
              <a href={vcela.wikipedia} rel="nofollow noopener" target="_blank">Wikipedie: {vcela.name}</a>
            </p>
          </section>
        )}

        {faqItems && (
          <section class="faq-card" aria-labelledby="faq-heading">
            <div class="card-head">
              <h2 id="faq-heading">Časté otázky</h2>
            </div>
            <dl class="faq-list">
              {faqItems.map((qa) => (
                <div class="faq-item">
                  <dt>{qa.q}</dt>
                  <dd set:html={qa.a} />
                </div>
              ))}
            </dl>
          </section>
        )}

        {related.length > 0 && (
          <section class="related-card">
            <div class="card-head">
              <h2>Další druhy včel</h2>
              <a class="card-head-link" href="/vcelarstvi/druhy/">Všechny druhy →</a>
            </div>
            <div class="rel-grid">
              {related.map((r) => (
                <a href={`/vcelarstvi/druhy/${r.slug}/`} class="rel-card">
                  <div class="rel-name">{r.name}</div>
                  <div class="rel-latin">{r.latinsky}</div>
                  <div class="rel-meta">{r.temperament} · {r.medny_vynos} výnos</div>
                </a>
              ))}
            </div>
          </section>
        )}

      </div>

      <aside class="content-aside">
        <div class="aside-card nav-card">
          <span class="acc-label">Navigace</span>
          <a href="/vcelarstvi/" class="aside-link">
            <span class="al-label">Sekce</span>
            <span class="al-value">Včelařství</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>
          <a href="/vcelarstvi/druhy/" class="aside-link">
            <span class="al-label">Katalog</span>
            <span class="al-value">Druhy včel</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </aside>
    </div>

  </div>
</Layout>

<style>
  .vcela-page {
    --yellow: #FFEA00;
    --yellow-soft: #FFF6A8;
    --yellow-glow: rgba(255, 234, 0, .35);
    --ink: #0A0A0B;
    --body: #1E1E22;
    --muted: #6B6B72;
    --muted-2: #9A9AA3;
    --line: #EAEAEC;
    --bg-cream: #FBFAF4;
    --card: #FFFFFF;
    --r-xl: 24px;
    --r-lg: 18px;
    --r-md: 12px;
    --sh-1: 0 1px 2px rgba(10,10,12,.04), 0 0 0 1px rgba(10,10,12,.03);
    --sh-3: 0 18px 40px -12px rgba(10,10,12,.18), 0 0 0 1px rgba(10,10,12,.04);
    max-width: 1280px;
    margin: 0 auto;
    padding: 26px 24px 96px;
    color: var(--body);
  }

  .vcela-page .breadcrumb { display: flex; gap: 8px; align-items: center; font-size: 13px; color: var(--muted); margin-bottom: 22px; flex-wrap: wrap; }
  .vcela-page .breadcrumb a { color: var(--muted); text-decoration: none; }
  .vcela-page .breadcrumb a:hover { color: #000; }
  .vcela-page .breadcrumb svg { width: 14px; height: 14px; color: var(--muted-2); flex-shrink: 0; }
  .vcela-page .breadcrumb .current { color: #000; font-weight: 600; }

  .vcela-page .hero {
    position: relative; overflow: hidden; color: #fff; border-radius: var(--r-xl);
    background:
      radial-gradient(600px 300px at 15% 20%, rgba(255, 234, 0, .18), transparent 60%),
      radial-gradient(700px 400px at 90% 90%, rgba(255, 160, 0, .28), transparent 60%),
      linear-gradient(135deg, #14110E 0%, #1F1A14 60%, #2A2218 100%);
    padding: 44px 44px 38px; margin-bottom: 22px;
    box-shadow: var(--sh-3);
    display: grid; grid-template-columns: 1.4fr 1fr; gap: 32px; align-items: center;
  }
  .vcela-page .hero::before {
    content: ""; position: absolute; inset: 0; pointer-events: none; opacity: .35;
    background-image: linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(600px 400px at 70% 100%, black, transparent 70%);
  }
  .vcela-page .hero-left { position: relative; z-index: 2; }

  .vcela-page .hero-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 14px; }
  .vcela-page .tag {
    display: inline-flex; align-items: center; gap: 6px;
    font: 600 11px/1 'Chakra Petch', sans-serif; letter-spacing: .14em; text-transform: uppercase;
    padding: 6px 11px; border-radius: 6px;
  }
  .vcela-page .tag-vcela { background: var(--yellow); color: #0A0A0B; }
  .vcela-page .tag-temperament { background: rgba(255,255,255,.1); color: #fff; border: 1px solid rgba(255,255,255,.16); }
  .vcela-page .tag-vynos { background: rgba(255,255,255,.06); color: #c8c8d0; border: 1px solid rgba(255,255,255,.12); }

  .vcela-page .hero h1 {
    font-family: 'Chakra Petch', sans-serif; font-weight: 700;
    font-size: clamp(2.4rem, 5.5vw, 4.4rem); color: #fff; line-height: .96; letter-spacing: -.03em; margin: 0;
  }
  .vcela-page .hero-altnames { margin-top: 8px; font: 400 17px 'Roboto Condensed', sans-serif; color: var(--yellow); font-style: italic; }
  .vcela-page .hero-lede { max-width: 600px; font-size: 15.5px; color: #c8c8d0; margin: 14px 0 22px; line-height: 1.7; }

  .vcela-page .hero-actions { display: flex; gap: 10px; flex-wrap: wrap; }
  .vcela-page .cta-secondary {
    display: inline-flex; align-items: center; gap: 8px;
    color: #c8c8d0; background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.12);
    padding: 13px 16px; border-radius: 12px; text-decoration: none;
    font: 500 13px 'Chakra Petch', sans-serif;
    transition: .15s;
  }
  .vcela-page .cta-secondary:hover { background: rgba(255,255,255,.1); color: #fff; border-color: rgba(255,255,255,.2); }

  .vcela-page .hero-right { position: relative; z-index: 1; min-height: 280px; display: flex; align-items: center; justify-content: center; }
  .vcela-page .hero-emoji-card {
    width: 100%; min-height: 280px;
    background: linear-gradient(135deg, rgba(255,160,0,.2) 0%, rgba(255,100,0,.12) 100%);
    border-radius: 18px;
    border: 1px solid rgba(255,255,255,.1);
    box-shadow: 0 30px 60px -20px rgba(0,0,0,.5), 0 0 0 1px rgba(255,255,255,.04);
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14px;
    padding: 24px;
  }
  .vcela-page .hec-emoji { font-size: 120px; line-height: 1; filter: drop-shadow(0 12px 30px rgba(0,0,0,.4)); }
  .vcela-page .hec-name { font: 700 22px 'Chakra Petch', sans-serif; color: #fff; letter-spacing: -.01em; text-align: center; }

  .vcela-page .hero-photo {
    width: 100%; margin: 0; position: relative;
    border-radius: 18px; overflow: hidden;
    border: 1px solid rgba(255,255,255,.1);
    box-shadow: 0 30px 60px -20px rgba(0,0,0,.5), 0 0 0 1px rgba(255,255,255,.04);
    aspect-ratio: 4/3; background: #0A0A0B;
  }
  .vcela-page .hero-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .vcela-page .content-grid { display: grid; grid-template-columns: 1fr 320px; gap: 22px; }
  .vcela-page .content-main { display: flex; flex-direction: column; gap: 22px; }

  .vcela-page .spec-card, .vcela-page .related-card, .vcela-page .body-card, .vcela-page .faq-card {
    background: var(--card); border: 1px solid var(--line); border-radius: var(--r-xl);
    padding: 24px 24px 22px; box-shadow: var(--sh-1);
  }

  .vcela-page .prose { color: var(--body); font-size: 16px; line-height: 1.72; }
  .vcela-page .prose :global(p) { margin: 0 0 14px; }
  .vcela-page .prose :global(p:last-child) { margin-bottom: 0; }
  .vcela-page .prose :global(strong) { color: var(--ink); font-weight: 600; }
  .vcela-page .prose :global(a) {
    color: #0A5E2E; text-decoration: underline; text-decoration-color: rgba(11,122,59,.35);
    text-underline-offset: 2px; font-weight: 500;
  }
  .vcela-page .prose :global(a:hover) { text-decoration-color: #0B7A3B; background: var(--yellow-soft); }

  .vcela-page .wiki-link { margin: 0; font-size: 15px; }
  .vcela-page .wiki-link a { color: #0A5E2E; text-decoration: underline; text-underline-offset: 2px; }
  .vcela-page .wiki-link a:hover { text-decoration-color: #0B7A3B; }

  .vcela-page .faq-list { margin: 0; padding: 0; display: flex; flex-direction: column; }
  .vcela-page .faq-item { padding: 16px 0; border-bottom: 1px dashed var(--line); }
  .vcela-page .faq-item:first-child { padding-top: 0; }
  .vcela-page .faq-item:last-child { border-bottom: 0; padding-bottom: 0; }
  .vcela-page .faq-item dt { font: 600 16px/1.4 'Chakra Petch', sans-serif; color: var(--ink); margin: 0 0 8px; letter-spacing: -.005em; }
  .vcela-page .faq-item dd { margin: 0; font-size: 15px; line-height: 1.65; color: var(--body); }

  .vcela-page .card-head { display: flex; justify-content: space-between; align-items: center; gap: 12px; margin-bottom: 18px; flex-wrap: wrap; }
  .vcela-page .card-head h2 { font-family: 'Chakra Petch', sans-serif; font-size: 22px; font-weight: 700; letter-spacing: -.02em; margin: 0; line-height: 1.1; color: var(--ink); }
  .vcela-page .card-head-meta { font: 600 12px 'Chakra Petch', sans-serif; color: var(--muted); background: #FBFAF4; padding: 5px 10px; border-radius: 8px; }
  .vcela-page .card-head-link { font: 600 13px 'Chakra Petch', sans-serif; color: #0A0A0B; text-decoration: none; }
  .vcela-page .card-head-link:hover { color: #000; text-decoration: underline; }

  .vcela-page .spec-group { margin-bottom: 18px; }
  .vcela-page .spec-group:last-child { margin-bottom: 0; }
  .vcela-page .spec-group-label {
    font: 600 11px 'Chakra Petch', sans-serif; letter-spacing: .18em; text-transform: uppercase;
    color: var(--muted); margin-bottom: 10px; display: flex; align-items: center; gap: 10px;
  }
  .vcela-page .spec-group-label::after { content: ""; flex: 1; height: 1px; background: var(--line); }
  .vcela-page .spec-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 0 28px; margin: 0; padding: 0; }
  .vcela-page .spec-item {
    display: flex; justify-content: space-between; align-items: baseline; gap: 14px;
    padding: 11px 0; border-bottom: 1px dashed var(--line);
  }
  .vcela-page .spec-item:last-child { border-bottom: 0; }
  .vcela-page .spec-item dt { font: 500 12.5px 'Chakra Petch', sans-serif; color: var(--muted); letter-spacing: .02em; margin: 0; }
  .vcela-page .spec-item dd { font: 600 14px 'Chakra Petch', sans-serif; color: var(--ink); letter-spacing: -.005em; margin: 0; text-align: right; }

  .vcela-page .rel-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px; }
  .vcela-page .rel-card {
    display: block; text-decoration: none; color: inherit;
    background: #FBFAF4; border: 1px solid var(--line); border-radius: var(--r-md);
    padding: 14px 16px; transition: .18s;
  }
  .vcela-page .rel-card:hover { background: #fff; transform: translateY(-2px); box-shadow: var(--sh-1); border-color: var(--yellow); }
  .vcela-page .rel-name { font: 700 16px 'Chakra Petch', sans-serif; color: var(--ink); letter-spacing: -.005em; margin-bottom: 4px; }
  .vcela-page .rel-latin { font: 400 12px 'Roboto Condensed', sans-serif; color: var(--muted); font-style: italic; margin-bottom: 5px; }
  .vcela-page .rel-meta { font: 500 11px 'Chakra Petch', sans-serif; color: var(--muted); letter-spacing: .05em; }

  .vcela-page .content-aside { display: flex; flex-direction: column; gap: 14px; align-self: start; position: sticky; top: 104px; }
  .vcela-page .aside-card {
    background: var(--card); border: 1px solid var(--line); border-radius: var(--r-lg);
    padding: 18px; box-shadow: var(--sh-1);
  }
  .vcela-page .nav-card .acc-label {
    display: inline-block; font: 600 11px 'Chakra Petch', sans-serif; letter-spacing: .18em; text-transform: uppercase;
    color: var(--muted); margin-bottom: 10px;
  }
  .vcela-page .aside-link {
    display: flex; align-items: center; gap: 10px;
    padding: 11px 12px; border: 1px solid var(--line); border-radius: var(--r-md);
    text-decoration: none; color: var(--ink); background: #FBFAF4;
    margin-bottom: 8px; transition: .15s;
  }
  .vcela-page .aside-link:last-child { margin-bottom: 0; }
  .vcela-page .aside-link:hover { background: var(--yellow-soft); border-color: var(--yellow); }
  .vcela-page .al-label { font: 500 11px 'Chakra Petch', sans-serif; color: var(--muted); letter-spacing: .1em; text-transform: uppercase; flex-shrink: 0; }
  .vcela-page .al-value {
    font: 700 13.5px 'Chakra Petch', sans-serif; color: var(--ink);
    flex: 1; text-align: right; letter-spacing: -.005em;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .vcela-page .aside-link svg { width: 14px; height: 14px; color: var(--muted); flex-shrink: 0; }

  @media (max-width: 960px) {
    .vcela-page .hero { grid-template-columns: 1fr; padding: 30px 24px 26px; gap: 18px; }
    .vcela-page .hero-right { min-height: 220px; order: 2; }
    .vcela-page .hero-emoji-card { min-height: 220px; }
    .vcela-page .hec-emoji { font-size: 84px; }
    .vcela-page .content-grid { grid-template-columns: 1fr; }
    .vcela-page .content-aside { position: static; top: auto; }
  }
  @media (max-width: 600px) {
    .vcela-page { padding: 20px 16px 60px; }
    .vcela-page .spec-card, .vcela-page .related-card { padding: 18px; }
  }
</style>
