---
export const prerender = true;
import Layout from '../../../layouts/Layout.astro';
import { getAllVybaveni, getVybaveni, VYBAVENI_KATEGORIE_LABELS } from '../../../lib/vcelarstvi';
import { SITE_URL } from '../../../lib/config';

export function getStaticPaths() {
  return getAllVybaveni().map((v) => ({ params: { slug: v.slug } }));
}

const { slug } = Astro.params;
const item = getVybaveni(slug!);
if (!item) return Astro.rewrite('/404');

const canonical = `${SITE_URL}/vcelarstvi/vybaveni/${item.slug}/`;
const pageTitle = item.name;
const pageDesc = item.popis_kratky.length > 160 ? item.popis_kratky.slice(0, 157) + '…' : item.popis_kratky;

const kategorieLabel = VYBAVENI_KATEGORIE_LABELS[item.kategorie];

type SpecRow = { label: string; value: string };
const specs: SpecRow[] = [
  { label: 'Kategorie', value: kategorieLabel },
];
if (item.orientacni_cena) specs.push({ label: 'Orientační cena', value: item.orientacni_cena });
if (item.pro_zacatecniky) specs.push({ label: 'Vhodné pro', value: 'Začátečníky' });

const related = (item.related ?? []).map((s) => getVybaveni(s)).filter(Boolean) as NonNullable<ReturnType<typeof getVybaveni>>[];

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Domů', item: `${SITE_URL}/` },
    { '@type': 'ListItem', position: 2, name: 'Včelařství', item: `${SITE_URL}/vcelarstvi/` },
    { '@type': 'ListItem', position: 3, name: 'Včelařské vybavení', item: `${SITE_URL}/vcelarstvi/vybaveni/` },
    { '@type': 'ListItem', position: 4, name: item.name, item: canonical },
  ],
};

const propertyValues: Array<{ '@type': 'PropertyValue'; name: string; value: string }> = [
  { '@type': 'PropertyValue', name: 'Kategorie', value: kategorieLabel },
];
if (item.orientacni_cena) propertyValues.push({ '@type': 'PropertyValue', name: 'Orientační cena', value: item.orientacni_cena });
if (item.pro_zacatecniky) propertyValues.push({ '@type': 'PropertyValue', name: 'Vhodné pro začátečníky', value: 'Ano' });

const thingJsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: item.name,
  description: item.description,
  url: canonical,
  inLanguage: 'cs-CZ',
  ...(item.image_url && { image: item.image_url.startsWith('http') ? item.image_url : `${SITE_URL}${item.image_url}` }),
  additionalProperty: propertyValues,
};
---

<Layout title={pageTitle} description={pageDesc} canonical={canonical}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(thingJsonLd)} />

  <div class="vybaveni-page">

    <nav class="breadcrumb" aria-label="Cesta">
      <a href="/">Domů</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/vcelarstvi/">Včelařství</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/vcelarstvi/vybaveni/">Včelařské vybavení</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <span class="current">{item.name}</span>
    </nav>

    <section class="hero">
      <div class="hero-left">
        <div class="hero-tags">
          <span class="tag tag-kategorie">{kategorieLabel}</span>
          {item.pro_zacatecniky && <span class="tag tag-zac">pro začátečníky</span>}
        </div>
        <h1>{item.name}</h1>
        <p class="hero-lede">{item.popis_kratky}</p>
        {item.orientacni_cena && (
          <div class="hero-cena">Orientační cena: <strong>{item.orientacni_cena}</strong></div>
        )}
        <div class="hero-actions">
          <a class="cta-secondary" href="/vcelarstvi/vybaveni/">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
            Všechno vybavení
          </a>
        </div>
      </div>

      <div class="hero-right">
        {item.image_url ? (
          <figure class="hero-photo">
            <img src={item.image_url} alt={item.name} width="800" height="600" loading="eager" decoding="async" />
            {(item.image_credit || item.image_license) && (
              <figcaption class="hero-photo-credit">
                {item.image_source_url ? (
                  <a href={item.image_source_url} target="_blank" rel="noopener noreferrer">
                    {item.image_credit || 'Zdroj'}
                  </a>
                ) : (
                  <span>{item.image_credit}</span>
                )}
                {item.image_license && <span class="hero-photo-license"> · {item.image_license}</span>}
              </figcaption>
            )}
          </figure>
        ) : (
          <div class="hero-emoji-card">
            <div class="hec-emoji" aria-hidden="true">🔧</div>
            <div class="hec-name">{item.name}</div>
          </div>
        )}
      </div>
    </section>

    <div class="content-grid">
      <div class="content-main">

        <section class="spec-card">
          <div class="card-head">
            <h2>Parametry</h2>
            <span class="card-head-meta">{specs.length} {specs.length === 1 ? 'parametr' : specs.length < 5 ? 'parametry' : 'parametrů'}</span>
          </div>
          <div class="spec-group">
            <div class="spec-group-label">Základní informace</div>
            <dl class="spec-list">
              {specs.map((row) => (
                <div class="spec-item"><dt>{row.label}</dt><dd>{row.value}</dd></div>
              ))}
            </dl>
          </div>
        </section>

        <section class="body-card">
          <div class="prose" set:html={item.description.trim().split(/\n\n+/).map((p) => `<p>${p.replace(/\n/g, '<br>')}</p>`).join('')} />
        </section>

        {related.length > 0 && (
          <section class="related-card">
            <div class="card-head">
              <h2>Související vybavení</h2>
              <a class="card-head-link" href="/vcelarstvi/vybaveni/">Všechno vybavení →</a>
            </div>
            <div class="rel-grid">
              {related.map((r) => (
                <a href={`/vcelarstvi/vybaveni/${r.slug}/`} class="rel-card">
                  <div class="rel-name">{r.name}</div>
                  <div class="rel-kategorie">{VYBAVENI_KATEGORIE_LABELS[r.kategorie]}</div>
                  {r.orientacni_cena && <div class="rel-meta">{r.orientacni_cena}</div>}
                </a>
              ))}
            </div>
          </section>
        )}

      </div>

      <aside class="content-aside">
        <div class="aside-card nav-card">
          <span class="acc-label">Navigace</span>
          <a href="/vcelarstvi/" class="aside-link">
            <span class="al-label">Sekce</span>
            <span class="al-value">Včelařství</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>
          <a href="/vcelarstvi/vybaveni/" class="aside-link">
            <span class="al-label">Katalog</span>
            <span class="al-value">Vybavení</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
        {item.pro_zacatecniky && (
          <div class="aside-card starter-card">
            <div class="starter-icon" aria-hidden="true">✅</div>
            <div class="starter-label">Vhodné pro začátečníky</div>
            <p class="starter-desc">Toto vybavení doporučujeme i těm, kteří s včelařením teprve začínají.</p>
          </div>
        )}
      </aside>
    </div>

  </div>
</Layout>

<style>
  .vybaveni-page {
    --yellow: #FFEA00;
    --yellow-soft: #FFF6A8;
    --yellow-glow: rgba(255, 234, 0, .35);
    --ink: #0A0A0B;
    --body: #1E1E22;
    --muted: #6B6B72;
    --muted-2: #9A9AA3;
    --line: #EAEAEC;
    --bg-cream: #FBFAF4;
    --card: #FFFFFF;
    --r-xl: 24px;
    --r-lg: 18px;
    --r-md: 12px;
    --sh-1: 0 1px 2px rgba(10,10,12,.04), 0 0 0 1px rgba(10,10,12,.03);
    --sh-3: 0 18px 40px -12px rgba(10,10,12,.18), 0 0 0 1px rgba(10,10,12,.04);
    max-width: 1280px;
    margin: 0 auto;
    padding: 26px 24px 96px;
    color: var(--body);
  }

  .vybaveni-page .breadcrumb { display: flex; gap: 8px; align-items: center; font-size: 13px; color: var(--muted); margin-bottom: 22px; flex-wrap: wrap; }
  .vybaveni-page .breadcrumb a { color: var(--muted); text-decoration: none; }
  .vybaveni-page .breadcrumb a:hover { color: #000; }
  .vybaveni-page .breadcrumb svg { width: 14px; height: 14px; color: var(--muted-2); flex-shrink: 0; }
  .vybaveni-page .breadcrumb .current { color: #000; font-weight: 600; }

  .vybaveni-page .hero {
    position: relative; overflow: hidden; color: #fff; border-radius: var(--r-xl);
    background:
      radial-gradient(600px 300px at 15% 20%, rgba(255, 234, 0, .18), transparent 60%),
      radial-gradient(700px 400px at 90% 90%, rgba(255, 160, 0, .28), transparent 60%),
      linear-gradient(135deg, #14110E 0%, #1F1A14 60%, #2A2218 100%);
    padding: 44px 44px 38px; margin-bottom: 22px;
    box-shadow: var(--sh-3);
    display: grid; grid-template-columns: 1.4fr 1fr; gap: 32px; align-items: center;
  }
  .vybaveni-page .hero::before {
    content: ""; position: absolute; inset: 0; pointer-events: none; opacity: .35;
    background-image: linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(600px 400px at 70% 100%, black, transparent 70%);
  }
  .vybaveni-page .hero-left { position: relative; z-index: 2; }

  .vybaveni-page .hero-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 14px; }
  .vybaveni-page .tag {
    display: inline-flex; align-items: center; gap: 6px;
    font: 600 11px/1 'Chakra Petch', sans-serif; letter-spacing: .14em; text-transform: uppercase;
    padding: 6px 11px; border-radius: 6px;
  }
  .vybaveni-page .tag-kategorie { background: var(--yellow); color: #0A0A0B; }
  .vybaveni-page .tag-zac { background: rgba(255,255,255,.1); color: #fff; border: 1px solid rgba(255,255,255,.16); }

  .vybaveni-page .hero h1 {
    font-family: 'Chakra Petch', sans-serif; font-weight: 700;
    font-size: clamp(2.4rem, 5.5vw, 4.4rem); color: #fff; line-height: .96; letter-spacing: -.03em; margin: 0;
  }
  .vybaveni-page .hero-lede { max-width: 600px; font-size: 15.5px; color: #c8c8d0; margin: 14px 0 16px; line-height: 1.7; }
  .vybaveni-page .hero-cena {
    font: 500 14px 'Chakra Petch', sans-serif; color: #c8c8d0; margin-bottom: 20px; letter-spacing: .02em;
  }
  .vybaveni-page .hero-cena strong { color: var(--yellow); font-weight: 700; }

  .vybaveni-page .hero-actions { display: flex; gap: 10px; flex-wrap: wrap; }
  .vybaveni-page .cta-secondary {
    display: inline-flex; align-items: center; gap: 8px;
    color: #c8c8d0; background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.12);
    padding: 13px 16px; border-radius: 12px; text-decoration: none;
    font: 500 13px 'Chakra Petch', sans-serif;
    transition: .15s;
  }
  .vybaveni-page .cta-secondary:hover { background: rgba(255,255,255,.1); color: #fff; border-color: rgba(255,255,255,.2); }

  .vybaveni-page .hero-right { position: relative; z-index: 1; min-height: 280px; display: flex; align-items: center; justify-content: center; }
  .vybaveni-page .hero-emoji-card {
    width: 100%; min-height: 280px;
    background: linear-gradient(135deg, rgba(255,160,0,.2) 0%, rgba(255,100,0,.12) 100%);
    border-radius: 18px;
    border: 1px solid rgba(255,255,255,.1);
    box-shadow: 0 30px 60px -20px rgba(0,0,0,.5), 0 0 0 1px rgba(255,255,255,.04);
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14px;
    padding: 24px;
  }
  .vybaveni-page .hec-emoji { font-size: 120px; line-height: 1; filter: drop-shadow(0 12px 30px rgba(0,0,0,.4)); }
  .vybaveni-page .hec-name { font: 700 22px 'Chakra Petch', sans-serif; color: #fff; letter-spacing: -.01em; text-align: center; }

  .vybaveni-page .hero-photo {
    width: 100%; margin: 0; position: relative;
    border-radius: 18px; overflow: hidden;
    border: 1px solid rgba(255,255,255,.1);
    box-shadow: 0 30px 60px -20px rgba(0,0,0,.5), 0 0 0 1px rgba(255,255,255,.04);
    aspect-ratio: 4/3; background: #0A0A0B;
  }
  .vybaveni-page .hero-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .vybaveni-page .hero-photo-credit {
    position: absolute; left: 0; right: 0; bottom: 0;
    padding: 18px 16px 10px;
    background: linear-gradient(to top, rgba(0,0,0,.7), transparent);
    font: 500 11px 'Chakra Petch', sans-serif;
    color: rgba(255,255,255,.78); letter-spacing: .04em;
  }
  .vybaveni-page .hero-photo-credit a { color: rgba(255,255,255,.9); text-decoration: underline; text-decoration-color: rgba(255,255,255,.3); text-underline-offset: 2px; }
  .vybaveni-page .hero-photo-credit a:hover { color: #fff; text-decoration-color: rgba(255,255,255,.7); }
  .vybaveni-page .hero-photo-license { color: rgba(255,255,255,.55); }

  .vybaveni-page .content-grid { display: grid; grid-template-columns: 1fr 320px; gap: 22px; }
  .vybaveni-page .content-main { display: flex; flex-direction: column; gap: 22px; }

  .vybaveni-page .spec-card, .vybaveni-page .related-card, .vybaveni-page .body-card {
    background: var(--card); border: 1px solid var(--line); border-radius: var(--r-xl);
    padding: 24px 24px 22px; box-shadow: var(--sh-1);
  }

  .vybaveni-page .prose { color: var(--body); font-size: 16px; line-height: 1.72; }
  .vybaveni-page .prose :global(p) { margin: 0 0 14px; }
  .vybaveni-page .prose :global(p:last-child) { margin-bottom: 0; }
  .vybaveni-page .prose :global(strong) { color: var(--ink); font-weight: 600; }
  .vybaveni-page .prose :global(a) {
    color: #0A5E2E; text-decoration: underline; text-decoration-color: rgba(11,122,59,.35);
    text-underline-offset: 2px; font-weight: 500;
  }
  .vybaveni-page .prose :global(a:hover) { text-decoration-color: #0B7A3B; background: var(--yellow-soft); }

  .vybaveni-page .card-head { display: flex; justify-content: space-between; align-items: center; gap: 12px; margin-bottom: 18px; flex-wrap: wrap; }
  .vybaveni-page .card-head h2 { font-family: 'Chakra Petch', sans-serif; font-size: 22px; font-weight: 700; letter-spacing: -.02em; margin: 0; line-height: 1.1; color: var(--ink); }
  .vybaveni-page .card-head-meta { font: 600 12px 'Chakra Petch', sans-serif; color: var(--muted); background: #FBFAF4; padding: 5px 10px; border-radius: 8px; }
  .vybaveni-page .card-head-link { font: 600 13px 'Chakra Petch', sans-serif; color: #0A0A0B; text-decoration: none; }
  .vybaveni-page .card-head-link:hover { color: #000; text-decoration: underline; }

  .vybaveni-page .spec-group { margin-bottom: 18px; }
  .vybaveni-page .spec-group:last-child { margin-bottom: 0; }
  .vybaveni-page .spec-group-label {
    font: 600 11px 'Chakra Petch', sans-serif; letter-spacing: .18em; text-transform: uppercase;
    color: var(--muted); margin-bottom: 10px; display: flex; align-items: center; gap: 10px;
  }
  .vybaveni-page .spec-group-label::after { content: ""; flex: 1; height: 1px; background: var(--line); }
  .vybaveni-page .spec-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 0 28px; margin: 0; padding: 0; }
  .vybaveni-page .spec-item {
    display: flex; justify-content: space-between; align-items: baseline; gap: 14px;
    padding: 11px 0; border-bottom: 1px dashed var(--line);
  }
  .vybaveni-page .spec-item:last-child { border-bottom: 0; }
  .vybaveni-page .spec-item dt { font: 500 12.5px 'Chakra Petch', sans-serif; color: var(--muted); letter-spacing: .02em; margin: 0; }
  .vybaveni-page .spec-item dd { font: 600 14px 'Chakra Petch', sans-serif; color: var(--ink); letter-spacing: -.005em; margin: 0; text-align: right; }

  .vybaveni-page .rel-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px; }
  .vybaveni-page .rel-card {
    display: block; text-decoration: none; color: inherit;
    background: #FBFAF4; border: 1px solid var(--line); border-radius: var(--r-md);
    padding: 14px 16px; transition: .18s;
  }
  .vybaveni-page .rel-card:hover { background: #fff; transform: translateY(-2px); box-shadow: var(--sh-1); border-color: var(--yellow); }
  .vybaveni-page .rel-name { font: 700 16px 'Chakra Petch', sans-serif; color: var(--ink); letter-spacing: -.005em; margin-bottom: 4px; }
  .vybaveni-page .rel-kategorie { font: 400 12px 'Roboto Condensed', sans-serif; color: var(--muted); margin-bottom: 5px; }
  .vybaveni-page .rel-meta { font: 500 11px 'Chakra Petch', sans-serif; color: var(--muted); letter-spacing: .05em; }

  .vybaveni-page .content-aside { display: flex; flex-direction: column; gap: 14px; align-self: start; position: sticky; top: 104px; }
  .vybaveni-page .aside-card {
    background: var(--card); border: 1px solid var(--line); border-radius: var(--r-lg);
    padding: 18px; box-shadow: var(--sh-1);
  }
  .vybaveni-page .nav-card .acc-label {
    display: inline-block; font: 600 11px 'Chakra Petch', sans-serif; letter-spacing: .18em; text-transform: uppercase;
    color: var(--muted); margin-bottom: 10px;
  }
  .vybaveni-page .aside-link {
    display: flex; align-items: center; gap: 10px;
    padding: 11px 12px; border: 1px solid var(--line); border-radius: var(--r-md);
    text-decoration: none; color: var(--ink); background: #FBFAF4;
    margin-bottom: 8px; transition: .15s;
  }
  .vybaveni-page .aside-link:last-child { margin-bottom: 0; }
  .vybaveni-page .aside-link:hover { background: var(--yellow-soft); border-color: var(--yellow); }
  .vybaveni-page .al-label { font: 500 11px 'Chakra Petch', sans-serif; color: var(--muted); letter-spacing: .1em; text-transform: uppercase; flex-shrink: 0; }
  .vybaveni-page .al-value {
    font: 700 13.5px 'Chakra Petch', sans-serif; color: var(--ink);
    flex: 1; text-align: right; letter-spacing: -.005em;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .vybaveni-page .aside-link svg { width: 14px; height: 14px; color: var(--muted); flex-shrink: 0; }

  .vybaveni-page .starter-card { text-align: center; }
  .vybaveni-page .starter-icon { font-size: 32px; margin-bottom: 8px; }
  .vybaveni-page .starter-label { font: 700 14px 'Chakra Petch', sans-serif; color: var(--ink); letter-spacing: -.005em; margin-bottom: 6px; }
  .vybaveni-page .starter-desc { font-size: 13px; color: var(--muted); line-height: 1.5; margin: 0; }

  @media (max-width: 960px) {
    .vybaveni-page .hero { grid-template-columns: 1fr; padding: 30px 24px 26px; gap: 18px; }
    .vybaveni-page .hero-right { min-height: 220px; order: 2; }
    .vybaveni-page .hero-emoji-card { min-height: 220px; }
    .vybaveni-page .hec-emoji { font-size: 84px; }
    .vybaveni-page .content-grid { grid-template-columns: 1fr; }
    .vybaveni-page .content-aside { position: static; top: auto; }
  }
  @media (max-width: 600px) {
    .vybaveni-page { padding: 20px 16px 60px; }
    .vybaveni-page .spec-card, .vybaveni-page .related-card { padding: 18px; }
  }
</style>
