---
export const prerender = false;
import Layout from '../../../layouts/Layout.astro';
import { getAllMed, getMed, medTypLabel, medKrystalizaceLabel } from '../../../lib/vcelarstvi';
import { SITE_URL } from '../../../lib/config';
import { useTranslations, getLocaleFromUrl, localizePath, plural } from '../../../i18n/utils';

const locale = Astro.locals.locale ?? getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const isSk = locale === 'sk';
const base = isSk ? '/sk' : '';
const bcp47 = isSk ? 'sk-SK' : 'cs-CZ';
Astro.response.headers.set('Cache-Control', 'public, max-age=600, s-maxage=3600, stale-while-revalidate=86400');

const { slug } = Astro.params;
const med = getMed(slug!, locale);
if (!med) return Astro.rewrite('/404');

const canonical = `${SITE_URL}${base}/vcelarstvi/med/${med.slug}/`;
const pageTitle = med.name;
const pageDesc = med.popis_kratky.length > 160 ? med.popis_kratky.slice(0, 157) + '…' : med.popis_kratky;

const typLabel = medTypLabel(med.typ, locale);
const krystLabel = medKrystalizaceLabel(med.krystalizace, locale);

type SpecRow = { label: string; value: string };
const specs: SpecRow[] = [
  { label: t('vcel.spec.typ'), value: typLabel },
  { label: t('vcel.spec.zdrojSnusky'), value: med.zdroj_snusky },
  { label: t('vcel.spec.barva'), value: med.barva },
  { label: t('vcel.spec.chut'), value: med.chut },
  { label: t('vcel.spec.krystalizace'), value: krystLabel },
];

const related = getAllMed(locale).filter((m) => m.slug !== med.slug).slice(0, 4);

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t('vcel.bc.home'), item: `${SITE_URL}${base}/` },
    { '@type': 'ListItem', position: 2, name: t('vcel.crumb'), item: `${SITE_URL}${base}/vcelarstvi/` },
    { '@type': 'ListItem', position: 3, name: t('vcel.med.crumb'), item: `${SITE_URL}${base}/vcelarstvi/med/` },
    { '@type': 'ListItem', position: 4, name: med.name, item: canonical },
  ],
};

const propertyValues: Array<{ '@type': 'PropertyValue'; name: string; value: string }> = [
  { '@type': 'PropertyValue', name: t('vcel.spec.typ'), value: typLabel },
  { '@type': 'PropertyValue', name: t('vcel.spec.zdrojSnusky'), value: med.zdroj_snusky },
  { '@type': 'PropertyValue', name: t('vcel.spec.barva'), value: med.barva },
  { '@type': 'PropertyValue', name: t('vcel.spec.chut'), value: med.chut },
  { '@type': 'PropertyValue', name: t('vcel.spec.krystalizace'), value: krystLabel },
];

const thingJsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Thing',
  name: med.name,
  description: med.description,
  url: canonical,
  inLanguage: bcp47,
  ...(med.image_url && { image: med.image_url.startsWith('http') ? med.image_url : `${SITE_URL}${med.image_url}` }),
  additionalProperty: propertyValues,
};
---

<Layout title={pageTitle} description={pageDesc} canonical={canonical}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(thingJsonLd)} />

  <div class="med-page">

    <nav class="breadcrumb" aria-label="Cesta">
      <a href={localizePath(locale, '/')}>{t('vcel.bc.home')}</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <a href={localizePath(locale, '/vcelarstvi/')}>{t('vcel.crumb')}</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <a href={localizePath(locale, '/vcelarstvi/med/')}>{t('vcel.med.crumb')}</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <span class="current">{med.name}</span>
    </nav>

    <section class="hero">
      <div class="hero-left">
        <div class="hero-tags">
          <span class={`tag tag-typ tag-typ-${med.typ}`}>{typLabel}</span>
          <span class="tag tag-kryst">{krystLabel} {t('vcel.krystalizace.word')}</span>
        </div>
        <h1>{med.name}</h1>
        <p class="hero-lede">{med.popis_kratky}</p>
        <div class="hero-actions">
          <a class="cta-secondary" href={localizePath(locale, '/vcelarstvi/med/')}>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
            {t('vcel.med.vsechnyDruhyBtn')}
          </a>
        </div>
      </div>

      <div class="hero-right">
        {med.image_url ? (
          <figure class="hero-photo">
            <img src={med.image_url} alt={med.name} width="800" height="600" loading="eager" decoding="async" />
            {(med.image_credit || med.image_license) && (
              <figcaption class="hero-photo-credit">
                {med.image_source_url ? (
                  <a href={med.image_source_url} target="_blank" rel="noopener noreferrer">
                    {med.image_credit || 'Zdroj'}
                  </a>
                ) : (
                  <span>{med.image_credit}</span>
                )}
                {med.image_license && <span class="hero-photo-license"> · {med.image_license}</span>}
              </figcaption>
            )}
          </figure>
        ) : (
          <div class="hero-emoji-card">
            <div class="hec-emoji" aria-hidden="true">🍯</div>
            <div class="hec-name">{med.name}</div>
          </div>
        )}
      </div>
    </section>

    <div class="content-grid">
      <div class="content-main">

        <section class="spec-card">
          <div class="card-head">
            <h2>{t('vcel.med.charakteristika')}</h2>
            <span class="card-head-meta">{specs.length} {plural(locale, specs.length, { one: t('vcel.param.one'), few: t('vcel.param.few'), many: t('vcel.param.many') })}</span>
          </div>
          <div class="spec-group">
            <div class="spec-group-label">{t('vcel.spec.groupZakladni')}</div>
            <dl class="spec-list">
              {specs.map((row) => (
                <div class="spec-item"><dt>{row.label}</dt><dd>{row.value}</dd></div>
              ))}
            </dl>
          </div>
        </section>

        <section class="body-card">
          <div class="prose" set:html={med.description.trim().split(/\n\n+/).map((p) => `<p>${p.replace(/\n/g, '<br>')}</p>`).join('')} />
        </section>

        {related.length > 0 && (
          <section class="related-card">
            <div class="card-head">
              <h2>{t('vcel.med.dalsiDruhy')}</h2>
              <a class="card-head-link" href={localizePath(locale, '/vcelarstvi/med/')}>{t('vcel.vsechnyDruhy')}</a>
            </div>
            <div class="rel-grid">
              {related.map((r) => (
                <a href={localizePath(locale, `/vcelarstvi/med/${r.slug}/`)} class="rel-card">
                  <div class="rel-name">{r.name}</div>
                  <div class="rel-typ">{medTypLabel(r.typ, locale)}</div>
                  <div class="rel-meta">{medKrystalizaceLabel(r.krystalizace, locale)} {t('vcel.krystalizace.word')}</div>
                </a>
              ))}
            </div>
          </section>
        )}

      </div>

      <aside class="content-aside">
        <div class="aside-card nav-card">
          <span class="acc-label">{t('vcel.aside.navigace')}</span>
          <a href={localizePath(locale, '/vcelarstvi/')} class="aside-link">
            <span class="al-label">{t('vcel.aside.sekce')}</span>
            <span class="al-value">{t('vcel.aside.sekceVal')}</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>
          <a href={localizePath(locale, '/vcelarstvi/med/')} class="aside-link">
            <span class="al-label">{t('vcel.aside.katalog')}</span>
            <span class="al-value">{t('vcel.med.katalogVal')}</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
      </aside>
    </div>

  </div>
</Layout>

<style>
  .med-page {
    --yellow: #FFEA00;
    --yellow-soft: #FFF6A8;
    --yellow-glow: rgba(255, 234, 0, .35);
    --ink: #0A0A0B;
    --body: #1E1E22;
    --muted: #6B6B72;
    --muted-2: #9A9AA3;
    --line: #EAEAEC;
    --bg-cream: #FBFAF4;
    --card: #FFFFFF;
    --r-xl: 24px;
    --r-lg: 18px;
    --r-md: 12px;
    --sh-1: 0 1px 2px rgba(10,10,12,.04), 0 0 0 1px rgba(10,10,12,.03);
    --sh-3: 0 18px 40px -12px rgba(10,10,12,.18), 0 0 0 1px rgba(10,10,12,.04);
    max-width: 1280px;
    margin: 0 auto;
    padding: 26px 24px 96px;
    color: var(--body);
  }

  .med-page .breadcrumb { display: flex; gap: 8px; align-items: center; font-size: 13px; color: var(--muted); margin-bottom: 22px; flex-wrap: wrap; }
  .med-page .breadcrumb a { color: var(--muted); text-decoration: none; }
  .med-page .breadcrumb a:hover { color: #000; }
  .med-page .breadcrumb svg { width: 14px; height: 14px; color: var(--muted-2); flex-shrink: 0; }
  .med-page .breadcrumb .current { color: #000; font-weight: 600; }

  .med-page .hero {
    position: relative; overflow: hidden; color: #fff; border-radius: var(--r-xl);
    background:
      radial-gradient(600px 300px at 15% 20%, rgba(255, 234, 0, .18), transparent 60%),
      radial-gradient(700px 400px at 90% 90%, rgba(255, 160, 0, .28), transparent 60%),
      linear-gradient(135deg, #14110E 0%, #1F1A14 60%, #2A2218 100%);
    padding: 44px 44px 38px; margin-bottom: 22px;
    box-shadow: var(--sh-3);
    display: grid; grid-template-columns: 1.4fr 1fr; gap: 32px; align-items: center;
  }
  .med-page .hero::before {
    content: ""; position: absolute; inset: 0; pointer-events: none; opacity: .35;
    background-image: linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(600px 400px at 70% 100%, black, transparent 70%);
  }
  .med-page .hero-left { position: relative; z-index: 2; }

  .med-page .hero-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 14px; }
  .med-page .tag {
    display: inline-flex; align-items: center; gap: 6px;
    font: 600 11px/1 'Chakra Petch', sans-serif; letter-spacing: .14em; text-transform: uppercase;
    padding: 6px 11px; border-radius: 6px;
  }
  .med-page .tag-typ-kvetovy { background: var(--yellow); color: #0A0A0B; }
  .med-page .tag-typ-medovicovy { background: rgba(139, 90, 43, .9); color: #fff; }
  .med-page .tag-typ-smiseny { background: rgba(255,255,255,.15); color: #fff; border: 1px solid rgba(255,255,255,.2); }
  .med-page .tag-kryst { background: rgba(255,255,255,.06); color: #c8c8d0; border: 1px solid rgba(255,255,255,.12); }

  .med-page .hero h1 {
    font-family: 'Chakra Petch', sans-serif; font-weight: 700;
    font-size: clamp(2.4rem, 5.5vw, 4.4rem); color: #fff; line-height: .96; letter-spacing: -.03em; margin: 0;
  }
  .med-page .hero-lede { max-width: 600px; font-size: 15.5px; color: #c8c8d0; margin: 14px 0 22px; line-height: 1.7; }

  .med-page .hero-actions { display: flex; gap: 10px; flex-wrap: wrap; }
  .med-page .cta-secondary {
    display: inline-flex; align-items: center; gap: 8px;
    color: #c8c8d0; background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.12);
    padding: 13px 16px; border-radius: 12px; text-decoration: none;
    font: 500 13px 'Chakra Petch', sans-serif;
    transition: .15s;
  }
  .med-page .cta-secondary:hover { background: rgba(255,255,255,.1); color: #fff; border-color: rgba(255,255,255,.2); }

  .med-page .hero-right { position: relative; z-index: 1; min-height: 280px; display: flex; align-items: center; justify-content: center; }
  .med-page .hero-emoji-card {
    width: 100%; min-height: 280px;
    background: linear-gradient(135deg, rgba(255,160,0,.2) 0%, rgba(255,100,0,.12) 100%);
    border-radius: 18px;
    border: 1px solid rgba(255,255,255,.1);
    box-shadow: 0 30px 60px -20px rgba(0,0,0,.5), 0 0 0 1px rgba(255,255,255,.04);
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14px;
    padding: 24px;
  }
  .med-page .hec-emoji { font-size: 120px; line-height: 1; filter: drop-shadow(0 12px 30px rgba(0,0,0,.4)); }
  .med-page .hec-name { font: 700 22px 'Chakra Petch', sans-serif; color: #fff; letter-spacing: -.01em; text-align: center; }

  .med-page .hero-photo {
    width: 100%; margin: 0; position: relative;
    border-radius: 18px; overflow: hidden;
    border: 1px solid rgba(255,255,255,.1);
    box-shadow: 0 30px 60px -20px rgba(0,0,0,.5), 0 0 0 1px rgba(255,255,255,.04);
    aspect-ratio: 4/3; background: #0A0A0B;
  }
  .med-page .hero-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .med-page .hero-photo-credit {
    position: absolute; left: 0; right: 0; bottom: 0;
    padding: 18px 16px 10px;
    background: linear-gradient(to top, rgba(0,0,0,.7), transparent);
    font: 500 11px 'Chakra Petch', sans-serif;
    color: rgba(255,255,255,.78); letter-spacing: .04em;
  }
  .med-page .hero-photo-credit a { color: rgba(255,255,255,.9); text-decoration: underline; text-decoration-color: rgba(255,255,255,.3); text-underline-offset: 2px; }
  .med-page .hero-photo-credit a:hover { color: #fff; text-decoration-color: rgba(255,255,255,.7); }
  .med-page .hero-photo-license { color: rgba(255,255,255,.55); }

  .med-page .content-grid { display: grid; grid-template-columns: 1fr 320px; gap: 22px; }
  .med-page .content-main { display: flex; flex-direction: column; gap: 22px; }

  .med-page .spec-card, .med-page .related-card, .med-page .body-card {
    background: var(--card); border: 1px solid var(--line); border-radius: var(--r-xl);
    padding: 24px 24px 22px; box-shadow: var(--sh-1);
  }

  .med-page .prose { color: var(--body); font-size: 16px; line-height: 1.72; }
  .med-page .prose :global(p) { margin: 0 0 14px; }
  .med-page .prose :global(p:last-child) { margin-bottom: 0; }
  .med-page .prose :global(strong) { color: var(--ink); font-weight: 600; }
  .med-page .prose :global(a) {
    color: #0A5E2E; text-decoration: underline; text-decoration-color: rgba(11,122,59,.35);
    text-underline-offset: 2px; font-weight: 500;
  }
  .med-page .prose :global(a:hover) { text-decoration-color: #0B7A3B; background: var(--yellow-soft); }

  .med-page .card-head { display: flex; justify-content: space-between; align-items: center; gap: 12px; margin-bottom: 18px; flex-wrap: wrap; }
  .med-page .card-head h2 { font-family: 'Chakra Petch', sans-serif; font-size: 22px; font-weight: 700; letter-spacing: -.02em; margin: 0; line-height: 1.1; color: var(--ink); }
  .med-page .card-head-meta { font: 600 12px 'Chakra Petch', sans-serif; color: var(--muted); background: #FBFAF4; padding: 5px 10px; border-radius: 8px; }
  .med-page .card-head-link { font: 600 13px 'Chakra Petch', sans-serif; color: #0A0A0B; text-decoration: none; }
  .med-page .card-head-link:hover { color: #000; text-decoration: underline; }

  .med-page .spec-group { margin-bottom: 18px; }
  .med-page .spec-group:last-child { margin-bottom: 0; }
  .med-page .spec-group-label {
    font: 600 11px 'Chakra Petch', sans-serif; letter-spacing: .18em; text-transform: uppercase;
    color: var(--muted); margin-bottom: 10px; display: flex; align-items: center; gap: 10px;
  }
  .med-page .spec-group-label::after { content: ""; flex: 1; height: 1px; background: var(--line); }
  .med-page .spec-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 0 28px; margin: 0; padding: 0; }
  .med-page .spec-item {
    display: flex; justify-content: space-between; align-items: baseline; gap: 14px;
    padding: 11px 0; border-bottom: 1px dashed var(--line);
  }
  .med-page .spec-item:last-child { border-bottom: 0; }
  .med-page .spec-item dt { font: 500 12.5px 'Chakra Petch', sans-serif; color: var(--muted); letter-spacing: .02em; margin: 0; }
  .med-page .spec-item dd { font: 600 14px 'Chakra Petch', sans-serif; color: var(--ink); letter-spacing: -.005em; margin: 0; text-align: right; }

  .med-page .rel-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px; }
  .med-page .rel-card {
    display: block; text-decoration: none; color: inherit;
    background: #FBFAF4; border: 1px solid var(--line); border-radius: var(--r-md);
    padding: 14px 16px; transition: .18s;
  }
  .med-page .rel-card:hover { background: #fff; transform: translateY(-2px); box-shadow: var(--sh-1); border-color: var(--yellow); }
  .med-page .rel-name { font: 700 16px 'Chakra Petch', sans-serif; color: var(--ink); letter-spacing: -.005em; margin-bottom: 4px; }
  .med-page .rel-typ { font: 400 12px 'Roboto Condensed', sans-serif; color: var(--muted); margin-bottom: 5px; }
  .med-page .rel-meta { font: 500 11px 'Chakra Petch', sans-serif; color: var(--muted); letter-spacing: .05em; }

  .med-page .content-aside { display: flex; flex-direction: column; gap: 14px; align-self: start; position: sticky; top: 104px; }
  .med-page .aside-card {
    background: var(--card); border: 1px solid var(--line); border-radius: var(--r-lg);
    padding: 18px; box-shadow: var(--sh-1);
  }
  .med-page .nav-card .acc-label {
    display: inline-block; font: 600 11px 'Chakra Petch', sans-serif; letter-spacing: .18em; text-transform: uppercase;
    color: var(--muted); margin-bottom: 10px;
  }
  .med-page .aside-link {
    display: flex; align-items: center; gap: 10px;
    padding: 11px 12px; border: 1px solid var(--line); border-radius: var(--r-md);
    text-decoration: none; color: var(--ink); background: #FBFAF4;
    margin-bottom: 8px; transition: .15s;
  }
  .med-page .aside-link:last-child { margin-bottom: 0; }
  .med-page .aside-link:hover { background: var(--yellow-soft); border-color: var(--yellow); }
  .med-page .al-label { font: 500 11px 'Chakra Petch', sans-serif; color: var(--muted); letter-spacing: .1em; text-transform: uppercase; flex-shrink: 0; }
  .med-page .al-value {
    font: 700 13.5px 'Chakra Petch', sans-serif; color: var(--ink);
    flex: 1; text-align: right; letter-spacing: -.005em;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .med-page .aside-link svg { width: 14px; height: 14px; color: var(--muted); flex-shrink: 0; }

  @media (max-width: 960px) {
    .med-page .hero { grid-template-columns: 1fr; padding: 30px 24px 26px; gap: 18px; }
    .med-page .hero-right { min-height: 220px; order: 2; }
    .med-page .hero-emoji-card { min-height: 220px; }
    .med-page .hec-emoji { font-size: 84px; }
    .med-page .content-grid { grid-template-columns: 1fr; }
    .med-page .content-aside { position: static; top: auto; }
  }
  @media (max-width: 600px) {
    .med-page { padding: 20px 16px 60px; }
    .med-page .spec-card, .med-page .related-card { padding: 18px; }
  }
</style>
