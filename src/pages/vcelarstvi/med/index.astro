---
export const prerender = true;
import Layout from '../../../layouts/Layout.astro';
import { getAllMed, MED_TYP_LABELS } from '../../../lib/vcelarstvi';
import { SITE_URL } from '../../../lib/config';

const all = getAllMed();

const title = 'Druhy medu — přehled a srovnání';
const description = 'Přehled a srovnání druhů medu: akátový, květový, medovicový, lipový, řepkový, pohankový a pastovaný. Typ, barva, chuť a krystalizace.';

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Domů', item: `${SITE_URL}/` },
    { '@type': 'ListItem', position: 2, name: 'Včelařství', item: `${SITE_URL}/vcelarstvi/` },
    { '@type': 'ListItem', position: 3, name: 'Druhy medu', item: `${SITE_URL}/vcelarstvi/med/` },
  ],
};

const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  url: `${SITE_URL}/vcelarstvi/med/`,
  inLanguage: 'cs-CZ',
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: all.length,
    itemListElement: all.map((m, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `${SITE_URL}/vcelarstvi/med/${m.slug}/`,
      name: m.name,
    })),
  },
};
---

<Layout title={title} description={description}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(collectionJsonLd)} />

  <div class="med-listing-root">

    <nav class="breadcrumb" aria-label="Cesta">
      <a href="/">Domů</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <a href="/vcelarstvi/">Včelařství</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      <span class="current">Druhy medu</span>
    </nav>

    <section class="hero">
      <div class="hero-left">
        <span class="kicker"><span class="dot"></span>Katalog · Včelařství</span>
        <h1>Druhy <em>medu</em></h1>
        <p class="hero-lede">{description}</p>
        <div class="hero-stats">
          <div class="s"><span class="n">{all.length}</span><span class="l">druhů medu</span></div>
          <div class="s"><span class="n">3</span><span class="l">typy snůšky</span></div>
        </div>
      </div>
      <div class="hero-right">
        <div class="hero-emoji-tile" aria-hidden="true">🍯</div>
      </div>
    </section>

    <section class="compare-section">
      <div class="card-head">
        <h2>Srovnávací tabulka druhů medu</h2>
        <span class="card-head-meta">{all.length} druhů</span>
      </div>
      <div class="table-wrap">
        <table class="compare-table">
          <thead>
            <tr>
              <th>Med</th>
              <th>Typ</th>
              <th>Barva</th>
              <th>Krystalizace</th>
            </tr>
          </thead>
          <tbody>
            {all.map((m) => (
              <tr>
                <td class="td-name">
                  <a href={`/vcelarstvi/med/${m.slug}/`}>{m.name}</a>
                </td>
                <td>
                  <span class={`typ-badge typ-${m.typ}`}>{MED_TYP_LABELS[m.typ]}</span>
                </td>
                <td class="td-barva">{m.barva}</td>
                <td>
                  <span class={`kryst-badge kryst-${m.krystalizace.replace(/ /g, '-')}`}>{m.krystalizace}</span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="cards-section">
      <h2 class="section-title">
        Průvodce druhy medu
        <span class="section-title-c">{all.length}</span>
      </h2>
      <div class="med-grid">
        {all.map((m) => (
          <a href={`/vcelarstvi/med/${m.slug}/`} class="med-card">
            {m.image_url ? (
              <div class="mc-photo" style={`background-image:url('${m.image_url}')`} role="img" aria-label={m.name}></div>
            ) : (
              <div class="mc-photo mc-photo-fallback" aria-hidden="true">🍯</div>
            )}
            <div class="mc-body">
              <div class="mc-tags">
                <span class={`mc-tag mc-tag-typ mc-tag-${m.typ}`}>{MED_TYP_LABELS[m.typ]}</span>
                <span class="mc-tag">{m.krystalizace} krystalizace</span>
              </div>
              <div class="mc-name">{m.name}</div>
              <p class="mc-desc">{m.popis_kratky}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="big-cta">
      <div>
        <span class="cta-kicker">Více o včelařství</span>
        <h2>Průvodce včelařstvím<br />pro začátečníky i pokročilé.</h2>
        <p>Vše o úlech, vybavení, medu a sezónní péči na jednom místě.</p>
        <div class="cta-actions">
          <a class="cta-btn primary" href="/vcelarstvi/">
            Zpět na včelařství
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
      </div>
    </section>

  </div>
</Layout>

<style>
  .med-listing-root {
    --yellow: #FFEA00;
    --yellow-soft: #FFF6A8;
    --yellow-glow: rgba(255, 234, 0, .35);
    --ink: #0A0A0B;
    --body: #1E1E22;
    --muted: #6B6B72;
    --muted-2: #9A9AA3;
    --line: #EAEAEC;
    --bg-cream: #FBFAF4;
    --card: #FFFFFF;
    --r-xl: 24px;
    --r-lg: 18px;
    --r-md: 12px;
    --sh-1: 0 1px 2px rgba(10,10,12,.04), 0 0 0 1px rgba(10,10,12,.03);
    --sh-3: 0 18px 40px -12px rgba(10,10,12,.18), 0 0 0 1px rgba(10,10,12,.04);
    max-width: 1280px;
    margin: 0 auto;
    padding: 26px 24px 96px;
    color: var(--body);
  }

  .med-listing-root .breadcrumb { display: flex; gap: 8px; align-items: center; font-size: 13px; color: var(--muted); margin-bottom: 22px; flex-wrap: wrap; }
  .med-listing-root .breadcrumb a { color: var(--muted); text-decoration: none; }
  .med-listing-root .breadcrumb a:hover { color: #000; }
  .med-listing-root .breadcrumb svg { width: 14px; height: 14px; color: var(--muted-2); flex-shrink: 0; }
  .med-listing-root .breadcrumb .current { color: #000; font-weight: 600; }

  .med-listing-root .hero {
    position: relative; overflow: hidden; color: #fff; border-radius: var(--r-xl);
    background: radial-gradient(600px 300px at 15% 20%, rgba(255, 234, 0, .18), transparent 60%),
      radial-gradient(700px 400px at 90% 90%, rgba(255, 160, 0, .28), transparent 60%),
      linear-gradient(135deg, #14110E 0%, #1F1A14 60%, #2A2218 100%);
    padding: 48px 48px 40px; margin-bottom: 22px;
    box-shadow: var(--sh-3);
    display: grid; grid-template-columns: 1.35fr 1fr; gap: 32px; align-items: center;
  }
  .med-listing-root .hero::before {
    content: ""; position: absolute; inset: 0; pointer-events: none; opacity: .35;
    background-image: linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(600px 400px at 70% 100%, black, transparent 70%);
  }
  .med-listing-root .hero-left { position: relative; z-index: 2; }
  .med-listing-root .kicker {
    display: inline-flex; align-items: center; gap: 10px;
    font: 600 11px/1 'Chakra Petch', sans-serif; letter-spacing: .22em; text-transform: uppercase;
    color: var(--yellow); margin-bottom: 18px;
    padding: 8px 14px; border: 1px solid rgba(255,234,0,.4); border-radius: 999px;
    background: rgba(255,234,0,.06);
  }
  .med-listing-root .kicker .dot { width: 7px; height: 7px; background: var(--yellow); border-radius: 50%; box-shadow: 0 0 0 3px rgba(255,234,0,.2); }
  .med-listing-root .hero h1 {
    font-family: 'Chakra Petch', sans-serif; font-weight: 700;
    font-size: clamp(2.4rem, 5.5vw, 4.4rem); color: #fff; line-height: .96; letter-spacing: -.03em; margin: 0;
  }
  .med-listing-root .hero h1 em { font-style: normal; color: var(--yellow); text-shadow: 0 0 40px rgba(255,234,0,.5); }
  .med-listing-root .hero-lede { max-width: 580px; font-size: 16px; color: #c8c8d0; margin: 18px 0 22px; line-height: 1.6; }
  .med-listing-root .hero-stats { display: flex; gap: 24px; flex-wrap: wrap; font-family: 'Chakra Petch', sans-serif; }
  .med-listing-root .hero-stats .s { display: flex; flex-direction: column; gap: 3px; }
  .med-listing-root .hero-stats .n { font-size: 24px; font-weight: 700; color: #fff; line-height: 1; letter-spacing: -.02em; }
  .med-listing-root .hero-stats .l { font-size: 11px; color: #8a8a92; letter-spacing: .14em; text-transform: uppercase; font-weight: 500; }
  .med-listing-root .hero-right { position: relative; z-index: 1; display: flex; align-items: center; justify-content: center; }
  .med-listing-root .hero-emoji-tile { font-size: 120px; line-height: 1; filter: drop-shadow(0 12px 40px rgba(255,160,0,.4)); }

  /* Comparison table */
  .med-listing-root .compare-section {
    background: var(--card); border: 1px solid var(--line); border-radius: var(--r-xl);
    padding: 24px 24px 22px; box-shadow: var(--sh-1); margin-bottom: 32px;
  }
  .med-listing-root .card-head { display: flex; justify-content: space-between; align-items: center; gap: 12px; margin-bottom: 18px; flex-wrap: wrap; }
  .med-listing-root .card-head h2 { font-family: 'Chakra Petch', sans-serif; font-size: 22px; font-weight: 700; letter-spacing: -.02em; margin: 0; line-height: 1.1; color: var(--ink); }
  .med-listing-root .card-head-meta { font: 600 12px 'Chakra Petch', sans-serif; color: var(--muted); background: #FBFAF4; padding: 5px 10px; border-radius: 8px; }

  .med-listing-root .table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .med-listing-root .compare-table {
    width: 100%; border-collapse: collapse;
    font-family: 'Chakra Petch', sans-serif;
  }
  .med-listing-root .compare-table th {
    font: 600 11px 'Chakra Petch', sans-serif; letter-spacing: .16em; text-transform: uppercase;
    color: var(--muted); padding: 10px 14px; text-align: left;
    border-bottom: 2px solid var(--line); white-space: nowrap;
  }
  .med-listing-root .compare-table td {
    padding: 12px 14px; border-bottom: 1px dashed var(--line);
    font-size: 14px; color: var(--body); vertical-align: middle;
  }
  .med-listing-root .compare-table tr:last-child td { border-bottom: 0; }
  .med-listing-root .compare-table tr:hover td { background: #FBFAF4; }
  .med-listing-root .td-name a {
    font: 700 15px 'Chakra Petch', sans-serif; color: var(--ink); text-decoration: none;
    letter-spacing: -.005em;
  }
  .med-listing-root .td-name a:hover { color: #0A5E2E; text-decoration: underline; text-underline-offset: 2px; }
  .med-listing-root .td-barva { color: var(--muted); font-size: 13px; }

  .med-listing-root .typ-badge {
    display: inline-flex; align-items: center;
    font: 600 10px 'Chakra Petch', sans-serif; letter-spacing: .1em; text-transform: uppercase;
    padding: 4px 9px; border-radius: 6px;
  }
  .med-listing-root .typ-kvetovy { background: #FFF6A8; color: #5a4a00; border: 1px solid #ffe066; }
  .med-listing-root .typ-medovicovy { background: #2d1a0a; color: #c8a06a; border: 1px solid #3d2510; }
  .med-listing-root .typ-smiseny { background: #F3F0E8; color: #5a5040; border: 1px solid var(--line); }

  .med-listing-root .kryst-badge {
    display: inline-flex; align-items: center;
    font: 500 11px 'Chakra Petch', sans-serif; letter-spacing: .06em;
    padding: 4px 9px; border-radius: 6px;
    background: var(--bg-cream); color: var(--muted); border: 1px solid var(--line);
  }
  .med-listing-root .kryst-badge.kryst-velmi-pomalá { background: #e8f5e9; color: #2e7d32; border-color: #a5d6a7; }
  .med-listing-root .kryst-badge.kryst-pomalá { background: #e3f2fd; color: #1565c0; border-color: #90caf9; }
  .med-listing-root .kryst-badge.kryst-střední { background: #fff8e1; color: #f57f17; border-color: #ffe082; }
  .med-listing-root .kryst-badge.kryst-rychlá { background: #fce4ec; color: #b71c1c; border-color: #f48fb1; }

  /* Card grid */
  .med-listing-root .cards-section { margin-bottom: 32px; }
  .med-listing-root .section-title {
    font-family: 'Chakra Petch', sans-serif; font-size: 24px; font-weight: 700; letter-spacing: -.02em;
    margin: 0 0 14px; color: var(--ink);
    display: inline-flex; align-items: center; gap: 10px;
  }
  .med-listing-root .section-title-c {
    font-size: 14px; background: var(--yellow); color: #0A0A0B; padding: 3px 10px; border-radius: 8px; letter-spacing: .04em;
  }

  .med-listing-root .med-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 14px;
  }
  .med-listing-root .med-card {
    display: flex; flex-direction: column;
    background: var(--card); border: 1px solid var(--line); border-radius: var(--r-lg);
    overflow: hidden; text-decoration: none; color: inherit;
    transition: .22s cubic-bezier(.2,.7,.2,1);
    box-shadow: var(--sh-1);
  }
  .med-listing-root .med-card:hover { transform: translateY(-3px); box-shadow: var(--sh-3); border-color: var(--yellow); }
  .med-listing-root .mc-photo {
    height: 200px; background-size: cover; background-position: center;
    background-color: #f0ede5;
  }
  .med-listing-root .mc-photo-fallback {
    display: flex; align-items: center; justify-content: center;
    font-size: 72px;
  }
  .med-listing-root .mc-body { padding: 16px 18px 18px; display: flex; flex-direction: column; gap: 5px; flex: 1; }
  .med-listing-root .mc-tags { display: flex; gap: 5px; flex-wrap: wrap; margin-bottom: 6px; }
  .med-listing-root .mc-tag {
    font: 600 10px 'Chakra Petch', sans-serif; letter-spacing: .1em; text-transform: uppercase;
    padding: 3px 7px; border-radius: 5px;
    background: #FBFAF4; color: var(--muted); border: 1px solid var(--line);
  }
  .med-listing-root .mc-tag-kvetovy { background: #FFF6A8; color: #5a4a00; border-color: #ffe066; }
  .med-listing-root .mc-tag-medovicovy { background: #2d1a0a; color: #c8a06a; border-color: #3d2510; }
  .med-listing-root .mc-tag-smiseny { background: #F3F0E8; color: #5a5040; border-color: var(--line); }
  .med-listing-root .mc-name { font: 700 19px 'Chakra Petch', sans-serif; color: var(--ink); letter-spacing: -.01em; }
  .med-listing-root .mc-desc { font-size: 13px; color: var(--muted); line-height: 1.5; margin: 4px 0 0; }

  /* CTA */
  .med-listing-root .big-cta {
    margin-top: 32px; padding: 36px; border-radius: var(--r-xl);
    background: linear-gradient(135deg, var(--yellow) 0%, #FFD400 100%);
    position: relative; overflow: hidden; box-shadow: 0 10px 30px -8px var(--yellow-glow);
  }
  .med-listing-root .big-cta h2 { font-family: 'Chakra Petch', sans-serif; font-size: 30px; line-height: 1.05; letter-spacing: -.02em; position: relative; z-index: 2; color: #0A0A0B; margin: 0; }
  .med-listing-root .big-cta p { color: #2a2a2a; margin-top: 10px; font-size: 15px; position: relative; z-index: 2; max-width: 600px; }
  .med-listing-root .cta-kicker {
    display: inline-block; font: 600 11px 'Chakra Petch', sans-serif; letter-spacing: .2em; text-transform: uppercase;
    color: #0A0A0B; background: rgba(0,0,0,.08); padding: 6px 12px; border-radius: 999px; margin-bottom: 14px; position: relative; z-index: 2;
  }
  .med-listing-root .cta-actions { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 18px; position: relative; z-index: 2; }
  .med-listing-root .cta-btn {
    padding: 15px 24px; border-radius: 14px; text-decoration: none;
    font: 700 14px 'Chakra Petch', sans-serif; letter-spacing: .04em;
    display: inline-flex; align-items: center; gap: 10px; transition: .15s;
  }
  .med-listing-root .cta-btn.primary { background: #0A0A0B; color: #fff; }
  .med-listing-root .cta-btn.primary:hover { transform: translateY(-2px); box-shadow: 0 14px 30px -10px rgba(0,0,0,.4); }

  @media (max-width: 960px) {
    .med-listing-root .hero { grid-template-columns: 1fr; padding: 32px 24px 28px; gap: 18px; }
    .med-listing-root .hero-right { display: none; }
  }
  @media (max-width: 600px) {
    .med-listing-root { padding: 20px 16px 60px; }
    .med-listing-root .compare-section { padding: 18px; }
  }
</style>
