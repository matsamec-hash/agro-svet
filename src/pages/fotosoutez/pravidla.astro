  }
  .legal-page h1 {
    font-family: 'Chakra Petch', sans-serif;
    font-weight: 700;
    font-size: 32px;
    margin: 0 0 8px;
    line-height: 1.2;
  }
  .legal-page h2 {
    font-family: 'Chakra Petch', sans-serif;
    font-weight: 700;
