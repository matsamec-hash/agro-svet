---
export const prerender = false;
import Layout from '../../../../layouts/Layout.astro';
import { createServerClient } from '../../../../lib/supabase';
import { claimUrl } from '../../../../lib/bazar-seed-email';
import { buildClaimWhatsAppMessage, claimWhatsAppUrl } from '../../../../lib/bazar-claim-whatsapp';

// Middleware už gate-uje /admin/* přes is_admin (viz ostatní admin .astro
// stránky — žádná z nich dělá vlastní kontrolu, locals.user navíc is_admin
// vůbec nemá jako pole, ten žije v bazar_users).
const supabase = createServerClient();
const { data: prospects } = await supabase
  .from('bazar_seed_prospects')
  .select('id, name, email, phone, source_url, claim_token, status, created_at')
  .order('created_at', { ascending: false })
  .limit(100);

// Draft (id/title/price) per prospekt — identita inzerátu + náhled + WhatsApp zpráva.
// Jeden dotaz, namapováno přes seed_prospect_id.
const prospectIds = (prospects ?? []).map((p) => p.id);
type Draft = { id: string; title: string; price: number | null };
const draftByProspect = new Map<string, Draft>();
if (prospectIds.length > 0) {
  const { data: drafts } = await supabase
    .from('bazar_listings')
    .select('id, seed_prospect_id, title, price')
    .in('seed_prospect_id', prospectIds);
  for (const d of drafts ?? []) {
    const row = d as { id: string; seed_prospect_id?: string; title?: string; price?: number | null };
    if (row.seed_prospect_id && !draftByProspect.has(row.seed_prospect_id)) {
      draftByProspect.set(row.seed_prospect_id, { id: row.id, title: row.title ?? '', price: row.price ?? null });
    }
  }
}

const dateFmt = new Intl.DateTimeFormat('cs-CZ', { day: 'numeric', month: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' });
const fmtDate = (iso?: string | null): string => (iso ? dateFmt.format(new Date(iso)) : '—');
const fmtPrice = (p: number | null): string => (p ? `${p.toLocaleString('cs-CZ')} Kč` : 'Dohodou');

// WhatsApp deep-link per prospekt s telefonem (klientský odkaz s předvyplněnou
// claim zprávou; null když tel. nejde normalizovat).
function waUrlFor(p: { phone?: string | null; name?: string | null; claim_token: string; id: string }): string | null {
  const message = buildClaimWhatsAppMessage({
    name: p.name,
    listingTitle: draftByProspect.get(p.id)?.title ?? null,
    url: claimUrl(p.claim_token),
  });
  return claimWhatsAppUrl(p.phone, message);
}

// Náhled draftu (pending_claim je neveřejný) — /bazar/<id>/?preview=<claim_token>.
function previewUrlFor(p: { id: string; claim_token: string }): string | null {
  const d = draftByProspect.get(p.id);
  return d ? `/bazar/${d.id}/?preview=${encodeURIComponent(p.claim_token)}` : null;
}

function statusInfo(s: string): { label: string; cls: string } {
  switch (s) {
    case 'pending_claim': return { label: 'Čeká na potvrzení', cls: 'bg-amber-100 text-amber-800' };
    case 'confirmed': return { label: 'Zveřejněno', cls: 'bg-green-100 text-green-800' };
    case 'sent': return { label: 'Odesláno', cls: 'bg-blue-100 text-blue-800' };
    default: return { label: s, cls: 'bg-gray-100 text-gray-700' };
  }
}

// Souhrn stavů pro hlavičku tabulky.
const counts = { pending_claim: 0, confirmed: 0, total: prospects?.length ?? 0 };
for (const p of prospects ?? []) {
  if (p.status === 'pending_claim') counts.pending_claim++;
  else if (p.status === 'confirmed') counts.confirmed++;
}
---
<Layout title="Bazar — Seeding">
  <main class="mx-auto max-w-4xl p-6">
    <h1 class="text-2xl font-bold mb-4">Předchystané inzeráty (seeding)</h1>

    <section class="mb-8 rounded border p-4">
      <h2 class="font-semibold mb-2">Import z URL (Bazoš)</h2>
      <form id="importForm" class="grid gap-2 sm:grid-cols-2">
        <input name="url" required placeholder="Odkaz na inzerát na bazos.cz" class="border p-2 sm:col-span-2" />
        <input name="name" placeholder="Jméno prodejce" class="border p-2" />
        <input name="phone" placeholder="Telefon" class="border p-2" />
        <input name="email" type="email" placeholder="E-mail prodejce" class="border p-2 sm:col-span-2" />
        <button class="bg-green-700 text-white p-2 rounded sm:col-span-2">Importovat a vytvořit draft</button>
      </form>
      <p id="importMsg" class="text-sm mt-2"></p>
    </section>

    <section class="mb-8 rounded border p-4">
      <h2 class="font-semibold mb-2">Hromadný import (víc odkazů najednou)</h2>
      <p class="text-sm text-gray-600 mb-2">Vlož odkazy na inzeráty z bazos.cz — jeden na řádek (max 20). Kontakt se vezme z inzerátu. Vytvoří se drafty ke schválení.</p>
      <form id="batchForm" class="grid gap-2">
        <textarea name="urls" rows="6" required placeholder="https://…bazos.cz/inzerat/…&#10;https://…bazos.cz/inzerat/…" class="border p-2 font-mono text-xs"></textarea>
        <button class="bg-green-800 text-white p-2 rounded">Importovat vše</button>
      </form>
      <p id="batchMsg" class="text-sm mt-2"></p>
      <ul id="batchResults" class="text-sm mt-2 space-y-1"></ul>
    </section>

    <div class="flex items-center justify-between mb-2">
      <h2 class="font-semibold">Importované inzeráty ({counts.total})</h2>
      <p class="text-sm text-gray-600">
        <span class="text-amber-700 font-medium">{counts.pending_claim} čeká na potvrzení</span>
        · <span class="text-green-700 font-medium">{counts.confirmed} zveřejněno</span>
      </p>
    </div>

    <div class="mb-2">
      <button type="button" id="bulkDelBtn" disabled class="bg-red-700 text-white text-sm px-3 py-1.5 rounded disabled:opacity-40 disabled:cursor-not-allowed">Smazat vybrané</button>
      <span class="text-xs text-gray-500 ml-2">Aktivní inzeráty (živé na webu) se přeskočí.</span>
    </div>

    <table class="w-full text-sm border-collapse">
      <thead><tr class="text-left border-b bg-gray-50">
        <th class="p-2 w-8"><input type="checkbox" id="selectAll" title="Vybrat vše" /></th>
        <th class="p-2">Inzerát</th>
        <th class="p-2">Prodejce</th>
        <th class="p-2">Stav</th>
        <th class="p-2">Přidáno</th>
        <th class="p-2">Akce</th>
      </tr></thead>
      <tbody>
        {prospects?.map((p) => {
          const waUrl = waUrlFor(p);
          const draft = draftByProspect.get(p.id);
          const preview = previewUrlFor(p);
          const st = statusInfo(p.status);
          return (
            <tr class="border-b align-top hover:bg-gray-50">
              <td class="p-2"><input type="checkbox" class="rowChk" data-id={p.id} /></td>
              <td class="p-2">
                {draft ? (
                  <>
                    <span class="font-medium">{draft.title || 'Bez názvu'}</span><br />
                    <span class="text-gray-500">{fmtPrice(draft.price)}</span>
                  </>
                ) : (
                  <span class="text-gray-400 italic">Draft nenalezen</span>
                )}
              </td>
              <td class="p-2">{p.name || '—'}<br /><span class="text-gray-500">{p.email || p.phone || '—'}</span></td>
              <td class="p-2"><span class={`inline-block rounded px-2 py-0.5 text-xs font-medium ${st.cls}`}>{st.label}</span></td>
              <td class="p-2 whitespace-nowrap text-gray-600">{fmtDate(p.created_at)}</td>
              <td class="p-2">
                <div class="flex flex-wrap gap-x-3 gap-y-1">
                  {preview && (
                    <a href={preview} target="_blank" rel="noopener" class="underline font-medium">Náhled</a>
                  )}
                  <button type="button" class="copyBtn underline" data-url={claimUrl(p.claim_token)}>Kopírovat odkaz</button>
                  {waUrl && (
                    <a href={waUrl} target="_blank" rel="noopener" class="underline text-green-700">WhatsApp</a>
                  )}
                  {p.email && (
                    <button type="button" class="sendBtn underline" data-id={p.id}>Poslat e-mailem</button>
                  )}
                  <button type="button" class="delBtn underline text-red-700" data-id={p.id} data-status={p.status}>Smazat</button>
                </div>
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </main>

  <script>
    const form = document.getElementById('importForm') as HTMLFormElement;
    const msg = document.getElementById('importMsg')!;
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      msg.textContent = 'Importuji…';
      const fd = new FormData(form);
      const res = await fetch('/admin/bazar/seed/api/import/', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({
          url: fd.get('url'),
          contact: { name: fd.get('name'), phone: fd.get('phone'), email: fd.get('email') },
        }),
      });
      const data = await res.json();
      msg.textContent = res.ok
        ? `Hotovo — draft vytvořen. Fotky ${data.imageCount ?? 0}/${data.imageUrlsFound ?? 0} — ${(data.imageDebug || []).join(' | ') || 'žádné URL'}`
        : `Chyba: ${data.error}`;
      // Bez auto-reloadu, ať je diagnostika fotek čitelná; řádek se objeví po ručním F5.
    });

    const batchForm = document.getElementById('batchForm') as HTMLFormElement;
    const batchMsg = document.getElementById('batchMsg')!;
    const batchResults = document.getElementById('batchResults')!;
    batchForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = batchForm.querySelector('button')!;
      btn.disabled = true;
      batchMsg.textContent = 'Importuji dávku… (může chvíli trvat)';
      batchResults.innerHTML = '';
      try {
        const res = await fetch('/admin/bazar/seed/api/import/', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ urls: (new FormData(batchForm).get('urls') as string) }),
        });
        const data = await res.json();
        if (!res.ok || !data.batch) {
          batchMsg.textContent = `Chyba: ${data.error || 'neznámá'}`;
        } else {
          batchMsg.innerHTML = `Hotovo — ${data.succeeded}/${data.total} vytvořeno, ${data.failed} selhalo. <button type="button" id="reloadTable" class="underline font-medium">↻ Zobrazit v tabulce</button>`;
          document.getElementById('reloadTable')?.addEventListener('click', () => location.reload());
          for (const r of data.results) {
            const li = document.createElement('li');
            li.textContent = r.ok
              ? `✅ ${r.title || r.url} — fotky ${r.imageCount ?? 0}/${r.imageUrlsFound ?? 0}`
              : `❌ ${r.url} — ${r.error}`;
            li.className = r.ok ? 'text-green-700' : 'text-red-700';
            batchResults.appendChild(li);
          }
        }
      } catch (err) {
        batchMsg.textContent = `Chyba sítě: ${(err as Error).message}`;
      } finally {
        btn.disabled = false;
      }
    });

    document.querySelectorAll('.copyBtn').forEach((b) =>
      b.addEventListener('click', () => {
        navigator.clipboard.writeText((b as HTMLElement).dataset.url!);
        (b as HTMLElement).textContent = 'Zkopírováno ✓';
      }),
    );
    document.querySelectorAll('.sendBtn').forEach((b) =>
      b.addEventListener('click', async () => {
        (b as HTMLElement).textContent = 'Odesílám…';
        const res = await fetch('/admin/bazar/seed/api/send/', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ prospectId: (b as HTMLElement).dataset.id }),
        });
        (b as HTMLElement).textContent = res.ok ? 'Odesláno ✓' : 'Chyba';
      }),
    );
    document.querySelectorAll('.delBtn').forEach((b) =>
      b.addEventListener('click', async () => {
        const el = b as HTMLElement;
        if (!confirm('Opravdu smazat tento prospekt i jeho draft inzerát? Akce je nevratná.')) return;
        el.textContent = 'Mažu…';
        const res = await fetch('/admin/bazar/seed/api/delete/', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ prospectId: el.dataset.id }),
        });
        if (res.ok) {
          el.closest('tr')?.remove();
        } else {
          const data = await res.json().catch(() => ({}));
          el.textContent = 'Chyba';
          alert(data.error || 'Smazání selhalo');
        }
      }),
    );

    // Hromadné mazání ---------------------------------------------------------
    const selectAll = document.getElementById('selectAll') as HTMLInputElement | null;
    const bulkBtn = document.getElementById('bulkDelBtn') as HTMLButtonElement | null;
    const rowChecks = () => Array.from(document.querySelectorAll('.rowChk')) as HTMLInputElement[];
    const checkedIds = () => rowChecks().filter((c) => c.checked).map((c) => c.dataset.id!).filter(Boolean);
    function refreshBulk() {
      const n = checkedIds().length;
      if (bulkBtn) {
        bulkBtn.disabled = n === 0;
        bulkBtn.textContent = n ? `Smazat vybrané (${n})` : 'Smazat vybrané';
      }
    }
    selectAll?.addEventListener('change', () => {
      rowChecks().forEach((c) => (c.checked = selectAll.checked));
      refreshBulk();
    });
    rowChecks().forEach((c) => c.addEventListener('change', refreshBulk));
    bulkBtn?.addEventListener('click', async () => {
      const ids = checkedIds();
      if (!ids.length) return;
      if (!confirm(`Opravdu smazat ${ids.length} vybraných záznamů i jejich drafty? Akce je nevratná.`)) return;
      bulkBtn.disabled = true;
      bulkBtn.textContent = `Mažu ${ids.length}…`;
      const res = await fetch('/admin/bazar/seed/api/delete/', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ prospectIds: ids }),
      });
      const data = await res.json().catch(() => ({}));
      if (res.ok) {
        const deleted: string[] = data.deleted ?? [];
        deleted.forEach((id) => document.querySelector(`.rowChk[data-id="${id}"]`)?.closest('tr')?.remove());
        if (selectAll) selectAll.checked = false;
        if (data.skippedCount) alert(`Smazáno ${data.deletedCount}. Přeskočeno ${data.skippedCount} (aktivní inzerát na webu).`);
      } else {
        alert(data.error || 'Hromadné smazání selhalo');
      }
      refreshBulk();
    });
    refreshBulk();
  </script>
</Layout>
