---
// src/pages/admin/akce/index.astro
import Layout from '../../../layouts/Layout.astro';
import { listPending, listUpcoming, akceFotoUrl, getAkceImagesMap } from '../../../lib/akce-supabase';
import { formatTermin, type TerminInput } from '../../../lib/akce-recurrence';
import { akceTypLabel, type AkceTyp } from '../../../lib/akce-constants';
import AdminAkceMedia from '../../../components/admin/AdminAkceMedia.astro';

export const prerender = false;
const pending = await listPending();
const published = await listUpcoming(300);
const imagesMap = await getAkceImagesMap([...pending, ...published].map((a) => a.id));

function termin(a: (typeof pending)[number]): string {
  const t: TerminInput = a.druh === 'jednorazova'
    ? { druh: 'jednorazova', zacatek: a.zacatek as string, konec: a.konec }
    : { druh: 'opakovana', dny_v_tydnu: a.dny_v_tydnu ?? [], cas_od: a.cas_od ?? '', cas_do: a.cas_do, plati_od: a.plati_od as string, plati_do: a.plati_do };
  return formatTermin(t);
}
function fallbackUrl(a: (typeof pending)[number]): string | null {
  return (imagesMap[a.id]?.length ? null : akceFotoUrl(a.foto_path));
}
---
<Layout title="Moderace akcí — admin" description="Schvalování akcí v kalendáři">
  <main class="mod">
    <h1>Moderace akcí <span>({pending.length} čeká)</span></h1>
    {pending.length === 0 && <p>Žádné akce nečekají na schválení. 🎉</p>}
    {pending.map((a) => (
      <article class="card" data-id={a.id}>
        <h2>{a.nazev}</h2>
        <p class="meta">{akceTypLabel(a.typ as AkceTyp)} · {a.obec} ({a.okres_slug}) · {termin(a)}</p>
        <p>{a.popis}</p>
        <p class="contact">{a.poradatel} · {a.email} · {a.web}</p>
        <AdminAkceMedia id={a.id} cena={a.cena} images={imagesMap[a.id] ?? []} fotoFallbackUrl={fallbackUrl(a)} />
        <div class="actions">
          <button data-action="approve">Schválit</button>
          <button data-action="reject">Zamítnout</button>
        </div>
      </article>
    ))}

    <section class="published">
      <h2 class="pub-head">Zveřejněné akce <span>({published.length}) — správa fotek a ceny</span></h2>
      {published.map((a) => (
        <article class="card card--pub" data-id={a.id}>
          <h3><a href={`/akce/${a.slug}/`} target="_blank" rel="noopener">{a.nazev} ↗</a></h3>
          <p class="meta">{akceTypLabel(a.typ as AkceTyp)} · {a.obec} ({a.okres_slug}) · {termin(a)}</p>
          <AdminAkceMedia id={a.id} cena={a.cena} images={imagesMap[a.id] ?? []} fotoFallbackUrl={fallbackUrl(a)} />
        </article>
      ))}
    </section>
  </main>

  <script>
    // Sdílený POST — pozná tichý redirect na login (vypršelá session) i chybu
    // z endpointu (JSON {error}), ať upload nikdy neselže „potichu".
    async function postAdmin(url: string, fd: FormData): Promise<Response> {
      const res = await fetch(url, { method: 'POST', body: fd });
      if (res.redirected && res.url.includes('prihlaseni')) {
        alert('Vypršelo přihlášení — přihlas se prosím znovu a akci zopakuj.');
        location.href = '/bazar/prihlaseni/?redirect=/admin/akce/';
        throw new Error('auth-redirect');
      }
      if (!res.ok) {
        let msg = String(res.status);
        try { const j = await res.json(); if (j && j.error) msg = j.error; } catch { /* not JSON */ }
        throw new Error(msg);
      }
      return res;
    }
    function reportErr(prefix: string, e: unknown) {
      if ((e as Error).message !== 'auth-redirect') alert(prefix + (e as Error).message);
    }

    document.querySelectorAll<HTMLElement>('.card').forEach((card) => {
      const id = card.dataset.id!;

      card.querySelector<HTMLButtonElement>('[data-action="approve"]')
        ?.addEventListener('click', () => act(id, 'approve'));
      card.querySelector<HTMLButtonElement>('[data-action="reject"]')
        ?.addEventListener('click', () => {
          const reason = prompt('Důvod zamítnutí (volitelné):') ?? '';
          act(id, 'reject', reason);
        });

      const fotoInput = card.querySelector<HTMLInputElement>('[data-foto]');
      const fotoLabel = card.querySelector<HTMLElement>('.foto-up');
      fotoInput?.addEventListener('change', async () => {
        const files = fotoInput.files;
        if (!files || !files.length) return;
        const orig = fotoLabel?.textContent ?? '';
        if (fotoLabel) fotoLabel.textContent = '⏳ Nahrávám…';
        const fd = new FormData();
        fd.set('akce_id', id); fd.set('action', 'upload');
        for (const f of Array.from(files)) fd.append('foto', f);
        try {
          await postAdmin('/admin/akce/api/foto/', fd);
          location.reload();
        } catch (e) {
          reportErr('Chyba nahrání fotky: ', e);
          if (fotoLabel) fotoLabel.textContent = orig;
        }
      });

      card.querySelectorAll<HTMLButtonElement>('.g-del').forEach((btn) => {
        btn.addEventListener('click', async () => {
          if (!confirm('Smazat fotku?')) return;
          const fd = new FormData();
          fd.set('akce_id', id);
          if (btn.dataset.imageId) { fd.set('action', 'remove_image'); fd.set('image_id', btn.dataset.imageId); }
          else { fd.set('action', 'remove'); }
          try { await postAdmin('/admin/akce/api/foto/', fd); location.reload(); }
          catch (e) { reportErr('Chyba mazání: ', e); }
        });
      });

      const cenaSave = card.querySelector<HTMLButtonElement>('[data-cena-save]');
      cenaSave?.addEventListener('click', async () => {
        const input = card.querySelector<HTMLInputElement>('[data-cena]');
        const fd = new FormData();
        fd.set('akce_id', id); fd.set('action', 'cena'); fd.set('cena', input?.value ?? '');
        try {
          await postAdmin('/admin/akce/api/foto/', fd);
          cenaSave.textContent = '✓ Uloženo'; setTimeout(() => { cenaSave.textContent = 'Uložit cenu'; }, 1500);
        } catch (e) { reportErr('Chyba uložení ceny: ', e); }
      });
    });

    async function act(id: string, action: string, reason = '') {
      const fd = new FormData();
      fd.set('akce_id', id); fd.set('action', action); fd.set('reason', reason);
      try { await postAdmin('/admin/akce/api/moderate/', fd); location.reload(); }
      catch (e) { reportErr('Chyba moderace: ', e); }
    }
  </script>

  <style>
    .mod { max-width: 820px; margin: 0 auto; padding: 32px 20px 80px; }
    .mod h1 span { font-weight: 400; color: #666; font-size: .7em; }
    .card { border: 1px solid #e8e8e8; border-radius: 12px; padding: 16px 20px; margin: 16px 0; }
    .card .meta { color: #555; font-size: .9rem; }
    .card .contact { color: #888; font-size: .85rem; }
    .actions { display: flex; gap: 10px; margin-top: 12px; }
    .actions button { padding: 8px 18px; cursor: pointer; }

    .media-row { margin-top: 12px; }
    .gallery { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
    .g-thumb { position: relative; width: 92px; height: 70px; }
    .g-thumb img { width: 100%; height: 100%; object-fit: cover; border-radius: 8px; border: 1px solid #e0e0e0; }
    .g-del { position: absolute; top: -7px; right: -7px; width: 22px; height: 22px; border-radius: 50%; border: 0; background: #b02020; color: #fff; cursor: pointer; font-size: .8rem; line-height: 1; }
    .foto-none { color: #999; font-size: .85rem; }
    .foto-up { display: inline-block; padding: 6px 14px; border: 1px solid #c4c4c4; border-radius: 8px; cursor: pointer; font-size: .9rem; background: #fafafa; }
    .cena-row { display: flex; gap: 8px; margin-top: 10px; flex-wrap: wrap; }
    .cena-input { flex: 1; min-width: 200px; padding: 7px 10px; border: 1px solid #c4c4c4; border-radius: 8px; font: inherit; }
    .cena-save { padding: 7px 14px; border: 1px solid #c4c4c4; border-radius: 8px; background: #fafafa; cursor: pointer; white-space: nowrap; }

    .published { margin-top: 48px; border-top: 2px solid #eee; padding-top: 8px; }
    .pub-head { font-size: 1.15rem; }
    .pub-head span { font-weight: 400; color: #888; font-size: .8em; }
    .card--pub { background: #fafafa; }
    .card--pub h3 { margin: 0 0 4px; font-size: 1.05rem; }
    .card--pub h3 a { color: #2f6a2a; text-decoration: none; }
    .card--pub h3 a:hover { text-decoration: underline; }
  </style>
</Layout>
