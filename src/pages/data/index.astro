---
// src/pages/data/index.astro
// Rozcestník datové sekce (hub). Sdružuje živá česká data, mezinárodní srovnání
// a nástroje do tří clusterů. Data jsou precomputed v src/data/agro-stats{,-sk}.json
// (žádný runtime fetch). prerender=false kvůli locale rewrite (stejně jako /statistiky).
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { useTranslations, navHref, isLaunchedPath } from '../../i18n/utils';
import { udrzovatelSlug } from '../../lib/plodiny';
import { imgSrcset } from '../../lib/image-variants';
import statsCs from '../../data/agro-stats.json';
import statsSk from '../../data/agro-stats-sk.json';

const locale = Astro.locals.locale ?? 'cs';
const t = useTranslations(locale);
const stats = locale === 'sk' ? statsSk : statsCs;
const numLocale = locale === 'sk' ? 'sk-SK' : 'cs-CZ';

Astro.response.headers.set('Cache-Control', 'public, max-age=600, s-maxage=86400, stale-while-revalidate=604800');

const { commodityStats, commodityFull, latestFuels, regional, crops, livestockHistorical, fuelSeries, fertSeries, scissorsPoints } = stats as any;

// ── Hero staty ──
const datasetCount = [commodityFull, fuelSeries, fertSeries, scissorsPoints, crops, livestockHistorical, regional]
  .filter((b: any[]) => Array.isArray(b) && b.length > 0).length;
const yearsCovered = (() => {
  const ys = commodityFull.flatMap((s: any) => s.data.map((d: any) => Number(String(d.label).split(' ')[1]))).filter((n: number) => !isNaN(n));
  return ys.length ? new Date().getFullYear() - Math.min(...ys) + 1 : 16;
})();
const COUNTRY_COUNT = 40; // /svet — počet profilů zemí
const regionCount = new Set(regional.map((r: any) => r.region)).size;

// ── Ticker (commodityStats + Nafta) ──
const fmt = (v: number, dec = 0) => v.toLocaleString(numLocale, { minimumFractionDigits: dec, maximumFractionDigits: dec });
type Tick = { name: string; value: string; changePct: number | null; href: string };
const tickItems: Tick[] = [
  ...commodityStats.map((c: any) => ({ name: c.name, value: `${fmt(c.price)} ${c.unit}`, changePct: typeof c.change === 'number' ? c.change : null, href: navHref(locale, `/statistiky/komodita/${udrzovatelSlug(c.name)}/`) })),
];
const nafta = latestFuels?.find((f: any) => /nafta/i.test(f.fuel));
if (nafta) tickItems.push({ name: 'Nafta', value: `${fmt(nafta.price, 2)} ${locale === 'sk' ? 'EUR/l' : 'Kč/l'}`, changePct: null, href: `${navHref(locale, '/statistiky/')}#vstupy` });

// ── Hero graf: posledních 24 měsíců vybraných komodit → klient ──
const HERO_NAMES = ['Pšenice', 'Řepka', 'Kukuřice', 'Ječmen', 'Mléko'];
const heroSeries = HERO_NAMES
  .map((n) => commodityFull.find((s: any) => s.name === n))
  .filter(Boolean)
  .map((s: any) => ({ name: s.name, unit: s.unit, points: s.data.slice(-24).map((d: any) => ({ label: d.label, value: d.value })) }));

// ── Statpill: Pšenice pro Trhy dlaždici ──
const wheat = commodityStats.find((c: any) => /pšenice|pšenica/i.test(c.name)) ?? commodityStats[0];

// ── Copy (cs primár, sk fallback na cs) ──
const CO: Record<string, any> = {
  cs: {
    eyebrow: 'Datová sekce · živě', h1a: 'Data o českém', h1mark: 'zemědělství',
    lede: 'Živé ceny komodit, hodnota půdy, srovnání se světem a nástroje pro vaši farmu — na jednom místě.',
    sDatasets: 'datových sad', sCountries: 'zemí světa', sYears: 'let historie',
    live: 'Živá data', jump: 'Skočit na',
    c1: 'Živá data — Česko', c1sub: 'Aktuální čísla u nás',
    c2: 'Svět', c2sub: 'Jak si ČR stojí',
    c3: 'Nástroje & dotace', c3sub: 'Spočítej to pro svoji farmu',
    trhy: 'Trhy a komodity', trhyP: 'Ceny plodin, vstupů a hnojiv, cenové nůžky, produkce i stavy zvířat — v živých interaktivních grafech.',
    puda: 'Zemědělská půda', pudaP: 'Cena, struktura, eroze a vlastnictví zemědělské půdy podle jednotlivých krajů.',
    profily: 'Profily zemí', profilyP: 'Zemědělství 40+ zemí — výměry, výnosy, dotace a regionální mapy až na úroveň krajů.',
    srovnani: 'Srovnání zemí', srovnaniP: 'Postavte kterékoli země vedle sebe a porovnejte výnosy, dotace i výměry v interaktivním grafu.',
    cap: 'Kalkulačky & dotace CAP', capP: 'Zadejte výměru a plodiny — spočítáme odhad přímých plateb ze SZP. Plus úspora nafty, převody jednotek a další.',
    dotace: 'Dotace', dotaceP: 'Přehled dotačních titulů, termínů a podmínek SZIF.',
    popular: 'Nejoblíbenější', komodit: 'komodit', kraju: 'krajů', zemi: 'zemí',
    regionMap: 'regionální data', multiGraf: 'interaktivní multi-graf', kalk5: '+ 5 kalkulaček', terminy: 'aktuální termíny',
    metaTitle: 'Data o českém zemědělství — ceny, půda, dotace | agro-svět.cz',
    metaDesc: 'Živé ceny komodit, hodnota zemědělské půdy, mezinárodní srovnání a kalkulačky dotací na jednom místě.',
  },
};
const c = CO[locale] ?? CO.cs;

// ── Dlaždice (locale gating přes isLaunchedPath) ──
const show = (p: string) => locale === 'cs' || isLaunchedPath(locale, p);
const href = (p: string) => navHref(locale, p);
---

<Layout title={c.metaTitle} description={c.metaDesc}>
  <main class="dh">
    <!-- HERO -->
    <section class="dh-hero">
      <div class="dh-grid-lines"></div>
      <div class="dh-wrap dh-hero-in">
        <div>
          <span class="dh-eyebrow"><span class="ln"></span>{c.eyebrow}</span>
          <h1>{c.h1a} <mark>{c.h1mark}</mark></h1>
          <p class="dh-lede">{c.lede}</p>
          <div class="dh-hstat">
            <div><div class="n" data-count={datasetCount}>0</div><div class="l">{c.sDatasets}</div></div>
            <div><div class="n" data-count={COUNTRY_COUNT}>0</div><div class="l">{c.sCountries}</div></div>
            <div><div class="n"><b data-count={yearsCovered}>0</b></div><div class="l">{c.sYears}</div></div>
          </div>
        </div>
        <div class="dh-chart">
          <div class="dh-chart-top">
            <div class="dh-hc-head">
              <button class="dh-arrow" id="hcPrev" aria-label="Předchozí komodita"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6l-6 6 6 6"/></svg></button>
              <div><div class="dh-hc-lbl" id="hcLabel"></div><div class="dh-hc-price"><span id="hcPrice"></span></div></div>
              <button class="dh-arrow" id="hcNext" aria-label="Další komodita"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg></button>
            </div>
            <span class="dh-chg" id="hcChg"></span>
          </div>
          <div class="dh-chartwrap">
            <svg class="dh-area" id="hcSvg" viewBox="0 0 340 120" preserveAspectRatio="none">
              <defs><linearGradient id="dhg1" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#FFEA00" stop-opacity=".35"/><stop offset="1" stop-color="#FFEA00" stop-opacity="0"/></linearGradient></defs>
              <path id="hcFill" fill="url(#dhg1)" d=""></path>
              <path id="hcLine" fill="none" stroke="#FFEA00" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" d=""></path>
              <line id="hcCross" class="dh-cross" x1="0" y1="0" x2="0" y2="120"></line>
              <circle id="hcDot" class="dh-dot" r="4" cx="0" cy="0"></circle>
            </svg>
            <div class="dh-tip" id="hcTip"><span class="d"></span><br><b></b></div>
          </div>
          <div class="dh-dots" id="hcDots"></div>
        </div>
      </div>
    </section>

    <!-- MARQUEE -->
    <div class="dh-marq"><div class="dh-track">
      {[...tickItems, ...tickItems].map((it) => (
        <a class="dh-it" href={it.href}>
          <span class="nm">{it.name}</span> <b>{it.value}</b>
          {it.changePct != null && <b class={it.changePct >= 0 ? 'up' : 'dn'}>{it.changePct >= 0 ? '▲' : '▼'}{Math.abs(it.changePct)}%</b>}
        </a>
      ))}
    </div></div>

    <!-- QUICK NAV -->
    <nav class="dh-qn" aria-label={c.jump}><div class="dh-wrap dh-qn-in">
      <span class="lab">{c.jump}</span>
      {show('/statistiky/') && <a class="chipnav" href={href('/statistiky/')}><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m7 14 4-4 3 3 5-5"/></svg>{c.trhy}</a>}
      {show('/puda/') && <a class="chipnav" href={href('/puda/')}><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V12"/><path d="M12 12c0-3 2-5 5-5 0 3-2 5-5 5z"/><path d="M12 12c0-3-2-5-5-5 0 3 2 5 5 5z"/></svg>{c.puda}</a>}
      {show('/svet/') && <a class="chipnav" href={href('/svet/')}><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.5 2.7 2.5 15.3 0 18M12 3c-2.5 2.7-2.5 15.3 0 18"/></svg>{c.profily}</a>}
      {show('/svet/srovnani/') && <a class="chipnav" href={href('/svet/srovnani/')}><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18M4 7h16M6 7l-3 6a3 3 0 0 0 6 0zM18 7l-3 6a3 3 0 0 0 6 0z"/></svg>{c.srovnani}</a>}
      {show('/kalkulacka/') && <a class="chipnav feat" href={href('/kalkulacka/')}><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="3" width="16" height="18" rx="2"/><path d="M8 7h8M8 11h8M8 15h5"/></svg>{c.cap}</a>}
      {show('/dotace/') && <a class="chipnav" href={href('/dotace/')}><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6l1 3H8zM8 6h8v14a1 1 0 0 1-1 1H9a1 1 0 0 1-1-1zM11 11h4M11 15h4"/></svg>{c.dotace}</a>}
    </div></nav>

    <div class="dh-body"><div class="dh-wrap">

      <!-- CLUSTER 01 -->
      <section class="dh-cluster">
        <div class="dh-chd"><span class="no">01</span><h2>{c.c1}</h2><span class="rule"></span><span class="sub">{c.c1sub}</span></div>
        <div class="dh-tiles">
          {show('/statistiky/') && (
          <a class="dh-tile" href={href('/statistiky/')}>
            <img class="bg" {...imgSrcset('/images/data-hub/trhy-komodity__v-w1600.webp', '(max-width:900px) 100vw, 560px', 1600)} alt="Zlaté pole pšenice" loading="lazy" decoding="async" width="1600" height="1067" />
            <div class="ov"></div>
            <div class="in">
              <div class="trow"><span class="cic"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m7 14 4-4 3 3 5-5"/></svg></span><span class="go"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M9 7h8v8"/></svg></span></div>
              <h3>{c.trhy}</h3><p>{c.trhyP}</p>
              <div class="tstat"><span class="statpill">{wheat.name} {fmt(wheat.price)} <span class="u">{wheat.unit}</span> {typeof wheat.change === 'number' && <span class={`chg ${wheat.change >= 0 ? 'up' : 'dn'}`}>{wheat.change >= 0 ? '▲' : '▼'}{Math.abs(wheat.change)}%</span>}</span><span class="statpill ghost">{commodityStats.length} {c.komodit}</span></div>
            </div>
          </a>)}
          {show('/puda/') && (
          <a class="dh-tile" href={href('/puda/')}>
            <img class="bg" {...imgSrcset('/images/data-hub/zemedelska-puda__v-w1600.webp', '(max-width:900px) 100vw, 560px', 1600)} alt="Zemědělská půda shora" loading="lazy" decoding="async" width="1600" height="1067" />
            <div class="ov"></div>
            <div class="in">
              <div class="trow"><span class="cic"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V12"/><path d="M12 12c0-3 2-5 5-5 0 3-2 5-5 5z"/><path d="M12 12c0-3-2-5-5-5 0 3 2 5 5 5z"/></svg></span><span class="go"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M9 7h8v8"/></svg></span></div>
              <h3>{c.puda}</h3><p>{c.pudaP}</p>
              <div class="tstat"><span class="statpill">{regionCount} <span class="u">{c.kraju}</span></span><span class="statpill ghost">{c.regionMap}</span></div>
            </div>
          </a>)}
        </div>
      </section>

      <!-- CLUSTER 02 -->
      {(show('/svet/') || show('/svet/srovnani/')) && (
      <section class="dh-cluster">
        <div class="dh-chd"><span class="no">02</span><h2>{c.c2}</h2><span class="rule"></span><span class="sub">{c.c2sub}</span></div>
        <div class="dh-tiles">
          {show('/svet/') && (
          <a class="dh-tile" href={href('/svet/')}>
            <img class="bg" {...imgSrcset('/images/data-hub/profily-zemi__v-w1600.webp', '(max-width:900px) 100vw, 560px', 1600)} alt="Horská zemědělská krajina" loading="lazy" decoding="async" width="1600" height="1067" />
            <div class="ov"></div>
            <div class="in">
              <div class="trow"><span class="cic"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.5 2.7 2.5 15.3 0 18M12 3c-2.5 2.7-2.5 15.3 0 18"/></svg></span><span class="go"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M9 7h8v8"/></svg></span></div>
              <h3>{c.profily}</h3><p>{c.profilyP}</p>
              <div class="tstat"><span class="statpill">{COUNTRY_COUNT}+ <span class="u">{c.zemi}</span></span></div>
            </div>
          </a>)}
          {show('/svet/srovnani/') && (
          <a class="dh-tile" href={href('/svet/srovnani/')}>
            <img class="bg" {...imgSrcset('/images/data-hub/srovnani-zemi__v-w1600.webp', '(max-width:900px) 100vw, 560px', 1600)} alt="Dvě různá pole vedle sebe" loading="lazy" decoding="async" width="1600" height="1067" />
            <div class="ov"></div>
            <div class="in">
              <div class="trow"><span class="cic"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18M4 7h16M6 7l-3 6a3 3 0 0 0 6 0zM18 7l-3 6a3 3 0 0 0 6 0z"/></svg></span><span class="go"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M9 7h8v8"/></svg></span></div>
              <h3>{c.srovnani}</h3><p>{c.srovnaniP}</p>
              <div class="tstat"><span class="statpill ghost">{c.multiGraf}</span></div>
            </div>
          </a>)}
        </div>
      </section>)}

      <!-- CLUSTER 03 -->
      {(show('/kalkulacka/') || show('/dotace/')) && (
      <section class="dh-cluster">
        <div class="dh-chd"><span class="no">03</span><h2>{c.c3}</h2><span class="rule"></span><span class="sub">{c.c3sub}</span></div>
        <div class="dh-tiles">
          {show('/kalkulacka/') && (
          <a class="dh-tile feat" href={href('/kalkulacka/')}>
            <img class="bg" {...imgSrcset('/images/data-hub/kalkulacka-cap__v-w1600.webp', '(max-width:900px) 100vw, 560px', 1600)} alt="Podání ruky v obilném poli" loading="lazy" decoding="async" width="1600" height="1067" />
            <div class="ov"></div>
            <span class="tag">{c.popular}</span>
            <div class="in">
              <div class="trow"><span class="cic"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="3" width="16" height="18" rx="2"/><path d="M8 7h8M8 11h8M8 15h5"/></svg></span><span class="go"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M9 7h8v8"/></svg></span></div>
              <h3>{c.cap}</h3><p>{c.capP}</p>
              <div class="tstat"><span class="statpill">120 ha → 1,84 mil. Kč</span><span class="statpill">{c.kalk5}</span></div>
            </div>
          </a>)}
          {show('/dotace/') && (
          <a class="dh-tile" href={href('/dotace/')}>
            <img class="bg" {...imgSrcset('/images/data-hub/dotace__v-w1600.webp', '(max-width:900px) 100vw, 560px', 1600)} alt="Klíčící sazenice" loading="lazy" decoding="async" width="1600" height="1067" />
            <div class="ov"></div>
            <div class="in">
              <div class="trow"><span class="cic"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6l1 3H8zM8 6h8v14a1 1 0 0 1-1 1H9a1 1 0 0 1-1-1zM11 11h4M11 15h4"/></svg></span><span class="go"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M9 7h8v8"/></svg></span></div>
              <h3>{c.dotace}</h3><p>{c.dotaceP}</p>
              <div class="tstat"><span class="statpill ghost">{c.terminy}</span></div>
            </div>
          </a>)}
        </div>
      </section>)}

    </div></div>
  </main>

  <script type="application/json" id="dhChartData" set:html={JSON.stringify({ series: heroSeries, numLocale })} />
  <script src="/scripts/data-hub.js" is:inline></script>
</Layout>

<style>
  .dh{--yellow:#FFEA00;--yellow-d:#FFD400;--ink:#0A0A0B;--line:#E7E7EA;--muted:#6E6E76;--muted2:#9A9AA2;
    --paper:#FBFAF3;--soft:#F5F5F2;--green:#2E9E57;--red:#D6492B;--dmuted:#9A9AA2;--dmuted2:#74747C;--dgreen:#38B36B;--dcard-b:rgba(255,255,255,.10);
    font-family:'Chakra Petch',system-ui,sans-serif;background:#fff;color:var(--ink);line-height:1.5}
  .dh-wrap{max-width:1180px;margin:0 auto;padding:0 28px}
  .dh svg{display:block}
  .dh a{text-decoration:none;color:inherit}

  /* HERO */
  .dh-hero{background:var(--ink);color:#fff;position:relative;overflow:hidden}
  .dh-hero::before{content:"";position:absolute;inset:0;background:radial-gradient(720px 360px at 88% -10%,rgba(255,234,0,.20),transparent 60%);pointer-events:none}
  .dh-grid-lines{position:absolute;inset:0;opacity:.05;background-image:linear-gradient(#fff 1px,transparent 1px),linear-gradient(90deg,#fff 1px,transparent 1px);background-size:44px 44px;pointer-events:none}
  .dh-hero-in{padding:46px 28px 38px;position:relative;z-index:1;display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:center}
  .dh-eyebrow{display:inline-flex;align-items:center;gap:10px;font-size:11px;font-weight:700;letter-spacing:.26em;text-transform:uppercase;color:var(--yellow);margin-bottom:18px}
  .dh-eyebrow .ln{width:28px;height:1px;background:var(--yellow);opacity:.55}
  .dh-hero h1{font-size:52px;line-height:1.02;letter-spacing:-.03em;margin-bottom:16px;font-weight:800;color:#fff}
  .dh-hero h1 mark{background:var(--yellow);color:var(--ink);padding:0 10px}
  .dh-lede{font-size:16px;color:var(--dmuted);max-width:44ch;margin-bottom:26px}
  .dh-hstat{display:flex;gap:28px}
  .dh-hstat .n{font-size:30px;font-weight:800;letter-spacing:-.02em;line-height:1;color:#fff}
  .dh-hstat .l{font-size:11px;color:var(--dmuted2);text-transform:uppercase;letter-spacing:.12em;margin-top:6px}
  .dh-hstat b{color:var(--yellow)}
  .dh-chart{background:linear-gradient(180deg,rgba(255,255,255,.05),rgba(255,255,255,.02));border:1px solid var(--dcard-b);border-radius:20px;padding:20px}
  .dh-chart-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px}
  .dh-hc-head{display:flex;align-items:center;gap:10px;user-select:none}
  .dh-hc-head>div{width:168px;text-align:center;overflow:hidden}
  .dh-hc-lbl{font-size:12px;color:var(--dmuted);font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .dh-hc-price{font-size:30px;font-weight:800;letter-spacing:-.02em;line-height:1.1}
