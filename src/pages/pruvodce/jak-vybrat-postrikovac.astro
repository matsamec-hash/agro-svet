  .g-body h3 { font-size: 18px; font-weight: 700; color: #0A0A0B; margin: 22px 0 8px; }
  .g-body p { font-size: 16px; line-height: 1.75; color: #333; margin: 0 0 14px; }
  .g-body ul { padding-left: 22px; margin: 0 0 16px; }
  .g-body li { font-size: 15px; line-height: 1.7; color: #333; margin-bottom: 6px; }
  .g-body strong { color: #0A0A0B; font-weight: 700; }
  .g-body a { color: #0B7A3B; text-decoration: underline; }
  table { width: 100%; border-collapse: collapse; font-size: 14px; margin: 0 0 20px; }
  th { text-align: left; padding: 10px 12px; background: #fafafa; border-bottom: 2px solid #0A0A0B; font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; color: #6B6B72; }
