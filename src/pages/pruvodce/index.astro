---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { breadcrumbSchema, itemListSchema } from '../../lib/structured-data';
import { SITE_URL } from '../../lib/config';
import { getLocaleFromUrl } from '../../i18n/utils';

const locale = Astro.locals.locale ?? getLocaleFromUrl(Astro.url);
const isSk = locale === 'sk';
const base = isSk ? '/sk' : '';
Astro.response.headers.set('Cache-Control', 'public, max-age=600, s-maxage=3600, stale-while-revalidate=86400');

const canonical = `${SITE_URL}${base}/pruvodce/`;

const guides = [
  {
    slug: 'jak-vybrat-traktor-100-150-koni',
    title: 'Jak vybrat traktor 100–150 koní (2026)',
    description: 'Kompletní průvodce výběrem traktoru ve výkonové třídě 100–150 koní pro střední farmu. Porovnání top 8 modelů, na co se ptát při prohlídce, jak vyjednat cenu.',
    duration: '~12 min čtení',
    status: 'live',
    badge: 'Aktuální',
    titleSk: 'Ako vybrať traktor 100–150 koní (2026)',
    descriptionSk: 'Kompletný sprievodca výberom traktora vo výkonovej triede 100–150 koní pre strednú farmu. Porovnanie top 8 modelov, na čo sa pýtať pri obhliadke, ako vyjednať cenu.',
    durationSk: '~12 min čítania',
    badgeSk: 'Aktuálny',
  },
  {
    slug: 'jak-vybrat-kombajn-stredni-farma',
    title: 'Jak vybrat kombajn pro střední farmu (150–500 ha)',
    description: 'Třída V–VII kombajnů, záběr žacího stolu, výkon, zásobník zrna. Klíčové parametry, ekonomika vs nájem ze sklizňové služby.',
    duration: '~10 min',
    status: 'live',
    badge: 'Aktuální',
    titleSk: 'Ako vybrať kombajn pre strednú farmu (150–500 ha)',
    descriptionSk: 'Trieda V–VII kombajnov, záber žacieho stola, výkon, zásobník zrna. Kľúčové parametre, ekonomika vs nájom zo zberovej služby.',
    durationSk: '~10 min',
    badgeSk: 'Aktuálny',
  },
  {
    slug: 'kontrola-ojeteho-traktoru',
    title: 'Checklist: Kontrola ojetého traktoru před koupí',
    description: 'Co prověřit při prohlídce — motor, převodovka, hydraulika, kabina, dokumenty. 30-bodový interaktivní checklist.',
    duration: '~8 min',
    status: 'live',
    badge: 'Checklist',
    titleSk: 'Checklist: Kontrola ojazdeného traktora pred kúpou',
    descriptionSk: 'Čo preveriť pri obhliadke — motor, prevodovka, hydraulika, kabína, dokumenty. 30-bodový interaktívny checklist.',
    durationSk: '~8 min',
    badgeSk: 'Checklist',
  },
  {
    slug: 'prvni-traktor-mlady-zemedelec',
    title: 'První traktor pro mladého zemědělce',
    description: 'Začínáte hospodařit do 40 let? Průvodce výběrem prvního traktoru s ohledem na dotaci Mladý zemědělec a budoucí růst farmy.',
    duration: '~10 min',
    status: 'live',
    badge: 'Pro startupy',
    titleSk: 'Prvý traktor pre mladého farmára',
    descriptionSk: 'Začínate hospodáriť do 40 rokov? Sprievodca výberom prvého traktora s ohľadom na dotáciu Mladý farmár a budúci rast farmy.',
    durationSk: '~10 min',
    badgeSk: 'Pre startupy',
  },
  {
    slug: 'jak-vybrat-seci-stroj',
    title: 'Jak vybrat secí stroj — mechanický vs pneumatický',
    description: 'Mechanická secička, pneumatická, přesná. Záběr, kompatibilita s traktorem, ISOBUS funkce, top značky. Praktické srovnání.',
    duration: '~12 min',
    status: 'live',
    badge: 'Aktuální',
    titleSk: 'Ako vybrať sejací stroj — mechanický vs pneumatický',
    descriptionSk: 'Mechanická sejačka, pneumatická, presná. Záber, kompatibilita s traktorom, ISOBUS funkcie, top značky. Praktické porovnanie.',
    durationSk: '~12 min',
    badgeSk: 'Aktuálny',
  },
  {
    slug: 'jak-vybrat-postrikovac',
    title: 'Jak vybrat postřikovač (2026)',
    description: 'Nesený vs tažený vs samojízdný, záběr ramen, ISOBUS Section Control, trysky, top značky.',
    duration: '~10 min',
    status: 'live',
    badge: 'Aktuální',
    titleSk: 'Ako vybrať postrekovač (2026)',
    descriptionSk: 'Nesený vs ťahaný vs samojazdný, záber ramien, ISOBUS Section Control, trysky, top značky.',
    durationSk: '~10 min',
    badgeSk: 'Aktuálny',
  },
  {
    slug: 'jak-vybrat-lis-na-baliky',
    title: 'Jak vybrat lis na balíky — kulatý vs hranolový',
    description: 'Kulatý vs hranolový, net wrap vs provázek, kombi lis+wrapper pro siláž, top značky.',
    duration: '~10 min',
    status: 'live',
    badge: 'Aktuální',
    titleSk: 'Ako vybrať lis na balíky — okrúhly vs hranolový',
    descriptionSk: 'Okrúhly vs hranolový, net wrap vs povrázok, kombi lis+wrapper pre siláž, top značky.',
    durationSk: '~10 min',
    badgeSk: 'Aktuálny',
  },
  {
    slug: 'jak-vybrat-rozmetadlo-hnojiv',
    title: 'Jak vybrat rozmetadlo hnojiv (2026)',
    description: 'Talířové vs pneumatické, objem, ISOBUS Section Control, WeighCell, VRA návratnost.',
    duration: '~10 min',
    status: 'live',
    badge: 'Aktuální',
    titleSk: 'Ako vybrať rozmetadlo hnojív (2026)',
    descriptionSk: 'Tanierové vs pneumatické, objem, ISOBUS Section Control, WeighCell, VRA návratnosť.',
    durationSk: '~10 min',
    badgeSk: 'Aktuálny',
  },
];

const breadcrumbJsonLd = breadcrumbSchema([
  { name: isSk ? 'Domov' : 'Domů', url: `${base}/` },
  { name: isSk ? 'Sprievodca nákupom' : 'Průvodce nákupem', url: canonical },
]);

const itemListJsonLd = itemListSchema(
  guides.filter((g) => g.status === 'live').map((g) => ({
    url: `${SITE_URL}${base}/pruvodce/${g.slug}/`,
    name: isSk ? g.titleSk : g.title,
  })),
  isSk ? 'Sprievodca nákupom poľnohospodárskej techniky' : 'Průvodce nákupem zemědělské techniky',
);
---

<Layout
  title={isSk ? 'Sprievodca nákupom poľnohospodárskej techniky' : 'Průvodce nákupem zemědělské techniky'}
  description={isSk ? 'Praktickí sprievodcovia výberom traktorov, kombajnov a strojov. Čo preveriť, ako porovnať, na čo sa pýtať, ako vyjednať cenu.' : 'Praktické průvodce výběrem traktorů, kombajnů a strojů. Co prověřit, jak srovnat, na co se ptát, jak vyjednat cenu.'}
  canonical={canonical}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(itemListJsonLd)} />

  {isSk ? (
  <div class="pr-root">
    <nav class="breadcrumb" aria-label="Cesta">
      <a href="/sk/">Domov</a>
      <span aria-hidden="true">›</span>
      <span class="current">Sprievodca nákupom</span>
    </nav>

    <header class="hub-head">
      <span class="kicker">Sprievodca nákupom</span>
      <h1>Sprievodca nákupom poľnohospodárskej techniky</h1>
      <p class="lede">
        Dlhí praktickí sprievodcovia pre nákupné rozhodovanie. Čo preveriť, ako porovnať, na čo sa pýtať, ako vyjednať cenu. Bez marketingu.
      </p>
    </header>

    <div class="grid">
      {guides.map((g) => (
        g.status === 'live' ? (
          <a href={`/sk/pruvodce/${g.slug}/`} class="card card-live">
            <span class="badge badge-live">{g.badgeSk}</span>
            <h2>{g.titleSk}</h2>
            <p>{g.descriptionSk}</p>
            <span class="meta">{g.durationSk} · Čítať →</span>
          </a>
        ) : (
          <div class="card card-soon">
            <span class="badge badge-soon">{g.badgeSk}</span>
            <h2>{g.titleSk}</h2>
            <p>{g.descriptionSk}</p>
            <span class="meta">Pripravujeme</span>
          </div>
        )
      ))}
    </div>

    <section class="related">
      <h2>Súvisiace nástroje</h2>
      <ul>
        <li>🔍 <a href="/sk/kviz/jaky-traktor-potrebujete/">Kvíz „Aký traktor potrebujete?"</a> — Top 5 odporúčaní podľa vašej farmy</li>
        <li>⚖️ <a href="/sk/srovnani/">Comparator</a> — bočné porovnanie ľubovoľných dvoch modelov</li>
        <li>⭐ <a href="/sk/zebricky/">Rebríčky top-N</a> — kurátorované rebríčky v každom segmente</li>
        <li>⛽ <a href="/sk/kalkulacka/uspora-nafty/">Diesel kalkulačka</a> — koľko ušetríte výmenou stroja</li>
        <li>💶 <a href="/sk/kalkulacka/dotace-cap/">Kalkulačka dotácií CAP</a> — orientačný výpočet platieb</li>
      </ul>
    </section>
  </div>
  ) : (
  <div class="pr-root">
    <nav class="breadcrumb" aria-label="Cesta">
      <a href="/">Domů</a>
      <span aria-hidden="true">›</span>
      <span class="current">Průvodce nákupem</span>
    </nav>

    <header class="hub-head">
      <span class="kicker">Průvodce nákupem</span>
      <h1>Průvodce nákupem zemědělské techniky</h1>
      <p class="lede">
        Dlouhé praktické průvodce pro nákupní rozhodování. Co prověřit, jak srovnat, na co se ptát, jak vyjednat cenu. Bez marketingu.
      </p>
    </header>

    <div class="grid">
      {guides.map((g) => (
        g.status === 'live' ? (
          <a href={`/pruvodce/${g.slug}/`} class="card card-live">
            <span class="badge badge-live">{g.badge}</span>
            <h2>{g.title}</h2>
            <p>{g.description}</p>
            <span class="meta">{g.duration} · Číst →</span>
          </a>
        ) : (
          <div class="card card-soon">
            <span class="badge badge-soon">{g.badge}</span>
            <h2>{g.title}</h2>
            <p>{g.description}</p>
            <span class="meta">Připravujeme</span>
          </div>
        )
      ))}
    </div>

    <section class="related">
      <h2>Související nástroje</h2>
      <ul>
        <li>🔍 <a href="/kviz/jaky-traktor-potrebujete/">Kvíz „Jaký traktor potřebujete?"</a> — Top 5 doporučení podle vaší farmy</li>
        <li>⚖️ <a href="/srovnani/">Comparator</a> — boční srovnání libovolných dvou modelů</li>
        <li>⭐ <a href="/zebricky/">Žebříčky top-N</a> — kurátorované žebříčky v každém segmentu</li>
        <li>⛽ <a href="/kalkulacka/uspora-nafty/">Diesel kalkulačka</a> — kolik ušetříte výměnou stroje</li>
        <li>💶 <a href="/kalkulacka/dotace-cap/">Kalkulačka dotací CAP</a> — orientační výpočet plateb</li>
      </ul>
    </section>
  </div>
  )}
</Layout>

<style>
  .pr-root { max-width: 1080px; margin: 0 auto; padding: 32px 24px 80px; }
  .breadcrumb { display: flex; gap: 8px; align-items: center; font-size: 13px; color: #666; margin-bottom: 20px; }
  .breadcrumb a { color: #666; text-decoration: none; }
  .breadcrumb a:hover { color: #000; }
  .breadcrumb .current { color: #000; font-weight: 600; }
  .hub-head { margin-bottom: 36px; max-width: 720px; }
  .kicker { display: inline-block; background: #FFEA00; color: #0A0A0B; font-size: 12px; font-weight: 700; padding: 4px 12px; border-radius: 4px; text-transform: uppercase; letter-spacing: 1px; }
  h1 { font-size: clamp(2rem, 5vw, 3rem); font-weight: 800; letter-spacing: -1px; line-height: 1.1; margin: 12px 0 8px; color: #1a1a1a; }
  .lede { font-size: 16px; color: #444; line-height: 1.6; margin: 0; }

  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 16px; margin-bottom: 48px; }
  .card {
    display: block; padding: 24px;
    border-radius: 14px; border: 1.5px solid #eaeaec;
    text-decoration: none; color: inherit;
    background: #fff;
  }
  .card-live { background: linear-gradient(135deg, #fff 0%, #fffef8 100%); }
  .card-live:hover { border-color: #FFEA00; transform: translateY(-2px); transition: all .15s; box-shadow: 0 6px 18px rgba(255, 234, 0, .15); }
  .card-soon { background: #fafafa; opacity: 0.7; }
  .badge { display: inline-block; font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 10px; }
  .badge-live { background: #0B7A3B; color: #fff; }
  .badge-soon { background: #6B6B72; color: #fff; }
  .card h2 { font-size: 18px; font-weight: 700; color: #0A0A0B; margin: 0 0 8px; line-height: 1.3; }
  .card p { font-size: 14px; color: #555; line-height: 1.55; margin: 0 0 12px; }
  .meta { font-size: 12px; color: #6B6B72; font-weight: 600; }
  .card-live .meta { color: #0B7A3B; }

  .related h2 { font-size: 20px; font-weight: 700; color: #0A0A0B; margin: 0 0 14px; }
  .related ul { list-style: none; padding: 0; margin: 0; }
  .related li { font-size: 14px; line-height: 1.8; padding: 6px 0; border-bottom: 1px solid #f0f0f0; }
  .related a { color: #0B7A3B; font-weight: 600; text-decoration: underline; }
</style>
