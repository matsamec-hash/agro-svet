---
import Layout from '../../layouts/Layout.astro';
import Newsletter from '../../components/Newsletter.astro';
import { createAnonClient } from '../../lib/supabase';
import { tagStyle } from '../../lib/tag-color';
import { AGRO_SVET_SITE_ID as SITE_ID } from '../../lib/config';
import { injectLinks } from '../../lib/auto-linker';

const { slug } = Astro.params;
const supabase = createAnonClient();

const { data: article } = await supabase
  .from('articles')
  .select('*')
  .eq('site_id', SITE_ID)
  .eq('slug', slug)
  .eq('status', 'published')
  .single();

if (!article) {
  return Astro.redirect('/novinky/');
}

// Related articles + prev/next nav: fetch a recent pool from same category
// + same site, score by tag overlap (deterministic, SEO-friendly).
// Single query keeps it cheap; pool is bounded for SSR latency.
const { data: poolRaw } = await supabase
  .from('articles')
  .select('id, title, slug, perex, featured_image_url, category, tags, published_at')
  .eq('site_id', SITE_ID)
  .eq('status', 'published')
  .neq('id', article.id)
  .order('published_at', { ascending: false })
  .limit(80);
const pool = poolRaw ?? [];

const articleTags: string[] = (article.tags as string[] | null) ?? [];
function scoreRelated(other: typeof pool[number]): number {
  let score = 0;
  if (other.category && article.category && other.category === article.category) score += 5;
  const tagSet = new Set(articleTags);
  const otherTags = (other.tags as string[] | null) ?? [];
  for (const t of otherTags) if (tagSet.has(t)) score += 3;
  if (other.featured_image_url) score += 1;
  return score;
}
const related = pool
  .map((p) => ({ p, s: scoreRelated(p) }))
  .filter(({ s }) => s > 0)
  .sort((a, b) => b.s - a.s || (a.p.published_at < b.p.published_at ? 1 : -1))
  .slice(0, 4)
  .map(({ p }) => p);

// Prev/next: chronological neighbors among published articles (any category).
// `pool` is already DESC by published_at, so newer = before our article in the list.
const articleDate = new Date(article.published_at).getTime();
const prevArticle = pool.find((p) => new Date(p.published_at).getTime() < articleDate) ?? null; // older
const nextArticle = [...pool].reverse().find((p) => new Date(p.published_at).getTime() > articleDate) ?? null; // newer

const date = new Intl.DateTimeFormat('cs-CZ', { day: 'numeric', month: 'long', year: 'numeric' }).format(new Date(article.published_at));
const categoryLabels: Record<string, string> = {
  technika: 'Technika', dotace: 'Dotace', trh: 'Trh', legislativa: 'Legislativa', znacky: 'Značky',
  psychologie: 'Psychologie', zdravi: 'Zdraví', finance: 'Finance', krasa: 'Krása',
};

const canonical = `https://agro-svet.cz/novinky/${article.slug}/`;
const publisher = {
  '@type': 'Organization',
  name: 'agro-svět.cz',
  url: 'https://agro-svet.cz',
  logo: {
    '@type': 'ImageObject',
    url: 'https://agro-svet.cz/icon-512.png',
    width: 512,
    height: 512,
  },
};
const author = {
  '@type': 'Organization',
  name: 'Redakce agro-svět.cz',
  url: 'https://agro-svet.cz/redakce/',
};
const articleSectionLabel = article.category ? (categoryLabels[article.category] || article.category) : undefined;
const dateModified = article.updated_at || article.published_at;
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'NewsArticle',
      headline: article.title,
      description: article.seo_description || article.perex,
      ...(article.featured_image_url && {
        image: {
          '@type': 'ImageObject',
          url: article.featured_image_url,
          width: 1600,
          height: 900,
        },
      }),
      datePublished: article.published_at,
      dateModified,
      url: canonical,
      mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
      author,
      publisher,
      inLanguage: 'cs-CZ',
      ...(articleSectionLabel && { articleSection: articleSectionLabel }),
      ...(article.tags?.length > 0 && { keywords: article.tags.join(', ') }),
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Domů', item: 'https://agro-svet.cz/' },
        { '@type': 'ListItem', position: 2, name: 'Novinky', item: 'https://agro-svet.cz/novinky/' },
        { '@type': 'ListItem', position: 3, name: article.title, item: canonical },
      ],
    },
  ],
};
---

<Layout
  title={article.seo_title || article.title}
  description={article.seo_description || article.perex}
  ogImage={article.featured_image_url || undefined}
  canonical={canonical}
  ogType="article"
  publishedTime={article.published_at}
  modifiedTime={dateModified}
  articleSection={articleSectionLabel}
  articleTags={article.tags ?? undefined}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

  <!-- Hero image -->
  {article.featured_image_url && (
    <div style="width:100%; height:clamp(260px,40vh,480px); overflow:hidden; position:relative;">
      <img
        src={article.featured_image_url}
        alt={article.title}
        width="1600"
        height="900"
        fetchpriority="high"
        decoding="async"
        style={`width:100%; height:100%; object-fit:cover; object-position: ${article.focal_point?.x ?? 50}% ${article.focal_point?.y ?? 50}%;`}
      />
      <div style="position:absolute; inset:0; background:linear-gradient(to bottom, transparent 50%, rgba(0,0,0,.35));"></div>
    </div>
  )}

  <div style="max-width:780px; margin:0 auto; padding:48px 32px 96px;">

    <!-- Breadcrumb -->
    <div style="font-size:13px; color:#666; margin-bottom:28px;">
      <a href="/novinky/" style="color:#666; text-decoration:none;">Novinky</a>
      <span style="margin:0 8px;">›</span>
      <span>{article.title}</span>
    </div>

    <!-- Meta -->
    <div style="display:flex; align-items:center; gap:10px; margin-bottom:20px; flex-wrap:wrap;">
      {article.category && (
        <span style="background:#FFFF00; color:#000; font-family:'Chakra Petch',sans-serif; font-weight:400; font-size:11px; padding:3px 10px; border-radius:4px; text-transform:uppercase; letter-spacing:.5px;">
          {categoryLabels[article.category] ?? article.category}
        </span>
      )}
      <time style="font-size:13px; color:#666;">{date}</time>
    </div>

    <!-- Headline -->
    <h1 style="font-size:clamp(1.8rem,4vw,2.6rem); font-weight:900; letter-spacing:-0.5px; line-height:1.15; color:#1a1a1a; margin-bottom:16px;">
      {article.title}
    </h1>
    <p style="font-size:18px; color:#555; line-height:1.6; margin-bottom:40px; border-bottom:1px solid #ebebeb; padding-bottom:32px;">
      {article.perex}
    </p>

    <!-- Article body (HTML from CMS) — auto-linker injects internal links to brands/plemena/stroje hubs. -->
    <div class="prose" set:html={injectLinks(article.content, `/novinky/${article.slug}/`)} />

    <!-- Tags (clickable — navigate to filtered novinky) -->
    {article.tags?.length > 0 && (
      <div style="margin-top:48px; padding-top:24px; border-top:1px solid #ebebeb;">
        <span style="font-size:12px; color:#767676; margin-right:8px;">Tagy:</span>
        {article.tags.map((tag: string) => (
          <a
            href={`/novinky/tema/${encodeURIComponent(tag)}/`}
            class="article-tag"
            style={tagStyle(tag)}
            title={`Další články s tagem „${tag}"`}
          >
            #{tag}
          </a>
        ))}
      </div>
    )}

    <!-- Prev / next chronological nav -->
    {(prevArticle || nextArticle) && (
      <nav class="prev-next" aria-label="Navigace mezi články">
        {prevArticle ? (
          <a href={`/novinky/${prevArticle.slug}/`} class="pn-link pn-prev" rel="prev">
            <span class="pn-label">← Předchozí</span>
            <span class="pn-title">{prevArticle.title}</span>
          </a>
        ) : <span></span>}
        {nextArticle ? (
          <a href={`/novinky/${nextArticle.slug}/`} class="pn-link pn-next" rel="next">
            <span class="pn-label">Další →</span>
            <span class="pn-title">{nextArticle.title}</span>
          </a>
        ) : <span></span>}
      </nav>
    )}

    <!-- Back link -->
    <div style="margin-top:48px;">
      <a href="/novinky/" style="display:inline-flex; align-items:center; gap:8px; color:#1a1a1a; font-weight:400; font-size:14px; text-decoration:none; border:2px solid #1a1a1a; padding:10px 18px; border-radius:8px; transition:background .15s;">
        ← Zpět na novinky
      </a>
    </div>

  </div>

  <!-- Related articles (topical clustering signal for Google) -->
  {related.length > 0 && (
    <aside class="related-section" aria-labelledby="related-heading">
      <div class="related-inner">
        <h2 id="related-heading">Další články k tématu</h2>
        <div class="related-grid">
          {related.map((r) => (
            <a href={`/novinky/${r.slug}/`} class="related-card">
              {r.featured_image_url && (
                <div class="rc-img">
                  <img src={r.featured_image_url} alt={r.title} loading="lazy" decoding="async" width="400" height="225" />
                </div>
              )}
              <div class="rc-body">
                {r.category && <span class="rc-cat">{categoryLabels[r.category] ?? r.category}</span>}
                <h3>{r.title}</h3>
                {r.perex && <p>{r.perex.length > 120 ? r.perex.slice(0, 120) + '…' : r.perex}</p>}
              </div>
            </a>
          ))}
        </div>
      </div>
    </aside>
  )}

  <!-- Newsletter signup -->
  <Newsletter />
</Layout>

<style>
  .prose :global(h2) { font-size:1.5rem; font-weight:400; margin:2em 0 .75em; letter-spacing:-.3px; color:#1a1a1a; }
  .prose :global(h3) { font-size:1.15rem; font-weight:400; margin:1.5em 0 .5em; color:#1a1a1a; }
  .prose :global(p) { font-size:17px; line-height:1.75; color:#333; margin-bottom:1.25em; }
  .prose :global(ul), .prose :global(ol) { padding-left:1.5em; margin-bottom:1.25em; }
  .prose :global(li) { font-size:16px; line-height:1.7; color:#333; margin-bottom:.4em; }
  .prose :global(strong) { font-weight:700; color:#1a1a1a; }
  .prose :global(table) { width:100%; border-collapse:collapse; margin-bottom:1.5em; font-size:15px; }
  .prose :global(th) { background:#f5f5f5; font-weight:600; padding:10px 14px; border:1px solid #e0e0e0; text-align:left; }
  .prose :global(td) { padding:9px 14px; border:1px solid #ebebeb; }
  .prose :global(blockquote) { border-left:4px solid #FFFF00; padding:8px 20px; margin:1.5em 0; background:#fafafa; }
  .prose :global(a) { color:#0A0A0B; text-decoration:underline; text-decoration-color:#FFFF00; text-decoration-thickness:2px; text-underline-offset:3px; transition:background .15s; }
  .prose :global(a:hover) { background:#FFFF00; }
  .prose :global(.auto-link) { text-decoration-color:#EAEAEC; text-decoration-style:dotted; }
  .prose :global(.auto-link:hover) { background:#FFFF00; text-decoration-color:#0A0A0B; }

  /* Prev / next chronological nav */
  .prev-next {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid #ebebeb;
  }
  .pn-link {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 14px 18px;
    background: #FBFAF4;
    border: 1.5px solid #0A0A0B;
    border-radius: 10px;
    box-shadow: 2px 2px 0 #0A0A0B;
    text-decoration: none;
    color: #0A0A0B;
    transition: transform .12s, box-shadow .12s, background .12s;
  }
  .pn-link:hover { transform: translate(-1px,-1px); box-shadow: 3px 3px 0 #0A0A0B; background: #FFFF00; }
  .pn-next { text-align: right; }
  .pn-label {
    font: 600 11px 'Chakra Petch', sans-serif;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: #6B6B72;
  }
  .pn-title {
    font: 600 14px 'Chakra Petch', sans-serif;
    line-height: 1.35;
    color: #0A0A0B;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  @media (max-width: 600px) {
    .prev-next { grid-template-columns: 1fr; }
    .pn-next { text-align: left; }
  }

  /* Related articles section */
  .related-section {
    background: #FBFAF4;
    border-top: 2px dashed #EAEAEC;
    padding: 56px 24px 64px;
    margin-top: 64px;
  }
  .related-inner { max-width: 1180px; margin: 0 auto; }
  .related-section h2 {
    font: 800 clamp(1.4rem, 3vw, 1.9rem) 'Chakra Petch', sans-serif;
    letter-spacing: -.02em;
    color: #0A0A0B;
    margin: 0 0 28px;
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 18px;
  }
  .related-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1.5px solid #0A0A0B;
    border-radius: 12px;
    box-shadow: 3px 3px 0 #0A0A0B;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform .12s, box-shadow .12s;
  }
  .related-card:hover { transform: translate(-2px, -2px); box-shadow: 5px 5px 0 #0A0A0B; }
  .rc-img { aspect-ratio: 16 / 9; overflow: hidden; background: #f0f0f0; }
  .rc-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .rc-body { padding: 14px 16px 18px; flex: 1; display: flex; flex-direction: column; gap: 8px; }
  .rc-cat {
    align-self: flex-start;
    font: 700 10px 'Chakra Petch', sans-serif;
    letter-spacing: .12em;
    text-transform: uppercase;
    background: #FFFF00;
    color: #0A0A0B;
    padding: 3px 8px;
    border-radius: 4px;
    border: 1.5px solid #0A0A0B;
  }
  .rc-body h3 {
    font: 700 15px 'Chakra Petch', sans-serif;
    line-height: 1.3;
    color: #0A0A0B;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .rc-body p {
    font-size: 13px;
    color: #6B6B72;
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .article-tag {
    display: inline-block;
    font-size: 12px;
    padding: 4px 12px;
    border-radius: 20px;
    margin: 2px 4px;
    text-decoration: none;
    border: 1px solid transparent;
    transition: filter .15s, transform .1s;
  }
  .article-tag:hover { filter: brightness(.94); transform: translateY(-1px); }
  .prose :global(code) { background:#f0f0f0; padding:2px 6px; border-radius:4px; font-size:.9em; font-family:'Chakra Petch',sans-serif; }
  .prose :global(img) { max-width:100%; height:auto; border-radius:12px; margin:1.5em 0; }
</style>
