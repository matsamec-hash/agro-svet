---
import Layout from '../../layouts/Layout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import BazarPagination from '../../components/bazar/BazarPagination.astro';
import { createAnonClient } from '../../lib/supabase';
import { categoryStyle, tagStyle } from '../../lib/tag-color';

const PER_PAGE = 24;

const SITE_ID = 'cadc73fd-6bd9-4dc5-a0da-ea33725762e1';
const supabase = createAnonClient();

const category = Astro.url.searchParams.get('kategorie') ?? '';
const query = Astro.url.searchParams.get('q') ?? '';
const dateFrom = Astro.url.searchParams.get('od') ?? '';
const dateTo = Astro.url.searchParams.get('do') ?? '';
const tag = Astro.url.searchParams.get('tag') ?? '';
const page = Math.max(1, parseInt(Astro.url.searchParams.get('page') ?? '1'));

let q = supabase
  .from('articles')
  .select('id, title, slug, perex, featured_image_url, focal_point, category, tags, published_at', { count: 'exact' })
  .eq('site_id', SITE_ID)
  .eq('status', 'published')
  .order('published_at', { ascending: false })
  .range((page - 1) * PER_PAGE, page * PER_PAGE - 1);

if (category) q = q.eq('category', category);
if (query) q = q.or(`title.ilike.%${query}%,perex.ilike.%${query}%`);
if (dateFrom) q = q.gte('published_at', dateFrom);
if (dateTo) {
  const end = new Date(dateTo);
  end.setHours(23, 59, 59, 999);
  q = q.lte('published_at', end.toISOString());
}
if (tag) q = q.contains('tags', [tag]);

const { data: articles, count } = await q;
const sorted = articles ?? [];
const totalPages = Math.ceil((count ?? 0) / PER_PAGE);

// Category counts (across all articles) + available tags
const { data: allForMeta } = await supabase
  .from('articles')
  .select('category, tags')
  .eq('site_id', SITE_ID)
  .eq('status', 'published');

const catCounts = new Map<string, number>();
const tagCounts = new Map<string, number>();
for (const a of allForMeta ?? []) {
  const c = (a.category as string) || 'novinky';
  catCounts.set(c, (catCounts.get(c) ?? 0) + 1);
  for (const t of (a.tags as string[]) ?? []) {
    tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
  }
}
const categoryLabels: Record<string, string> = {
  technika: 'Technika',
  dotace: 'Dotace',
  trh: 'Trh',
  legislativa: 'Legislativa',
  znacky: 'Značky',
  novinky: 'Novinky',
};
const catPills = [...catCounts.entries()]
  .map(([slug, count]) => ({ slug, label: categoryLabels[slug] ?? slug, count }))
  .sort((a, b) => b.count - a.count);
const topTags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 20);

const activeLabel = category ? (categoryLabels[category] ?? category) : null;
const hasFilters = Boolean(category || query || dateFrom || dateTo || tag);
const totalAll = allForMeta?.length ?? 0;

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Domů', item: 'https://agro-svet.cz/' },
    { '@type': 'ListItem', position: 2, name: 'Novinky', item: 'https://agro-svet.cz/novinky/' },
  ],
};
---

<Layout
  title={activeLabel ? `Novinky: ${activeLabel}` : (query ? `Novinky: „${query}"` : 'Novinky')}
  description={activeLabel ? `Články v kategorii ${activeLabel}.` : 'Aktuální zprávy ze světa zemědělské techniky — nové stroje, dotace, trh a legislativa.'}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
  <div style="max-width:1280px; margin:0 auto; padding:48px 32px 80px;">

    <div style="margin-bottom:24px;">
      <span class="section-label">Novinky</span>
      <h1 style="font-size:clamp(2rem,5vw,3.2rem); margin-bottom:16px;">
        {activeLabel ? `Kategorie: ${activeLabel}` : (query ? `Hledáte: „${query}"` : 'Zemědělství v pohybu')}
      </h1>
      {!hasFilters && (
        <p style="font-size:16px; color:#666; max-width:560px; line-height:1.6;">
          Sledujeme nové stroje, dotační programy, trhy i legislativní změny. Vše, co potřebujete vědět jako zemědělec.
        </p>
      )}
    </div>

    <!-- Collapsible advanced filter bar — closed by default -->
    <details class="nov-filter-details" open={Boolean(query || dateFrom || dateTo || tag)}>
      <summary class="nov-filter-summary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M3 6h18M7 12h10M11 18h2"/>
        </svg>
        <span>Rozšířené filtry</span>
        {(query || dateFrom || dateTo || tag) && <span class="nov-filter-badge">aktivní</span>}
        <svg class="nov-filter-caret" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
      </summary>
      <form method="GET" action="/novinky/" class="nov-filter">
        <div class="nov-search-row">
          <div class="nov-search-wrap">
            <svg class="nov-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="2" stroke-linecap="round">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
            </svg>
            <input type="search" name="q" value={query} placeholder="Hledat v názvech a perexech…" class="nov-search-input" />
          </div>
          <button type="submit" class="btn-primary">Hledat</button>
        </div>
        <div class="nov-date-row">
          <label class="nov-date-field">
            <span class="nov-date-label">Od</span>
            <input type="date" name="od" value={dateFrom} class="nov-date-input" />
          </label>
          <label class="nov-date-field">
            <span class="nov-date-label">Do</span>
            <input type="date" name="do" value={dateTo} class="nov-date-input" />
          </label>
          {category && <input type="hidden" name="kategorie" value={category} />}
          {tag && <input type="hidden" name="tag" value={tag} />}
          {hasFilters && <a href="/novinky/" class="nov-reset">Vymazat vše</a>}
        </div>

        {topTags.length > 0 && (
          <div style="margin-top:16px; padding-top:14px; border-top:1px solid #eee;">
            <div style="display:inline-flex; align-items:center; gap:6px; font-family:'Chakra Petch',sans-serif; font-size:11px; letter-spacing:.08em; text-transform:uppercase; color:#666; margin-bottom:8px;">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.59 13.41 13.42 20.58a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
              Témata
            </div>
            <div style="display:flex; gap:6px; flex-wrap:wrap;">
              {topTags.map(([t, count]) => (
                <a
                  href={`/novinky/tema/${encodeURIComponent(t)}/`}
                  class:list={["nov-tag", { active: t === tag }]}
                  style={t !== tag ? tagStyle(t) : ''}
                >
                  #{t} <span class="nov-tag-count">{count}</span>
                </a>
              ))}
            </div>
          </div>
        )}
      </form>
    </details>

    <!-- Category pills -->
    <div style="display:flex; gap:8px; flex-wrap:wrap; margin-bottom:16px;">
      <a href="/novinky/" class:list={["pill", { active: !category }]}>
        Vše <span class="pill-count">{totalAll}</span>
      </a>
      {catPills.map((c) => (
        <a
          href={`/novinky/kategorie/${c.slug}/`}
          class:list={["pill", { active: c.slug === category }]}
          style={c.slug !== category ? categoryStyle(c.slug) : ''}
        >
          {c.label} <span class="pill-count">{c.count}</span>
        </a>
      ))}
    </div>


    <!-- Results -->
    {sorted.length > 0 ? (
      <>
        <div style="margin-bottom:14px; font-size:13px; color:#666;">
          Nalezeno {(count ?? 0).toLocaleString('cs-CZ')} článků{hasFilters ? ' odpovídajících filtrům' : ''}{totalPages > 1 ? ` · stránka ${page} z ${totalPages}` : ''}.
        </div>
        <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:20px;">
          {sorted.map(article => (
            <ArticleCard
              title={article.title}
              description={article.perex}
              slug={article.slug}
              publishDate={new Date(article.published_at)}
              category={article.category}
              heroImage={article.featured_image_url}
              focalPoint={article.focal_point}
            />
          ))}
        </div>
        <BazarPagination currentPage={page} totalPages={totalPages} baseUrl={Astro.url.toString()} />
      </>
    ) : (
      <p style="color:#666; font-size:16px; padding:48px 0; text-align:center;">
        Žádné články neodpovídají filtrům.
        {hasFilters && <> <a href="/novinky/" style="color:#1a1a1a;">Vymazat filtry</a>.</>}
      </p>
    )}
  </div>

  <style>
    .nov-filter-details {
      margin-bottom: 16px;
    }
    .nov-filter-summary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 14px;
      background: #fff;
      border: 1px solid #e0e0e0;
      border-radius: 999px;
      cursor: pointer;
      font-family: 'Chakra Petch', sans-serif;
      font-size: 13px;
      color: #1a1a1a;
      list-style: none;
      transition: background .15s, border-color .15s;
    }
    .nov-filter-summary::-webkit-details-marker { display: none; }
    .nov-filter-summary:hover { background: #fff0a8; border-color: #FFFF00; }
    .nov-filter-badge {
      background: #FFFF00;
      color: #000;
      padding: 1px 8px;
      border-radius: 10px;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
    }
    .nov-filter-caret { transition: transform .2s; opacity: .6; }
    .nov-filter-details[open] .nov-filter-caret,
    .nov-topics-details[open] .nov-filter-caret { transform: rotate(180deg); }

    .nov-topics-details {
      margin-bottom: 24px;
      padding-top: 8px;
      border-top: 1px solid #f0f0f0;
    }
    .nov-topics-summary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 12px;
      background: #fff;
      border: 1px solid #e0e0e0;
      border-radius: 999px;
      cursor: pointer;
      font-family: 'Chakra Petch', sans-serif;
      font-size: 12px;
      color: #555;
      list-style: none;
      transition: background .15s, border-color .15s;
    }
    .nov-topics-summary::-webkit-details-marker { display: none; }
    .nov-topics-summary:hover { background: #fff0a8; border-color: #FFFF00; color: #1a1a1a; }
    .nov-topics-count {
      background: rgba(0,0,0,.06);
      padding: 1px 7px;
      border-radius: 10px;
      font-size: 11px;
    }

    .nov-filter {
      margin-top: 12px;
      padding: 16px;
      background: #fafafa;
      border: 1px solid #e8e8e8;
      border-radius: 14px;
    }
    .nov-search-row {
      display: flex;
      gap: 10px;
      margin-bottom: 12px;
    }
    .nov-search-wrap {
      position: relative;
      flex: 1;
    }
    .nov-search-icon {
      position: absolute;
      left: 16px;
      top: 50%;
      transform: translateY(-50%);
      pointer-events: none;
    }
    .nov-search-input {
      width: 100%;
      height: 44px;
      padding: 0 16px 0 44px;
      font-family: inherit;
      font-size: 14px;
      background: #fff;
      border: 1px solid #d9d9d9;
      border-radius: 10px;
    }
    .nov-search-input:focus {
      outline: none;
      border-color: #1a1a1a;
      box-shadow: 0 0 0 3px rgba(255,255,0,.4);
    }
    .nov-date-row {
      display: flex;
      gap: 12px;
      align-items: end;
      flex-wrap: wrap;
    }
    .nov-date-field {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .nov-date-label {
      font-family: 'Chakra Petch', sans-serif;
      font-size: 10px;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: #666;
    }
    .nov-date-input {
      height: 38px;
      padding: 0 10px;
      font-size: 13px;
      border: 1px solid #ddd;
      border-radius: 8px;
      background: #fff;
    }
    .nov-reset {
      margin-left: auto;
      align-self: center;
      font-size: 13px;
      color: #666;
      text-decoration: underline;
    }
    .nov-reset:hover { color: #000; }

    .pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 14px;
      background: #fff;
      border: 1px solid #e0e0e0;
      border-radius: 999px;
      font-family: 'Chakra Petch', sans-serif;
      font-size: 13px;
      color: #1a1a1a;
      text-decoration: none;
      transition: background .15s, border-color .15s;
    }
    .pill:hover { background: #fff0a8; border-color: #FFFF00; }
    .pill.active { background: #1a1a1a; border-color: #1a1a1a; color: #fff; }
    .pill-count {
      font-size: 11px;
      color: #666;
      background: rgba(0,0,0,.06);
      padding: 1px 7px;
      border-radius: 10px;
    }
    .pill.active .pill-count {
      color: #FFFF00;
      background: rgba(255,255,0,.16);
    }

    .nov-tag {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 4px 10px;
      background: #fff;
      border: 1px solid #e8e8e8;
      border-radius: 6px;
      font-size: 12px;
      color: #555;
      text-decoration: none;
    }
    .nov-tag:hover { background: #fff0a8; border-color: #FFFF00; color: #1a1a1a; }
    .nov-tag.active { background: #1a1a1a; color: #fff; border-color: #1a1a1a; }
    .nov-tag-count {
      font-size: 10px;
      color: #767676;
    }
    .nov-tag.active .nov-tag-count { color: #FFFF00; }
  </style>
</Layout>
