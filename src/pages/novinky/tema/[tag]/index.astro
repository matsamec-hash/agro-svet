---
export const prerender = false;
import Layout from '../../../../layouts/Layout.astro';
import ArticleCard from '../../../../components/ArticleCard.astro';
import { createAnonClient } from '../../../../lib/supabase';
import { tagStyle, categoryStyle, getTagColor } from '../../../../lib/tag-color';

const { tag } = Astro.params;
if (!tag) return Astro.redirect('/novinky/');

const SITE_ID = 'cadc73fd-6bd9-4dc5-a0da-ea33725762e1';
const supabase = createAnonClient();

const { data: articles } = await supabase
  .from('articles')
  .select('id, title, slug, perex, featured_image_url, category, tags, published_at')
  .eq('site_id', SITE_ID)
  .eq('status', 'published')
  .contains('tags', [tag])
  .order('published_at', { ascending: false });

const items = articles ?? [];

// Categories present under this tag (for faceted nav)
const catCounts = new Map<string, number>();
for (const a of items) {
  const c = (a.category as string) || 'novinky';
  catCounts.set(c, (catCounts.get(c) ?? 0) + 1);
}
const categoryLabels: Record<string, string> = {
  technika: 'Technika',
  dotace: 'Dotace',
  trh: 'Trh',
  legislativa: 'Legislativa',
  znacky: 'Značky',
  novinky: 'Novinky',
};
const catFacets = [...catCounts.entries()]
  .map(([slug, count]) => ({ slug, label: categoryLabels[slug] ?? slug, count }))
  .sort((a, b) => b.count - a.count);

// Related tags (co-occurring in these articles, top 12, excluding current)
const coTagCounts = new Map<string, number>();
for (const a of items) {
  for (const t of (a.tags as string[]) ?? []) {
    if (t === tag) continue;
    coTagCounts.set(t, (coTagCounts.get(t) ?? 0) + 1);
  }
}
const relatedTags = [...coTagCounts.entries()].sort((a, b) => b[1] - a[1]).slice(0, 12);

const pageTitle = `Téma: ${tag}`;
const pageDesc = `Články k tématu „${tag}" na agro-svět.cz — ${items.length} článků${items.length === 0 ? '' : ' z kategorií ' + catFacets.map((c) => c.label).join(', ')}.`;
---

<Layout title={pageTitle} description={pageDesc}>
  <div style="max-width:1280px; margin:0 auto; padding:48px 32px 80px;">
    <div style="margin-bottom:8px; font-size:13px; color:#666;">
      <a href="/novinky/" style="color:#666; text-decoration:none;">Novinky</a>
      <span style="margin:0 6px;">/</span>
      <span style="color:#666;">Téma</span>
      <span style="margin:0 6px;">/</span>
      <span style="color:#1a1a1a;">{tag}</span>
    </div>

    <div style="margin-bottom:24px;">
      <span class="section-label" style={tagStyle(tag!)}>Téma</span>
      <h1 style="font-family:'Chakra Petch',sans-serif; font-size:clamp(2rem,5vw,3rem); font-weight:700; letter-spacing:-1px; color:#1a1a1a; margin-top:10px; margin-bottom:10px;">
        <span style={`color:${getTagColor(tag!).fg};`}>#{tag}</span>
      </h1>
      <p style="font-size:15px; color:#666; line-height:1.6;">
        {items.length === 0
          ? `Pro téma „${tag}" zatím žádné články.`
          : `${items.length} ${items.length === 1 ? 'článek' : (items.length < 5 ? 'články' : 'článků')} k tématu ${tag}.`}
      </p>
    </div>

    {catFacets.length > 1 && (
      <div style="display:flex; gap:8px; flex-wrap:wrap; margin-bottom:24px;">
        <span style="font-family:'Chakra Petch',sans-serif; font-size:11px; letter-spacing:.08em; text-transform:uppercase; color:#666; padding:8px 0;">V kategoriích:</span>
        {catFacets.map((c) => (
          <a href={`/novinky/kategorie/${c.slug}/`} class="pill" style={categoryStyle(c.slug)}>
            {c.label} <span class="pill-count">{c.count}</span>
          </a>
        ))}
      </div>
    )}

    {items.length > 0 ? (
      <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:20px; margin-bottom:32px;">
        {items.map((a: any) => (
          <ArticleCard
            title={a.title}
            description={a.perex}
            slug={a.slug}
            publishDate={new Date(a.published_at)}
            category={a.category}
            heroImage={a.featured_image_url}
          />
        ))}
      </div>
    ) : (
      <p style="padding:48px 0; text-align:center; color:#666;">
        <a href="/novinky/" style="color:#1a1a1a;">← Zpět na novinky</a>
      </p>
    )}

    {relatedTags.length > 0 && (
      <aside style="margin-top:48px; padding-top:24px; border-top:1px solid #eee;">
        <div style="font-family:'Chakra Petch',sans-serif; font-size:11px; letter-spacing:.08em; text-transform:uppercase; color:#666; margin-bottom:12px;">
          Související témata
        </div>
        <div style="display:flex; gap:6px; flex-wrap:wrap;">
          {relatedTags.map(([t, count]) => (
            <a href={`/novinky/tema/${encodeURIComponent(t)}/`} class="nov-tag" style={tagStyle(t)}>
              #{t} <span class="nov-tag-count">{count}</span>
            </a>
          ))}
        </div>
      </aside>
    )}
  </div>

  <style>
    .pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      background: #fff;
      border: 1px solid #e0e0e0;
      border-radius: 999px;
      font-family: 'Chakra Petch', sans-serif;
      font-size: 12px;
      color: #1a1a1a;
      text-decoration: none;
    }
    .pill:hover { background: #fff0a8; border-color: #FFFF00; }
    .pill-count {
      background: rgba(0,0,0,.06);
      padding: 1px 7px;
      border-radius: 10px;
      font-size: 11px;
      color: #666;
    }
    .nov-tag {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 4px 10px;
      background: #fff;
      border: 1px solid #e8e8e8;
      border-radius: 6px;
      font-size: 12px;
      color: #555;
      text-decoration: none;
    }
    .nov-tag:hover { background: #fff0a8; border-color: #FFFF00; color: #1a1a1a; }
    .nov-tag-count { font-size: 10px; color: #767676; }
  </style>
</Layout>
