---
// SSR — tagy nemají fixní enum, vznikají dynamicky z článků. Pro prerender
// by se musely query všechny tagy build-time + getStaticPaths(). Pro nyní SSR.
export const prerender = false;
import Layout from '../../../../layouts/Layout.astro';
import ArticleCard from '../../../../components/ArticleCard.astro';
import { createAnonClient } from '../../../../lib/supabase';
import { tagStyle, categoryStyle, getTagColor } from '../../../../lib/tag-color';
import { AGRO_SVET_SITE_ID as SITE_ID, SITE_URL } from '../../../../lib/config';
import { breadcrumbSchema } from '../../../../lib/structured-data';
import { fetchArticleTranslations, overlayArticle, buildTranslationMap } from '../../../../lib/articles-i18n';
import { localizePath, t, localizedCategory } from '../../../../i18n/utils';

const { tag } = Astro.params;
if (!tag) return Astro.rewrite('/404');
const locale = Astro.locals.locale ?? 'cs';

const supabase = createAnonClient();

const { data: articles } = await supabase
  .from('articles')
  .select('id, title, slug, perex, featured_image_url, category, tags, published_at')
  .eq('site_id', SITE_ID)
  .eq('status', 'published')
  .contains('tags', [tag])
  .order('published_at', { ascending: false });

let items = articles ?? [];
if (locale !== 'cs' && items.length) {
  const trMap = buildTranslationMap(await fetchArticleTranslations(supabase, items.map((a) => a.id), locale));
  items = items.map((a) => overlayArticle(a, trMap.get(a.id)));
}

// Categories present under this tag (for faceted nav)
const catCounts = new Map<string, number>();
for (const a of items) {
  const c = (a.category as string) || 'novinky';
  catCounts.set(c, (catCounts.get(c) ?? 0) + 1);
}
const catFacets = [...catCounts.entries()]
  .map(([slug, count]) => ({ slug, label: localizedCategory(locale, slug), count }))
  .sort((a, b) => b.count - a.count);

// Related tags (co-occurring in these articles, top 12, excluding current)
const coTagCounts = new Map<string, number>();
for (const a of items) {
  for (const t of (a.tags as string[]) ?? []) {
    if (t === tag) continue;
    coTagCounts.set(t, (coTagCounts.get(t) ?? 0) + 1);
  }
}
const relatedTags = [...coTagCounts.entries()].sort((a, b) => b[1] - a[1]).slice(0, 12);

const pageTitle = `${t(locale, 'nov.theme')}: ${tag}`;
const pageDesc = locale === 'sk'
  ? `Články k téme „${tag}" na agro-svět.cz — ${items.length} článkov${items.length === 0 ? '' : ' z kategórií ' + catFacets.map((c) => c.label).join(', ')}.`
  : `Články k tématu „${tag}" na agro-svět.cz — ${items.length} článků${items.length === 0 ? '' : ' z kategorií ' + catFacets.map((c) => c.label).join(', ')}.`;

const breadcrumbJsonLd = breadcrumbSchema([
  { name: t(locale, 'nav.home'), url: localizePath(locale, '/') },
  { name: t(locale, 'nov.breadcrumb'), url: localizePath(locale, '/novinky/') },
  { name: `#${tag}`, url: localizePath(locale, `/novinky/tema/${encodeURIComponent(tag!)}/`) },
]);
const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: pageTitle,
  description: pageDesc,
  url: `${SITE_URL}${localizePath(locale, `/novinky/tema/${encodeURIComponent(tag!)}/`)}`,
  inLanguage: locale === 'sk' ? 'sk-SK' : locale === 'uk' ? 'uk-UA' : 'cs-CZ',
  numberOfItems: items.length,
};
---

<Layout title={pageTitle} description={pageDesc}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(collectionJsonLd)} />
  <div style="max-width:1280px; margin:0 auto; padding:48px 32px 80px;">
    <div style="margin-bottom:8px; font-size:13px; color:#666;">
      <a href={localizePath(locale, '/novinky/')} style="color:#666; text-decoration:none;">{t(locale, 'nov.breadcrumb')}</a>
      <span style="margin:0 6px;">/</span>
      <span style="color:#666;">{t(locale, 'nov.theme')}</span>
      <span style="margin:0 6px;">/</span>
      <span style="color:#1a1a1a;">{tag}</span>
    </div>

    <div style="margin-bottom:24px;">
      <span class="section-label" style={tagStyle(tag!)}>{t(locale, 'nov.theme')}</span>
      <h1 style="font-family:'Chakra Petch',sans-serif; font-size:clamp(2rem,5vw,3rem); font-weight:700; letter-spacing:-1px; color:#1a1a1a; margin-top:10px; margin-bottom:10px;">
        <span style={`color:${getTagColor(tag!).fg};`}>#{tag}</span>
      </h1>
      <p style="font-size:15px; color:#666; line-height:1.6;">
        {items.length === 0
          ? (locale === 'sk' ? `Pre tému „${tag}" zatiaľ žiadne články.` : `Pro téma „${tag}" zatím žádné články.`)
          : (locale === 'sk'
              ? `${items.length} ${items.length === 1 ? 'článok' : (items.length < 5 ? 'články' : 'článkov')} k téme ${tag}.`
              : `${items.length} ${items.length === 1 ? 'článek' : (items.length < 5 ? 'články' : 'článků')} k tématu ${tag}.`)}
      </p>
    </div>

    {catFacets.length > 1 && (
      <div style="display:flex; gap:8px; flex-wrap:wrap; margin-bottom:24px;">
        <span style="font-family:'Chakra Petch',sans-serif; font-size:11px; letter-spacing:.08em; text-transform:uppercase; color:#666; padding:8px 0;">{t(locale, 'nov.inCategories')}</span>
        {catFacets.map((c) => (
          <a href={localizePath(locale, `/novinky/kategorie/${c.slug}/`)} class="pill" style={categoryStyle(c.slug)}>
            {c.label} <span class="pill-count">{c.count}</span>
          </a>
        ))}
      </div>
    )}

    {items.length > 0 ? (
      <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:20px; margin-bottom:32px;">
        {items.map((a: any) => (
          <ArticleCard
            title={a.title}
            description={a.perex}
            slug={a.slug}
            publishDate={new Date(a.published_at)}
            category={a.category}
            heroImage={a.featured_image_url}
            locale={locale}
          />
        ))}
      </div>
    ) : (
      <p style="padding:48px 0; text-align:center; color:#666;">
        <a href={localizePath(locale, '/novinky/')} style="color:#1a1a1a;">{t(locale, 'nov.back')}</a>
      </p>
    )}

    {relatedTags.length > 0 && (
      <aside style="margin-top:48px; padding-top:24px; border-top:1px solid #eee;">
        <div style="font-family:'Chakra Petch',sans-serif; font-size:11px; letter-spacing:.08em; text-transform:uppercase; color:#666; margin-bottom:12px;">
          {t(locale, 'nov.relatedTopics')}
        </div>
        <div style="display:flex; gap:6px; flex-wrap:wrap;">
          {relatedTags.map(([tagName, count]) => (
            <a href={localizePath(locale, `/novinky/tema/${encodeURIComponent(tagName)}/`)} class="nov-tag" style={tagStyle(tagName)}>
              #{tagName} <span class="nov-tag-count">{count}</span>
            </a>
          ))}
        </div>
      </aside>
    )}
  </div>

  <style>
    .pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      background: #fff;
      border: 1px solid #e0e0e0;
      border-radius: 999px;
      font-family: 'Chakra Petch', sans-serif;
      font-size: 12px;
      color: #1a1a1a;
      text-decoration: none;
    }
    .pill:hover { background: #fff0a8; border-color: #FFFF00; }
    .pill-count {
      background: rgba(0,0,0,.06);
      padding: 1px 7px;
      border-radius: 10px;
      font-size: 11px;
      color: #666;
    }
    .nov-tag {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 4px 10px;
      background: #fff;
      border: 1px solid #e8e8e8;
      border-radius: 6px;
      font-size: 12px;
      color: #555;
      text-decoration: none;
    }
    .nov-tag:hover { background: #fff0a8; border-color: #FFFF00; color: #1a1a1a; }
    .nov-tag-count { font-size: 10px; color: #767676; }
  </style>
</Layout>
