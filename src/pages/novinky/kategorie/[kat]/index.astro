---
export const prerender = true;
import Layout from '../../../../layouts/Layout.astro';
import ArticleCard from '../../../../components/ArticleCard.astro';
import { createAnonClient } from '../../../../lib/supabase';
import { tagStyle, getCategoryColor } from '../../../../lib/tag-color';
import { AGRO_SVET_SITE_ID as SITE_ID } from '../../../../lib/config';

// Prerender pro fixní enum kategorií. Articles content načteno build-time
// per kategorie. Note: nově publikovaný článek se objeví až po dalším buildu.
export function getStaticPaths() {
  return ['technika', 'dotace', 'trh', 'legislativa', 'znacky', 'novinky'].map(
    (kat) => ({ params: { kat } }),
  );
}

const { kat } = Astro.params;
if (!kat) return Astro.redirect('/novinky/');

const categoryLabels: Record<string, string> = {
  technika: 'Technika',
  dotace: 'Dotace',
  trh: 'Trh',
  legislativa: 'Legislativa',
  znacky: 'Značky',
  novinky: 'Novinky',
};
const categoryDescriptions: Record<string, string> = {
  technika: 'Novinky ze zemědělské techniky — traktory, kombajny, postřikovače, secí stroje a další stroje.',
  dotace: 'Dotační programy, podpora zemědělství, Společná zemědělská politika EU, národní dotace.',
  trh: 'Vývoj cen zemědělských komodit, trh s mlékem, masem, obilím, trendy a analýzy.',
  legislativa: 'Novely zákonů, nařízení a vyhlášky pro zemědělce, pachty, udržitelnost.',
  znacky: 'Zprávy od výrobců zemědělské techniky, tiskové zprávy, nové modely.',
  novinky: 'Obecné zemědělské novinky.',
};
const label = categoryLabels[kat] ?? kat;
const description = categoryDescriptions[kat] ?? `Články v kategorii ${label}.`;

const supabase = createAnonClient();

const { data: articles } = await supabase
  .from('articles')
  .select('id, title, slug, perex, featured_image_url, category, tags, published_at')
  .eq('site_id', SITE_ID)
  .eq('status', 'published')
  .eq('category', kat)
  .order('published_at', { ascending: false });

const items = articles ?? [];

// Top tags within this category
const tagCounts = new Map<string, number>();
for (const a of items) {
  for (const t of (a.tags as string[]) ?? []) {
    tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
  }
}
const topTags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]).slice(0, 16);
---

<Layout title={`${label} — agro-svět.cz`} description={description}>
  <div style="max-width:1280px; margin:0 auto; padding:48px 32px 80px;">
    <nav class="kat-breadcrumb" aria-label="Drobečková navigace">
      <a href="/novinky/">Novinky</a>
      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      <span>{label}</span>
    </nav>

    <header class="kat-hero">
      <span class="kat-kicker">
        <span class="kat-kicker-dot" style={`background:${getCategoryColor(kat).fg};`}></span>
        Kategorie
      </span>
      <h1 class="kat-title">{label}</h1>
      <div class="kat-meta">
        <span class="kat-count">
          {items.length === 0
            ? 'Zatím bez článků'
            : `${items.length} ${items.length === 1 ? 'článek' : items.length < 5 ? 'články' : 'článků'}`}
        </span>
        <span class="kat-divider"></span>
        <p class="kat-desc">{description}</p>
      </div>
    </header>

    {topTags.length > 0 && (
      <details style="margin-bottom:24px;" open={false}>
        <summary class="kat-topics-summary">
          <span style="display:inline-flex; align-items:center; gap:6px;"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.59 13.41 13.42 20.58a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>Témata v této kategorii</span>
          <span class="kat-topics-count">{topTags.length}</span>
        </summary>
        <div style="display:flex; gap:6px; flex-wrap:wrap; margin-top:12px;">
          {topTags.map(([t, count]) => (
            <a href={`/novinky/tema/${encodeURIComponent(t)}/`} class="nov-tag" style={tagStyle(t)}>
              #{t} <span class="nov-tag-count">{count}</span>
            </a>
          ))}
        </div>
      </details>
    )}

    {items.length > 0 ? (
      <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:20px;">
        {items.map((a: any) => (
          <ArticleCard
            title={a.title}
            description={a.perex}
            slug={a.slug}
            publishDate={new Date(a.published_at)}
            category={a.category}
            heroImage={a.featured_image_url}
          />
        ))}
      </div>
    ) : (
      <p style="padding:48px 0; text-align:center; color:#666;">
        <a href="/novinky/" style="color:#1a1a1a;">← Zpět na novinky</a>
      </p>
    )}
  </div>

  <style>
    /* Breadcrumb */
    .kat-breadcrumb {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 12px;
      background: #FBFAF4;
      border: 1.5px solid #0A0A0B;
      border-radius: 10px;
      font: 600 12px 'Chakra Petch', sans-serif;
      letter-spacing: .02em;
      color: #0A0A0B;
      margin-bottom: 20px;
      box-shadow: 2px 2px 0 #0A0A0B;
    }
    .kat-breadcrumb a {
      color: #6B6B72;
      text-decoration: none;
      transition: color .15s;
    }
    .kat-breadcrumb a:hover { color: #0A0A0B; }
    .kat-breadcrumb svg { color: #c0c0c5; }
    .kat-breadcrumb span { color: #0A0A0B; }

    /* Hero */
    .kat-hero {
      margin-bottom: 32px;
      padding-bottom: 24px;
      border-bottom: 2px dashed #EAEAEC;
    }
    .kat-kicker {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 12px;
      background: #FFFF00;
      border: 1.5px solid #0A0A0B;
      border-radius: 8px;
      box-shadow: 3px 3px 0 #0A0A0B;
      font: 700 11px 'Chakra Petch', sans-serif;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: #0A0A0B;
    }
    .kat-kicker-dot {
      width: 9px;
      height: 9px;
      border-radius: 50%;
      border: 1.5px solid #0A0A0B;
      flex-shrink: 0;
    }
    .kat-title {
      font: 800 clamp(2.4rem, 6vw, 3.6rem) 'Chakra Petch', sans-serif;
      letter-spacing: -.025em;
      color: #0A0A0B;
      margin: 18px 0 14px;
      line-height: 1.05;
    }
    .kat-meta {
      display: flex;
      align-items: center;
      gap: 14px;
      flex-wrap: wrap;
      max-width: 820px;
    }
    .kat-count {
      display: inline-flex;
      align-items: center;
      flex-shrink: 0;
      font: 700 12px 'Chakra Petch', sans-serif;
      letter-spacing: .04em;
      text-transform: uppercase;
      color: #0A0A0B;
      padding: 5px 11px;
      background: #fff;
      border: 1.5px solid #0A0A0B;
      border-radius: 6px;
    }
    .kat-divider {
      width: 4px;
      height: 4px;
      background: #c0c0c5;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .kat-desc {
      font-size: 15px;
      color: #6B6B72;
      line-height: 1.6;
      margin: 0;
      flex: 1;
      min-width: 280px;
    }
    @media (max-width: 600px) {
      .kat-divider { display: none; }
      .kat-desc { width: 100%; }
    }

    .kat-topics-summary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 12px;
      background: #fff;
      border: 1px solid #e0e0e0;
      border-radius: 999px;
      cursor: pointer;
      font-family: 'Chakra Petch', sans-serif;
      font-size: 12px;
      color: #555;
      list-style: none;
    }
    .kat-topics-summary::-webkit-details-marker { display: none; }
    .kat-topics-summary:hover { background: #fff0a8; border-color: #FFFF00; }
    .kat-topics-count {
      background: rgba(0,0,0,.06);
      padding: 1px 7px;
      border-radius: 10px;
      font-size: 11px;
    }
    .nov-tag {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 4px 10px;
      background: #fff;
      border: 1px solid #e8e8e8;
      border-radius: 6px;
      font-size: 12px;
      color: #555;
      text-decoration: none;
    }
    .nov-tag:hover { background: #fff0a8; border-color: #FFFF00; color: #1a1a1a; }
    .nov-tag-count { font-size: 10px; color: #767676; }
  </style>
</Layout>
