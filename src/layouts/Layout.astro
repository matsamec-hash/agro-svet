---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Lightbox from '../components/bazar/Lightbox.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  ogType?: 'website' | 'article' | 'product' | 'profile';
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
  articleSection?: string;
  articleTags?: string[];
}

const {
  title,
  description = 'Novinky ze světa zemědělství, encyklopedie strojů, značky a agro bazar.',
  ogImage,
  canonical,
  ogType = 'website',
  noindex = false,
  publishedTime,
  modifiedTime,
  articleSection,
  articleTags,
} = Astro.props;

const SITE_ORIGIN = 'https://agro-svet.cz';
const canonicalPath = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const canonicalUrl = canonical ?? new URL(canonicalPath, SITE_ORIGIN).toString();
---

<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <meta name="google-site-verification" content="QXiqxpCmcP9HJZMH7M6I3J-X6j7p6U8lhk1aehxG7Io" />
  <meta name="msvalidate.01" content="A401032123927401E73FAB1151E94F3D" />
  <title>{title} | agro-svět.cz</title>
  <meta name="description" content={description} />
  <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'} />

  <link rel="canonical" href={canonicalUrl} />
  <link rel="alternate" hreflang="cs" href={canonicalUrl} />
  <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:locale" content="cs_CZ" />
  <meta property="og:site_name" content="agro-svět.cz" />
  {ogImage && <meta property="og:image" content={ogImage} />}
  {ogImage && <meta property="og:image:width" content="1200" />}
  {ogImage && <meta property="og:image:height" content="630" />}
  {ogImage && <meta property="og:image:alt" content={title} />}
  {publishedTime && <meta property="article:published_time" content={publishedTime} />}
  {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
  {articleSection && <meta property="article:section" content={articleSection} />}
  {articleTags && articleTags.map((t) => <meta property="article:tag" content={t} />)}
  <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
  {ogImage && <meta name="twitter:image" content={ogImage} />}

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <meta name="theme-color" content="#FFFF00" />

  <!-- Google Fonts: Chakra Petch + Roboto Condensed (with latin-ext for Czech diacritics) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@300;400;500;600;700&family=Roboto+Condensed:wght@300;400;500;600;700&display=swap"
  />
</head>
<body>
  <a href="#main-content" class="skip-link">Přeskočit na obsah</a>
  <Header />
  <main id="main-content" tabindex="-1">
    <slot />
  </main>
  <Lightbox />
  <Footer />
</body>
</html>
