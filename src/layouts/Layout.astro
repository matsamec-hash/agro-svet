---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Lightbox from '../components/bazar/Lightbox.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'Novinky ze světa zemědělství, encyklopedie strojů, značky a agro bazar.', ogImage } = Astro.props;
---

<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <meta name="google-site-verification" content="QXiqxpCmcP9HJZMH7M6I3J-X6j7p6U8lhk1aehxG7Io" />
  <meta name="msvalidate.01" content="A401032123927401E73FAB1151E94F3D" />
  <title>{title} | agro-svět.cz</title>
  <meta name="description" content={description} />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  {ogImage && <meta property="og:image" content={ogImage} />}
  {ogImage && <meta property="og:image:width" content="1200" />}
  {ogImage && <meta property="og:image:height" content="630" />}
  <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
  {ogImage && <meta name="twitter:image" content={ogImage} />}

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <meta name="theme-color" content="#FFFF00" />

  <!-- Google Fonts: Chakra Petch + Roboto Condensed (with latin-ext for Czech diacritics) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@300;400;500;600;700&family=Roboto+Condensed:wght@300;400;500;600;700&display=swap"
  />
</head>
<body>
  <a href="#main-content" class="skip-link">Přeskočit na obsah</a>
  <Header />
  <main id="main-content" tabindex="-1">
    <slot />
  </main>
  <Lightbox />
  <footer style="background:#1a1a1a; color:rgba(255,255,255,0.5); text-align:center; padding:32px 24px; font-size:13px;">
    <div style="margin-bottom:12px;">
      <a href="/" style="display:inline-block; background:#FFFF00; padding:8px 16px; border-radius:4px; text-decoration:none;">
        <span style="font-family:'Chakra Petch',sans-serif; font-weight:400; font-size:18px; color:#000;">agro-svět.cz</span>
      </a>
    </div>
    <p>Zemědělská technika, novinky a encyklopedie &nbsp;·&nbsp; © {new Date().getFullYear()}</p>
  </footer>
</body>
</html>
