---
import '../styles/global.css';
// Font preloads — Vite imports resolve to hashed CDN paths at build time.
// Preloading the most-used latin weights cuts FOIT/CLS on first paint.
import chakraPetch400 from '@fontsource/chakra-petch/files/chakra-petch-latin-400-normal.woff2?url';
import chakraPetch700 from '@fontsource/chakra-petch/files/chakra-petch-latin-700-normal.woff2?url';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { siteSchemaGraph } from '../lib/structured-data';
import Lightbox from '../components/bazar/Lightbox.astro';
import CookieConsent from '../components/CookieConsent.astro';

// Microsoft Clarity — session recordings + heatmaps. Project ID je veřejný
// (zobrazí se v HTML), takže hardcoded je OK. Clarity respektuje DNT,
// běží anonymous bez PII → neblokuje cookie consent.
const clarityId = 'ws6puxcjnb';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  ogType?: 'website' | 'article' | 'product' | 'profile';
  noindex?: boolean;
  publishedTime?: string;
  modifiedTime?: string;
  articleSection?: string;
  articleTags?: string[];
}

const {
  title,
  description = 'Novinky ze světa zemědělství, encyklopedie strojů, značky a agro bazar.',
  ogImage,
  canonical,
  ogType = 'website',
  noindex = false,
  publishedTime,
  modifiedTime,
  articleSection,
  articleTags,
} = Astro.props;

const SITE_ORIGIN = 'https://agro-svet.cz';
const canonicalPath = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const canonicalUrl = canonical ?? new URL(canonicalPath, SITE_ORIGIN).toString();

// Route-based OG fallback: páry top-level cest k landing PNGs vygenerovaným
// v scripts/build-og-images.mjs. Pokud konkrétní stránka nepředala ogImage,
// vybereme nejlepší match podle prvního segmentu. Pro / je to /og/default.png.
function resolveDefaultOg(pathname: string): string {
  const seg = pathname.replace(/^\/+/, '').split('/')[0] ?? '';
  const landings = new Set([
    'stroje', 'encyklopedie', 'jak-na-to', 'znacky', 'plemena',
    'dotace', 'prodejci', 'kalkulacka', 'srovnani', 'bazar', 'puda',
  ]);
  if (landings.has(seg)) return `${SITE_ORIGIN}/og/landing-${seg}.png`;
  return `${SITE_ORIGIN}/og/default.png`;
}
const resolvedOgImage = ogImage ?? resolveDefaultOg(Astro.url.pathname);
---

<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  <meta name="google-site-verification" content="QXiqxpCmcP9HJZMH7M6I3J-X6j7p6U8lhk1aehxG7Io" />
  <meta name="google-site-verification" content="CY_qIX6BN8tWkMXGOKdM8d-k-_le-qmUsk-eoZwS5Eo" />
  <meta name="msvalidate.01" content="A401032123927401E73FAB1151E94F3D" />
  <meta name="seznam-wmt" content="H957FuP9Pc7eQLHuPaTpuyrG03OUV0FD" />
  <title>{title} | agro-svět.cz</title>
  <meta name="description" content={description} />
  <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'} />

  <link rel="canonical" href={canonicalUrl} />
  <link rel="alternate" hreflang="cs" href={canonicalUrl} />
  <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:locale" content="cs_CZ" />
  <meta property="og:site_name" content="agro-svět.cz" />
  <meta property="og:image" content={resolvedOgImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={title} />
  {publishedTime && <meta property="article:published_time" content={publishedTime} />}
  {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
  {articleSection && <meta property="article:section" content={articleSection} />}
  {articleTags && articleTags.map((t) => <meta property="article:tag" content={t} />)}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content={resolvedOgImage} />

  <link rel="alternate" type="application/rss+xml" title="agro-svět.cz — novinky (RSS)" href="/rss.xml" />

  <!-- Sitewide Organization + WebSite entity (@graph). Stránkové JSON-LD bloky
       referencují tyto @id místo duplikace → Google slučuje do jedné entity. -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify(siteSchemaGraph())} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <meta name="theme-color" content="#FFFF00" />

  <!-- Preconnect: hero/article images + bazar listing photos. Šetří ~100ms TLS handshake na 1. requestu. -->
  <link rel="preconnect" href="https://cdn.samecdigital.com" crossorigin />
  <link rel="preconnect" href="https://obhypfuzmknvmknskdwh.supabase.co" crossorigin />
  <!-- YouTube facade na encyklopedii — preconnect šetří TLS handshake při kliknutí na video poster. -->
  <link rel="preconnect" href="https://www.youtube-nocookie.com" />
  <link rel="preconnect" href="https://i.ytimg.com" />

  <!-- Fonts self-hosted via @fontsource (imported in src/styles/global.css). -->
  <!-- Preload the two most-used Chakra Petch latin weights to cut first paint FOIT. -->
  <link rel="preload" as="font" type="font/woff2" href={chakraPetch400} crossorigin />
  <link rel="preload" as="font" type="font/woff2" href={chakraPetch700} crossorigin />

  {clarityId && (
    <script is:inline set:html={`(function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);})(window, document, "clarity", "script", "${clarityId.replace(/[^a-zA-Z0-9_-]/g, '')}");`} />
  )}
</head>
<body>
  <a href="#main-content" class="skip-link">Přeskočit na obsah</a>
  <Header />
  <main id="main-content" tabindex="-1">
    <slot />
  </main>
  <Lightbox />
  <Footer />
  <CookieConsent />
</body>
</html>
