{
  "name": "agro-svet",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/build-og-images.mjs && astro build",
    "build:og": "node scripts/build-og-images.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "deploy": "wrangler deploy && node --env-file=.env scripts/cf-purge.mjs",
    "purge": "node --env-file=.env scripts/cf-purge.mjs",
    "commodities:refresh": "node scripts/fetch-commodities.mjs",
    "stats:refresh": "node scripts/fetch-commodities.mjs && node scripts/fetch-stats.mjs",
    "stats:refresh:sk": "node scripts/fetch-stats-sk.mjs",
    "puda:refresh:sk": "node scripts/fetch-puda-sk.mjs",
    "catalog:refresh": "node scripts/fetch-remote-catalog.mjs",
    "akce:maintenance": "tsx --env-file=.env scripts/akce-maintenance.mjs",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.10",
    "@fontsource/chakra-petch": "^5.2.7",
    "@fontsource/roboto-condensed": "^5.2.8",
    "@supabase/supabase-js": "^2.104.0",
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^6.0.3",
    "resend": "^6.12.2",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@modyfi/vite-plugin-yaml": "^1.1.1",
    "@resvg/resvg-js": "^2.6.2",
    "@vitest/ui": "^4.1.5",
    "gray-matter": "^4.0.3",
    "happy-dom": "^20.9.0",
    "satori": "^0.26.0",
    "satori-html": "^0.3.2",
    "tsx": "^4.22.4",
    "vitest": "^4.1.5",
    "yaml": "^2.9.0"
  }
}
